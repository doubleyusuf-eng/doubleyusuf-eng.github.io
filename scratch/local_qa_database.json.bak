  {
    "id": "clinical_followup_neonatal_resus_alternatives_0",
    "category": "clinical_followups",
    "keywords": [
      "alternatives",
      "clinical_followup_neonatal_resus_alternatives_0",
      "cocuk",
      "followup",
      "neonatal",
      "pediatri",
      "pediatric",
      "resus",
      "var0",
      "yenidoğan",
      "çocuk"
    ],
    "question_tr": "Pediatrik maske ventilasyonu başarısız olursa alternatif havayolu nedir?",
    "question_en": "What is the alternative airway if pediatric bag-mask fails?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🔄 Balon-maske ventilasyonu ile göğüs kalkmıyorsa, havayolu manevraları (MR. SOPA) uygulanır. Hala yetersizse, endotrakeal entübasyon veya supraglottik havayolu cihazı (LMA size 1) derhal yerleştirilmelidir. LMA, 2000 gramın üzerindeki bebeklerde son derece başarılı bir alternatiftir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🔄 If chest rise is inadequate during bag-mask ventilation, execute airway troubleshooting (MR. SOPA). If still unsuccessful, perform endotracheal intubation or insert a supraglottic airway (e.g. Size 1 LMA). LMA is a highly successful rescue alternative for infants > 2000 g.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
