    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "⚠️ There are no absolute contraindications to lipid rescue therapy in the presence of acute cardiac arrest or severe neurotoxicity from LAST. Egg or soy allergy represents a relative contraindication but is disregarded in life-threatening scenarios.",
      "immediateRedFlags": [],
