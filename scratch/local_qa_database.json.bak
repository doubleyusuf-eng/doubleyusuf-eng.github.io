    ],
    "question_tr": "Prone ventilasyon",
    "question_en": "Prone ventilation",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Prone pozisyonda tüp, devre, damar yolları ve bası noktaları özellikle güvenceye alınmalıdır. 1. Tüp derinliği ve cuff basıncı pozisyon sonrası tekrar kontrol edilir. 2. Göz, yüz, brakiyal pleksus, meme, genital bölge ve bası noktaları korunur. 3. Akciğer kompliyansı ve oksijenasyon değişebilir; ventilatör ayarları yeniden değerlendirilir. 4. Abdominal bası artarsa ventilasyon ve venöz dönüş kötüleşebilir. 5. Acil havayolu erişimi zor olduğu için supin çevirme ve reentübasyon planı önceden belirlenmelidir. 6. Prone sonrası yüz/havayolu ödemi ekstübasyon riskini artırabilir.",
      "immediateRedFlags": [
        "Prone pozisyona çevirme esnasında endotrakeal tüpün kazara çıkması (ekstübasyon).",
        "Pozisyon verme sonrasında SpO2'nin hızla düşmesi ve solunum seslerinin tek taraflı kaybolması.",
        "Gözlere doğrudan bası yapılmasına bağlı orbital iskemi riski."
      ],
      "missingCriticalInformation": [
        "Tüpün ağız kenarındaki derinlik santimetresinin prone öncesi ve sonrası değerleri",
        "Pozisyon veren ekibin koordinasyon ve liderlik planı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Prone Pozisyonda Ventilasyon",
        "Pozisyon Güvenliği ve Monitörizasyon",
        "Kazara Ekstübasyon Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Prone pozisyona çevirmeden önce tüpü ağız içinde çok sağlam bir şekilde sabitleyin.",
        "Çevirme işlemi esnasında başı ve tüpü bizzat yönetin, devreyi ayırın/koruyun.",
        "Prone pozisyonda abdominal serbestliği (abdomen bası altında kalmamalı) silikon desteklerle sağlayın.",
        "Pozisyon sonrasında bilateral akciğer seslerini oskülte edin ve tüp derinliğini kontrol edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "prone_position",
          "titleTr": "Prone Pozisyonu"
        },
        {
          "id": "difficult_extubation",
          "titleTr": "Zor Ekstübasyon"
        },
        {
          "id": "high_pressure",
          "titleTr": "Yüksek Havayolu Basıncı"
        }
      ],
      "relatedCalculators": [
        {
          "id": "cuff_pressure_calculator",
          "titleTr": "Kaf Basıncı Hesaplayıcı"
        },
        {
          "id": "plateau_pressure",
          "titleTr": "Plato Basıncı Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Prone pozisyonda karın üzerindeki aşırı basının diyaframı yukarı iterek akciğer kompliyansını düşüreceğini ve havayolu basınçlarını ciddi şekilde artıracağını"
      ],
      "whenToEscalate": [
        "Prone pozisyonda tüp yerinden çıkar veya tamamen tıkanırsa ve havalandırma sağlanamazsa, vakit kaybetmeden hastayı acilen supin (sırtüstü) pozisyona geri çevirin ve havayolunu yeniden sağlayın"
      ],
      "referencesToShow": [
        "ASA Practice Advisory on Patient Positioning. 2017.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "In prone position, secure the tube, circuit, vascular access, and pressure points carefully. Recheck tube depth and cuff pressure after positioning. Protect eyes, face, brachial plexus, breasts, genital area, and pressure points. Lung compliance and oxygenation may change; reassess ventilator settings. Increased abdominal pressure can worsen ventilation and venous return. Emergency airway access is difficult, so supine-turning and reintubation plans must be defined in advance. Facial/airway edema after prone positioning may increase extubation risk.",
      "immediateRedFlags": [
        "Accidental extubation during the transition to the prone position.",
        "Rapid oxygen desaturation and loss of bilateral breath sounds after positioning.",
        "Direct pressure on the globes of the eyes, risking blindness."
      ],
      "missingCriticalInformation": [
        "The exact ETT insertion depth (cm) pre- and post-positioning",
        "Clear coordination and roles within the team performing the turn"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Prone Position Ventilation",
        "Positioning Safety and Monitoring",
        "Accidental Extubation Management"
      ],
      "suggestedNextStepsGeneral": [
        "Secure the ETT firmly using robust tape before initiating the turn.",
        "Manage the head and airway personally during the turning process; disconnect or protect the circuit.",
        "Ensure the abdomen hangs free using dedicated chest rolls/silicone bolsters to prevent diaphragmatic splinting.",
        "Auscultate bilateral breath sounds and confirm ETT depth immediately after positioning."
      ],
      "relatedAlgorithms": [
        {
          "id": "prone_position",
          "titleTr": "Prone Position"
        },
        {
          "id": "difficult_extubation",
          "titleTr": "Difficult Extubation"
        },
        {
          "id": "high_pressure",
          "titleTr": "High Airway Pressure"
        }
      ],
      "relatedCalculators": [
        {
          "id": "cuff_pressure_calculator",
          "titleTr": "Cuff Pressure Calculator"
        },
        {
          "id": "plateau_pressure",
          "titleTr": "Plateau Pressure Calculator"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Abdominal pressure in the prone position pushes the diaphragm cephalad, decreasing functional residual capacity (FRC) and increasing airway pressures"
      ],
      "whenToEscalate": [
        "If the ETT displaces or occludes in the prone position and ventilation is impossible, immediately turn the patient supine onto a gurney or the floor and re-secure the airway"
      ],
      "referencesToShow": [
        "ASA Practice Advisory on Patient Positioning. 2017.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "one_lung_ventilation_basics",
    "category": "clinical_scenarios",
    "keywords": [
      "akciğer",
      "basics",
      "hedefleri",
      "lung",
      "olv",
      "one",
      "tek",
      "temel",
      "ventilasyonu",
      "ventilation"
    ],
    "question_tr": "Tek akciğer ventilasyonu temel",
    "question_en": "One lung ventilation basics",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Tek akciğer ventilasyonunda hedef yeterli oksijenasyon, kabul edilebilir CO₂ eliminasyonu ve ventilasyon kaynaklı akciğer hasarını azaltmaktır. 1. Tidal volüm PBW’ye göre düşük-orta aralıkta seçilir. 2. Plato basıncı ve driving pressure izlenir. 3. Ventile edilen akciğere uygun PEEP uygulanır. 4. FiO₂ yeterli SpO₂ sağlayacak şekilde ayarlanır. 5. Hipoksemi gelişirse tüp/bloker pozisyonu, sekresyon, cerrahi kompresyon, PEEP, CPAP non-ventile akciğer ve iki akciğer ventilasyonuna dönüş seçenekleri değerlendirilir. 6. Hiperkapni genellikle ventilasyon ayarıyla yönetilir; permissive hypercapnia seçilmiş hastada kabul edilebilir. ([PMC])",
      "immediateRedFlags": [
        "Tek akciğer ventilasyonuna geçer geçmez gelişen ani ve derin SpO2 düşüşü (< %85).",
        "Ventile edilen tek akciğerde peak ve plato basınçlarının > 30-35 cmH2O değerini aşması.",
        "Şant fraksiyonunun aşırı artmasına bağlı hemodinamik bozulma."
      ],
      "missingCriticalInformation": [
        "Hastanın predicted body weight (PBW) değeri (tek akciğer için tidal volüm 4-6 mL/kg PBW olmalıdır)",
        "Ventile edilen akciğerin bazal parankim kalitesi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Tek Akciğer Ventilasyonu (OLV)",
        "Torasik Anestezi İlkeleri",
        "Akciğer İzolasyon Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Tek akciğer ventilasyonunda tidal volümü 4-6 mL/kg PBW düzeyinde ayarlayın.",
        "Ventile edilen akciğere 5 cmH2O PEEP uygulayarak atelektaziyi önleyin.",
        "Solunum frekansını hafifçe artırarak normokapni veya hafif permissive hypercapnia hedefleyin.",
        "FiO2 oranını SpO2 >= %92-94 olacak şekilde minimum düzeyde tutun."
      ],
      "relatedAlgorithms": [
        {
          "id": "one_lung_ventilation",
          "titleTr": "Tek Akciğer Ventilasyonu"
        },
        {
          "id": "olv_hypoxemia",
          "titleTr": "OLV Hipoksemi Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "pbw_calculator",
          "titleTr": "PBW Hesaplayıcı"
        },
        {
          "id": "pf_ratio_calculator",
          "titleTr": "P/F Oranı"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Tek akciğer ventilasyonuna başlandığında, ventilasyon hacminin yarıya düşürülmesi gerektiğini, aksi takdirde tek akciğere aşırı volüm (volutravma) uygulanmış olacağını"
      ],
      "whenToEscalate": [
        "Dirençli hipoksemi ve ağır solunumsal asidoz gelişirse, derhal cerrahı bilgilendirin ve geçici olarak iki akciğer ventilasyonuna (TLV) geri dönün"
      ],
      "referencesToShow": [
        "Double-lumen tubes and bronchial blockers. PMC 2023.",
        "Principles of Thoracic Anesthesia. Clinical Review."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "One-lung ventilation goals are adequate oxygenation, acceptable CO₂ elimination, and reduction of ventilator-induced lung injury. Use low-to-moderate tidal volume based on PBW, monitor plateau pressure and driving pressure, apply appropriate PEEP to the ventilated lung, and set FiO₂ to maintain adequate SpO₂. If hypoxemia occurs, assess tube/blocker position, secretions, surgical compression, PEEP, CPAP to the non-ventilated lung, and return to two-lung ventilation. Hypercapnia is usually managed by ventilator adjustment; permissive hypercapnia may be acceptable in selected patients. ([PMC])",
      "immediateRedFlags": [
        "Sudden deep oxygen desaturation (SpO2 < 85%) immediately upon switching to one-lung ventilation.",
        "Peak and plateau pressures > 30-35 cmH2O in the single ventilated lung.",
        "Hemodynamic instability secondary to high shunt fraction."
      ],
      "missingCriticalInformation": [
        "The patient's predicted body weight (PBW) (OLV tidal volume must be set to 4-6 mL/kg PBW)",
        "Baseline parenchymal status of the ventilated lung"
      ],
      "likelyClinicalCategoriesToConsider": [
        "One-Lung Ventilation (OLV)",
        "Thoracic Anesthesia Principles",
        "Lung Isolation Management"
      ],
      "suggestedNextStepsGeneral": [
        "Set tidal volume to 4-6 mL/kg PBW for single-lung ventilation.",
        "Apply a PEEP of 5 cmH2O to the ventilated lung to prevent progressive atelectasis.",
        "Increase respiratory rate slightly to maintain normocapnia or mild permissive hypercapnia.",
        "Titrate FiO2 to the lowest level that maintains SpO2 >= 92-94%."
      ],
      "relatedAlgorithms": [
        {
          "id": "one_lung_ventilation",
          "titleTr": "One-Lung Ventilation"
        },
        {
          "id": "olv_hypoxemia",
          "titleTr": "OLV Hypoxemia Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "pbw_calculator",
          "titleTr": "PBW Calculator"
        },
        {
          "id": "pf_ratio_calculator",
          "titleTr": "P/F Ratio"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "When starting OLV, tidal volume must be reduced to avoid delivering the entire two-lung volume into a single lung (volutrauma)"
      ],
      "whenToEscalate": [
        "In cases of refractory hypoxemia or severe acidosis, inform the surgical team immediately and temporarily return to two-lung ventilation (TLV)"
      ],
      "referencesToShow": [
        "Double-lumen tubes and bronchial blockers. PMC 2023.",
        "Principles of Thoracic Anesthesia. Clinical Review."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "olv_hypoxemia",
    "category": "clinical_scenarios",
    "keywords": [
      "akciğer",
      "hypoxemia",
      "lung",
      "olv",
      "one",
      "tek",
      "torasik"
    ],
    "question_tr": "Tek akciğer",
    "question_en": "Torasik",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Tek akciğer ventilasyonunda SpO₂ düşerse ne yapmalıyım? 1. FiO₂’yi artır ve %100 oksijen ver. 2. Tüp veya bronşiyal bloker pozisyonunu fiberoptik ile kontrol et. 3. Sekresyon/tıkaç varsa suction yap. 4. Hemodinami ve hemoglobini değerlendir. 5. Ventile edilen akciğere PEEP uygula veya optimize et. 6. Cerrahiden izin alarak non-ventile akciğere CPAP veya aralıklı reinflasyon uygula. 7. Şiddetli hipoksemide iki akciğer ventilasyonuna dön. 8. Pnömotoraks, endobronşiyal malpozisyon, düşük kardiyak output ve şant artışı ayırıcı tanıda tutulur.",
      "immediateRedFlags": [
        "%100 O2 verilmesine rağmen SpO2'nin <%80'in altına gerilemesi ve bradikardi gelişmesi.",
        "Ventile edilen akciğerde solunum seslerinin tamamen kaybolması.",
        "Akut tansiyon pnömotoraksına bağlı aniden gelişen kardiyak arrest riski."
      ],
      "missingCriticalInformation": [
        "Tüpün veya blokerin güncel konumu (fiberoptik ile teyit edilmelidir)",
        "Hastanın güncel hemoglobin düzeyi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "OLV Sırasında Hipoksemi Yönetimi",
        "Şant Fraksiyonunun Azaltılması",
        "Torasik Havayolu Acilleri"
      ],
      "suggestedNextStepsGeneral": [
        "FiO2 oranını derhal %100 düzeyine yükseltin.",
        "Fiberoptik bronkoskop kullanarak çift lümenli tüpün (veya blokerin) yerini hemen teyit edin.",
        "Tüpü aspire ederek sekresyonları ve kan pıhtılarını temizleyin.",
        "Ventile edilmeyen sönük akciğere cerrahın izniyle 2-5 cmH2O CPAP uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "olv_hypoxemia",
          "titleTr": "OLV Hipoksemi Algoritması"
        },
        {
          "id": "hypoxemia",
          "titleTr": "Hipoksemi Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "pf_ratio_calculator",
          "titleTr": "P/F Oranı"
        },
        {
          "id": "hemoglobin_calculator",
          "titleTr": "Hemoglobin"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "oxygen",
          "titleTr": "Oksijen"
        },
        {
          "id": "vasopressors_if_needed",
          "titleTr": "Vazopressörler"
        }
      ],
      "doNotMiss": [
        "Tek akciğer ventilasyonunda hipokseminin en sık nedeninin tüpün yer değiştirmesi (malpozisyon) olduğunu, ilk yapılacak işlerden birinin fiberoptik kontrol olduğunu"
      ],
      "whenToEscalate": [
        "Tüm önlemlere rağmen SpO2 <%85 düzeyinde kalırsa, cerraha cerrahi işlemi durdurtun ve akciğeri re-inflte ederek iki akciğer ventilasyonuna (TLV) geçin"
      ],
      "referencesToShow": [
        "Double-lumen tubes and bronchial blockers. PMC 2023.",
        "Principles of Thoracic Anesthesia. Clinical Review."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "What should be done if SpO₂ drops during one-lung ventilation? Increase FiO₂ and give 100% oxygen. Check double-lumen tube or bronchial blocker position with fiberoptic bronchoscopy. Suction secretions or plugs. Assess hemodynamics and hemoglobin. Apply or optimize PEEP to the ventilated lung. With surgical permission, apply CPAP or intermittent reinflation to the non-ventilated lung. In severe hypoxemia, return to two-lung ventilation. Consider pneumothorax, endobronchial malposition, low cardiac output, and increased shunt.",
      "immediateRedFlags": [
        "SpO2 dropping below 80% with bradycardia despite 100% FiO2.",
        "Complete loss of breath sounds in the ventilated lung.",
        "Acute tension pneumothorax causing circulatory arrest."
      ],
      "missingCriticalInformation": [
        "The exact position of the DLT or bronchial blocker verified via fiberoptic bronchoscopy",
        "The patient's current hemoglobin level"
      ],
      "likelyClinicalCategoriesToConsider": [
        "OLV Hypoxemia Management",
        "Shunt Fraction Reduction",
        "Thoracic Airway Emergencies"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately increase FiO2 to 100%.",
        "Insert a fiberoptic bronchoscope to verify correct DLT or blocker placement.",
        "Suction the ventilated lung to clear secretions or blood clots.",
        "With surgical consent, apply 2-5 cmH2O CPAP to the non-ventilated (collapsed) lung."
      ],
      "relatedAlgorithms": [
        {
          "id": "olv_hypoxemia",
          "titleTr": "OLV Hypoxemia"
        },
        {
          "id": "hypoxemia",
          "titleTr": "Hypoxemia Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "pf_ratio_calculator",
          "titleTr": "P/F Ratio"
        },
        {
          "id": "hemoglobin_calculator",
          "titleTr": "Hemoglobin"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "oxygen",
          "titleTr": "Oxygen"
        },
        {
          "id": "vasopressors_if_needed",
          "titleTr": "Vasopressors"
        }
      ],
      "doNotMiss": [
        "The most common cause of hypoxemia during OLV is tube malposition; immediate fiberoptic verification is mandatory"
      ],
      "whenToEscalate": [
        "If SpO2 remains < 85% despite all corrective steps, ask the surgeon to stop and temporarily resume two-lung ventilation (TLV)"
      ],
      "referencesToShow": [
        "Double-lumen tubes and bronchial blockers. PMC 2023.",
        "Principles of Thoracic Anesthesia. Clinical Review."
      ],
      "safetyLevel": "urgent"
    }
  },
