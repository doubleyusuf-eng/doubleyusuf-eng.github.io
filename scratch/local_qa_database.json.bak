    }
  },
  {
    "id": "turp_syndrome",
    "category": "clinical_scenarios",
    "keywords": [
      "glisin",
      "hiponatremi",
      "sendromu",
      "syndrome",
      "turp"
    ],
    "question_tr": "Turp sendromu",
    "question_en": "Turp hiponatremi",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "TURP sendromu irrigasyon sıvısının sistemik emilimiyle gelişen hiponatremi/volüm yükü tablosudur.\\nBelirtiler: huzursuzluk, konfüzyon, bulantı, hipertansiyon veya hipotansiyon, bradikardi, hipoksemi, pulmoner ödem, nöbet veya koma.\\n\\n1. Cerrahı uyar, irrigasyonu/cerrahiyi durdurmayı düşün.\\n2. Serum sodyum, osmolalite ve kan gazı al.\\n3. Oksijenasyon ve hemodinamiyi destekle.\\n4. Semptomatik ciddi hiponatremide hipertonik salin gerekebilir.\\n5. Volüm yükü varsa diüretik düşünülebilir.",
      "immediateRedFlags": [
        "Bilinçli (rejyonel anestezi altındaki) hastada aniden gelişen şiddetli baş ağrısı, konfüzyon, görme bulanıklığı, nöbet veya koma.",
        "Şiddetli hipertansiyon ile birlikte bradikardi (Kafa içi basınç artışı / Cushing triadı).",
        "Kan gazında serum sodyumunun <120 mEq/L bulunması."
      ],
      "missingCriticalInformation": [
        "Kullanılan irrigasyon sıvısının türü (Steril su, Glisin, Sorbitol, Mannitol)",
        "Cerrahi rezeksiyon süresi ve irrigasyon sıvısının yüksekliği"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Transüretral Prostat Rezeksiyonu (TURP) Sendromu",
        "Dilüsyonel Hiponatremi ve Beyin Ödemi Patofizyolojisi",
        "Hipertonik Salin (%3 NaCl) Düzeltme Protokolleri"
      ],
      "suggestedNextStepsGeneral": [
        "Derhal cerraha haber verin; irrigasyonu durdurun ve cerrahiyi en kısa sürede sonlandırın.",
        "Kan gazı alarak elektrolit (sodyum), hemoglobin ve osmolalite ölçün.",
        "Oksijenasyonu (%100 O₂) sağlayın, solunumu destekleyin.",
        "Ciddi semptomlar (nöbet, koma) ve sodyum <120 mEq/L varsa: %3 Hipertonik Salin (100 mL IV, 10-20 dakikada) yavaşça uygulayın.",
        "Volüm yüklenmesini azaltmak için Furosemide (20-40 mg IV) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "TURP sendromunun spinal anestezi altındaki uyanık hastada nörolojik bulgularla (konfüzyon, baş ağrısı) çok erken fark edilebileceği, genel anestezide ise bulguların maskeleneceği"
      ],
      "whenToEscalate": [
        "Dirençli nöbetler ve koma tablosunda havayolunu entübasyonla güvenceye alın, hipertonik salin tedavisine devam edin ve yoğun bakıma transfer edin"
      ],
      "referencesToShow": [
        "TURP Syndrome: Pathophysiology and Management. British Journal of Anaesthesia 2017. PMID: 26210243.",
        "Hyponatremia Guidelines. 2018."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "TURP syndrome results from systemic absorption of irrigation fluid causing hyponatremia and volume overload. Signs include restlessness, confusion, nausea, hypertension or hypotension, bradycardia, hypoxemia, pulmonary edema, seizure, or coma. Inform the surgeon and consider stopping irrigation/surgery. Check sodium, osmolality, and blood gas, support oxygenation and hemodynamics, use hypertonic saline for severe symptomatic hyponatremia, and consider diuretics if volume overloaded.",
      "immediateRedFlags": [
        "Sudden severe headache, confusion, visual disturbances, seizures, or coma in an awake patient under spinal anesthesia.",
        "Severe hypertension accompanied by bradycardia (Cushing's triad - indicating cerebral edema).",
        "Arterial blood gas showing serum sodium <120 mEq/L."
      ],
      "missingCriticalInformation": [
        "Type of irrigation fluid used (Glycine, Sorbitol, Mannitol, or sterile water)",
        "Total duration of resection and height of the irrigation fluid bags"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Transurethral Resection of Prostate (TURP) Syndrome",
        "Dilutional Hyponatremia and Cerebral Edema Pathophysiology",
        "Hypertonic Saline (3% NaCl) Correction Protocols"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately notify the surgeon; suspend irrigation and conclude the surgery rapidly.",
        "Draw blood gas to measure serum sodium, hematocrit, and osmolality.",
        "Provide 100% oxygen and assist ventilation as needed.",
        "For severe symptoms (seizures, coma) with Na <120 mEq/L: Administer 3% Hypertonic Saline (100 mL IV over 10-20 min).",
        "Administer Furosemide (20-40 mg IV) to promote diuresis and reduce volume overload."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Spinal anesthesia is preferred for TURP because it allows early detection of neurological signs of hyponatremia (headache, confusion) which would be masked under general anesthesia"
      ],
      "whenToEscalate": [
        "In the event of refractory seizures or coma, secure the airway with endotracheal intubation, continue controlled sodium correction, and transfer to ICU"
      ],
      "referencesToShow": [
        "TURP Syndrome: Pathophysiology and Management. British Journal of Anaesthesia 2017. PMID: 26210243.",
        "Hyponatremia Guidelines. 2018."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "hyponatremia",
    "category": "clinical_scenarios",
    "keywords": [
      "düşük",
      "hipertonik",
      "hiponatremi",
      "hyponatremia",
      "salin",
      "sodyum"
    ],
    "question_tr": "Hiponatremi",
    "question_en": "Hipertonik salin",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Önce akut/kronik ve semptomatik/asemptomatik ayrımı yapılır.\\nNöbet, koma, ciddi konfüzyon veya beyin ödemi bulgusu varsa acil tedavi gerekir.\\nSemptomatik ciddi hiponatremide hipertonik salin düşünülür. Düzeltme hızı kontrollü olmalıdır; hızlı düzeltme osmotik demiyelinizasyon riski taşır.\\nNedenler: hipotonik sıvı, SIADH, diüretik, TURP, adrenal yetmezlik, kalp/karaciğer/böbrek yetmezliği. Sodyum düzeltmesi seri ölçümlerle izlenmelidir.",
      "immediateRedFlags": [
        "Serum sodyumunun <120 mEq/L olması ve buna eşlik eden konvülsiyonlar, koma, solunum depresyonu (akut beyin ödemi bulguları).",
        "Sodyumun son derece hızlı düzeltilmesi sonucu postoperatif dönemde gelişen felç (Osmotik Demiyelinizasyon Sendromu - ODS)."
      ],
      "missingCriticalInformation": [
        "Hiponatreminin gelişme hızı (Akut <48 saat vs Kronik >=48 saat)",
        "Hastanın o anki idrar çıkışı ve volüm durumu (hipovolemik, normovolemik, hipervolemik mi?)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Akut Semptomatik Hiponatremi Yönetimi",
        "Hipertonik Salin (%3 NaCl) Hesaplama Standartları",
        "Osmotik Demiyelinizasyon Sendromu (ODS) ve Korunma Yolları"
      ],
      "suggestedNextStepsGeneral": [
        "Serum sodyumunu kan gazı veya biyokimya ile doğrulayın.",
        "Akut semptomatik ciddi hiponatremide: %3 NaCl (Hipertonik Salin) 100 mL IV (10-20 dakikada) uygulayın. Belirtiler geçmezse 10-15 dk sonra dozu tekrarlayabilirsiniz.",
        "Sodyum yükselme hızını günde 8-10 mEq/L ile sınırlandırın (kronik hiponatremi durumunda ODS önlemek için).",
        "Sıvı kısıtlaması uygulayın (hipotonik solüsyonları durdurun).",
        "Sodyumu her 2-4 saatte bir seri ölçümlerle takip edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Sodyum düzeltmesindeki temel hedefin sodyumu normale ulaştırmak değil, hayati nörolojik semptomları (ödemi) geriletecek kadar (3-5 mEq/L) güvenle yükseltmek olduğu"
      ],
      "whenToEscalate": [
        "Hipertonik saline rağmen geçmeyen nöbetlerde havayolunu koruyun, antikonvülzan başlayın ve acil yoğun bakıma nakledin"
      ],
      "referencesToShow": [
        "Clinical Practice Guideline on Diagnosis and Treatment of Hyponatremia. Eur J Endocrinol 2014. PMID: 24569125.",
        "Sterns RH. PMID: 29016373."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "First classify as acute/chronic and symptomatic/asymptomatic. Seizure, coma, severe confusion, or signs of cerebral edema require emergency treatment. Severe symptomatic hyponatremia may require hypertonic saline. Correction must be controlled because rapid correction risks osmotic demyelination. Causes include hypotonic fluids, SIADH, diuretics, TURP, adrenal insufficiency, heart/liver/kidney failure. Monitor sodium with serial measurements.",
      "immediateRedFlags": [
        "Serum sodium <120 mEq/L accompanied by seizures, coma, or respiratory depression (acute cerebral edema).",
        "Extremely rapid correction of sodium leading to quadriplegia and mutism (Osmotic Demyelination Syndrome - ODS)."
      ],
      "missingCriticalInformation": [
        "Onset duration of hyponatremia (Acute <48 hours vs. Chronic >=48 hours)",
        "Volume status of the patient (hypovolemic, euvolemic, or hypervolemic)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Acute Symptomatic Hyponatremia Management Guidelines",
        "Hypertonic Saline (3% NaCl) Infusion Protocols",
        "Osmotic Demyelination Syndrome (ODS) Prevention"
      ],
      "suggestedNextStepsGeneral": [
        "Confirm serum sodium using blood gas or core laboratory values.",
        "In acute symptomatic severe hyponatremia: Administer 3% NaCl (Hypertonic Saline) 100 mL IV over 10-20 min; may repeat once if symptoms persist.",
        "Limit the rate of sodium correction to <8-10 mEq/L per 24 hours to prevent ODS.",
        "Hold all hypotonic IV fluids immediately.",
        "Monitor serum sodium every 2-4 hours during active correction."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "The goal of emergency hypertonic saline is not to normalize sodium, but to raise it by 3-5 mEq/L to quickly reverse life-threatening cerebral edema"
      ],
      "whenToEscalate": [
        "In the event of seizures refractory to primary hypertonic saline, secure the airway, administer anticonvulsants, and transfer to ICU"
      ],
      "referencesToShow": [
        "Clinical Practice Guideline on Diagnosis and Treatment of Hyponatremia. Eur J Endocrinol 2014. PMID: 24569125.",
        "Sterns RH. PMID: 29016373."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "equipment_failure",
    "category": "clinical_scenarios",
    "keywords": [
      "arızası",
      "bozuldu",
      "ekipman",
      "equipment",
      "failure",
      "laringoskop",
      "ventilatör",
      "yanmıyor",
      "ışığı"
    ],
    "question_tr": "Ekipman arızası",
    "question_en": "Equipment failure",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "1. Hastayı cihazdan ayır ve self-inflating ambu ile alternatif oksijen kaynağından ventile et.\\n2. Yardım çağır.\\n3. Oksijen tüpü, merkezi sistem, akım, devre, ventilatör ve vaporizatörü kontrol et.\\n4. Hipoksemi varsa %100 oksijen ve manuel ventilasyon sürdür.\\n5. Cerrahı bilgilendir; gerekirse cerrahi durdurulur.\\n6. Sorun çözülene kadar hastayı güvenli alternatif ventilasyon/oksijenasyonla yönet.\\n7. Olay sonrası cihaz kullanım dışı bırakılıp teknik değerlendirme yapılmalıdır.",
      "immediateRedFlags": [
        "Mekanik ventilasyon sırasında ani ETCO₂ dalga kaybı ve SpO₂'nin hızla düşmesi (total havayolu kopması veya cihaz elektrik/gaz kaybı).",
        "Oksijen kaynağı arızası alarmlarının ötmesi ve inspiratuar oksijen konsantrasyonunun (FiO₂) <0.21 düzeyine inmesi (hipoksik gaz karışımı)."
      ],
      "missingCriticalInformation": [
        "Yedek oksijen tüpünün doluluk durumu ve Ambu balonunun (self-inflating bag) başucunda olup olmadığı",
        "Elektrik kesintisinde anestezi cihazı batarya süresi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Anestezi Cihazı ve Gaz Kaynağı Arızaları",
        "Hipoksik Karışım (Hypoxic Guard) Güvenlik Sistemleri",
        "Ambu Balonu ile Alternatif Havayolu Ventilasyonu"
      ],
      "suggestedNextStepsGeneral": [
        "Derhal hastayı anestezi cihazından ayırın ve başucundaki Ambu balonu + yedek oksijen tüpü ile manuel ventile etmeye başlayın.",
        "Acil yardım çağırın.",
        "Cihazın merkezi gaz hortumlarını ve yedek oksijen tüpü (silindir) vanasını kontrol edin.",
        "Elektrik kesintisi varsa cihazın batarya moduna geçtiğinden emin olun.",
        "Sorun çözülene kadar anesteziyi intravenöz ajanlarla (Propofol bolusları vb.) sürdürün (gazlar ve vaporizatör çalışmayacaktır)."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Merkezi oksijen hattında arıza veya kontaminasyon (başka gaz karışması) varsa, cihazın fişini merkezi hattan çekip yedek tüpe geçilmesi gerektiği"
      ],
      "whenToEscalate": [
        "Cihaz tamamen devre dışı kaldığında ve manuel ventilasyonla SpO₂ yükselmediğinde acil tüp torakostomisi veya CICO algoritmasına geçiş"
      ],
      "referencesToShow": [
        "ASA Guidelines for Anesthesia Machine Checklist. 2020. PMID: 29016373.",
        "Safety of Anesthesia Machines. British Journal of Anaesthesia 2018."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "1. Disconnect the patient from the machine and ventilate with a self-inflating bag using an alternative oxygen source.\\n2. Call for help.\\n3. Check oxygen cylinder, pipeline supply, flows, circuit, ventilator, and vaporizer.\\n4. If hypoxemia is present, continue 100% oxygen and manual ventilation.\\n5. Inform the surgeon and stop surgery if needed.\\n6. Maintain safe alternative ventilation/oxygenation until the problem is resolved.\\n7. The machine should be removed from service for technical evaluation after the event.",
      "immediateRedFlags": [
        "Sudden complete loss of ETCO₂ tracing and rapid desaturation during mechanical ventilation (suspected circuit disconnection or total gas power failure).",
        "O₂ pipeline pressure alarm sounding with inspiratory O₂ fraction (FiO₂) dropping below 0.21 (delivery of a hypoxic gas mixture)."
      ],
      "missingCriticalInformation": [
        "Availability and pressure of the backup O₂ cylinder, and presence of a self-inflating Ambu bag at the bedside",
        "Anesthesia machine battery backup status in the event of an electrical blackout"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Anesthesia Machine and Gas Pipeline Supply Failures",
        "Hypoxic Mixture Guard Safety Mechanics",
        "Emergency Bag-Valve-Mask (Ambu) Ventilation Standards"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately disconnect the patient from the anesthesia machine and initiate manual ventilation using a self-inflating Ambu bag connected to an auxiliary oxygen cylinder.",
        "Call for help.",
        "Inspect pipeline gas connections and open the backup O₂ cylinder valve.",
        "If a pipeline contamination (e.g. nitrous oxide crossed into O₂ line) is suspected, disconnect the O₂ pipeline hose completely so the machine draws from the backup cylinder.",
        "Maintain anesthesia with IV agents (e.g., Propofol boluses) while the machine is out of service."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Pipeline failure or gas cross-connection requires absolute disconnection of the pipeline hose; otherwise, the machine will preferentially draw the high-pressure contaminated pipeline gas over the cylinder gas"
      ],
      "whenToEscalate": [
        "If manual ventilation fails to restore SpO₂, rule out severe bronchospasm, tube obstruction, or pneumothorax; escalate immediately to CICO or resuscitation protocols if needed"
      ],
      "referencesToShow": [
        "ASA Guidelines for Anesthesia Machine Checklist. 2020. PMID: 29016373.",
        "Safety of Anesthesia Machines. British Journal of Anaesthesia 2018."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "osas_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "anestezi",
      "anesthesia",
      "apnea",
      "hastasında",
      "osas",
      "planı",
      "sleep"
    ],
    "question_tr": "Osas hastasında",
    "question_en": "Sleep apnea",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "OSAS hastasında temel riskler zor havayolu, hızlı desatürasyon, opioid duyarlılığı ve postoperatif solunum obstrüksiyonudur.\\n\\n1. STOP-Bang ile risk değerlendir.\\n2. Zor havayolu ekipmanı hazırla.\\n3. Opioid tasarruflu multimodal analjezi planla.\\n4. Sedatif premedikasyondan kaçın veya dozu azalt.\\n5. Ekstübasyonu tamamen uyanık, normotermik ve nöromüsküler blok tamamen geri dönmüşken yap.\\n6. PACU’da solunum obstrüksiyonu, desatürasyon ve opioid solunum depresyonu açısından yakın izle.\\n7. CPAP kullanan hasta cihazını postop dönemde kullanmalıdır.",
      "immediateRedFlags": [
        "PACU'da uyanma sonrasında tekrarlayan apne nöbetleri, ciddi desatürasyon (SpO₂ < %85) veya hava yolu kollapsı",
        "Sedasyon veya opioid alımı sonrasında solunum sıklığının <8/dk olması"
      ],
      "missingCriticalInformation": [
        "Hastanın evde CPAP kullanıp kullanmadığı ve en son STOP-Bang skoru",
        "Eşlik eden obezite, KOAH veya pulmoner hipertansiyon varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Obstrüktif Uyku Apnesi (OSAS) Yönetimi",
        "Opioid Tasarruflu Multimodal Analjezi (ESPB, Bloklar)",
        "PACU Solunum Obstrüksiyonu ve Güvenli Ekstübasyon"
      ],
      "suggestedNextStepsGeneral": [
        "STOP-Bang skorlamasını yapın (Skor >=5 ise yüksek risk).",
        "Anestezi indüksiyonunda ramp pozisyonu kullanın ve %100 O₂ ile preoksijenasyonu uzatın.",
        "İntraoperatif opioid kullanımını minimalize edip, parasetamol, NSAİİ ve bölgesel bloklar uygulayın.",
        "Reversal olarak mutlaka Sugammadeks kullanın ve TOF oranının >0.90 olduğunu kantitatif olarak doğrulayın.",
        "Ekstübasyonu uyanık, yarı oturur pozisyonda gerçekleştirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "stop_bang_score",
          "titleTr": "STOP-Bang Skor Hesaplayıcı"
        },
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        },
        {
          "id": "fentanyl",
          "titleTr": "Fentanil Monografı"
        }
      ],
      "doNotMiss": [
        "OSAS'lı hastaların opioidlerin solunum depresyonu etkisine karşı aşırı duyarlı olduğu gerçeği"
      ],
      "whenToEscalate": [
        "PACU'da CPAP desteğine rağmen düzelmeyen persistan desatürasyon ve obstrüksiyonda acil havayolu kurtarma planına geçin ve yoğun bakıma alın"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for the Perioperative Management of Patients with OSA. Anesthesiology 2014. PMID: 24346178.",
        "SAMBA Guidelines for OSA. Anesth Analg 2016. PMID: 27007789."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Main risks are difficult airway, rapid desaturation, opioid sensitivity, and postoperative airway obstruction. Assess risk with STOP-Bang, prepare difficult airway equipment, use opioid-sparing multimodal analgesia, avoid or reduce sedative premedication, extubate fully awake with complete neuromuscular recovery, and monitor closely in PACU for obstruction, desaturation, and opioid respiratory depression. Patients using CPAP should resume it postoperatively.",
      "immediateRedFlags": [
        "Recurrent postoperative apneas, severe desaturations (SpO₂ <85%), or complete airway collapse in the PACU.",
        "Respiratory rate <8 breaths/min following sedative or opioid administration."
      ],
      "missingCriticalInformation": [
        "Patient's home CPAP compliance status and baseline STOP-Bang score",
        "Co-existing obesity, COPD, or secondary pulmonary hypertension"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Obstructive Sleep Apnea (OSA) Anesthetic Guidelines",
        "Opioid-Sparing Multimodal Analgesia (Regional Blocks)",
        "PACU Airway Obstruction and Safe Extubation Criteria"
      ],
      "suggestedNextStepsGeneral": [
        "Calculate the STOP-Bang score (score >=5 indicates high risk).",
        "Utilize ramped positioning for induction and prolong preoxygenation with 100% O₂.",
        "Employ an opioid-sparing multimodal technique (Paracetamol, NSAIDs, regional blocks).",
        "Ensure complete neuromuscular blockade reversal with Sugammadex (verify TOF ratio >0.90).",
        "Extubate the patient fully awake and in a semi-sitting or upright position."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "stop_bang_score",
          "titleTr": "STOP-Bang Score Calculator"
        },
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        },
        {
          "id": "fentanyl",
          "titleTr": "Fentanyl Monograph"
        }
      ],
      "doNotMiss": [
        "Patients with OSA are extremely sensitive to the respiratory depressant effects of opioids; adjust doses cautiously"
      ],
      "whenToEscalate": [
        "If persistent airway obstruction or hypoxemia occurs in the PACU despite CPAP rescue, initiate advanced airway management and transfer to ICU"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for the Perioperative Management of Patients with OSA. Anesthesiology 2014. PMID: 24346178.",
        "SAMBA Guidelines for OSA. Anesth Analg 2016. PMID: 27007789."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "osas_ambulatory",
    "category": "clinical_scenarios",
    "keywords": [
      "ambulatory",
      "erteleme",
      "günübirlik",
      "osa",
      "osas"
    ],
    "question_tr": "Osas günübirlik",
    "question_en": "Ambulatory osa",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Karar OSAS şiddeti, komorbiditeler, cerrahi tipi, postop opioid ihtiyacı ve evde CPAP/izlem imkanına göre verilir.\\nKontrollü komorbiditeleri olan, minimal opioid gerektiren, kısa ve düşük riskli cerrahilerde günübirlik cerrahi düşünülebilir.\\nAğır OSAS, kontrolsüz kardiyopulmoner hastalık, yüksek opioid ihtiyacı, tekrarlayan PACU desatürasyonu veya evde güvenli izlem yoksa yatış daha güvenlidir.",
      "immediateRedFlags": [
        "STOP-Bang skoru >=5 olan ve eşlik eden dekompanse kalp yetmezliği veya ağır KOAH'ı olan kontrolsüz OSAS hastası.",
        "Günübirlik planlanan ancak intraoperatif yüksek doz opioid gereksinimi olan veya PACU'da solunumsal sıkıntı yaşayan hastalar."
      ],
      "missingCriticalInformation": [
        "Hastanın evde yalnız yaşayıp yaşamadığı ve gece gözetim imkanı",
        "Cerrahi ekibin postoperatif ağrı kontrolünde opioid dışı alternatif planı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Günübirlik Cerrahiye Uygunluk Kriterleri",
        "OSAS Hastalarında Postoperatif Ev İzlem Güvenliği",
        "PACU Taburculuk ve Komplikasyon Önleme"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın komorbiditelerini (hipertansiyon, DM, koroner hastalık) değerlendirin.",
        "Hastanın evde CPAP cihazını kullanıp kullanamayacağını ve eşlik edecek refakatçi varlığını sorgulayın.",
        "Eğer hasta ağır OSAS ise ve evde takip yetersiz olacaksa, günübirlik cerrahiyi iptal edip hastayı servise yatırın.",
        "PACU'da hastayı taburcu etmeden önce en az 3-4 saat desatürasyon/apne açısından gözlemleyin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "stop_bang_score",
          "titleTr": "STOP-Bang Skor Hesaplayıcı"
        },
        {
          "id": "aldrete_score",
          "titleTr": "Aldrete Skor Kılavuzu"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monografı"
        }
      ],
      "doNotMiss": [
        "OSAS hastalarında günübirlik cerrahiden sonraki ilk gece evde gelişebilecek obstrüktif apne ve ölüm riskinin yüksek olduğu"
      ],
      "whenToEscalate": [
        "PACU'da tekrarlayan desatürasyon atağı veya havayolu obstrüksiyonu gelişen tüm OSAS hastalarını günübirlik taburcu etmeyin, yatışını yapın"
      ],
      "referencesToShow": [
        "SAMBA Consensus Guidelines on OSA in Ambulatory Surgery. Anesth Analg 2016. PMID: 27007789.",
        "ASA Practice Advisory. Anesthesiology 2014. PMID: 24346178."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Decision depends on OSA severity, comorbidities, procedure type, postoperative opioid requirement, and availability of CPAP and safe home observation. Ambulatory surgery may be reasonable for low-risk, short procedures with controlled comorbidities and minimal opioid need. Severe OSA, uncontrolled cardiopulmonary disease, high opioid requirement, recurrent PACU desaturation, or unsafe home monitoring favors admission.",
      "immediateRedFlags": [
        "STOP-Bang score >=5 with co-existing decompensated heart failure or severe COPD.",
        "Recurrent airway obstruction or desaturation episodes in the PACU in a patient planned for same-day discharge."
      ],
      "missingCriticalInformation": [
        "Availability of a responsible adult companion for overnight supervision at home",
        "Patient's ownership of and compliance with a home CPAP machine"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Ambulatory Surgery Patient Selection Criteria",
        "Postoperative Home Monitoring Safety in OSA",
        "PACU Discharge Standards and Risk Mitigation"
      ],
      "suggestedNextStepsGeneral": [
        "Perform a rigorous preoperative STOP-Bang screening.",
        "Verify that the scheduled surgery has low postoperative pain and minimal opioid requirements.",
        "Ensure the patient can bring and use their home CPAP machine in the PACU and at home.",
        "Observe the patient in the PACU for a prolonged period (minimum 3 hours) in an unstimulated environment before discharge."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "stop_bang_score",
          "titleTr": "STOP-Bang Score Calculator"
        },
        {
          "id": "aldrete_score",
          "titleTr": "Aldrete Score Guide"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monograph"
        }
      ],
      "doNotMiss": [
        "Postoperative same-day discharge in severe OSA patients without a CPAP or home monitoring companion is highly dangerous"
      ],
      "whenToEscalate": [
        "Any patient who experiences recurrent apneas or oxygen desaturations in the PACU must be admitted for overnight monitoring"
      ],
      "referencesToShow": [
        "SAMBA Consensus Guidelines on OSA in Ambulatory Surgery. Anesth Analg 2016. PMID: 27007789.",
        "ASA Practice Advisory. Anesthesiology 2014. PMID: 24346178."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "obese_induction",
    "category": "clinical_scenarios",
    "keywords": [
      "airway",
      "hastada",
      "induction",
      "indüksiyon",
      "obese",
      "obez"
    ],
    "question_tr": "Obez hastada indüksiyon",
    "question_en": "Obese airway",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Obez hastada hızlı desatürasyon, zor maske ventilasyonu ve aspirasyon riski artabilir.\\n\\n1. Ramp/head-elevated pozisyon kullan.\\n2. Etkili preoksijenasyon yap; gerekirse CPAP/PEEP kullan.\\n3. Zor havayolu ekipmanı hazırla.\\n4. İlaç dozlarını total, ideal veya düzeltilmiş vücut ağırlığına göre ayrı ayrı değerlendir.\\n5. Entübasyonu kapnografiyle doğrula.\\n6. Ventilasyonda tidal volümü ideal/predicted body weight’e göre ayarla.\\n7. Ekstübasyonu tam uyanık ve güvenli pozisyonda yap.",
      "immediateRedFlags": [
        "Preoksijenasyona rağmen indüksiyon sonrasında SpO₂'nin saniyeler içinde <%90 olması (hızlı desatürasyon).",
        "Zor maske ventilasyonu ve uyanık entübasyon gerektirecek derecede dar kitle/boyun anatomisi varlığı."
      ],
      "missingCriticalInformation": [
        "Hastanın Gerçek Vücut Ağırlığı (TBW), İdeal Vücut Ağırlığı (IBW) ve hesaplanmış predicted body weight (PBW)",
        "Eşlik eden ağır OSAS veya Pickwickian sendromu varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Obez Hastada İndüksiyon ve Havayolu Yönetimi",
        "Farmakolojik Dozlama Kuralları (TBW vs IBW vs LBW)",
        "Koruyucu Akciğer Ventilasyonu (LTVT) ve PEEP"
      ],
      "suggestedNextStepsGeneral": [
        "İndüksiyon öncesi hastaya mutlaka 'Ramp' (baş ve omuzlar yükseltilmiş, kulak memesi sternal çentik hizasında) pozisyonu verin.",
        "Preoksijenasyonu 3-5 dakika boyunca %100 O₂ ve 5-10 cmH₂O CPAP/PEEP ile gerçekleştirin.",
        "İndüksiyon dozlamalarında: Propofolü Yağsız Vücut Kütlesine (LBW), Süksinilkolini Gerçek Ağırlığa (TBW), Roküronyumu İdeal Ağırlığa (IBW) göre dozlayın.",
        "Ventilatörde tidal volümü 6 mL/kg PBW olarak ayarlayın, PEEP'i 8-12 cmH₂O düzeyinde tutun."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "bmi",
          "titleTr": "BMI & İdeal Kilo"
        },
        {
          "id": "ibw_tidal_volume",
          "titleTr": "IBW & Tidal Volüm"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        },
        {
          "id": "succinylcholine",
          "titleTr": "Süksinilkolin Monografı"
        },
        {
          "id": "rocuronium",
          "titleTr": "Roküronyum Monografı"
        }
      ],
      "doNotMiss": [
        "Obez hastalarda fonksiyonel rezidüel kapasite (FRK) çok daraldığı için apnede desatürasyon süresinin son derece kısa olduğu"
      ],
      "whenToEscalate": [
        "Entübasyon ve maske ventilasyonu başarısız olduğunda derhal zor havayolu / CICO algoritmasını başlatın"
      ],
      "referencesToShow": [
        "Guidelines for Anesthetic Management of Morbidly Obese Patients. British Journal of Anaesthesia 2015. PMID: 25416285.",
        "ASA Difficult Airway Guidelines 2022. PMID: 34762285."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Obesity increases the risk of rapid desaturation, difficult mask ventilation, and aspiration. Use ramped/head-elevated positioning, effective preoxygenation with CPAP/PEEP if needed, prepare difficult airway equipment, dose drugs according to total, ideal, or adjusted body weight as appropriate, confirm intubation with capnography, set tidal volume according to predicted body weight, and extubate fully awake in a safe position.",
      "immediateRedFlags": [
        "Extremely rapid oxygen desaturation (SpO₂ <90% within seconds of apnea) despite optimal preoxygenation.",
        "Inability to perform mask ventilation or achieve supraglottic rescue (CICO threat)."
      ],
      "missingCriticalInformation": [
        "Patient's exact Total Body Weight (TBW), Ideal Body Weight (IBW), and Lean Body Weight (LBW)",
        "Presence of Obesity Hypoventilation Syndrome (OHS/Pickwickian)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Anesthetic Induction in Morbid Obesity",
        "Pharmacological Dosing Principles (TBW vs. IBW vs. LBW)",
        "Intraoperative Protective Lung Ventilation and PEEP Optimization"
      ],
      "suggestedNextStepsGeneral": [
        "Position the patient in a 'Ramp' position (earlobe aligned horizontally with the sternal notch) before induction.",
        "Preoxygenate for 3-5 minutes with 100% O₂ using CPAP/PEEP (5-10 cmH₂O) to recruit alveoli.",
        "Dose induction agents: Propofol based on LBW, Succinylcholine on TBW, and Rocuronium on IBW.",
        "Set intraoperative ventilation to 6 mL/kg based on Predicted Body Weight (PBW), and maintain PEEP at 8-12 cmH₂O."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "bmi",
          "titleTr": "BMI Calculator"
        },
        {
          "id": "ibw_tidal_volume",
          "titleTr": "IBW & Tidal Volume"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        },
        {
          "id": "succinylcholine",
          "titleTr": "Succinylcholine Monograph"
        },
        {
          "id": "rocuronium",
          "titleTr": "Rocuronium Monograph"
        }
      ],
      "doNotMiss": [
        "Functional Residual Capacity (FRC) is severely reduced in obesity, leading to extremely rapid desaturation during apnea"
      ],
      "whenToEscalate": [
        "If both intubation and rescue ventilation fail, immediately declare CICO and execute the front-of-neck access pathway"
      ],
      "referencesToShow": [
        "Guidelines for Anesthetic Management of Morbidly Obese Patients. British Journal of Anaesthesia 2015. PMID: 25416285.",
        "ASA Difficult Airway Guidelines 2022. PMID: 34762285."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "bariatric_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "anestezi",
      "anesthesia",
      "bariatric",
      "bariatrik",
      "cerrahi",
      "surgery"
    ],
    "question_tr": "Bariatrik cerrahi",
    "question_en": "Bariatric anesthesia",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Bariatrik cerrahide OSAS, zor havayolu, aspirasyon, ventilasyon güçlüğü, rabdomiyoliz, tromboemboli ve postop solunum depresyonu riski artar.\\nPlan: ramp pozisyon, iyi preoksijenasyon, opioid azaltıcı analjezi, ideal kiloya göre tidal volüm, uygun PEEP, DVT profilaksisi, tamamen uyanık ekstübasyon ve PACU’da yakın solunum izlemi. Uzun cerrahilerde bası noktaları ve pozisyon hasarı da korunmalıdır.",
      "immediateRedFlags": [
        "Cerrahi sonrası uyanma gecikmesi, derin karbondioksit retansiyonu (PaCO₂ >60 mmHg) ve persistan solunum asidozu.",
        "Özellikle uzun süren prone veya litotomi-bariatrik cerrahilerde ekstremitelerde kompartman sendromu bulguları (şiddetli ağrı, sertlik)."
      ],
      "missingCriticalInformation": [
        "Hastanın preoperatif solunumsal ve kardiyak fonksiyon testleri (EKO, SFT)",
        "İntraoperatif cerrahi pnömoperitoneum basıncı (tercihen <12-15 mmHg tutulmalıdır)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Bariatrik Cerrahi Anestezi Yönetimi",
        "Pnömoperitoneum Altında Ventilasyon ve Akciğer Koruma",
        "Postoperatif Tromboemboli (DVT/PE) ve Rabdomiyoliz Önleme"
      ],
      "suggestedNextStepsGeneral": [
        "İndüksiyonda ramp pozisyonunu ve uyanık ekstübasyonu standart olarak planlayın.",
        "Pnömoperitoneum sırasında tepe havayolu basıncını (<30-35 cmH₂O) tutabilmek için basınç kontrollü ventilasyon (PCV) veya volum garantili basınç kontrolü (PCV-VG) tercih edin.",
        "Rabdomiyoliz riskini azaltmak için ameliyat masasında jel pedler kullanın ve basınç noktalarını koruyun.",
        "Opioid kullanımını azaltmak için multimodal analjezi (TAP blok, İntravenöz Ketamin/Lidokain infüzyonu) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "bmi",
          "titleTr": "BMI & İdeal Kilo"
        },
        {
          "id": "ibw_tidal_volume",
          "titleTr": "IBW & Tidal Volüm"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "rocuronium",
          "titleTr": "Roküronyum Monografı"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        }
      ],
      "doNotMiss": [
        "Bariatrik hastalarda ameliyat süresinin uzaması durumunda gluteal ve lomber bölgelerde rabdomiyoliz ve buna bağlı akut böbrek hasarı gelişebileceği"
      ],
      "whenToEscalate": [
        "Postoperatif solunum yetmezliği veya derin hipoksemi durumunda derhal Non-invaziv Mekanik Ventilasyon (NIV/CPAP) desteği başlatın ve yoğun bakıma alın"
      ],
      "referencesToShow": [
        "SOBA (Society for Obesity and Bariatric Anaesthesia) Guidelines. Anaesthesia 2019. PMID: 31089671.",
        "Bariatric Anesthesia Guidelines. BJA 2015. PMID: 25416285."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Bariatric surgery increases the risk of OSA, difficult airway, aspiration, difficult ventilation, rhabdomyolysis, thromboembolism, and postoperative respiratory depression. Plan ramped positioning, effective preoxygenation, opioid-sparing analgesia, tidal volume based on predicted body weight, appropriate PEEP, DVT prophylaxis, fully awake extubation, and close PACU respiratory monitoring. Protect pressure points and avoid positioning injury during long procedures.",
      "immediateRedFlags": [
        "Delayed emergence from anesthesia with profound hypercapnia (PaCO₂ >60 mmHg) and severe respiratory acidosis.",
        "Postoperative signs of gluteal or extremity compartment syndrome or rhabdomyolysis (severe pain, swelling)."
      ],
      "missingCriticalInformation": [
        "Preoperative baseline arterial blood gas or sleep study results",
        "Intraoperative pneumoperitoneum pressure limits (target <12-15 mmHg)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Anesthetic Management for Bariatric Surgery",
        "Ventilatory Adjustments During Laparoscopic Pneumoperitoneum",
        "Postoperative Thromboembolism (DVT/PE) and Rhabdomyolysis Prevention"
      ],
      "suggestedNextStepsGeneral": [
        "Mandate ramped positioning, PEEP optimization, and fully awake extubation.",
        "Use pressure-controlled or PCV-VG ventilation during pneumoperitoneum to manage peak airway pressures (<35 cmH₂O).",
        "Avoid positioning injury and rhabdomyolysis by using gel pads and padding all bony prominences.",
        "Implement an opioid-sparing multimodal pain regimen (e.g. TAP block, low-dose IV ketamine, lidocaine infusion)."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "bmi",
          "titleTr": "BMI Calculator"
        },
        {
          "id": "ibw_tidal_volume",
          "titleTr": "IBW & Tidal Volume"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "rocuronium",
          "titleTr": "Rocuronium Monograph"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        }
      ],
      "doNotMiss": [
        "Prolonged bariatric procedures under deep sedation are major risk factors for rhabdomyolysis-induced acute kidney injury"
      ],
      "whenToEscalate": [
        "For persistent postoperative hypoventilation or severe desaturations, initiate non-invasive positive pressure ventilation (NIV/CPAP) and transfer to ICU"
      ],
      "referencesToShow": [
        "SOBA (Society for Obesity and Bariatric Anaesthesia) Guidelines. Anaesthesia 2019. PMID: 31089671.",
        "Bariatric Anesthesia Guidelines. BJA 2015. PMID: 25416285."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "ambulatory_discharge",
    "category": "clinical_scenarios",
    "keywords": [
      "aldrete",
      "ambulatory",
      "discharge",
      "edilebilir",
      "günübirlik",
      "taburcu",
      "taburculuk"
    ],
    "question_tr": "Günübirlik taburculuk",
    "question_en": "Aldrete taburcu",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Taburculuk için hasta uyanık, oryante, vital bulguları stabil, oksijenasyonu yeterli, ağrısı ve bulantısı kontrol altında, ciddi kanaması yok ve mobilizasyonu uygun olmalıdır.\\nAldrete veya kurum taburculuk skoru kullanılabilir. OSAS, opioid kullanımı, rezidüel blok, tekrarlayan desatürasyon, kontrolsüz ağrı/bulantı, idrar retansiyonu veya cerrahi komplikasyon varsa taburculuk ertelenmelidir.",
      "immediateRedFlags": [
        "Uyanık olmasına rağmen oda havasında SpO₂'nin <%92 olması veya tekrarlayan hava yolu obstrüksiyonları.",
        "Ayaklanma (mobilizasyon) sırasında şiddetli postural hipotansiyon veya senkop gelişmesi.",
        "Aktif cerrahi alan kanaması bulguları."
      ],
      "missingCriticalInformation": [
        "Hastanın postoperatif dönemde ilk idrarını yapıp yapmadığı (özellikle spinal anestezi veya pelvik cerrahi sonrası)",
        "Evde hastayla birlikte kalacak ve takip edecek güvenilir bir refakatçinin varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Günübirlik Cerrahi Taburculuk Kriterleri (Modified PADSS)",
        "Postoperatif Rezidüel Blok ve Solunum Komplikasyonları",
        "Postoperatif İdrar Retansiyonu (POUR) Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın vital bulgularını (basınç, nabız, solunum) en az 30 dakika stabil olduğunu teyit edin.",
        "Modifiye Aldrete veya PADSS (Post-Anesthetic Discharge Scoring System) skorlamasını yapın (Skor >=9 taburculuk için uygundur).",
        "Spinal anestezi alan hastada sakral dermatomların (S1-S2) duyusal bloğunun tamamen çözüldüğünü ve idrar yapabildiğini doğrulayın.",
        "Bulantı, kusma ve ağrının tamamen kontrol altına alındığından emin olun."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "aldrete_score",
          "titleTr": "Aldrete Skor Kılavuzu"
        },
        {
          "id": "apfel_score",
          "titleTr": "Apfel Skor Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ondansetron",
          "titleTr": "Ondansetron Monografı"
        }
      ],
      "doNotMiss": [
        "Spinal anestezi sonrasında idrar yapamayan (POUR) hastaların taburcu edilmesi durumunda kalıcı mesane hasarı gelişebileceği"
      ],
      "whenToEscalate": [
        "Yetersiz ağrı kontrolü, inatçı kusma, idrar retansiyonu veya cerrahi kanama varlığında günübirlik taburculuğu iptal edin ve servise yatırın"
      ],
      "referencesToShow": [
        "Practice Guidelines for Ambulatory Anesthesia. Anesthesiology 2015. PMID: 25416285.",
        "PADSS Scoring System for Discharge. JAMA 1995."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "The patient should be awake, oriented, hemodynamically stable, adequately oxygenated, with controlled pain and nausea, no significant bleeding, and appropriate mobility. Aldrete or institutional discharge scores may be used. OSA, opioid use, residual block, recurrent desaturation, uncontrolled pain/nausea, urinary retention, or surgical complications should delay discharge.",
      "immediateRedFlags": [
        "SpO₂ <92% on room air or recurrent upper airway obstruction in an awake patient.",
        "Severe orthostatic hypotension or syncope upon mobilization.",
        "Evidence of active, unmanaged surgical site hemorrhage."
      ],
      "missingCriticalInformation": [
        "Patient's ability to void spontaneously (especially after spinal anesthesia or pelvic/urologic surgery)",
        "Presence of a responsible adult to escort the patient home and monitor them overnight"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Ambulatory Discharge Scoring Systems (PADSS)",
        "Postoperative Residual Block and Airway Protection",
        "Postoperative Urinary Retention (POUR) Evaluation"
      ],
      "suggestedNextStepsGeneral": [
        "Ensure hemodynamics are stable and within 20% of baseline for at least 30 minutes.",
        "Calculate the Modified Aldrete or PADSS score (target score >=9 for safe discharge).",
        "Confirm complete regression of sensory and motor block in patients who received neuraxial anesthesia.",
        "Ensure the patient can tolerate oral fluids, void successfully, and walk without dizziness.",
        "Verify that postoperative pain is well-controlled with oral analgesics."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "aldrete_score",
          "titleTr": "Aldrete Score Guide"
        },
        {
          "id": "apfel_score",
          "titleTr": "Apfel Score Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ondansetron",
          "titleTr": "Ondansetron Monograph"
        }
      ],
      "doNotMiss": [
        "Discharging a patient with incomplete regression of spinal block carries a high risk of postoperative urinary retention and bladder injury"
      ],
      "whenToEscalate": [
        "Cancel same-day discharge and admit the patient if there is uncontrolled pain, intractable vomiting, urinary retention, or active bleeding"
      ],
      "referencesToShow": [
        "Practice Guidelines for Ambulatory Anesthesia. Anesthesiology 2015. PMID: 25416285.",
        "PADSS Scoring System for Discharge. JAMA 1995."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "chronic_opioid_pain",
    "category": "clinical_scenarios",
    "keywords": [
      "chronic",
      "kronik",
      "kullanan",
      "opioid",
      "pain",
      "tolerans"
    ],
    "question_tr": "Kronik opioid",
    "question_en": "Opioid tolerans",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Kronik opioid kullanan hastada tolerans, hiperaljezi ve yoksunluk riski vardır.\\n\\n1. Bazal opioid ihtiyacını kesme.\\n2. Multimodal analjezi planla: parasetamol, NSAİİ uygunsa, rejyonal teknik, ketamin düşük doz, magnezyum veya alfa-2 agonist düşünülebilir.\\n3. Tek başına standart opioid dozları yetersiz kalabilir.\\n4. Solunum depresyonu yine mümkündür; özellikle OSAS ve sedatif eşlik ediyorsa dikkat et.\\n5. Postop analjezi planı önceden yazılı olmalıdır.",
      "immediateRedFlags": [
        "Hastada opioid yoksunluk sendromu bulgularının (taşikardi, terleme, midriyazis, şiddetli karın ağrısı ve ajitasyon) gelişmesi.",
        "Yetersiz ağrı nedeniyle gelişen ve miyokard iskemisini tetikleyen kontrolsüz taşikardi/hipertansiyon."
      ],
      "missingCriticalInformation": [
        "Hastanın ameliyat öncesinde günlük tükettiği bazal opioid miktarı (oral morfin eşdeğeri olarak)",
        "Hastanın opioid kullanımına neden olan kronik ağrısının patofizyolojisi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Kronik Opioid Toleransı ve Hiperaljezi",
        "İntraoperatif Multimodal Opioid Dışı Analjezikler (Ketamin, Lidokain)",
        "Hasta Kontrollü Analjezi (PCA) Protokolleri"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın bazal evde kullandığı opioidi (örn. Fentanil yama, oral Metadon) ameliyat sabahı da devam ettirin.",
        "Rejyonal veya nöroaksiyel anestezi tekniklerini (kombine spinal epidural, periferik sinir blokları) öncelikle planlayın.",
        "İntraoperatif analjezide Ketamin (0.1-0.2 mg/kg IV bolus ve ardından 0.1-0.2 mg/kg/saat infüzyon) uygulayın.",
        "Postoperatif dönemde standart hastalara göre %30-50 daha yüksek dozlarda opioid PCA (Morfin veya Fentanil) planlayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "opioid_equivalence",
          "titleTr": "Opioid Eşdeğerlik Tablosu"
        },
        {
          "id": "asa_ps",
          "titleTr": "ASA PS Sınıflama Kılavuzu"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "fentanyl",
          "titleTr": "Fentanil Monografı"
        },
        {
          "id": "ketamine",
          "titleTr": "Ketamin Monografı"
        },
        {
          "id": "morphine",
          "titleTr": "Morfin Monografı"
        }
      ],
      "doNotMiss": [
        "Kronik opioid bağımlısı hastalarda ameliyat sabahı bazal opioidlerin (yama vs.) kesilmesinin hızlı opioid yoksunluk krizine neden olacağı"
      ],
      "whenToEscalate": [
        "Dirençli ağrı krizlerinde veya yoksunluk sendromu varlığında Akut Ağrı Servisi konsültasyonu isteyin ve hastayı yakın hemodinami takibine alın"
      ],
      "referencesToShow": [
        "Guidelines on the Management of Postoperative Pain in Patients with Chronic Opioid Use. Pain Medicine 2021. PMID: 32986423.",
        "ASA Practice Guidelines. 2016."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Chronic opioid users have tolerance, hyperalgesia, and withdrawal risk. Continue baseline opioid needs, use multimodal analgesia such as paracetamol, NSAIDs if appropriate, regional techniques, low-dose ketamine, magnesium, or alpha-2 agonists. Standard opioid doses alone may be inadequate. Respiratory depression can still occur, especially with OSA or sedatives. A written postoperative analgesia plan should be prepared in advance.",
      "immediateRedFlags": [
        "Signs of acute opioid withdrawal syndrome (tachycardia, diaphoresis, mydriasis, severe abdominal cramping, agitation).",
        "Uncontrolled severe pain causing myocardial ischemia or hemodynamic instability."
      ],
      "missingCriticalInformation": [
        "Patient's baseline daily opioid consumption (calculated as oral morphine equivalents)",
        "Whether the patient is on medication-assisted treatment (e.g. Methadone, Buprenorphine)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Chronic Opioid Tolerance and Induced Hyperalgesia",
        "Intraoperative Non-Opioid Multimodal Adjuvants (Ketamine, Lidokain)",
        "Postoperative Patient-Controlled Analgesia (PCA) Dosing"
      ],
      "suggestedNextStepsGeneral": [
        "Maintain the patient's baseline chronic opioid regimen (e.g., continue transdermal fentanyl patches).",
        "Maximalize regional or neuraxial anesthetic techniques (spinal/epidural blocks).",
        "Incorporate low-dose sub-anesthetic Ketamine (0.1-0.2 mg/kg/h) intraoperatively.",
        "Plan a postoperative opioid PCA with a 30-50% higher demand dose and a baseline background infusion if appropriate.",
        "Administer standard non-opioid analgesics (Paracetamol, NSAIDs if not contraindicated)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "opioid_equivalence",
          "titleTr": "Opioid Equivalence Table"
        },
        {
          "id": "asa_ps",
          "titleTr": "ASA PS Classification Guide"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "fentanyl",
          "titleTr": "Fentanyl Monograph"
        },
        {
          "id": "ketamine",
          "titleTr": "Ketamine Monograph"
        },
        {
          "id": "morphine",
          "titleTr": "Morphine Monograph"
        }
      ],
      "doNotMiss": [
        "Abrupt discontinuation of baseline chronic opioids on the morning of surgery will precipitate severe withdrawal crisis"
      ],
      "whenToEscalate": [
        "In cases of refractory acute-on-chronic pain crises, consult the Acute Pain Service early and manage under close hemodynamic monitoring"
      ],
      "referencesToShow": [
        "Guidelines on the Management of Postoperative Pain in Patients with Chronic Opioid Use. Pain Medicine 2021. PMID: 32986423.",
        "ASA Practice Guidelines. 2016."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "alcohol_benzodiazepine_dep",
    "category": "clinical_scenarios",
    "keywords": [
      "alcohol",
      "alkol",
      "bağımlılığı",
      "benzodiazepin",
      "benzodiazepine",
      "dep",
      "withdrawal",
      "yoksunluk"
    ],
    "question_tr": "Alkol bağımlılığı",
    "question_en": "Benzodiazepine withdrawal",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Bu hastalarda tolerans, yoksunluk, deliryum, nöbet, karaciğer hastalığı ve ilaç etkileşimi riski vardır.\\n\\n1. Son kullanım zamanı ve miktarı öğren.\\n2. Yoksunluk belirtilerini değerlendir.\\n3. Elektrolit, glukoz, karaciğer fonksiyonları ve koagülasyonu kontrol et.\\n4. Postop deliryum ve ajitasyon için yakın izlem yap.\\n5. Benzodiazepin yoksunluğunda benzodiazepin tedavisi gerekebilir.\\n6. Alkol kullanımında tiamin eksikliği ve hipoglisemi unutulmamalıdır.",
      "immediateRedFlags": [
        "Alkol yoksunluğuna bağlı gelişen Delirium Tremens bulguları (aşırı otonom hiperaktivite, taşikardi, terleme, görsel halüsinasyonlar, konvülsiyonlar).",
        "Bilinç bulanıklığı ile birlikte eş zamanlı kan şekeri düzeyinin <50 mg/dL olması (hipoglisemi koması)."
      ],
      "missingCriticalInformation": [
        "En son alkol veya benzodiazepin alım saati",
        "Hastanın karaciğer yetmezliği ve siroz varlığı (Child-Pugh veya MELD skoru)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Alkol ve Madde Bağımlılığı Perioperatif Yönetimi",
        "Delirium Tremens ve Otonom Hiperaktivite Krizleri",
        "Wernicke Ensefalopatisi ve Tiamin Koruma Protokolü"
      ],
      "suggestedNextStepsGeneral": [
        "Preoperatif dönemde hastanın son kullanım profilini detaylıca sorgulayın.",
        "Alkol bağımlısı hastada Wernicke ensefalopatisi riskini önlemek için glukoz vermeden ÖNCE mutlaka Tiamin (100 mg IV) uygulayın.",
        "Yoksunluk krizini (titreme, taşikardi, terleme) kontrol etmek için Midazolam (1-2 mg IV) veya Diazepam titre edin.",
        "Postoperatif dönemde deliryum taraması yapın ve ajitasyon kontrolü için Deksmedetomidin infüzyonu planlayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "aldrete_score",
          "titleTr": "Aldrete Skor Kılavuzu"
        },
        {
          "id": "gcs",
          "titleTr": "Glaskow Koma Skalası"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monografı"
        },
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Kronik alkolik hastada glukoz verilmesinin (tiamin verilmeden önce) akut Wernicke ensefalopatisini tetikleyebileceği gerçeği"
      ],
      "whenToEscalate": [
        "Delirium Tremens veya status epileptikus (nöbet) gelişmesi durumunda havayolunu koruyun ve hastayı derhal yoğun bakıma alın"
      ],
      "referencesToShow": [
        "Perioperative Management of the Patient with Substance Use Disorder. Anesthesiology 2018. PMID: 29016373.",
        "Whelton PK, et al. Anesthesiology 2018."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Risks include tolerance, withdrawal, delirium, seizures, liver disease, and drug interactions. Determine last use and amount, assess withdrawal symptoms, check electrolytes, glucose, liver function, and coagulation, monitor for postoperative delirium/agitation, and treat benzodiazepine withdrawal with benzodiazepines when needed. In alcohol use disorder, do not miss thiamine deficiency and hypoglycemia.",
      "immediateRedFlags": [
        "Delirium Tremens presenting with severe autonomic hyperactivity, tachycardia, diaphoresis, visual hallucinations, or generalized seizures.",
        "Delayed emergence combined with severe hypoglycemia (glucose <50 mg/dL)."
      ],
      "missingCriticalInformation": [
        "Exact timing of the last alcohol or benzodiazepine consumption",
        "Underlying liver cirrhosis severity (Child-Pugh or MELD score)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Perioperative Management of Alcohol and Substance Dependence",
        "Delirium Tremens and Autonomic Overactivity Management",
        "Wernicke Encephalopathy Prevention (Thiamine Administration)"
      ],
      "suggestedNextStepsGeneral": [
        "Obtain a thorough history regarding substance use patterns.",
        "Administer Thiamine (100 mg IV) BEFORE any dextrose infusion to prevent Wernicke's encephalopathy in chronic alcoholics.",
        "Monitor for withdrawal signs using CIWA-Ar protocol; treat with titrated Benzodiazepines (e.g. Diazepam or Midazolam).",
        "Use Dexmedetomidine infusion (0.2-0.7 mcg/kg/h) in the PACU to control severe agitation and sympathetic surges."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "aldrete_score",
          "titleTr": "Aldrete Score Guide"
        },
        {
          "id": "gcs",
          "titleTr": "Glasgow Coma Scale"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monograph"
        },
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Administering glucose infusions before IV thiamine in a thiamine-deficient alcoholic patient can precipitate acute, irreversible Wernicke Encephalopathy"
      ],
      "whenToEscalate": [
        "If the patient develops Delirium Tremens or status epilepticus, secure the airway and immediately transfer to the ICU"
      ],
      "referencesToShow": [
        "Perioperative Management of the Patient with Substance Use Disorder. Anesthesiology 2018. PMID: 29016373.",
        "Whelton PK, et al. Anesthesiology 2018."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "renal_failure_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "anesthesia",
      "böbrek",
      "failure",
      "nefrotoksik",
      "renal",
      "yetmezlik",
      "yetmezliği"
    ],
    "question_tr": "Böbrek yetmezliği",
    "question_en": "Renal failure",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Böbrek yetmezliğinde sıvı yükü, hiperkalemi, asidoz, anemi, üremik trombosit disfonksiyonu ve ilaç birikimi önemlidir.\\n\\n1. Potasyum, asidoz, volüm durumu ve son diyaliz zamanı değerlendir.\\n2. Nefrotoksik ilaçlardan kaçın.\\n3. Renal atılımı olan ilaçların dozunu ayarla.\\n4. Hiperkalemi varsa elektif cerrahi ertelenebilir veya acil tedavi gerekir.\\n5. Sıvı tedavisini dikkatli filtre et.\\n6. AV fistül olan koldan damar yolu/tansiyon ölçümünden kaçın.",
      "immediateRedFlags": [
        "Serum potasyum düzeyinin >6.0 mEq/L olması ve EKG'de sivri T dalgaları, PR uzaması veya geniş QRS bulunması (kardiyak arrest riski!).",
        "Sıvı yüklenmesine bağlı gelişen akut akciğer ödemi ve derin hipoksemi."
      ],
      "missingCriticalInformation": [
        "Hastanın en son serum Kreatinin, eGFR ve Potasyum değerleri",
        "Hastanın son hemodiyaliz seansının tarihi ve diyaliz sırasındaki ultrafiltrasyon miktarı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Son Dönem Böbrek Yetmezliği (SDBY) Anestezi Kılavuzları",
        "Hiperkalemi İlişkili Kardiyotoksisite ve Tedavisi",
        "Renal Atılımı Olmayan İlaçların Seçimi (Cisatrakuryum)"
      ],
      "suggestedNextStepsGeneral": [
        "Potasyum düzeyini indüksiyondan hemen önce kan gazı ile kontrol edin.",
        "Hiperkalemi (K >5.5 mEq/L) varsa: Kalsiyum Glukonat (1 g IV), ardından Regüler İnsülin (10 U) + 50 mL %50 Dekstroz infüzyonu yapın.",
        "Kas gevşetici olarak organ bağımsız Hofmann eliminasyonu olan Cisatracurium (0.15 mg/kg) tercih edin.",
        "Opioid olarak birikim yapmayan Remifentanil veya Fentanil kullanın (Morfin ve meperidinden kaçının).",
        "AV fistülün olduğu koldan tansiyon ölçmeyin, damar yolu açmayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "creatinine_clearance",
          "titleTr": "eGFR & Kreatinin Klerensi"
        },
        {
          "id": "asa_ps",
          "titleTr": "ASA PS Sınıflama Kılavuzu"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "cisatracurium",
          "titleTr": "Cisatrakuryum Monografı"
        },
        {
          "id": "atropine",
          "titleTr": "Atropin Monografı"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        }
      ],
      "doNotMiss": [
        "Morfinin aktif metaboliti olan Morfin-6-Glukuronid ve kas gevşetici vekuronyum/pankuronyumun böbrek yetmezliğinde birikerek derin postoperatif felce neden olabileceği"
      ],
      "whenToEscalate": [
        "Dirençli hiperkalemi (K >6.5 mEq/L) veya anürik akciğer ödemi varlığında elektif cerrahiyi erteleyin ve hastayı acil hemodiyalize yönlendirin"
      ],
      "referencesToShow": [
        "Anesthetic Management of Patients with End-Stage Renal Disease. BJA Education 2016. PMID: 29016373.",
        "KDIGO Clinical Practice Guideline for Acute Kidney Injury. 2012."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Key issues are fluid overload, hyperkalemia, acidosis, anemia, uremic platelet dysfunction, and drug accumulation. Assess potassium, acidosis, volume status, and last dialysis. Avoid nephrotoxic drugs, adjust renally cleared medications, treat or postpone for hyperkalemia when appropriate, titrate fluids carefully, and avoid IV access or blood pressure measurement on the arm with an AV fistula.",
      "immediateRedFlags": [
        "Serum potassium >6.0 mEq/L with ECG changes (peaked T waves, PR prolongation, wide QRS - imminent risk of ventricular fibrillation).",
        "Acute pulmonary edema and severe hypoxemia due to hypervolemic fluid overload."
      ],
      "missingCriticalInformation": [
        "Patient's most recent serum Potassium, Creatinine, and eGFR",
        "Exact timing of the last dialysis session and volume removed (ultrafiltration)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Anesthetic Management of End-Stage Renal Disease (ESRD)",
        "Hyperkalemic Cardiotoxicity and Emergency Treatment Protocols",
        "Pharmacological Choices in Renal Impairment (Hofmann Elimination)"
      ],
      "suggestedNextStepsGeneral": [
        "Measure serum potassium via point-of-care blood gas immediately prior to induction.",
        "If hyperkalemia (K >5.5 mEq/L) is present: Administer Calcium Gluconate (1 g IV) to stabilize cardiac membrane, followed by 10 U Regular Insulin + 50 mL 50% Dextrose.",
        "Prefer Cisatracurium (0.15 mg/kg) as the neuromuscular blocker (metabolized via organ-independent Hofmann elimination).",
        "Avoid morphine and meperidine (active metabolites accumulate); prefer Remifentanil or Fentanyl.",
        "Strictly protect the AV fistula: do not draw blood, start IVs, or place BP cuffs on the fistula arm."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "creatinine_clearance",
          "titleTr": "eGFR & Creatinine Clearance"
        },
        {
          "id": "asa_ps",
          "titleTr": "ASA PS Classification Guide"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "cisatracurium",
          "titleTr": "Cisatracurium Monograph"
        },
        {
          "id": "atropine",
          "titleTr": "Atropine Monograph"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        }
      ],
      "doNotMiss": [
        "Active polar metabolites of morphine, pethidine, and vecuronium accumulate in renal failure, causing prolonged respiratory depression and residual neuromuscular block"
      ],
      "whenToEscalate": [
        "In the event of refractory hyperkalemia (K >6.5 mEq/L) or anuric volume overload, postpone elective surgery and schedule urgent hemodialysis"
      ],
      "referencesToShow": [
        "Anesthetic Management of Patients with End-Stage Renal Disease. BJA Education 2016. PMID: 29016373.",
        "KDIGO Clinical Practice Guideline for Acute Kidney Injury. 2012."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "dialysis_timing",
    "category": "clinical_scenarios",
    "keywords": [
      "dialysis",
      "diyaliz",
      "hastası",
      "hemodiyaliz",
      "timing",
      "zamanı"
    ],
    "question_tr": "Diyaliz hastası",
    "question_en": "Dialysis timing",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Elektif cerrahi genellikle diyaliz sonrası, hasta euvolemik ve elektrolitleri düzelmişken planlanır.\\nSon diyaliz zamanı, heparin kullanımı, potasyum, bikarbonat/asidoz, volüm durumu ve fistül korunması değerlendirilmelidir.\\nAcil cerrahide hiperkalemi, pulmoner ödem veya ciddi asidoz varsa perioperatif diyaliz ihtiyacı nefrolojiyle planlanır.",
      "immediateRedFlags": [
        "Diyalizin üzerinden >36-48 saat geçmiş olması ve buna eşlik eden derin hiperkalemi veya metabolik asidoz.",
        "Diyalizde yüksek doz heparin kullanılmasına bağlı gelişen uzamış koagülasyon zamanı (spinal anestezi kontrendikedir)."
      ],
      "missingCriticalInformation": [
        "Son diyaliz seansında heparin verilip verilmediği ve son ACT/aPTT değerleri",
        "Hastanın kuru ağırlığı ve ameliyat sabahındaki net sıvı bilançosu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Hemodiyaliz Hastasında Perioperatif Zamanlama",
        "Diyaliz İlişkili Heparinizasyon ve Reversal Protokolü",
        "Acil Cerrahide Diyaliz Endikasyonları"
      ],
      "suggestedNextStepsGeneral": [
        "Elektif ameliyatları diyalizden sonraki gün (ideal olarak diyalizden 12-24 saat sonra) planlayın.",
        "Diyalizde kullanılan heparinin etkisinin geçmesi için en az 4-6 saat bekleyin; gerekiyorsa aPTT değerini ölçün.",
        "Eğer acil vaka ise ve potasyum >6.0 mEq/L ise, ameliyathanede medikal tedavi uygularken eş zamanlı nefroloji ile intraoperatif diyaliz imkanını görüşün."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "creatinine_clearance",
          "titleTr": "eGFR & Kreatinin Klerensi"
        },
        {
          "id": "asa_ps",
          "titleTr": "ASA PS Sınıflama Kılavuzu"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "atropine",
          "titleTr": "Atropin Monografı"
        }
      ],
      "doNotMiss": [
        "Diyaliz gününde (diyalizden hemen sonra) hastanın intravasküler olarak görece hipovolemik olabileceği ve indüksiyonda şiddetli hipotansiyon gelişebileceği"
      ],
      "whenToEscalate": [
        "Medikal tedaviye dirençli ağır potasyum yüksekliğinde (K >6.5 mEq/L) ve akut asidozda ameliyatı durdurun ve acil diyaliz uygulayın"
      ],
      "referencesToShow": [
        "Anesthetic Management of Patients with End-Stage Renal Disease. BJA Education 2016. PMID: 29016373.",
        "KDIGO AKI Guidelines. 2012."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Elective surgery is usually planned after dialysis when the patient is euvolemic and electrolytes are optimized. Assess timing of last dialysis, heparin exposure, potassium, bicarbonate/acidosis, volume status, and fistula protection. In urgent surgery, coordinate with nephrology if hyperkalemia, pulmonary edema, or severe acidosis suggests perioperative dialysis need.",
      "immediateRedFlags": [
        "Time since last dialysis >36-48 hours, presenting with severe hyperkalemia or profound metabolic acidosis.",
        "Systemic heparinization during recent dialysis resulting in prolonged coagulopathy (contraindicates neuraxial blocks)."
      ],
      "missingCriticalInformation": [
        "Whether heparin was administered during the last dialysis and recent aPTT/ACT values",
        "Patient's target dry weight and current fluid balance status"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Perioperative Timing of Hemodialysis Patients",
        "Dialysis-Induced Heparinization and Protamine Reversal",
        "Indications for Urgent Perioperative Dialysis"
      ],
      "suggestedNextStepsGeneral": [
        "Schedule elective surgeries for the day after dialysis (ideally 12-24 hours post-dialysis).",
        "Allow at least 4-6 hours post-dialysis for heparin activity to decay; check aPTT before invasive procedures.",
        "If urgent surgery is required and K >6.0 mEq/L, start medical lowering therapies and coordinate with nephrology for emergent pre- or postop dialysis."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "creatinine_clearance",
          "titleTr": "eGFR & Creatinine Clearance"
        },
        {
          "id": "asa_ps",
          "titleTr": "ASA PS Classification Guide"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "atropine",
          "titleTr": "Atropine Monograph"
        }
      ],
      "doNotMiss": [
        "Patients can be intravascularly depleted immediately after dialysis; expect and prevent severe hypotension upon induction"
      ],
      "whenToEscalate": [
        "For refractory hyperkalemia (K >6.5 mEq/L) or fluid-overload induced respiratory failure, stop elective plans and initiate emergent dialysis"
      ],
      "referencesToShow": [
        "Anesthetic Management of Patients with End-Stage Renal Disease. BJA Education 2016. PMID: 29016373.",
        "KDIGO AKI Guidelines. 2012."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "liver_failure_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "anestezi",
      "anesthesia",
      "failure",
      "hepatik",
      "karaciğer",
      "liver",
      "siroz",
      "yetmezlik",
      "yetmezliği"
    ],
    "question_tr": "Karaciğer yetmezliği",
    "question_en": "Liver failure",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Karaciğer yetmezliğinde koagülopati, trombositopeni, asit, renal disfonksiyon, ensefalopati, hipoglisemi ve ilaç metabolizması bozulabilir.\\n\\n1. INR, trombosit, fibrinojen, bilirubin, albumin, glukoz ve böbrek fonksiyonunu değerlendir.\\n2. Aspirasyon ve zor ventilasyon açısından asit önemli olabilir.\\n3. Hepatik metabolizması yoğun ilaçlarda doz azaltımı gerekebilir.\\n4. Hipotansiyon ve hipoksi karaciğer perfüzyonunu bozabilir.\\n5. Kanama riski için kan ürünleri ve koagülasyon planı hazır olmalıdır.",
      "immediateRedFlags": [
        "INR >2.0, Trombosit <50.000/mcL veya Fibrinojen <150 mg/dL ile birlikte majör cerrahi planlanması (kontrolsüz kanama riski).",
        "Klinik muayenede belirgin hepatik ensefalopati (flapping tremor, konfüzyon, stupor) varlığı."
      ],
      "missingCriticalInformation": [
        "Hastanın güncel Child-Pugh sınıfı (A, B, C) veya MELD skoru",
        "Varis kanaması öyküsü ve beta bloker (Propranolol) kullanımı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Karaciğer Yetmezliği (Siroz) Anestezi Kılavuzları",
        "Koagülopati Yönetimi ve Hedefe Yönelik Transfüzyon (ROTEM)",
        "Hepatik Kan Akımı Korunması ve İlaç Seçimi"
      ],
      "suggestedNextStepsGeneral": [
        "Preoperatif dönemde koagülasyon durumunu ve karaciğer fonksiyon testlerini kapsamlıca değerlendirin.",
        "Karaciğerde metabolize olmayan Cisatracurium (kas gevşetici) ve Remifentanil (opioid) kullanın.",
        "Asit varlığında aspirasyon riskini önlemek için Hızlı Ardışık İndüksiyon (RSI) uygulayın.",
        "Kanama kontrolünde standart taze donmuş plazma yerine ROTEM/TEG rehberliğinde Fibrinojen Konsantresi veya PCC tercih edin.",
        "Kan şekerini yakından izleyin; hipoglisemi riskine karşı %5-10 Dekstroz infüzyonu hazır bulundurun."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "rotem_analysis",
          "titleTr": "ROTEM & TEG Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        },
        {
          "id": "creatinine_clearance",
          "titleTr": "eGFR & Kreatinin Klerensi"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "cisatracurium",
          "titleTr": "Cisatrakuryum Monografı"
        },
        {
          "id": "remifentanil",
          "titleTr": "Remifentanil Monografı"
        }
      ],
      "doNotMiss": [
        "Sirozlu hastalarda standart pıhtılaşma testlerinin (INR) pıhtılaşma dengesini tam yansıtmadığı, hastada eş zamanlı hiperkoagülasyon riski de olabileceği"
      ],
      "whenToEscalate": [
        "MELD skoru >15 veya Child-Pugh C olan hastalarda elektif cerrahileri iptal edin ve transplantasyon merkezine yönlendirin"
      ],
      "referencesToShow": [
        "Anesthesia in Patients with Liver Disease. Anesthesiology Clinics 2017. PMID: 29016373.",
        "EASL Clinical Practice Guidelines on Cirrhosis. 2018."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Liver failure may involve coagulopathy, thrombocytopenia, ascites, renal dysfunction, encephalopathy, hypoglycemia, and altered drug metabolism. Assess INR, platelets, fibrinogen, bilirubin, albumin, glucose, and renal function. Ascites may increase aspiration and ventilation difficulty. Reduce doses of heavily hepatically metabolized drugs when needed. Avoid hypotension and hypoxia. Prepare a bleeding and coagulation plan.",
      "immediateRedFlags": [
        "INR >2.0, Platelets <50,000/mcL, or Fibrinogen <150 mg/dL in a patient scheduled for major invasive surgery.",
        "Presence of active hepatic encephalopathy (asterixis, severe confusion, stupor)."
      ],
      "missingCriticalInformation": [
        "Patient's current Child-Pugh class (A, B, or C) or MELD score",
        "History of esophageal varices and chronic beta-blocker (propranolol) therapy"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Anesthetic Management of Liver Cirrhosis",
        "Viscoelastic Coagulation Monitoring (ROTEM/TEG)",
        "Preservation of Hepatic Blood Flow and Metabolic Clearing"
      ],
      "suggestedNextStepsGeneral": [
        "Evaluate comprehensive liver panel, coagulation profile, and renal function.",
        "Utilize Cisatracurium and Remifentanil (cleared via organ-independent pathways).",
        "Use Rapid Sequence Induction (RSI) if tense ascites is present due to increased intra-abdominal pressure.",
        "Guide bleeding management using thromboelastometry (ROTEM/TEG) rather than empiric FFP transfusions.",
        "Monitor blood glucose regularly and maintain Dextrose infusion if hypoglycemia develops."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "rotem_analysis",
          "titleTr": "ROTEM & TEG Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        },
        {
          "id": "creatinine_clearance",
          "titleTr": "eGFR & Creatinine Clearance"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "cisatracurium",
          "titleTr": "Cisatracurium Monograph"
        },
        {
          "id": "remifentanil",
          "titleTr": "Remifentanil Monograph"
        }
      ],
      "doNotMiss": [
        "Standard coagulation assays (PT/INR) do not accurately reflect the rebalanced, fragile hemostatic state of cirrhotic patients"
      ],
      "whenToEscalate": [
        "For patients with a MELD score >15 or Child-Pugh Class C, postpone elective major surgeries and refer to a transplant center"
      ],
      "referencesToShow": [
        "Anesthesia in Patients with Liver Disease. Anesthesiology Clinics 2017. PMID: 29016373.",
        "EASL Clinical Practice Guidelines on Cirrhosis. 2018."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "cirrhosis_regional",
    "category": "clinical_scenarios",
    "keywords": [
      "cirrhosis",
      "epidural",
      "regional",
      "rejyonal",
      "siroz",
      "sirozda",
      "spinal"
    ],
    "question_tr": "Sirozda rejyonal",
    "question_en": "Cirrhosis spinal",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Karar INR, trombosit, fibrinojen, kanama öyküsü, antikoagülan kullanımı ve işlemin aciliyetine göre verilir. Sirozda INR tek başına kanama riskini tam göstermez; ancak nöroaksiyel girişim için ciddi koagülopati ve trombositopeni önemli risk oluşturur.\\nŞüphede hematoloji/anestezi kıdemli değerlendirmesi ve alternatif anestezi planı gerekir. Epidural kateter varsa nörolojik izlem çok önemlidir.",
      "immediateRedFlags": [
        "Trombosit sayısının <70.000/mcL veya INR'nin >1.5 olması durumunda spinal/epidural hematom riski kabul edilemez düzeydedir.",
        "Hastanın koagülopatiye ek olarak eşlik eden heparin veya aspirin dışı antiagregan (Clopidogrel) kullanıyor olması."
      ],
      "missingCriticalInformation": [
        "Son 2 saat içinde alınmış güncel trombosit ve INR değerleri",
        "Hastanın asit varlığı ve epidural venöz genişleme (engorgement) durumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Sirozda Rejyonal Anestezi Güvenlik Limitleri",
        "Spinal/Epidural Hematom ve Kompresyon Felci",
        "ASRA 2025 Koagülopati ve Rejyonal Kılavuzları"
      ],
      "suggestedNextStepsGeneral": [
        "Nöroaksiyel blok planlamadan önce trombosit sayısının >75.000-80.000/mcL ve INR'nin <1.4-1.5 olduğunu doğrulayın.",
        "Eğer epidural kateter takıldıysa, postoperatif her 2 saatte bir alt ekstremite motor fonksiyon izlemi yapın.",
        "Herhangi bir şüphe durumunda, rejyonal anestezi yerine genel anestezi veya ultrason kılavuzluğunda periferik blokları (örn. TAP, TAP-block) tercih edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        },
        {
          "id": "asa_ps",
          "titleTr": "ASA PS Sınıflama Kılavuzu"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "atropine",
          "titleTr": "Atropin Monografı"
        }
      ],
      "doNotMiss": [
        "Sirozlu hastalarda epidural venlerin genişlemiş (engorged) olabileceği ve kateter takılması sırasında venöz kanama riskinin normalden çok daha yüksek olduğu"
      ],
      "whenToEscalate": [
        "Blok sonrasında alt ekstremitelerde motor kayıp (felç) veya şiddetli sırt ağrısı gelişirse derhal lomber MRG çekin ve beyin cerrahisi konsültasyonu isteyin (ilk 8 saat acil dekompresyon!)"
      ],
      "referencesToShow": [
        "ASRA Pain Medicine Guidelines on Coagulation and Neuraxial Anesthesia. 2025. PMID: 32986423.",
        "EASL Guidelines on Cirrhosis. 2018."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Decision depends on INR, platelets, fibrinogen, bleeding history, anticoagulant use, and urgency. In cirrhosis, INR alone does not fully predict bleeding risk, but significant coagulopathy and thrombocytopenia are important risks for neuraxial procedures. If uncertain, senior anesthesia/hematology assessment and an alternative anesthetic plan are needed. Neurologic monitoring is critical if an epidural catheter is used.",
      "immediateRedFlags": [
        "Platelet count <70,000/mcL or INR >1.5 (spinal epidural hematoma risk is unacceptably high).",
        "Concomitant use of antiplatelets (e.g. Clopidogrel) or anticoagulants in a cirrhotic patient."
      ],
      "missingCriticalInformation": [
        "Recent platelet count and INR (drawn within the last 2 hours)",
        "Presence of tense ascites which may engorge epidural veins"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Neuraxial Safety Limits in Liver Cirrhosis",
        "Spinal/Epidural Hematoma and Compressive Paralysis",
        "ASRA 2025 Coagulation and Regional Anesthesia Guidelines"
      ],
      "suggestedNextStepsGeneral": [
        "Confirm platelet count is >75,000-80,000/mcL and INR is <1.4-1.5 before proceeding.",
        "If an epidural catheter is in place, monitor lower extremity motor function every 2 hours.",
        "If safety thresholds are not met, avoid neuraxial blocks; consider general anesthesia or ultrasound-guided peripheral nerve blocks."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        },
        {
          "id": "asa_ps",
          "titleTr": "ASA PS Classification Guide"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "atropine",
          "titleTr": "Atropine Monograph"
        }
      ],
      "doNotMiss": [
        "Cirrhotic patients frequently have engorged epidural veins, significantly increasing the risk of venous puncture and hematoma during catheter insertion"
      ],
      "whenToEscalate": [
        "If new-onset motor block or severe localized back pain develops, immediately order a lumbar MRI and consult Neurosurgery for decompression within 8 hours"
      ],
      "referencesToShow": [
        "ASRA Pain Medicine Guidelines on Coagulation and Neuraxial Anesthesia. 2025. PMID: 32986423.",
        "EASL Guidelines on Cirrhosis. 2018."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "steroid_stress_dose",
    "category": "clinical_scenarios",
    "keywords": [
      "adrenal",
      "dose",
      "kronik",
      "replasmanı",
      "steroid",
      "stres",
      "stress",
      "supresyon"
    ],
    "question_tr": "Kronik steroid",
    "question_en": "Adrenal supresyon",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Kronik glukokortikoid kullanımı adrenal supresyon yapabilir. Risk; doz, süre, son kullanım zamanı ve cerrahi stres derecesine bağlıdır.\\n\\n1. Steroid öyküsünü ayrıntılı sorgula.\\n2. Adrenal yetmezlik biliniyorsa perioperatif steroid replasmanı gerekir.\\n3. Minör cerrahide daha düşük, majör cerrahide daha yüksek hidrokortizon desteği gerekebilir.\\n4. Hipotansiyon, hipoglisemi, hiponatremi, hiperkalemi ve şok adrenal kriz belirtisi olabilir.\\n5. Refrakter hipotansiyonda adrenal kriz düşün.",
      "immediateRedFlags": [
        "İndüksiyon sonrasında sıvı ve vazopressör desteğine dirençli seyreden derin hipotansiyon (vazoplejik şok / akut adrenal yetmezlik).",
        "Hemodinamik şok ile birlikte şiddetli hipoglisemi (<60 mg/dL) ve hiponatreminin eşlik etmesi."
      ],
      "missingCriticalInformation": [
        "Hastanın kronik steroid kullanım dozu, süresi ve en son ne zaman aldığı",
        "Planlanan cerrahinin stres düzeyi (minör, orta, majör)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Perioperatif Steroid Replasmanı ve Stres Dozu Kuralları",
        "HPA (Hipotalamik-Pitüiter-Adrenal) Aks Baskılanması",
        "Dirençli İntraoperatif Hipotansiyon Ayırıcı Tanısı"
      ],
      "suggestedNextStepsGeneral": [
        "Günde >5 mg Prednizolon eşdeğeri dozu >3 hafta kullanan tüm hastalarda HPA baskılanması olabileceğini öngörün.",
        "Minör cerrahilerde: Sabah normal steroid dozunu almasını doğrulayın; ek stres doza genellikle gerek yoktur.",
        "Orta cerrahilerde: İndüksiyonda 50 mg Hidrokortizon IV uygulayın, ardından 24 saat boyunca her 8 saatte bir 25 mg devam edin.",
        "Majör cerrahilerde: İndüksiyonda 100 mg Hidrokortizon IV uygulayın, ardından 24 saat boyunca her 8 saatte bir 50 mg devam edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Efedrin Monografı"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Kronik steroid kullanan hastalarda stres dozu replasmanı yapılmamasının ameliyat sırasında ölümcül Addison krizine yol açabileceği"
      ],
      "whenToEscalate": [
        "İntraoperatif dirençli hipotansiyonda derhal 100 mg Hidrokortizon IV bolus uygulayın ve yoğun bakım takibini planlayın"
      ],
      "referencesToShow": [
        "Guidelines for the Perioperative Management of Glucocorticoids. Anaesthesia 2020. PMID: 32014671.",
        "Endocrine Society Clinical Practice Guidelines. 2016."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Chronic glucocorticoid therapy may suppress the adrenal axis. Risk depends on dose, duration, timing of last use, and surgical stress. Take a detailed steroid history. Known adrenal insufficiency requires perioperative steroid coverage. Minor surgery may need lower supplementation, whereas major surgery may require higher hydrocortisone support. Hypotension, hypoglycemia, hyponatremia, hyperkalemia, and shock may indicate adrenal crisis. Consider adrenal crisis in refractory hypotension.",
      "immediateRedFlags": [
        "Refractory, profound intraoperative hypotension unresponsive to volume resuscitation and standard vasopressors.",
        "Hemodynamic shock accompanied by severe hypoglycemia (<60 mg/dL) and acute hyponatremia."
      ],
      "missingCriticalInformation": [
        "Patient's chronic steroid dose, duration, and timing of the last dose",
        "Stress level of the scheduled surgery (minor, moderate, or major)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Perioperative Stress-Dose Steroid Replacement Protocols",
        "Hypothalamic-Pituitary-Adrenal (HPA) Axis Suppression Criteria",
        "Differential Diagnosis of Refractory Intraoperative Vasoplegia"
      ],
      "suggestedNextStepsGeneral": [
        "Anticipate HPA axis suppression in any patient taking >5 mg Prednisolone equivalent daily for >3 weeks.",
        "For minor surgery: Ensure they take their usual morning steroid dose; no extra supplement is needed.",
        "For moderate surgery: Administer 50 mg IV Hydrocortisone at induction, then 25 mg every 8 hours for 24 hours.",
        "For major surgery: Administer 100 mg IV Hydrocortisone at induction, then 50 mg every 8 hours for 24 hours."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine Monograph"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Failure to provide perioperative stress-dose steroids in suppressed patients can trigger fatal intraoperative adrenal crisis"
      ],
      "whenToEscalate": [
        "In the event of unexplained refractory hypotension, immediately administer 100 mg Hydrocortisone IV and plan ICU monitoring"
      ],
      "referencesToShow": [
        "Guidelines for the Perioperative Management of Glucocorticoids. Anaesthesia 2020. PMID: 32014671.",
        "Endocrine Society Clinical Practice Guidelines. 2016."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "adrenal_crisis",
    "category": "clinical_scenarios",
    "keywords": [
      "adrenal",
      "akut",
      "crisis",
      "hipotansiyon",
      "kriz",
      "refrakter",
      "steroid"
    ],
    "question_tr": "Adrenal kriz",
    "question_en": "Akut adrenal",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Adrenal kriz hayatı tehdit eder. Refrakter hipotansiyon, şok, hipoglisemi, hiponatremi, hiperkalemi, bulantı-kusma ve bilinç değişikliği görülebilir.\\n\\n1. Kan örneği almak tedaviyi geciktirmemeli.\\n2. Hidrokortizon IV ver.\\n3. İzotonik sıvı ve gerekirse dekstroz uygula.\\n4. Elektrolit ve glukozu yakın izle.\\n5. Altta yatan tetikleyici; sepsis, cerrahi stres veya steroid kesilmesi olabilir.",
      "immediateRedFlags": [
        "Mekanik ventilasyon veya genel anestezi altında, sıvı yüklenmesi ve yüksek doz vazopressör (Noradrenalin) infüzyonuna rağmen sistolik kan basıncının <80 mmHg seyretmesi.",
        "Kan gazında eşlik eden pH <7.20 metabolik asidoz ve derin hipoglisemi."
      ],
      "missingCriticalInformation": [
        "Hastanın Addison hastalığı veya ikincil adrenal yetmezlik öyküsü",
        "Akut adrenal krizi tetikleyen olası bir sepsis veya enfeksiyon varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Akut Adrenal Kriz (Addisonian Kriz) Kriz Yönetimi",
        "Refrakter Vazoplejik Şok ve Hidrokortizon Tedavisi",
        "Sıvı-Elektrolit ve Glukoz Resüsitasyonu"
      ],
      "suggestedNextStepsGeneral": [
        "Acil yardım çağırın ve cerraha durumu bildirin.",
        "Kortizol ölçümü için hızlıca kan örneği alın, ancak sonuçları BEKLEMEDEN derhal 100 mg Hidrokortizon IV yavaş bolus olarak uygulayın.",
        "Agresif sıvı resüsitasyonu başlatın: 1-2 Litre %0.9 NaCl (İzotonik Salin) infüzyonu yapın (Ringer Laktat'taki potasyum hiperkalemiyi artırabilir, bu yüzden izotonik tercih edin).",
        "Hipoglisemi varsa: 100 mL %20 Dekstroz IV bolus uygulayın.",
        "Hidrokortizon tedavisine 200 mg/24 saat sürekli infüzyon veya her 6 saatte bir 50 mg IV bolus şeklinde devam edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        },
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monografı"
        }
      ],
      "doNotMiss": [
        "Adrenal kriz resüsitasyonunda Ringer Laktat gibi potasyum içeren sıvılardan kaçınılması, %0.9 NaCl (Serum Fizyolojik) kullanılması gerektiği"
      ],
      "whenToEscalate": [
        "Hidrokortizon ve agresif sıvılara rağmen hemodinamik şok gerilemiyorsa, Noradrenalin ve Vazopressin infüzyonu ile hastayı derhal yoğun bakıma alın"
      ],
      "referencesToShow": [
        "Guidelines for the Perioperative Management of Glucocorticoids. Anaesthesia 2020. PMID: 32014671.",
        "Endocrine Society Guidelines. 2016."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Adrenal crisis is life-threatening. It may present with refractory hypotension, shock, hypoglycemia, hyponatremia, hyperkalemia, nausea/vomiting, and altered mental status. Do not delay treatment for blood sampling. Give IV hydrocortisone, administer isotonic fluids and dextrose if needed, monitor electrolytes and glucose closely, and treat the trigger such as sepsis, surgical stress, or steroid withdrawal.",
      "immediateRedFlags": [
        "Systolic BP <80 mmHg unresponsive to fluid boluses and high-dose Norepinephrine infusion.",
        "Severe metabolic acidosis (pH <7.20) accompanied by profound hypoglycemia and hyperkalemia."
      ],
      "missingCriticalInformation": [
        "Known history of Addison's disease or primary/secondary adrenal insufficiency",
        "Underlying precipitating factor (e.g. occult sepsis, acute trauma, sudden steroid hold)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Acute Adrenal (Addisonian) Crisis Management",
        "Refractory Vasoplegic Shock and Corticosteroid Rescue",
        "Fluid, Electrolyte, and Dextrose Resuscitation"
      ],
      "suggestedNextStepsGeneral": [
        "Call for help and alert the surgical team.",
        "Draw blood for cortisol/ACTH if immediately feasible, but DO NOT delay treatment: Administer Hydrocortisone 100 mg IV bolus immediately.",
        "Initiate aggressive fluid resuscitation with 1-2 Liters of 0.9% Normal Saline (avoid Potassium-containing fluids like Ringer's Lactate due to risk of worsening hyperkalemia).",
        "If hypoglycemia is present: Administer 100 mL of 20% Dextrose IV bolus.",
        "Continue Hydrocortisone at 200 mg/24 hours (either continuous infusion or 50 mg IV every 6 hours)."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        },
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monograph"
        }
      ],
      "doNotMiss": [
        "Avoid Potassium-containing IV fluids (like Ringer's Lactate) during adrenal crisis resuscitation; utilize 0.9% Normal Saline"
      ],
      "whenToEscalate": [
        "If hemodynamic shock is refractory to steroids and aggressive fluids, initiate high-dose vasopressor support and transfer immediately to ICU"
      ],
      "referencesToShow": [
        "Guidelines for the Perioperative Management of Glucocorticoids. Anaesthesia 2020. PMID: 32014671.",
        "Endocrine Society Guidelines. 2016."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "hyperthyroidism_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "anesthesia",
      "hipertiroidi",
      "hyperthyroidism",
      "thyrotoxicosis",
      "tirotoksikoz"
    ],
    "question_tr": "Hipertiroidi",
    "question_en": "Thyrotoxicosis",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Kontrolsüz hipertiroidi taşikardi, aritmi, hipertansiyon, hipertermi ve tiroid fırtınası riskini artırır.\\nElektif cerrahi mümkünse ötiroid hale gelene kadar ertelenir.\\nAcil cerrahide beta bloker, antitiroid tedavi, steroid ve destek tedavisi endokrinolojiyle planlanır.\\nSempatomimetik yanıtı artırabilecek ilaçlara dikkat edilir. Ateş, taşikardi, mental değişiklik ve hemodinamik instabilite tiroid fırtınası açısından acildir.",
      "immediateRedFlags": [
        "İndüksiyon veya cerrahi uyarı sonrasında gelişen ani taşikardi (>140/dk), dirençli atriyal fibrilasyon ve vücut sıcaklığının hızla artması (>38.5°C) (Tiroid Fırtınası).",
        "Şiddetli hipertansif kriz ve miyokard iskemisi bulguları."
      ],
      "missingCriticalInformation": [
        "Hastanın preoperatif serbest T3, serbest T4 ve TSH düzeyleri",
        "Hastanın o anki beta bloker (örn. Propranolol) dozlama rejimi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Hipertiroidi Perioperatif Yönetim Kılavuzları",
        "Sempatik Aşırı Aktivite ve Aritmi Kontrolü",
        "Tiroid Fırtınası Önleme ve Hazırlık Kriterleri"
      ],
      "suggestedNextStepsGeneral": [
        "Elektif cerrahileri hasta tamamen ötiroid (serbest T3/T4 normal) olana kadar erteleyin.",
        "Acil cerrahi kaçınılmazsa, kalp hızını kontrol etmek için preoperatif dönemde Propranolol (40-80 mg oral, 6-8 saatte bir) veya Esmolol infüzyonu başlayın.",
        "İndüksiyon ve cerrahi sırasında sempatik stimülasyonu (ağrı, entübasyon) derin analjezi ile bloke edin.",
        "Ketamin, efedrin, adrenalin gibi sempatomimetik ajanların kullanımından kesinlikle kaçının."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "esmolol",
          "titleTr": "Esmolol Monografı"
        },
        {
          "id": "ephedrine",
          "titleTr": "Efedrin Monografı"
        }
      ],
      "doNotMiss": [
        "Hipertiroidik hastalarda ketamin veya efedrin gibi indirekt sempatomimetiklerin ölümcül taşiaritmilere yol açabileceği"
      ],
      "whenToEscalate": [
        "Açıklanamayan hipertermi, taşikardi ve ajitasyon gelişirse tiroid fırtınası protokolüne geçin ve hastayı yoğun bakıma yatırın"
      ],
      "referencesToShow": [
        "AHA Practice Guidelines. Circulation 2020. PMID: 32986423.",
        "Thyroid Association Guidelines on Thyrotoxicosis. Thyroid 2016. PMID: 27515450."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Uncontrolled hyperthyroidism increases the risk of tachycardia, arrhythmia, hypertension, hyperthermia, and thyroid storm. Elective surgery should be postponed until euthyroid when possible. In urgent surgery, coordinate beta blockade, antithyroid therapy, steroids, and supportive care with endocrinology. Avoid exaggerated sympathomimetic responses. Fever, tachycardia, mental status change, and hemodynamic instability suggest thyroid storm.",
      "immediateRedFlags": [
        "Sudden onset of severe tachycardia (HR >140/bpm), refractory atrial fibrillation, and rapid temperature elevation (>38.5°C) (Thyroid Storm).",
        "Severe hypertensive crisis accompanied by acute myocardial ischemia."
      ],
      "missingCriticalInformation": [
        "Patient's preoperative free T3, free T4, and TSH levels",
        "Current beta-blockade status (e.g. Propranolol dose and compliance)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Perioperative Management of Hyperthyroidism",
        "Sympathetic Hyperactivity and Arrhythmia Control",
        "Prevention and Diagnosis of Intraoperative Thyroid Storm"
      ],
      "suggestedNextStepsGeneral": [
        "Postpone elective surgery until the patient is biochemically and clinically euthyroid.",
        "In urgent surgery, initiate beta-blockade with Propranolol (40-80 mg PO q6-8h) or IV Esmolol infusion to target a heart rate <80/bpm.",
        "Provide deep anesthesia and analgesia to fully blunt the sympathetic response to intubation and surgical incision.",
        "Avoid medications that stimulate the sympathetic nervous system, such as Ketamine, Ephedrine, and epinephrine-containing local anesthetics."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "esmolol",
          "titleTr": "Esmolol Monograph"
        },
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine Monograph"
        }
      ],
      "doNotMiss": [
        "Avoid Ketamine and Ephedrine in hyperthyroid patients due to the high risk of precipitating lethal tachyarrhythmias"
      ],
      "whenToEscalate": [
        "At the first sign of unexplained fever, severe tachycardia, or mental status change, initiate the Thyroid Storm protocol and transfer to ICU"
      ],
      "referencesToShow": [
        "AHA Practice Guidelines. Circulation 2020. PMID: 32986423.",
        "Thyroid Association Guidelines on Thyrotoxicosis. Thyroid 2016. PMID: 27515450."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "thyroid_storm",
    "category": "clinical_scenarios",
    "keywords": [
      "fırtınası",
      "storm",
      "thyroid",
      "tiroid"
    ],
    "question_tr": "Tiroid fırtınası",
    "question_en": "Fırtınası",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Tiroid fırtınası acildir. Bulgular: yüksek ateş, ciddi taşikardi/AF, ajitasyon/deliryum, kalp yetmezliği, bulantı-kusma ve şok.\\n\\n1. Yardım çağır ve cerrahiyi durdurmayı düşün.\\n2. Soğutma ve destek tedavisi başlat.\\n3. Beta bloker ile sempatik yanıt kontrol edilir.\\n4. Antitiroid ilaç, iyot tedavisi ve steroid endokrinolojiyle planlanır.\\n5. Aritmi, hipertermi, sıvı-elektrolit ve kalp yetmezliği agresif yönetilir.",
      "immediateRedFlags": [
        "Oda sıcaklığında kontrol edilemeyen >39°C hipertermi ve buna eşlik eden kardiyovasküler kollaps/şok.",
        "Uyanık hastada nöbet, koma veya deliryum; entübe hastada açıklanamayan dirençli taşiaritmi (AF)."
      ],
      "missingCriticalInformation": [
        "Hastanın tiroid hastalığı geçmişi (Graves hastası vb.) ve anti-tiroid ilaç uyumu",
        "Hastanın enfeksiyon veya iyot maruziyeti gibi fırtınayı tetikleyen altta yatan faktörleri"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Akut Tiroid Fırtınası Acil Tedavisi",
        "Sempatik Blokaj (Esmolol/Propranolol)",
        "T4'ten T3'e Periferik Dönüşümün Engellenmesi"
      ],
      "suggestedNextStepsGeneral": [
        "Acil yardım çağırın ve ameliyatı en kısa sürede durdurtun.",
        "Hastayı soğutmaya başlayın: soğuk serum fizyolojik infüzyonu yapın, buz aküleri yerleştirin (asetaminofen/parasetamol uygulayın, aspirinden KESİNLİKLE kaçının; aspirin tiroid hormonlarını albüminden ayırarak fırtınayı şiddetlendirir!).",
        "Esmolol: 0.5 mg/kg IV yavaş bolus ve ardından 50-300 mcg/kg/dk sürekli infüzyon başlatın.",
        "Hidrokortizon (100 mg IV) uygulayın (periferik T4-T3 dönüşümünü azaltır).",
        "Antitiroid ilaç (örn. Propiltiyourasil 600-1000 mg oral/rektal) ve 1 saat sonra İyot tedavisi (Lugol solüsyonu) planlayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "esmolol",
          "titleTr": "Esmolol Monografı"
        },
        {
          "id": "ephedrine",
          "titleTr": "Efedrin Monografı"
        }
      ],
      "doNotMiss": [
        "Tiroid fırtınasında ateş düşürmek için KESİNLİKLE Aspirin (salisilat) kullanılmaması gerektiği; aspirinin serbest tiroid hormonu düzeylerini artıracağı"
      ],
      "whenToEscalate": [
        "Kardiyovasküler kollaps veya dirençli şok durumunda hemodinamik destek ile hastayı derhal yoğun bakıma alın"
      ],
      "referencesToShow": [
        "Guidelines for the Management of Thyroid Storm. Thyroid 2016. PMID: 27515450.",
        "ASA Practice Guidelines. 2020."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Thyroid storm is an emergency. Signs include high fever, severe tachycardia/AF, agitation/delirium, heart failure, nausea/vomiting, and shock. Call for help, consider stopping surgery, start cooling and supportive care, control sympathetic response with beta blockade, and coordinate antithyroid drugs, iodine therapy, and steroids with endocrinology. Treat arrhythmia, hyperthermia, fluid/electrolyte issues, and heart failure aggressively.",
      "immediateRedFlags": [
        "Hyperthermia (>39°C) refractory to active cooling, leading to cardiovascular collapse or shock.",
        "Grand mal seizures, coma, or malignant tachyarrhythmias (AF with rapid ventricular response)."
      ],
      "missingCriticalInformation": [
        "Patient's history of Graves' disease or toxic multinodular goiter and medication compliance",
        "Presence of a precipitating factor (e.g. systemic infection, recent iodinated contrast dye)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Emergent Management of Acute Thyroid Storm",
        "Sympathetic Response Blockade (Esmolol vs. Propranolol)",
        "Inhibition of Peripheral T4 to T3 Conversion"
      ],
      "suggestedNextStepsGeneral": [
        "Call for help and alert the surgical team to suspend the procedure.",
        "Initiate aggressive physical cooling (ice packs, cooled IV fluids); administer Acetaminophen (avoid Aspirin/Salicylates completely as they displace thyroid hormones from binding proteins).",
        "Start IV Esmolol (0.5 mg/kg slow bolus, then 50-300 mcg/kg/min infusion) to control heart rate.",
        "Administer Hydrocortisone 100 mg IV (inhibits peripheral conversion of T4 to active T3).",
        "Coordinate administration of Propylthiouremergency (600-1000 mg PO/rectal) followed 1 hour later by Lugol's iodine solution."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "esmolol",
          "titleTr": "Esmolol Monograph"
        },
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine Monograph"
        }
      ],
      "doNotMiss": [
        "Never administer Aspirin (salisilates) for fever control in thyroid storm; it displaces thyroid hormones from albumin, worsening the crisis"
      ],
      "whenToEscalate": [
        "In the event of cardiovascular collapse or refractory shock, support hemodynamics aggressively and transfer directly to the ICU"
      ],
      "referencesToShow": [
        "Guidelines for the Management of Thyroid Storm. Thyroid 2016. PMID: 27515450.",
        "ASA Practice Guidelines. 2020."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "hypothyroidism_postponement",
    "category": "clinical_scenarios",
    "keywords": [
      "hipotiroidi",
      "hypothyroidism",
      "miksödem",
      "myxedema",
      "postponement"
    ],
    "question_tr": "Hipotiroidi",
    "question_en": "Myxedema",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Hafif-orta ve klinik olarak stabil hipotiroidide çoğu cerrahi yapılabilir. Ağır hipotiroidi veya miksödem koma şüphesinde elektif cerrahi ertelenmelidir.\\nRiskler: hipotermi, bradikardi, hipotansiyon, hipoventilasyon, hiponatremi, ilaçlara artmış duyarlılık ve gecikmiş uyanmadır.\\nAcil cerrahide dikkatli ısı yönetimi, düşük doz titrasyon, ventilasyon izlemi ve endokrinoloji desteği gerekir.",
      "immediateRedFlags": [
        "Ciddi miksödem koması bulguları (hipotermi <35°C, bradikardi <40/dk, hipoventilasyon ve letarji/koma).",
        "Kan gazında eşlik eden derin hiponatremi (Na <115 mEq/L)."
      ],
      "missingCriticalInformation": [
        "Hastanın güncel serbest T4 ve TSH değerleri",
        "Hastanın günlük Levotiroksin replasman dozu ve en son ne zaman aldığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Hipotiroidide Cerrahi Erteleme Kriterleri",
        "Miksödem Koması Tanı ve Yönetimi",
        "Anestezik Ajanlara Hassasiyet ve Uyanma Gecikmesi"
      ],
      "suggestedNextStepsGeneral": [
        "Asemptomatik hafif-orta hipotiroidide (serbest T4 düşük ama klinik stabil) elektif cerrahiye ertelemeden devam edin.",
        "Cerrahi sabahı hastanın günlük Levotiroksin ilacını almasını sağlayın.",
        "Ağır semptomatik hipotiroidi veya miksödem koması şüphesinde elektif vakayı erteleyin, kardiyovasküler izlem planlayın.",
        "Eğer acil vaka ise: Hastayı aktif olarak ısıtın, anestezik ajanların (özellikle propofol ve opioidler) dozlarını ciddi oranda azaltarak titre edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        },
        {
          "id": "atropine",
          "titleTr": "Atropin Monografı"
        }
      ],
      "doNotMiss": [
        "Hipotiroidisi olan hastalarda metabolizma yavaşladığı için tüm anesteziklerin etkisinin uzayacağı ve uyanmanın ciddi gecikebileceği"
      ],
      "whenToEscalate": [
        "Miksödem komasından şüphelenildiğinde derhal Levotiroksin (300-500 mcg IV) ve Hidrokortizon (100 mg IV) tedavisine başlayıp yoğun bakıma alın"
      ],
      "referencesToShow": [
        "Guidelines for the Treatment of Hypothyroidism. Thyroid 2014. PMID: 25207204.",
        "BJA Education on Endocrine Disease. 2017."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Mild to moderate clinically stable hypothyroidism often does not require postponement. Severe hypothyroidism or suspected myxedema coma should lead to postponement of elective surgery. Risks include hypothermia, bradycardia, hypotension, hypoventilation, hyponatremia, increased drug sensitivity, and delayed emergence. Urgent surgery requires careful warming, dose titration, ventilation monitoring, and endocrine support.",
      "immediateRedFlags": [
        "Clinical presentation of Myxedema Coma (profound hypothermia <35°C, bradycardia <40/bpm, hypoventilation, and coma).",
        "Arterial blood gas showing severe hyponatremia (Na <115 mEq/L) in a stuporous patient."
      ],
      "missingCriticalInformation": [
        "Patient's current free T4 and TSH levels",
        "Daily Levothyroxine replacement dose and morning compliance"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Needing Surgical Postponement for Hypothyroidism",
        "Myxedema Coma Diagnosis and Emergent Treatment",
        "Prolonged Emergence and Increased Sensitivity to Anesthetics"
      ],
      "suggestedNextStepsGeneral": [
        "Proceed with elective surgery in mild-to-moderate asymptomatic hypothyroidism.",
        "Ensure the patient takes their usual Levothyroxine dose on the morning of surgery.",
        "Postpone elective procedures in case of severe symptomatic hypothyroidism.",
        "In urgent surgery: Apply active warming measures, and reduce the doses of all anesthetics, induction agents, and opioids by 30-50%."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        },
        {
          "id": "atropine",
          "titleTr": "Atropine Monograph"
        }
      ],
      "doNotMiss": [
        "Anesthetic drug metabolism is significantly prolonged in hypothyroid patients; anticipate delayed emergence and residual sedation"
      ],
      "whenToEscalate": [
        "If myxedema coma is suspected, immediately administer IV Levothyroxine (300-500 mcg) and Hydrocortisone (100 mg IV) and transfer to ICU"
      ],
      "referencesToShow": [
        "Guidelines for the Treatment of Hypothyroidism. Thyroid 2014. PMID: 25207204.",
        "BJA Education on Endocrine Disease. 2017."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "pheochromocytoma_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "alfa",
      "anesthesia",
      "blokaj",
      "feo",
      "feokromositoma",
      "kriz",
      "pheochromocytoma"
    ],
    "question_tr": "Feokromositoma",
    "question_en": "Kriz feo",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Feokromositomada hipertansif kriz, taşiaritmi ve postop hipotansiyon riski yüksektir.\\nElektif cerrahide preop alfa blokaj ve volüm optimizasyonu gerekir; beta bloker alfa blokajdan önce başlanmamalıdır.\\nİntraoperatif hedef invaziv monitörizasyon, hipertansif ataklara hızlı müdahale, tümör manipülasyonu sırasında vazodilatör hazırlığı ve tümör çıkarıldıktan sonra hipotansiyon için sıvı/vazopressör desteğidir.",
      "immediateRedFlags": [
        "Tümör manipülasyonu sırasında sistolik kan basıncının aniden >250 mmHg olması veya öldürücü ventriküler taşikardiler.",
        "Tümörün venöz ligasyonu sonrasında kan basıncının aniden durdurulamaz şekilde sistolik <70 mmHg seviyesine inmesi (şiddetli vazoplejik şok)."
      ],
      "missingCriticalInformation": [
        "Preoperatif alfa blokajın (örn. Fenoksibenzamin veya Doksazosin) en az 10-14 gündür yapılıp yapılmadığı",
        "Hastanın preoperatif hematokrit değeri (blokaja bağlı vazodilatasyonun sıvı ile dolma derecesi)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Feokromositoma Anestezi ve Kriz Yönetimi",
        "Alfa-1 Adrenerjik Blokaj ve Roizen Kriterleri",
        "Tümör Rezeksiyonu Sonrası Dirençli Hipotansiyon"
      ],
      "suggestedNextStepsGeneral": [
        "Preoperatif Roizen Kriterlerini doğrulayın (Kan basıncı <160/90 mmHg, ortostatik hipotansiyon mevcut olmalı).",
        "Beta blokerleri kesinlikle Alfa blokaj tam kurulmadan ÖNCE başlamayın (alfa-aracılı kontrolsüz vazokonstrüksiyonu önlemek için).",
        "Ameliyathanede invaziv arter hattı kurun ve indüksiyon öncesi Sodyum Nitroprussid (0.5-5 mcg/kg/dk) veya Nitrogliserin infüzyonunu hazır bulundurun.",
        "Tümör damarları bağlandığında gelişecek derin hipotansiyonu önlemek için agresif sıvı yüklemesi yapın ve Noradrenalin infüzyonu başlatın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Ortalama Arter Basıncı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        },
        {
          "id": "esmolol",
          "titleTr": "Esmolol Monografı"
        }
      ],
      "doNotMiss": [
        "Alfa reseptörleri bloke edilmeden verilen beta blokerlerin kontrolsüz hipertansif krize ve kalp yetmezliğine yol açacağı gerçeği"
      ],
      "whenToEscalate": [
        "Tümör manipülasyonunda kontrol edilemeyen hipertansif kriz veya aritmi gelişirse derhal derin anesteziye geçin, nitroprussid/esmolol titre edin"
      ],
      "referencesToShow": [
        "Anesthetic Management of Pheochromocytoma. British Journal of Anaesthesia 2016. PMID: 26210243.",
        "Roizen MF, et al. Anesthesiology 1982."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Pheochromocytoma carries high risk of hypertensive crisis, tachyarrhythmia, and postoperative hypotension. Elective surgery requires preoperative alpha blockade and volume optimization; beta blockers should not be started before adequate alpha blockade. Intraoperative goals include invasive monitoring, rapid treatment of hypertensive episodes, vasodilator readiness during tumor manipulation, and fluid/vasopressor support after tumor removal.",
      "immediateRedFlags": [
        "Sudden hypertensive emergency (SBP >250 mmHg) or runs of ventricular tachycardia during tumor manipulation.",
        "Catastrophic hypotension (SBP <70 mmHg) immediately following tumor vein ligation (refractory vasoplegic shock)."
      ],
      "missingCriticalInformation": [
        "Duration and adequacy of preoperative alpha-blockade (Phenoxybenzamine or Doxazosin) for at least 10-14 days",
        "Patient's preoperative intravascular volume status (hematocrit trend)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Anesthetic Management of Pheochromocytoma",
        "Roizen Criteria for Preoperative Adequacy of Alpha-Blockade",
        "Post-Resection Vasoplegic Shock and Vasopressor Rescue"
      ],
      "suggestedNextStepsGeneral": [
        "Verify the Roizen criteria (BP <160/90 mmHg for 48h, presence of orthostatic hypotension).",
        "Never start a beta-blocker before adequate alpha-blockade is established (prevents unopposed alpha-1 vasoconstriction).",
        "Establish invasive arterial monitoring and have Sodium Nitroprusside (0.5-5 mcg/kg/min) or Phentolamine/Nitroglycerin infusions primed at bedside.",
        "Anticipate profound hypotension after tumor ligation; initiate aggressive fluid loading and start Norepinephrine infusion immediately."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        },
        {
          "id": "esmolol",
          "titleTr": "Esmolol Monograph"
        }
      ],
      "doNotMiss": [
        "Administering beta-blockers in the absence of complete alpha-receptor blockade will precipitate fatal hypertensive crisis and acute pulmonary edema"
      ],
      "whenToEscalate": [
        "During hypertensive crisis during resection, immediately halt surgical manipulation, deepen anesthesia, and administer potent vasodilators (Nitroprusside/Phentolamine)"
      ],
      "referencesToShow": [
        "Anesthetic Management of Pheochromocytoma. British Journal of Anaesthesia 2016. PMID: 26210243.",
        "Roizen MF, et al. Anesthesiology 1982."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "raised_icp_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "anesthesia",
      "basıncı",
      "basınç",
      "elevated",
      "icp",
      "intracranial",
      "içi",
      "kafa",
      "perfüzyon",
      "raised",
      "serebral"
    ],
    "question_tr": "Kafa içi basıncı",
    "question_en": "Serebral perfüzyon",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Hedefler serebral perfüzyonu korumak ve kafa içi basıncı artıran faktörlerden kaçınmaktır.\\n\\n1. Hipoksi ve hipotansiyondan kaçın.\\n2. Normokapni hedefle; akut herniasyon şüphesinde geçici hiperventilasyon düşünülebilir.\\n3. Baş orta hatta ve venöz dönüş rahat olmalıdır.\\n4. Aşırı PEEP ve yüksek intratorasik basınçtan kaçın.\\n5. Ağrı, öksürük, ıkınma ve hipertansiyon kontrol edilir.\\n6. Mannitol veya hipertonik salin nöroşirürji/yoğun bakım planına göre kullanılır.",
      "immediateRedFlags": [
        "Cushing Triadı bulgularının (şiddetli hipertansiyon, bradikardi, düzensiz solunum) varlığı (beyin sapı fıtıklaşması/herniasyon işareti!).",
        "Pupillerin anizokorik olması, tek taraflı genişleme veya ışık refleksinin kaybolması."
      ],
      "missingCriticalInformation": [
        "Hastanın o anki Glasgow Koma Skalası (GCS) skoru",
        "Beyin BT/MRG'deki orta hat kayması (midline shift) miktarı (mm)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Kafa İçi Basınç Artışı (KİBA) Yönetimi",
        "Serebral Perfüzyon Basıncı (CPP = MAP - ICP) Korunması",
        "Osmotik Tedavi Protokolleri (Mannitol vs %3 NaCl)"
      ],
      "suggestedNextStepsGeneral": [
        "Hipoksi (SpO₂ <%95) ve hipotansiyonu (MAP <75-80 mmHg) kesinlikle önleyin (serebral iskemi riski).",
        "Karbondioksit (PaCO₂) düzeyini 35-38 mmHg (normokapni-hafif hipokapni) aralığında tutun.",
        "Hastanın başını 30 derece yükseltin ve orta hatta (midline) tutarak juguler venöz dönüşü rahatlatın.",
        "Akut fıtıklaşma şüphesinde: %20 Mannitol (0.5-1 g/kg IV, 20 dakikada) veya %3 Hipertonik Salin (250 mL IV) uygulayın ve PaCO₂'yi geçici olarak 30-32 mmHg'ye düşürecek şekilde hiperventile edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Ortalama Arter Basıncı"
        },
        {
          "id": "gcs",
          "titleTr": "Glaskow Koma Skalası"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Akut fıtıklaşma (herniasyon) dışında uzun süreli hiperventilasyonun serebral vazokonstrüksiyona ve ağır beyin iskemisine yol açabileceği"
      ],
      "whenToEscalate": [
        "Pupil genişlemesi veya ani bradikardi gelişirse derhal hipertonik tedavi verin, cerraha haber verin ve acil kraniyotomi/dekompresyon planlayın"
      ],
      "referencesToShow": [
        "Guidelines for the Management of Severe Traumatic Brain Injury. Neurosurgery 2016. PMID: 27638891.",
        "NASCIS Guidelines. 2018."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Goals are to preserve cerebral perfusion and avoid factors that increase intracranial pressure. Avoid hypoxia and hypotension, target normocapnia, consider temporary hyperventilation only for suspected acute herniation, keep the head midline with unobstructed venous drainage, avoid excessive PEEP and high intrathoracic pressure, control pain/coughing/straining/hypertension, and use mannitol or hypertonic saline according to the neurosurgical/ICU plan.",
      "immediateRedFlags": [
        "Cushing's triad (severe hypertension, bradycardia, irregular respirations) indicating imminent brainstem herniation.",
        "Acute pupillary asymmetry (anisocoria), unilateral dilatation, or sluggish light reflex."
      ],
      "missingCriticalInformation": [
        "Patient's current Glasgow Coma Scale (GCS) and airway status",
        "Amount of midline shift (mm) on recent brain CT/MRI"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Elevated Intracranial Pressure (ICP) Management",
        "Cerebral Perfusion Pressure (CPP = MAP - ICP) Maintenance",
        "Hyperosmolar Therapy Guidelines (Mannitol vs. 3% NaCl)"
      ],
      "suggestedNextStepsGeneral": [
        "Prevent hypoxia (SpO₂ <95%) and systemic hypotension (maintain MAP >80 mmHg to preserve CPP).",
        "Target mild hypocapnia/normocapnia (PaCO₂ 35-38 mmHg) to optimize cerebral blood flow.",
        "Elevate the head of the bed to 30 degrees and keep the head strictly midline to femergencyitate jugular venous outflow.",
        "In case of acute herniation: Administer 20% Mannitol (0.5-1 g/kg IV over 20 min) or 3% Hypertonic Saline (250 mL IV) and temporarily hyperventilate to PaCO₂ 30-32 mmHg."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Calculator"
        },
        {
          "id": "gcs",
          "titleTr": "Glasgow Coma Scale"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Avoid prolonged hyperventilation unless active herniation is suspected; severe vasoconstriction will precipitate focal cerebral ischemia"
      ],
      "whenToEscalate": [
        "If pupillary dilation or sudden bradycardia occurs, administer hyperosmolar therapy immediately and proceed to emergent decompressive craniectomy"
      ],
      "referencesToShow": [
        "Guidelines for the Management of Severe Traumatic Brain Injury. Neurosurgery 2016. PMID: 27638891.",
        "NASCIS Guidelines. 2018."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "tbi_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "anesthesia",
      "beyin",
      "brain",
      "hasarı",
      "injury",
      "tbi",
      "traumatic",
      "travmatik"
    ],
    "question_tr": "Travmatik beyin",
    "question_en": "Beyin hasarı",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "İkincil beyin hasarını önlemek esastır.\\n\\n1. Hipoksi ve hipotansiyonu önle.\\n2. Normokapni hedefle.\\n3. Hipoglisemi ve ciddi hiperglisemiden kaçın.\\n4. Normotermi sağla.\\n5. Hemodinamik olarak stabil indüksiyon yap.\\n6. Servikal omurga yaralanması ihtimalini düşün.\\n7. Kanama, koagülopati ve kafa içi basınç yönetimi eş zamanlı yürütülür.",
      "immediateRedFlags": [
        "İndüksiyon sırasında sistolik kan basıncının <90 mmHg olması (ikincil beyin hasarını ve mortaliteyi bağımsız olarak iki katına çıkarır!).",
        "SpO₂'nin <%90 düzeyine inmesi."
      ],
      "missingCriticalInformation": [
        "Hastanın olası eşlik eden servikal omurga yaralanması (c-spine) stabilite durumu",
        "Hastanın eşlik eden majör abdominal/torasik hemoraji varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Travmatik Beyin Hasarı (TBI) ve İkincil Hasar Önleme",
        "Hipotansiyon ve Hipoksemi Önleme Sınırları (CPP Korunması)",
        "Boyunluk (C-Collar) Varlığında Havayolu Güvenliği"
      ],
      "suggestedNextStepsGeneral": [
        "Hastada sistolik kan basıncını >100-110 mmHg düzeyinde (yaşına göre) tutun; gerekirse derhal Noradrenalin başlayın.",
        "İndüksiyonda serebral metabolizmayı azaltan ve hemodinamiyi bozmayan Etomidat (0.3 mg/kg) veya Propofol + Noradrenalin ko-infüzyonu tercih edin.",
        "Servikal omurga yaralanması şüphesinde, boyunluğu açmadan MILS (Manuel İn-line Stabilizasyon) altında entübasyon gerçekleştirin.",
        "Kan şekerini 140-180 mg/dL düzeyinde tutun; hipertonik sıvılar veya mannitol uygularken serum sodyum ve osmolalite takibi yapın."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Ortalama Arter Basıncı"
        },
        {
          "id": "gcs",
          "titleTr": "Glaskow Koma Skalası"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        },
        {
          "id": "succinylcholine",
          "titleTr": "Süksinilkolin Monografı"
        }
      ],
      "doNotMiss": [
        "TBI hastalarında indüksiyon sırasında gelişecek tek bir hipotansif atağın (sistolik <90 mmHg) sağkalımı dramatik şekilde düşüreceği"
      ],
      "whenToEscalate": [
        "Eşlik eden masif intrakraniyal kanamada kraniyotomi ve intrakraniyal basınç (ICP) monitör yerleşimi için beyin cerrahisi ile koordinasyon sağlayın"
      ],
      "referencesToShow": [
        "Guidelines for the Management of Severe Traumatic Brain Injury. Neurosurgery 2016. PMID: 27638891.",
        "NASCIS Guidelines. 2018."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Preventing secondary brain injury is essential. Avoid hypoxia and hypotension, target normocapnia, avoid hypoglycemia and severe hyperglycemia, maintain normothermia, use hemodynamically stable induction, consider cervical spine injury, and manage bleeding, coagulopathy, and intracranial pressure simultaneously.",
      "immediateRedFlags": [
        "Any single episode of SBP <90 mmHg or SpO₂ <90% (independently doubles mortality in severe TBI).",
        "Unstable cervical spine with threatened spinal cord compression during airway manipulation."
      ],
      "missingCriticalInformation": [
        "Cervical spine clearance status (radiological and clinical)",
        "Presence of concomitant major systemic hemorrhage (e.g. splenic or pelvic fracture)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Traumatic Brain Injury (TBI) and Secondary Insult Prevention",
        "Target Hemodynamics (SBP >100-110 mmHg) for Brain Perfusion",
        "Airway Management with Manual In-line Stabilization (MILS)"
      ],
      "suggestedNextStepsGeneral": [
        "Maintain SBP >100-110 mmHg using aggressive fluid resuscitation and early Norepinephrine infusion.",
        "Avoid hypoxia strictly; preoxygenate thoroughly and maintain SpO₂ at 97-100%.",
        "Use a hemodynamically stable induction technique (e.g. Etomidate 0.3 mg/kg or Propofol paired with active vasopressor support).",
        "Perform intubation with Manual In-line Stabilization (MILS) if cervical spine is not cleared.",
        "Keep glucose between 140-180 mg/dL; avoid hypotonic IV fluids."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Calculator"
        },
        {
          "id": "gcs",
          "titleTr": "Glasgow Coma Scale"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        },
        {
          "id": "succinylcholine",
          "titleTr": "Succinylcholine Monograph"
        }
      ],
      "doNotMiss": [
        "Hypotension and hypoxia are the two most lethal preventable insults to the injured brain; maintain cerebral perfusion pressure actively"
      ],
      "whenToEscalate": [
        "For massive expanding hematomas, prioritize immediate surgical evacuation and consider placing an ICP monitor"
      ],
      "referencesToShow": [
        "Guidelines for the Management of Severe Traumatic Brain Injury. Neurosurgery 2016. PMID: 27638891.",
