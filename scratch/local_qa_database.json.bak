  {
    "id": "clinical_followup_malignant_hyperthermia_how_0",
    "category": "clinical_followups",
    "keywords": [
      "clinical_followup_malignant_hyperthermia_how_0",
      "followup",
      "hipertermi",
      "hyperthermia",
      "malign",
      "malignant",
      "mh",
      "var0"
    ],
    "question_tr": "Dantrolen nasıl sulandırılır ve uygulanır?",
    "question_en": "How is dantrolene reconstituted and administered?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "💉 Her bir 20 mg Dantrolen flakonu, 60 mL steril distile su (sterile water) ile sulandırılmalıdır. Serum fizyolojik (%0.9 NaCl) veya dekstroz kesinlikle kullanılmamalıdır, aksi takdirde etkin madde çöker. Başlangıç dozu 2.5 mg/kg IV bolustur ve semptomlar kontrol altına alınana kadar her 5-10 dakikada bir tekrarlanır.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "💉 Reconstitute each 20 mg vial of Dantrolene with exactly 60 mL of sterile water for injection. Do not use physiological saline (0.9% NaCl) or dextrose, as this will cause precipitation of the active compound. Administer initial dose of 2.5 mg/kg IV bolus, repeat every 5-10 minutes until crisis resolves.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    }
  },
