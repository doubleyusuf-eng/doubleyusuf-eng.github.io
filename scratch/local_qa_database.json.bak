    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Öncelik oksijenasyonu korumaktır.\\n1. Maske ventilasyonunu optimize et: iki kişi tekniği, oral/nazal airway, iyi baş-boyun pozisyonu.\\n2. Yardım çağır.\\n3. Entübasyon denemelerini sınırla; aynı tekniği tekrar tekrar deneme.\\n4. Videolaringoskop, farklı blade, stile/bougie veya fiberoptik seçeneklerini kullan.\\n5. Başarısızlık devam ederse supraglottik airway yerleştir.\\n6. Oksijenasyon sağlanıyorsa hastayı uyandırmayı veya cerrahiyi ertelemeyi düşün.\\n7. Oksijenasyon bozulursa CICO algoritmasına geç.",
      "immediateRedFlags": [
        "Entübasyon denemeleri sırasında SpO₂'nin %90'ın altına düşmesi hipoksik beyin hasarı riskini hızla artırır.",
        "Aynı laringoskopi tekniğinde ısrar etmek havayolu travması, ödem ve kanamaya yol açarak ventilasyonu da imkansızlaştırır."
      ],
      "missingCriticalInformation": [
        "Mevcut SpO₂ düzeyi ve hastanın desatürasyon hızı",
        "Kullanılan kas gevşeticinin türü ve reversal (Sugammadeks) bulunabilirliği"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Beklenmeyen Zor Entübasyon Yönetimi",
        "Supraglottik Airway (SGA) Kurtarma Adımları",
        "Hastayı Uyandırma ve Cerrahiyi Erteleme Kararı"
      ],
      "suggestedNextStepsGeneral": [
        "İki el tekniği (jaw thrust) ve %100 O₂ ile maske ventilasyonunu optimize edin.",
        "Tekrar laringoskopi yapacaksanız pozisyonu değiştirin (koklama pozisyonu) veya videolaringoskopa geçin.",
        "Oksijenasyon korunamıyorsa derhal I-gel veya LMA yerleştirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "rocuronium",
          "titleTr": "Roküronyum Monografı"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        }
      ],
      "doNotMiss": [
        "Oksijenasyon sağlanabiliyorsa, hastayı uyandırmak ve elektif cerrahiyi ertelemek en güvenli seçenektir"
      ],
      "whenToEscalate": [
        "Entübasyon ve maske ventilasyonu başarısız olduğunda ve SGA oksijenasyon sağlayamadığında acil CICO protokolünü başlatın"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "DAS 2015 Guidelines. Anaesthesia 2015. PMID: 26558482."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "The priority is maintaining oxygenation. Optimize mask ventilation with two-person technique, airway adjuncts, and positioning. Call for help. Limit repeated attempts and avoid repeating the same failed technique. Use videolaryngoscopy, different blades, stylet/bougie, or fiberoptic options. If failure persists, place a supraglottic airway. If oxygenation is adequate, consider waking the patient or postponing surgery. If oxygenation fails, proceed to the CICO pathway.",
      "immediateRedFlags": [
        "SpO₂ falling below 90% during attempts dramatically escalates the risk of hypoxic brain injury.",
        "Persisting with the same failed technique causes airway trauma, edema, and bleeding, compromising mask ventilation."
      ],
      "missingCriticalInformation": [
        "Current SpO₂ level and rate of desaturation",
        "Type of neuromuscular blocker used and availability of sugammadex"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Unexpected Difficult Intubation Management",
        "Supraglottic Airway (SGA) Rescue Steps",
        "Decision to Wake the Patient and Postpone Surgery"
      ],
      "suggestedNextStepsGeneral": [
        "Optimize mask ventilation using two-person jaw thrust and 100% O₂.",
        "Change position (sniffing position) or switch to videolaryngoscopy before a repeat attempt.",
        "If oxygenation is threatened, immediately insert a supraglottic device (e.g., I-gel or LMA)."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "rocuronium",
          "titleTr": "Rocuronium Monograph"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        }
      ],
      "doNotMiss": [
        "If oxygenation is secure, waking the patient and postponing elective surgery is the safest clinical path"
      ],
      "whenToEscalate": [
        "If both intubation and ventilation fail and SGA cannot secure oxygenation, initiate the CICO emergency protocol"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "DAS 2015 Guidelines. Anaesthesia 2015. PMID: 26558482."
      ],
      "safetyLevel": "emergency"
    }
