  {
    "id": "clinical_followup_last_protocol_why_0",
    "category": "clinical_followups",
    "keywords": [
      "anesthetic",
      "bupivakain",
      "clinical_followup_last_protocol_why_0",
      "followup",
      "last",
      "local",
      "toksisite",
      "toxic",
      "var0",
      "why"
    ],
    "question_tr": "Neden lipid emülsiyon tedavisi uygulamalıyım?",
    "question_en": "Why should i apply lipid emulsion treatment?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 Lokal anestezikler (özellikle Bupivakain) lipofiliktir ve miyokardiyal sodyum kanallarına bağlanarak kardiyak iletimi durdurur. %20 Lipid Emülsiyonu, kanda bir 'lipid havuzu' (lipid sink) oluşturarak lokal anesteziği kalp ve beyin dokularından çekip bağlar. Hücrelerin metabolik aktivitesini de doğrudan destekler.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 Local anesthetics (especially Bupivacaine) are lipophilic and bind to myocardial sodium channels, blocking cardiac conduction. 20% Lipid Emulsion works as a 'lipid sink', drawing the lipophilic anesthetic away from target heart and brain tissues. It also directly supplies energy substrates to cardiac cells.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
