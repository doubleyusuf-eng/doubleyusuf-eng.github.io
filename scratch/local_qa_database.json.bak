  {
    "id": "pca_settings",
    "category": "clinical_scenarios",
    "keywords": [
      "analjezi",
      "kontrollu",
      "kontrollü",
      "morfin",
      "morphine",
      "pca",
      "settings"
    ],
    "question_tr": "Pca morfin",
    "question_en": "Pca",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Hasta Kontrollü Analjezi (PCA), hastanın kendi ağrısını kontrol etmesini sağlayan ve aşırı doz riskini minimize eden güvenli bir sistemdir. Standart Morfin PCA protokolü: 1. Yükleme dozu (ameliyathanede veya derlenmede ağrı dinene kadar): 2-5 mg IV yavaş boluslar. 2. Bolus dozu (hasta düğmeye bastığında verilecek): 1 mg. 3. Kilitlenme süresi (lockout interval): 5-10 dakika (bu sürede cihaz yeni basışları reddeder). 4. Saatlik limit: Genellikle 10-15 mg. 5. Bazal infüzyon: Opioid naif hastalarda solunum depresyonu riskini ciddi şekilde artırdığından kesinlikle önerilmez; sadece opioid toleransı olanlarda düşünülebilir.",
      "immediateRedFlags": [
        "Cihazın kilitlenme süresinin çok kısa tutulması veya hasta yerine yakınlarının düğmeye basması (proxy PCA) sonucu gelişen aşırı doz toksisitesi.",
        "PCA kullanımına bağlı olarak gelişen ve nalokson gerektiren derin sedasyon."
      ],
      "missingCriticalInformation": [
        "Hastanın yaş grubu, komorbiditeleri (özellikle uyku apnesi, böbrek yetmezliği) ve opioid tolerans durumu",
        "Kullanılan opioid türü (Morfin, Fentanil veya Hidromorfon)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "PCA Programlama ve Protokolleri",
        "Opioid Doz Güvenliği",
        "Solunum Depresyonu Takibi"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın opioid naif olup olmadığını sorgulayın; naif ise bazal infüzyon hızını '0' (sıfır) olarak ayarlayın.",
        "Morfin için bolus dozunu 1 mg, kilitlenme süresini 6-10 dakika ve 4 saatlik limiti 20-30 mg olarak ayarlayın.",
        "Hastaya ve refakatçisine PCA mantığını, düğmeye sadece ve sadece hastanın basması gerektiğini strictly anlatın.",
        "PCA aktifken saatlik sedasyon skorunu (Ramsay veya Richmond) ve solunum hızını strictly kaydedin."
      ],
      "relatedAlgorithms": [
        {
          "id": "opioid_respiratory",
          "titleTr": "Opioid Solunum Depresyonu"
        },
        {
          "id": "postop_pain_ladder",
          "titleTr": "Ağrı Tedavisi"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        }
      ],
      "doNotMiss": [
        "PCA düğmesine hastanın yakınlarının basmasının (PCA by proxy) kesinlikle yasak olduğunu ve solunum arrestine yol açabileceğini hastaya ve ailesine bildirmeyi"
      ],
      "whenToEscalate": [
        "Solunum hızı < 8/dk altına inerse veya hasta uyandırılamazsa (sedasyon skoru > 3) PCA pompasını derhal durdurun, oksijen desteği sağlayın ve titre ederek Nalokson (40 mcg IV boluslarla) uygulayın"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Acute Pain Management. Anesthesiology 2016.",
        "Acute Pain Management: Scientific Evidence, ANZCA 5th Edition."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Patient-Controlled Analgesia (PCA) allows patients to manage their acute pain while minimizing the risk of accidental overdose. Standard Morphine PCA protocol: 1. Loading dose (administered in OR or PACU until pain is controlled): 2-5 mg IV slow boluses. 2. Bolus dose (delivered when patient presses button): 1 mg. 3. Lockout interval: 5-10 minutes (during which the device rejects further demands). 4. Hourly limit: Typically 10-15 mg. 5. Basal infusion: Strictly avoided in opioid-naïve patients due to high risk of respiratory depression; reserved only for opioid-tolerant patients.",
      "immediateRedFlags": [
        "Accidental overdose from proxy PCA (family members pressing the button instead of the patient) or inappropriately short lockout intervals.",
        "Deep sedation requiring airway support or Naloxone reversal during PCA therapy."
      ],
      "missingCriticalInformation": [
        "The patient's age, comorbidities (specifically sleep apnea, renal failure), and chronic opioid status",
        "The specific opioid ordered (Morphine, Fentanyl, or Hydromorphone)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "PCA Programming and Protocols",
        "Opioid Dosing Safety",
        "Respiratory Depression Monitoring"
      ],
      "suggestedNextStepsGeneral": [
        "Confirm the patient is opioid-naïve; if so, set the basal infusion rate strictly to '0' (zero).",
        "Program Morphine PCA with a 1 mg bolus, a 6-10 minute lockout interval, and a 4-hour limit of 20-30 mg.",
        "Strictly educate the patient and family that only the patient must press the PCA button.",
        "Document the patient's respiratory rate and sedation score hourly while the PCA is running."
      ],
      "relatedAlgorithms": [
        {
          "id": "opioid_respiratory",
          "titleTr": "Opioid Respiratory Depression"
        },
        {
          "id": "postop_pain_ladder",
          "titleTr": "Postoperative Pain Management"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        }
      ],
      "doNotMiss": [
        "PCA by proxy (family members pressing the button) is extremely dangerous and strictly contraindicated as it bypasses the safety feedback loop of sedation"
      ],
      "whenToEscalate": [
        "If the respiratory rate falls < 8 bpm or the patient is unresponsive, immediately stop the PCA pump, administer oxygen, and titrate low-dose Naloxone (40 mcg IV boluses)"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Acute Pain Management. Anesthesiology 2016.",
        "Acute Pain Management: Scientific Evidence, ANZCA 5th Edition."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "epidural_motor_block",
    "category": "clinical_scenarios",
    "keywords": [
      "block",
      "blok",
      "epidural",
      "hipotansiyon",
      "motor"
    ],
    "question_tr": "Epidural motor blok",
    "question_en": "Epidural motor block",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Epidural analjezi sırasında gelişen ciddi motor blok veya belirgin hipotansiyon acil değerlendirme gerektirir. Hipotansiyon, epidural lokal anesteziğin neden olduğu sempatik blokaja bağlı vazodilatasyondan kaynaklanır. Motor blok ise lokal anestezik konsantrasyonunun yüksekliğine, kateterin subaraknoid (intratekal) boşluğa göç etmesine (gelişmiş total spinal) veya en korkulan komplikasyon olan epidural hematom/apse gelişimine bağlı olabilir. İlk olarak infüzyonu durdurun, motor bloğun seviyesini ve bilateral simetrisini strictly değerlendirin.",
      "immediateRedFlags": [
        "Yeni başlayan, hızla ilerleyen bilateral alt ekstremite motor felci ve sfinkter disfonksiyonu (epidural hematom/apse belirtisi).",
        "İnfüzyon sonrası ani solunum yetmezliği ve midriyazis gelişmesi (total spinal blokaj)."
      ],
      "missingCriticalInformation": [
        "Kullanılan epidural lokal anestezik konsantrasyonu ve infüzyon hızı",
        "Hastanın en son koagülasyon parametreleri ve antikoagülan (LMWH, Heparin) dozu/zamanlaması"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Epidural Komplikasyonları Yönetimi",
        "Epidural Hematom ve Apse Taraması",
        "Sempatik Blokaj Hipotansiyonu"
      ],
      "suggestedNextStepsGeneral": [
        "İlk iş olarak epidural infüzyonu derhal durdurun ve hastanın hayati bulgularını sabitleyin.",
        "Bromage skalasını kullanarak motor bloğun derecesini ve duysal seviyeyi bilateral olarak test edin.",
        "Hipotansiyonu düzeltmek için intravasküler volümü kristalloitlerle destekleyin ve Efedrin (5-10 mg IV) veya Norepinefrin uygulayın.",
        "Kateterden BOS veya kan gelip gelmediğini kontrol etmek için kateteri yavaşça aspire edin (intratekal/intravasküler göç testi)."
      ],
      "relatedAlgorithms": [
        {
          "id": "hypotension",
          "titleTr": "Hipotansiyon Algoritması"
        },
        {
          "id": "epidural_hematoma",
          "titleTr": "Epidural Hematom Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monografı"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "Yeni başlayan ilerleyici motor bloğun, epidural hematoma bağlı spinal kord kompresyonunun en önemli klinik belirtisi olduğunu ve acil dekompresyon için zamanla yarışıldığını"
      ],
      "whenToEscalate": [
        "İlerleyici nörolojik defisit, sfinkter kontrol kaybı veya sırt ağrısı varlığında acilen beyin cerrahisi konsültasyonu isteyin ve spinal MRG planlayın (kalıcı hasarı önlemek için cerrahi dekompresyon ilk 8 saat içinde yapılmalıdır)"
      ],
      "referencesToShow": [
        "ASRA Neurological Complications in Regional Anesthesia Guidelines. 2018.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Developing severe motor block or significant hypotension during epidural analgesia requires immediate evaluation. Hypotension results from sympathetic blockade-induced vasodilation. Motor block may be due to high local anesthetic concentration, catheter migration into the subarachnoid (intrathecal) space, or most critically, the development of an epidural hematoma or abscess. First, stop the epidural infusion immediately and systematically evaluate the sensory level and motor block symmetry.",
      "immediateRedFlags": [
        "New-onset, rapidly progressive bilateral lower extremity motor weakness or bowel/bladder dysfunction (highly suggestive of epidural hematoma/abscess).",
        "Sudden respiratory distress, bradycardia, and pupillary dilation (total spinal anesthesia)."
      ],
      "missingCriticalInformation": [
        "The exact concentration and infusion rate of the epidural local anesthetic",
        "The patient's current coagulation profile and timing of any low-molecular-weight heparin or heparin doses"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Epidural Complications Management",
        "Epidural Hematoma and Abscess Screening",
        "Sympathetic Blockade Hypotension"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately stop the epidural infusion and stabilize vital signs.",
        "Assess the motor block using the Bromage scale and document the sensory level bilaterally.",
        "Treat hypotension with fluid boluses and vasopressors (Ephedrine 5-10 mg IV or Norepinephrine infusion).",
        "Aspirate the epidural catheter gently to check for the return of cerebrospinal fluid (CSF) or blood to rule out migration."
      ],
      "relatedAlgorithms": [
        {
          "id": "hypotension",
          "titleTr": "Hypotension Algorithm"
        },
        {
          "id": "epidural_hematoma",
          "titleTr": "Epidural Hematoma Management"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monograph"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Progressive motor weakness is the hallmark of spinal cord compression from an epidural hematoma; early diagnosis and surgical decompression are time-critical"
      ],
      "whenToEscalate": [
        "In the presence of progressive neurological deficit, loss of sphincter control, or severe back pain, consult neurosurgery immediately and obtain an urgent spinal MRI"
      ],
      "referencesToShow": [
        "ASRA Neurological Complications in Regional Anesthesia Guidelines. 2018.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "epidural_inadequacy",
    "category": "clinical_scenarios",
    "keywords": [
      "epidural",
      "inadequacy",
      "patchy",
      "tarafli",
      "taraflı",
      "tek",
      "yetersizlik"
    ],
    "question_tr": "Epidural yetersizlik",
    "question_en": "Epidural inadequacy",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Epidural analjezinin yetersiz olması, yama tarzında (patchy) blok oluşması veya tek taraflı blok gelişmesi sık karşılaşılan sorunlardır. Olası nedenler: Kateterin epidural boşlukta çok fazla ilerlemesi (tek taraflı veya spinal sinir köküne yakın yerleşim), kateterin kıvrılması/tıkanması, epidural aralığın anatomik septumları veya kateterin dışarı çıkmasıdır. Sorun giderme adımları: 1. Kateteri strictly steril koşullarda aspire edin (kan/BOS gelmediğini doğrulayın). 2. Kateter derindeyse (örn. > 5 cm içerdeyse) 1-2 cm geri çekin. 3. Tek taraflı blokta hastayı blok olmayan tarafı aşağıda kalacak şekilde pozisyonlandırın. 4. Düşük doz ek bolus (örn. 5 ml %0.25 Bupivakain) uygulayın.",
      "immediateRedFlags": [
        "Aspirasyonda serbest BOS gelmesi (kateterin intratekal göçü) veya serbest kan gelmesi (intravasküler göç).",
        "Ek bolus sonrası ani gelişen yüksek spinal anestezi tablosu."
      ],
      "missingCriticalInformation": [
        "Kateterin cilt seviyesindeki yerleşim derinliği ve ilk yerleştirilme mesafesi",
        "Kullanılan infüzyon pompası alarmları (yüksek basınç tıkanıklık uyarısı)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Yetersiz Epidural Blok Çözümü",
        "Epidural Kateter Sorun Giderme",
        "Bölgesel Analjezi Optimizasyonu"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle epidural kateteri yavaşça aspire ederek subaraknoid veya intravasküler yerleşimi strictly dışlayın.",
        "Kateteri ciltteki bandaj seviyesinden kontrol edin; eğer kateter derindeyse aseptik teknikle 1-2 cm geri çekin.",
        "Tek taraflı blok varlığında hastayı bloke olmayan tarafına yatırıp o tarafa doğru yer çekimiyle yayılımı destekleyin.",
        "Kateter tıkanıklığından şüpheleniyorsa steril salin ile yavaşça yıkayarak açıklığı test edin; tıkanıklık açılmıyorsa kateteri çekin."
      ],
      "relatedAlgorithms": [
        {
          "id": "failed_epidural_troubleshooting",
          "titleTr": "Başarısız Epidural Yönetimi"
        },
        {
          "id": "epidural_motor_block",
          "titleTr": "Epidural Motor Blok"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monografı"
        }
      ],
      "doNotMiss": [
        "Kateterin intratekal veya intravasküler göçünü dışlamak için her ek bolus öncesinde strictly aspirasyon yapılması ve test dozu verilmesi gerektiğini"
      ],
      "whenToEscalate": [
        "Geri çekme, pozisyon verme ve ek boluslara rağmen hastanın ağrısı dindirilemiyorsa veya kateterden BOS/kan gelmeye devam ediyorsa kateteri çekin ve yeni bir kateter yerleştirin"
      ],
      "referencesToShow": [
        "Chestnut's Obstetric Anesthesia: Principles and Practice, 6th Edition.",
        "Failed Epidural Analgesia: Troubleshooting. British Journal of Anaesthesia 2020."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Inadequate epidural analgesia, patchy blockade, or unilateral block are common clinical issues. Potential causes include catheter insertion too deep in the epidural space (leading to unilateral or transforaminal positioning), catheter kinking/obstruction, anatomical septa within the epidural space, or dislodgement. Troubleshooting steps: 1. Aspirate the catheter gently under strict sterile conditions (verify no blood/CSF). 2. If the catheter is too deep (e.g., > 5 cm), withdraw it by 1-2 cm. 3. Position the patient with the unblocked side down. 4. Administer an additional low-dose local anesthetic bolus (e.g., 5 mL of 0.25% Bupivacaine).",
      "immediateRedFlags": [
        "Aspiration yielding free-flowing CSF (intrathecal migration) or frank blood (intravascular migration).",
        "Sudden development of high spinal blockade immediately following a rescue bolus."
      ],
      "missingCriticalInformation": [
        "Catheter depth marking at the skin and the initial insertion distance in the epidural space",
        "Any active high-pressure or occlusion alarms on the infusion pump"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Inadequate Epidural Block Resolution",
        "Epidural Catheter Troubleshooting",
        "Regional Analgesia Optimization"
      ],
      "suggestedNextStepsGeneral": [
        "Perform a gentle aspiration test on the epidural catheter to rule out subarachnoid or intravascular migration.",
        "Check the catheter marking at the skin; if inserted too deep, withdraw it 1-2 cm using an aseptic technique.",
        "In unilateral block, place the patient on their unblocked side to allow gravity-assisted spread of the local anesthetic.",
        "Test catheter patency by flushing gently with sterile saline; if resistance is high or kinking is suspected, replace it."
      ],
      "relatedAlgorithms": [
        {
          "id": "failed_epidural_troubleshooting",
          "titleTr": "Failed Epidural Management"
        },
        {
          "id": "epidural_motor_block",
          "titleTr": "Epidural Motor Block"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monograph"
        }
      ],
      "doNotMiss": [
        "Always perform a gentle aspiration test before administering any rescue bolus to rule out late catheter migration into the intrathecal or intravascular space"
      ],
      "whenToEscalate": [
        "If the pain remains uncontrolled despite repositioning, withdrawal, and repeat bolusing, or if CSF/blood continues to aspirate, remove and replace the epidural catheter"
      ],
      "referencesToShow": [
        "Chestnut's Obstetric Anesthesia: Principles and Practice, 6th Edition.",
        "Failed Epidural Analgesia: Troubleshooting. British Journal of Anaesthesia 2020."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "ketamine_infusion",
    "category": "clinical_scenarios",
    "keywords": [
      "infusion",
      "infuzyonu",
      "infüzyonu",
      "ketamin",
      "ketamine"
    ],
    "question_tr": "Ketamin infüzyonu",
    "question_en": "Ketamine infusion",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Sub-anestezik (düşük doz) intravenöz Ketamin infüzyonu, perioperatif multimodal analjezinin güçlü bir bileşenidir. NMDA reseptör antagonizması yoluyla opioid tüketimini azaltır, hiperaljeziyi önler ve kronik postoperatif ağrı riskini düşürür. Protokol: İndüksiyonda 0.1-0.25 mg/kg IV bolus, ardından intraoperatif olarak 0.1-0.2 mg/kg/saat (veya postop servis/yoğun bakımda 0.05-0.1 mg/kg/saat) hızında sürekli infüzyondur. Kontrendikasyonları: Ciddi kontrolsüz hipertansiyon, aktif psikoz veya şizofreni ve artmış kafa içi basınç (ICP) şüphesidir.",
      "immediateRedFlags": [
        "İnfüzyon sırasında gelişen şiddetli halüsinasyonlar, disosiyatif durumlar ve ajitasyon tablosu.",
        "Ketamine bağlı gelişen akut kontrolsüz hipertansif atak ve taşikardi."
      ],
      "missingCriticalInformation": [
        "Hastanın psikiyatrik öyküsü ve aktif kardiyovasküler komorbiditeleri (örn. koroner arter hastalığı)",
        "Hastanın eş zamanlı aldığı diğer sedatif veya analjezik ilaçlar"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Ketamin Analjezi Protokolleri",
        "NMDA Reseptör Antagonizması",
        "Opioid Koruyucu Adjuvanlar"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın psikiyatrik ve kardiyovasküler açıdan ketamin infüzyonuna uygunluğunu preoperatif olarak kontrol edin.",
        "İntraoperatif infüzyon hızını strictly 0.2 mg/kg/saat altında tutarak psikotik yan etkileri en aza indirin.",
        "Disosiyatif yan etkiler (halüsinasyon, nistagmus) gelişirse infüzyonu durdurun veya düşük doz Midazolam uygulayın.",
        "Ketaminin sempatomimetik etkileri nedeniyle ameliyat boyunca kan basıncı ve kalp hızı trendlerini izleyin."
      ],
      "relatedAlgorithms": [
        {
          "id": "postop_pain_ladder",
          "titleTr": "Ağrı Tedavisi"
        },
        {
          "id": "hypertension",
          "titleTr": "Hipertansiyon Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "dexmedetomidine",
          "titleTr": "Deksmedetomidin Monografı"
        }
      ],
      "doNotMiss": [
        "Sub-anestezik dozlarda (örn. < 0.25 mg/kg) ketaminin hava yolu reflekslerini baskılamadığını ancak disosiyasyon riskinin her zaman mevcut olduğunu"
      ],
      "whenToEscalate": [
        "İnfüzyon sırasında inatçı aktif psikoz bulguları veya kontrol altına alınamayan hemodinamik instabilite varlığında infüzyonu derhal sonlandırın ve hastayı anestezi/yoğun bakım ekibine devredin"
      ],
      "referencesToShow": [
        "Consensus Guidelines on the Use of Intravenous Ketamine Infusions for Acute Pain. Regional Anesthesia & Pain Medicine 2018.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Sub-anesthetic (low-dose) intravenous Ketamine infusion is a highly effective component of perioperative multimodal analgesia. Through NMDA receptor antagonism, it reduces opioid consumption, prevents hyperalgesia, and lowers the risk of chronic postsurgical pain. Protocol: Bolus dose of 0.1-0.25 mg/kg IV at induction, followed by an intraoperative maintenance infusion of 0.1-0.2 mg/kg/h (or 0.05-0.1 mg/kg/h in the PACU/ward). Contraindications: Severe uncontrolled hypertension, active psychosis or schizophrenia, and suspected intracranial hypertension.",
      "immediateRedFlags": [
        "Severe hallucinations, dissociative states, or agitation developing during infusion.",
        "Acute uncontrolled hypertensive crisis and severe tachycardia related to ketamine's sympathomimetic effects."
      ],
      "missingCriticalInformation": [
        "The patient's psychiatric history and active cardiovascular comorbidities (e.g., coronary artery disease)",
        "Concomitant sedatives or analgesics administered to the patient"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Ketamine Analgesia Protocols",
        "NMDA Receptor Antagonism",
        "Opioid-Sparing Adjuvants"
      ],
      "suggestedNextStepsGeneral": [
        "Assess the patient's psychiatric and cardiovascular profile for suitability of ketamine infusion.",
        "Maintain the intraoperative infusion rate strictly below 0.2 mg/kg/h to minimize psychotomimetic side effects.",
        "If dissociative side effects (hallucinations, nystagmus) develop, discontinue the infusion or administer low-dose Midazolam.",
        "Monitor blood pressure and heart rate closely during infusion due to ketamine-induced sympathetic stimulation."
      ],
      "relatedAlgorithms": [
        {
          "id": "postop_pain_ladder",
          "titleTr": "Postoperative Pain Management"
        },
        {
          "id": "hypertension",
          "titleTr": "Hypotension Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "dexmedetomidine",
          "titleTr": "Dexmedetomidine Monograph"
        }
      ],
      "doNotMiss": [
        "Sub-anesthetic doses (< 0.25 mg/kg) preserve airway reflexes, but the risk of mild dissociation remains and requires patient reassurance"
      ],
      "whenToEscalate": [
        "In the event of persistent psychosis or refractory hemodynamic instability during infusion, stop the infusion immediately and consult the anesthesia/ICU team"
      ],
      "referencesToShow": [
        "Consensus Guidelines on the Use of Intravenous Ketamine Infusions for Acute Pain. Regional Anesthesia & Pain Medicine 2018.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "lidocaine_infusion",
    "category": "clinical_scenarios",
    "keywords": [
      "infusion",
      "infuzyonu",
      "infüzyonu",
      "iv",
      "lidocaine",
      "lidokain"
    ],
    "question_tr": "Iv lidokain",
    "question_en": "Lidocaine infusion",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "İntravenöz Lidokain infüzyonu, perioperatif multimodal analjezi protokollerinin (özellikle major laparoskopik abdominal cerrahide) güçlü bir parçasıdır. Sistemik antiinflamatuar ve analjezik etkileri ile ileus süresini kısaltır ve hastanede kalış süresini azaltır. Protokol: İndüksiyonda 1.5 mg/kg IV bolus (10-20 dakikada yavaşça), ardından intraoperatif olarak 1-1.5 mg/kg/saat hızında sürekli infüzyondur. Cerrahi bitiminde veya PACU'da sonlandırılır. İnfüzyon boyunca hastada Lokal Anestezik Sistemik Toksisitesi (LAST) bulguları strictly izlenmelidir.",
      "immediateRedFlags": [
        "İnfüzyon sırasında gelişen perioral uyuşukluk, tinnitus, metalik tat, ajitasyon veya nöbet (erken LAST bulguları).",
        "EKG'de PR/QRS uzaması, bradikardi veya ani kardiyak arrest gelişimi (şiddetli LAST bulguları)."
      ],
      "missingCriticalInformation": [
        "Hastanın güncel vücut ağırlığı (dozlama ideal vücut ağırlığına göre yapılmalıdır)",
        "Hastanın bazal karaciğer ve böbrek fonksiyonları (lidokain klirensi için önemlidir)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İntravenöz Lidokain İnfüzyonu",
        "LAST Güvenlik Protokolleri",
        "Multimodal Analjezi Adjuvanları"
      ],
      "suggestedNextStepsGeneral": [
        "Lidokain dozlarını strictly hastanın İdeal Vücut Ağırlığına (IBW) göre hesaplayın (aşırı dozu önlemek için).",
        "İndüksiyonda bolus dozunu hızlı puşe etmeyin, 10-20 dakikalık bir infüzyon şeklinde yavaşça uygulayın.",
        "İntraoperatif idame hızını 1.5 mg/kg/saat üzerine çıkarmayın; karaciğer yetmezliği olanlarda hızı %50 azaltın.",
        "Ameliyat boyunca EKG ve nörolojik bulguları (varsa) izleyin; cerrahi bitiminde infüzyonu kesinlikle sonlandırın."
      ],
      "relatedAlgorithms": [
        {
          "id": "last",
          "titleTr": "LAST Toksisite Algoritması"
        },
        {
          "id": "postop_pain_ladder",
          "titleTr": "Ağrı Tedavisi"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "lipid",
          "titleTr": "Lipid Emülsiyon Monografı"
        }
      ],
      "doNotMiss": [
        "IV lidokain infüzyonu alan bir hastada, eş zamanlı olarak rejyonal veya lokal sızma (örn. TAP blok, epidural) için başka bir lokal anestezik yapılmasının toksisite (LAST) riskini strictly katlayacağını"
      ],
      "whenToEscalate": [
        "Herhangi bir LAST şüphesinde (örn. nöbet veya aritmi) lidokain infüzyonunu derhal durdurun, %20 Lipid Emülsiyon tedavisini (1.5 mL/kg bolus ve ardından 0.25 mL/kg/dk infüzyon) başlatın ve acil resüsitasyon ekibini çağırın"
      ],
      "referencesToShow": [
        "Consensus Guidelines on the Use of Intravenous Lidocaine for Surgical Patients. Anaesthesia 2021.",
        "ASRA Practice Advisory on Local Anesthetic Systemic Toxicity. 2018."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Intravenous Lidocaine infusion is a highly effective component of perioperative multimodal analgesia, particularly in major laparoscopic abdominal surgery. Through systemic anti-inflammatory and analgesic effects, it accelerates bowel function recovery (reduces ileus) and shortens hospital stay. Protocol: Bolus dose of 1.5 mg/kg IV (slowly over 10-20 minutes) at induction, followed by an intraoperative infusion of 1-1.5 mg/kg/h. Discontinue at surgery completion or in the PACU. Monitor strictly for signs of Local Anesthetic Systemic Toxicity (LAST).",
      "immediateRedFlags": [
        "Perioral numbness, tinnitus, metallic taste, agitation, or seizures developing during infusion (early LAST signs).",
        "PR/QRS prolongation, severe bradycardia, or sudden cardiac arrest (severe LAST signs)."
      ],
      "missingCriticalInformation": [
        "The patient's actual vs. ideal body weight (dosing must be based strictly on Ideal Body Weight)",
        "Baseline hepatic and renal function panels (lidocaine is metabolized by the liver)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Intravenous Lidocaine Infusion",
        "LAST Safety Protocols",
        "Multimodal Analgesia Adjuvants"
      ],
      "suggestedNextStepsGeneral": [
        "Calculate lidocaine bolus and infusion doses strictly based on the patient's Ideal Body Weight (IBW).",
        "Do not administer the induction bolus as a rapid IV push; run it slowly over 10-20 minutes.",
        "Limit the maintenance infusion rate to 1.5 mg/kg/h; reduce the rate by 50% in patients with hepatic impairment.",
        "Monitor the EKG continuously during anesthesia and discontinue the infusion promptly at the end of surgery."
      ],
      "relatedAlgorithms": [
        {
          "id": "last",
          "titleTr": "LAST Toxicity Algorithm"
        },
        {
          "id": "postop_pain_ladder",
          "titleTr": "Postoperative Pain Management"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "lipid",
          "titleTr": "Lipid Emulsion Monograph"
        }
      ],
      "doNotMiss": [
        "Co-administering other local anesthetics (e.g., via regional blocks or infiltration) while an IV lidocaine infusion is active significantly increases the risk of LAST"
      ],
      "whenToEscalate": [
        "At any suspicion of LAST (e.g., seizures, ventricular arrhythmias), immediately stop the infusion, initiate 20% Lipid Emulsion therapy, and summon the emergency resuscitation team"
      ],
      "referencesToShow": [
        "Consensus Guidelines on the Use of Intravenous Lidocaine for Surgical Patients. Anaesthesia 2021.",
        "ASRA Practice Advisory on Local Anesthetic Systemic Toxicity. 2018."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "dexmedetomidine_infusion",
    "category": "clinical_scenarios",
    "keywords": [
      "deksmedetomidin",
      "dexmedetomidine",
      "infusion",
      "infuzyonu",
      "infüzyonu"
    ],
    "question_tr": "Deksmedetomidin infüzyonu",
    "question_en": "Deksmedetomidin",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Deksmedetomidin, yüksek derecede selektif bir alfa-2 adrenerjik reseptör agonistidir. Solunum depresyonu yapmadan sedasyon, analjezi ve anksiyoliz sağlar. Perioperatif dönemde uyanma deliryumunu önlemek, opioid tüketimini azaltmak ve mekanik ventilatör uyumunu artırmak için tercih edilir. Protokol: Genellikle yükleme dozu (bradikardi ve hipotansiyon riskini en aza indirmek için sıklıkla atlanır veya 0.5-1 mcg/kg, 10-20 dakikada yavaşça verilir) ardından 0.2-0.7 mcg/kg/saat hızında idame infüzyonudur. Bradikardi ve hipotansiyon izlemi esastır.",
      "immediateRedFlags": [
        "Ciddi bradikardi (kalp hızının < 40/dk altına düşmesi) ve buna eşlik eden sistemik hipotansiyon.",
        "İnfüzyonun hızlı yüklenmesi sonucu gelişen geçici paradoksal sistemik hipertansiyon atakları."
      ],
      "missingCriticalInformation": [
        "Hastanın bazal kalp hızı, EKG ritmi (örn. kalp bloğu varlığı) ve aktif hemodinamik verileri",
        "Hastanın karaciğer fonksiyon testleri (deksmedetomidin karaciğerde metabolize edilir)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Deksmedetomidin Sedasyon Protokolleri",
        "Alfa-2 Agonist Klinik Yönetimi",
        "Solunumu Korumalı Sedasyon"
      ],
      "suggestedNextStepsGeneral": [
        "Sempatik deşarjı baskılayan bu ajanı kullanırken bazal kalp hızının > 55/dk olduğundan emin olun.",
        "Bradikardi ve hipotansiyon riskini azaltmak için yükleme (bolus) dozunu atlayıp doğrudan idame infüzyonla başlayın.",
        "İdame infüzyon hızını 0.2-0.7 mcg/kg/saat arasında titre edin; karaciğer yetmezliğinde dozu azaltın.",
        "Uyanma deliryumunu önlemek için infüzyonu cerrahi bitiminden 20-30 dakika önce veya PACU'da sonlandırın."
      ],
      "relatedAlgorithms": [
        {
          "id": "bradycardia",
          "titleTr": "Bradikardi Algoritması"
        },
        {
          "id": "postoperative_delirium",
          "titleTr": "Deliryum Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "Deksmedetomidin sedasyonunun en büyük avantajının hastanın kolayca uyandırılabilir olması (kooperatif sedasyon) ve solunumsal dürtüyü baskılamaması olduğunu"
      ],
      "whenToEscalate": [
        "Derin bradikardi (< 40/dk), hemodinamik instabilite veya 2. veya 3. derece AV blok gelişmesi durumunda infüzyonu derhal kapatın ve atropin (0.5 mg IV) uygulayın"
      ],
      "referencesToShow": [
        "Anesthesiology: Clinical Uses of Dexmedetomidine. 2020.",
        "Marino's The ICU Book, 4th Edition."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Dexmedetomidine is a highly selective alpha-2 adrenergic receptor agonist. It provides sedation, analgesia, and anxiolysis without causing respiratory depression. It is preferred in the perioperative period to prevent emergence delirium, reduce opioid consumption, and improve mechanical ventilator compliance. Protocol: The loading dose (often omitted or given slowly as 0.5-1 mcg/kg over 10-20 minutes to minimize bradycardia and hypotension) is followed by a maintenance infusion of 0.2-0.7 mcg/kg/h. Monitoring for bradycardia and hypotension is essential.",
      "immediateRedFlags": [
        "Severe bradycardia (heart rate < 40 bpm) accompanied by systemic hypotension.",
        "Transient paradoxical systemic hypertension caused by rapid loading dose administration."
      ],
      "missingCriticalInformation": [
        "The patient's baseline heart rate, EKG rhythm (e.g., presence of heart block), and active hemodynamic status",
        "Baseline hepatic function tests (dexmedetomidine is metabolized by the liver)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Dexmedetomidine Sedation Protocols",
        "Alpha-2 Agonist Clinical Management",
        "Respiratory-Preserved Sedation"
      ],
      "suggestedNextStepsGeneral": [
        "Ensure the baseline heart rate is > 55 bpm when utilizing this sympatholytic agent.",
        "Skip the loading (bolus) dose and start directly with a maintenance infusion to reduce the risk of bradycardia and hypotension.",
        "Titrate the maintenance infusion rate between 0.2 and 0.7 mcg/kg/h; reduce the dose in hepatic impairment.",
        "To prevent emergence delirium, discontinue the infusion 20-30 minutes before the end of surgery or in the PACU."
      ],
      "relatedAlgorithms": [
        {
          "id": "bradycardia",
          "titleTr": "Bradycardia Algorithm"
        },
        {
          "id": "postoperative_delirium",
          "titleTr": "Delirium Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "The key benefit of dexmedetomidine is that the patient remains easily arousable (cooperative sedation) without respiratory drive depression"
      ],
      "whenToEscalate": [
        "At any sign of severe bradycardia (< 40 bpm), hemodynamic instability, or development of second- or third-degree AV block, immediately stop the infusion and administer atropine (0.5 mg IV)"
      ],
      "referencesToShow": [
        "Anesthesiology: Clinical Uses of Dexmedetomidine. 2020.",
        "Marino's The ICU Book, 4th Edition."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "medication_dose_error",
    "category": "clinical_scenarios",
    "keywords": [
      "dose",
      "error",
      "hatası",
      "medication",
      "wrong",
      "yanlış"
    ],
    "question_tr": "Ilaç doz hatası",
    "question_en": "Wrong dose",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "İlaç doz hatasında öncelik hastanın güvenliğidir. İlk olarak ilacı hemen durdurun, verilen ilacı, dozu, zamanı ve veriliş yolunu doğrulayın. Hastanın ABC'sini, hemodinamisini (KB, KH), EKG'sini, SpO2, ETCO2 ve bilinç/sedasyon düzeyini hızla değerlendirin. Spesifik bir antidot (örn. opioid için nalokson, benzodiazepin için flumazenil, heparin için protamin, lokal anestezik toksisitesi için lipid emülsiyon) bulunup bulunmadığını kontrol edin. Yardım çağırın ve gerekirse toksikoloji veya yoğun bakım desteği alın. Hastayı ilacın beklenen etki süresinden daha uzun süre izleyin. Olayı açık ve dürüst şekilde dokümante edip kurum ilaç güvenliği bildirimini gerçekleştirin.",
      "immediateRedFlags": [
        "Akut solunum depresyonu, hipoksemi veya solunum arresti gelişimi.",
        "Ağır hipotansiyon, bradikardi, aritmi veya ani kardiyak arrest.",
        "Bilinç kaybı, derin sedasyon veya nöbet aktivitesi."
      ],
      "missingCriticalInformation": [
        "Yanlışlıkla verilen ilacın net adı, konsantrasyonu, toplam dozu ve veriliş saati",
        "Hastanın güncel kardiyovasküler, solunumsal ve nörolojik bulguları"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İlaç Doz Hataları Yönetimi",
        "Anestezide İlaç Güvenliği",
        "Hasta Güvenliği ve Kriz Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Hatalı ilaç infüzyonunu veya uygulamasını derhal sonlandırın.",
        "Hastanın havayolunu, solunumunu ve hemodinamik parametrelerini yakın takibe alın.",
        "İlacın türüne göre spesifik bir antidot endikasyonu ve dozu olup olmadığını kontrol edin.",
        "Olayı anestezi kaydına tam olarak işleyin ve ilgili idari güvenlik bildirimlerini yapın."
      ],
      "relatedAlgorithms": [
        {
          "id": "last",
          "titleTr": "LAST Toksisite Algoritması"
        },
        {
          "id": "sepsis",
          "titleTr": "Sepsis & Şok Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "Doz hatası sonrasında hastanın güvenliğini sağladıktan sonra durumu dürüstçe dokümante etmenin ve takım içi açık iletişimin önemini"
      ],
      "whenToEscalate": [
        "Geri dönüşümsüz derin sedasyon, dirençli solunum veya dolaşım depresyonu gelişirse acil ileri havayolu desteği başlatın ve yoğun bakım konsültasyonu isteyin"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "ASA Statement on Patient Safety in Anesthesia. 2023."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Patient safety is the priority during a medication dose error. Stop the drug immediately, verify the drug, dose, timing, and route. Assess ABCs, hemodynamics (BP, HR), ECG, SpO2, ETCO2, and consciousness/sedation level. Check for specific antidotes: naloxone for opioids, flumazenil for benzodiazepines, protamine for heparin, lipid emulsion for local anesthetic toxicity. Call for help and involve toxicology/ICU when needed. Monitor the patient longer than the expected drug duration. Document clearly and report through the institutional medication safety system.",
      "immediateRedFlags": [
        "Acute respiratory depression, hypoxemia, or respiratory arrest.",
        "Severe hypotension, bradycardia, arrhythmia, or sudden cardiac arrest.",
        "Loss of consciousness, profound sedation, or seizure activity."
      ],
      "missingCriticalInformation": [
        "The exact drug name, concentration, total dose, and timing of the erroneous administration",
        "The patient's current hemodynamic, respiratory, and neurological baseline"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Medication Error Management",
        "Medication Safety in Anesthesia",
        "Crisis Resource Management"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately discontinue the incorrect drug infusion or administration.",
        "Closely monitor the patient's airway, breathing, and hemodynamic parameters.",
        "Determine if a specific antidote is indicated and calculate the correct dosage.",
        "Document the event thoroughly in the anesthetic record and complete safety reports."
      ],
      "relatedAlgorithms": [
        {
          "id": "last",
          "titleTr": "LAST Toxicity Algorithm"
        },
        {
          "id": "sepsis",
          "titleTr": "Sepsis & Shock Management"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Patient safety must be stabilized first, followed by transparent documentation and non-punitive open safety reporting"
      ],
      "whenToEscalate": [
        "At any sign of irreversible deep sedation, refractory respiratory depression, or cardiovascular instability, secure the airway and transfer to the ICU"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "ASA Statement on Patient Safety in Anesthesia. 2023."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "wrong_drug_administration",
    "category": "clinical_scenarios",
    "keywords": [
      "administration",
      "drug",
      "error",
      "karıştı",
      "wrong",
      "yanlış"
    ],
    "question_tr": "Yanlış ilaç",
    "question_en": "Drug error",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Yanlış ilaç uygulamasında ilaç etkisi henüz başlamamış olsa bile hızlı ve proaktif bir yaklaşım gerekir. İlacın adını, konsantrasyonunu, veriliş yolunu ve tam miktarını doğrulayın. İlacın beklenen farmakolojik ve toksik etkilerini öngörün: ağır hipotansiyon, hipertansiyon, aritmi, solunum depresyonu, nöbet, kas paralizisi, hipoglisemi veya ciddi alerjik reaksiyonlar. Monitörizasyonu sıklaştırın (EKG, kan basıncı, solunum). Gerekirse uygun destek tedavilerini ve spesifik antidotları derhal başlatın. Cerrahi ekibi bilgilendirin. Hasta ve kurum güvenliği açısından olay kaydı, açık iletişim ve kök neden analizi gerçekleştirilmelidir.",
      "immediateRedFlags": [
        "Uyumsuz ilaç verilmesi sonrası gelişen ani anafilaktik şok ve havayolu ödemi.",
        "Yanlışlıkla kas gevşetici verilmesine bağlı uyanık hastada gelişen ani solunum felci ve panik.",
        "Kardiyotoksik ilaçların yanlışlıkla verilmesine bağlı refrakter aritmiler."
      ],
      "missingCriticalInformation": [
        "Hatalı verilen ilacın net etki mekanizması ve yarı ömrü",
        "Hastanın bilinen ilaç alerjileri ve eş zamanlı aldığı diğer tedaviler"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Yanlış İlaç Uygulaması Yönetimi",
        "İlaç Güvenliği ve Hata Önleme",
        "Klinik Kriz Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Yanlış ilacın verilme hızını ve miktarını belirlemek için ampulü/etiketi kontrol edin.",
        "Beklenen toksik etkileri engellemek veya hafifletmek için önceden hazırlık yapın.",
        "Gerekli havayolu ekipmanını ve acil resüsitasyon ilaçlarını hazır bulundurun.",
        "Olayı gizlemeden, tüm süreçleri şeffaf şekilde anestezi dosyasına kaydedin."
      ],
      "relatedAlgorithms": [
