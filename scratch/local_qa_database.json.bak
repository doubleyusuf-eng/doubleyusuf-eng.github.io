        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        },
        {
          "id": "neostigmine",
          "titleTr": "Neostigmin Monografı"
        }
      ],
      "doNotMiss": [
        "Opioid etkisini geri döndürürken naloksonun çok hızlı ve yüksek doz verilmesinin ağır akut akciğer ödemine ve şiddetli ağrı krizine yol açabileceğini"
      ],
      "whenToEscalate": [
        "Hastada karbondioksit narkozu (letarji), SpO2 desatürasyonu ve pH < 7.20 varsa, non-invaziv desteğe vakit harcamadan hastayı acilen entübe edin"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Postoperative Respiratory Depression Management Review."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Postoperative hypercapnia indicates inadequate alveolar ventilation. Causes include opioid/sedative effect, residual neuromuscular blockade, COPD/obesity hypoventilation, shallow breathing due to pain, atelectasis, airway obstruction, inadequate ventilator settings, or metabolic load. Assess consciousness, respiratory rate/depth, SpO₂, ETCO₂/ABG, TOF, pain, and medications. Titrate naloxone for opioid effect; use appropriate reversal for residual blockade. NIV may help selected patients; severe altered consciousness or aspiration risk requires intubation.",
      "immediateRedFlags": [
        "Altered mental status, progressive lethargy, or coma secondary to CO2 narcosis.",
        "Arterial blood gas showing PaCO2 > 65-70 mmHg and pH < 7.20.",
        "Profound respiratory depression with respiratory rate < 8 bpm."
      ],
      "missingCriticalInformation": [
        "Quantitative TOF ratio (to rule out residual blockade)",
        "The patient's pain score (severe pain causes splinting and shallow breathing)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postoperative Hypercapnia",
        "Alveolar Hypoventilation",
        "Carbon Dioxide Narcosis"
      ],
      "suggestedNextStepsGeneral": [
        "Evaluate respiratory rate, depth, and the patient's level of consciousness immediately.",
        "Obtain an arterial blood gas (ABG) to determine precise pH and PaCO2 levels.",
        "Perform a quantitative TOF check and reverse residual block with Sugammadex if needed.",
        "For opioid-induced depression, titrate IV naloxone in small increments (0.04-0.1 mg)."
      ],
      "relatedAlgorithms": [
        {
          "id": "postoperative_hypercapnia",
          "titleTr": "Postoperative Hypercapnia"
        },
        {
          "id": "residual_block",
          "titleTr": "Residual Block"
        },
        {
          "id": "opioid_respiratory",
          "titleTr": "Opioid Respiratory Depression"
        }
      ],
      "relatedCalculators": [
        {
          "id": "abg_interpretation",
          "titleTr": "ABG Interpretation"
        },
        {
          "id": "tof_calculator",
          "titleTr": "TOF Calculator"
        },
        {
          "id": "naloxone_dose_calculator",
          "titleTr": "Naloxone Dose"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "naloxone",
          "titleTr": "Naloxone"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        },
        {
          "id": "neostigmine",
          "titleTr": "Neostigmine Monograph"
        }
      ],
      "doNotMiss": [
        "Rapid, aggressive naloxone boluses can precipitate acute pulmonary edema, severe hypertension, and excruciating pain; titrate carefully"
      ],
      "whenToEscalate": [
        "If the patient presents with CO2 narcosis, inability to protect the airway, and severe acidosis (pH < 7.20), proceed with immediate reintubation"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Postoperative Respiratory Depression Management Review."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "patient_ventilator_asynchrony",
    "category": "clinical_scenarios",
    "keywords": [
      "asenkroni",
      "asynchrony",
      "patient",
      "uyumsuzluğu",
      "ventilator",
      "ventilatör"
    ],
    "question_tr": "Hasta ventilatör uyumsuzluğu",
    "question_en": "Asenkroni",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Hasta-ventilatör uyumsuzluğunda önce neden aranmalıdır. 1. Ağrı, anksiyete, yetersiz sedasyon veya deliryum var mı? 2. Tüp tıkanıklığı, sekresyon, bronkospazm veya devre sorunu var mı? 3. Akım yetersizliği, trigger hassasiyeti, auto-PEEP, uygunsuz inspirasyon süresi veya tidal volüm ayarı var mı? 4. Hipoksemi, hiperkapni, asidoz ve ateş değerlendir. 5. Nedene yönelik ventilatör ayarı, analjezi/sedasyon, bronkodilatör veya suction uygulanır. 6. Sadece sedasyonu artırmak sorunu maskeleyebilir; dalga formu ve klinik birlikte değerlendirilmelidir.",
      "immediateRedFlags": [
        "Hastanın ventilatörle tamamen savaşması (bucking) ve peak basınçların > 40 cmH2O değerini aşması.",
        "Uyumsuzluk esnasında SpO2'nin <%90'ın altına düşmesi ve ciddi taşikardi gelişimi.",
        "Tüpün bükülmesi veya tıkanmasına bağlı hiç hacim verilememesi."
      ],
      "missingCriticalInformation": [
        "Uyumsuzluğun tetiklendiği an (örn. hasta nefes almaya çalışırken akım mı yetersiz kalıyor yoksa ekspirasyon fazı mı engelleniyor)",
        "Hastanın güncel sedasyon derinliği skoru"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Hasta-Ventilatör Uyumsuzluğu (Asenkroni)",
        "Ventilatör Ayarları Optimizasyonu",
        "Hasta Güvenliği"
      ],
      "suggestedNextStepsGeneral": [
        "Pressure-time ve flow-time grafiklerini inceleyerek asenkroni türünü (örn. çift tetikleme, yetersiz akım, autotriggering) belirleyin.",
        "Tüpü aspire edin ve sekresyonları temizleyin; hastanın tüpü ısırmasını engelleyin.",
        "Ventilatörün akım hızını (flow rate) artırın veya tetikleme duyarlılığını optimize edin.",
        "Uyumsuzluğun nedeni ağrı ise analjeziyi (örn. fentanyl) artırın."
      ],
      "relatedAlgorithms": [
        {
          "id": "waveform_analysis",
          "titleTr": "Dalga Formu Analizi"
        },
        {
          "id": "high_pressure",
          "titleTr": "Yüksek Havayolu Basıncı"
        }
      ],
      "relatedCalculators": [
        {
          "id": "abg_interpretation",
          "titleTr": "Kan Gazı"
        },
        {
          "id": "auto_peep_calculator",
          "titleTr": "Auto-PEEP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "analgesics",
          "titleTr": "Analjezikler"
        },
        {
          "id": "sedatives",
          "titleTr": "Sedatifler"
        },
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol"
        }
      ],
      "doNotMiss": [
        "Hastanın solunum çabasına cihazın yetersiz akımla yanıt vermesinin (flow starvation) ağır ajitasyona ve asenkroniye yol açacağını, ilk adımın sedasyon değil akım ayarı olduğunu"
      ],
      "whenToEscalate": [
        "Asenkroni düzeltilemez, hemodinami bozulur ve ağır hipoksemi gelişirse, hastayı ventilatörden ayırıp self-inflating bag ile manuel ventile edin ve anesteziyi derinleştirin"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Patient-Ventilator Asynchrony Clinical Review. CHEST 2018."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "First identify the cause. Check pain, anxiety, inadequate sedation, or delirium. Look for tube obstruction, secretions, bronchospasm, or circuit problems. Assess inadequate flow, trigger sensitivity, auto-PEEP, inappropriate inspiratory time, or tidal volume settings. Evaluate hypoxemia, hypercapnia, acidosis, and fever. Treat the cause with ventilator adjustment, analgesia/sedation, bronchodilator, or suction. Simply increasing sedation may mask the problem; interpret waveforms and clinical findings together.",
      "immediateRedFlags": [
        "Patient actively fighting the ventilator ('bucking') with peak pressures > 40 cmH2O.",
        "Deteriorating oxygen saturation (SpO2 < 90%) and severe tachycardia.",
        "ETT kink or obstruction resulting in zero volume delivery."
      ],
      "missingCriticalInformation": [
        "The exact timing of dyssynchrony (e.g., flow starvation during trigger phase vs. expiratory mismatch)",
        "The patient's current sedation depth score"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Patient-Ventilator Dyssynchrony (Asynchrony)",
        "Ventilator Setting Optimization",
        "Patient Safety"
      ],
      "suggestedNextStepsGeneral": [
        "Examine pressure-time and flow-time waveforms to identify the type of dyssynchrony (e.g., double triggering, flow starvation, autotriggering).",
        "Suction the ETT, clear secretions, and ensure a bite block is in place.",
        "Increase the inspiratory flow rate or optimize trigger sensitivity.",
        "If dyssynchrony is pain-related, administer titrated intravenous analgesics."
      ],
      "relatedAlgorithms": [
        {
          "id": "waveform_analysis",
          "titleTr": "Waveform Analysis"
        },
        {
          "id": "high_pressure",
          "titleTr": "High Airway Pressure"
        }
      ],
      "relatedCalculators": [
        {
          "id": "abg_interpretation",
          "titleTr": "ABG Interpretation"
        },
        {
          "id": "auto_peep_calculator",
          "titleTr": "Auto-PEEP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "analgesics",
          "titleTr": "Analgesics"
        },
        {
          "id": "sedatives",
          "titleTr": "Sedatives"
        },
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol"
        }
      ],
      "doNotMiss": [
        "Flow starvation (ventilator flow not meeting patient demand) causes severe agitation; increasing flow, rather than sedating, is the correct solution"
      ],
      "whenToEscalate": [
        "If dyssynchrony is refractory, resulting in critical hypoxemia and hemodynamic instability, disconnect from the ventilator, manually ventilate, and deepen sedation/paralysis"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Patient-Ventilator Asynchrony Clinical Review. CHEST 2018."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "ventilator_alarm_failure",
    "category": "clinical_scenarios",
    "keywords": [
      "alarm",
      "alarmı",
      "failure",
      "kaybı",
      "loss",
      "manual",
      "manuel",
      "ventilasyon",
      "ventilation",
      "ventilator",
      "ventilatör"
    ],
    "question_tr": "Ventilatör alarmı",
    "question_en": "Loss of ventilation",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Ani ventilasyon kaybında hızlı ve basit yaklaşım hayat kurtarır. 1. Hastayı ventilatörden ayır ve self-inflating bag ile %100 oksijenle manuel ventile et. 2. Göğüs hareketi ve kompliyansı değerlendir. 3. Tüp/devre ayrılması, kink, tıkaç, cuff kaçağı, yanlış bağlantı, bronkospazm veya pnömotoraksı düşün. 4. Kapnografi ve SpO₂’yi takip et. 5. Manuel ventilasyon kolay ise ventilatör/devre sorunu olasıdır. 6. Manuel ventilasyon juga zor ise hasta/tüp/akciğer sorunu olasıdır. 7. Yardım çağır ve zor havayolu/hipoksemi algoritmasına geç.",
      "immediateRedFlags": [
        "Ventilatörün tamamen susması, elektrik kesintisi veya gaz kaynağı kaybı alarmı vermesi.",
        "Ventilatör ayrıldıktan sonra bile hastanın manuel torba ile hiç ventile edilememesi (CICO veya Tam Tüp Tıkanıklığı).",
        "Akut desatürasyon, bradikardi ve kardiyak arrest gelişimi."
      ],
      "missingCriticalInformation": [
        "Odanın yedek gaz kaynaklarının ve yedek elektrik prizlerinin çalışıp çalışmadığı",
        "Hastanın göğsünün manuel solutma sırasında kalkıp kalkmadığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Ventilatör Alarmı ve Arızası",
        "Ani Ventilasyon Kaybı Yönetimi",
        "Acil Durum Manuel Havayolu"
      ],
      "suggestedNextStepsGeneral": [
        "Hiç vakit kaybetmeden hastayı ventilatör devresinden ayırın.",
        "Self-inflating ambu (balon) yardımıyla %100 oksijen vererek hastayı manuel solutun.",
        "Göğsün kalkışını gözleyin ve manuel torbadaki direnci (akciğer kompliyansını) hissedin.",
        "Manuel ventilasyon normalse, anestezi cihazında veya devrede arıza arayın (cihazı değiştirin)."
      ],
      "relatedAlgorithms": [
        {
          "id": "equipment_failure",
          "titleTr": "Cihaz Arızası"
        },
        {
          "id": "hypoxemia",
          "titleTr": "Hipoksemi Algoritması"
        },
        {
          "id": "high_pressure",
          "titleTr": "Yüksek Havayolu Basıncı"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "oxygen",
          "titleTr": "Oksijen"
        },
        {
          "id": "salbutamol_if_bronchospasm",
          "titleTr": "Salbutamol"
        }
      ],
      "doNotMiss": [
        "Ventilatör arızalandığında sorun gidermekle saniyeler kaybetmek yerine ilk yapılacak işin hastayı devreden ayırıp manuel olarak ambulamak olduğunu"
      ],
      "whenToEscalate": [
        "Manuel ventilasyon da imkansızsa ve SpO2 hızla düşüyorsa, havayolunda tam tıkanıklık veya pnömotoraks düşünün, acil reentübasyon veya interkostal dekompresyon yapın"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "ASA Practice Advisory for Airway Management. 2022."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "In sudden ventilation failure, a rapid simple approach is lifesaving. Disconnect from the ventilator and manually ventilate with a self-inflating bag and 100% oxygen. Assess chest movement and compliance. Consider tube/circuit disconnection, kink, plug, cuff leak, wrong connection, bronchospasm, or pneumothorax. Follow capnography and SpO₂. If manual ventilation is easy, ventilator/circuit problem is likely. If manual ventilation is also difficult, patient/tube/lung problem is likely. Call for help and activate hypoxemia/difficult airway algorithms.",
      "immediateRedFlags": [
        "Total ventilator black-out, power failure, or loss of central oxygen supply alarm.",
        "Inability to ventilate manually even with a self-inflating bag after disconnection (CICO or complete ETT plug).",
        "Acute oxygen desaturation, progressive bradycardia, and cardiac arrest."
      ],
      "missingCriticalInformation": [
        "Functionality of backup oxygen cylinders and emergency power outlets (red outlets)",
        "Presence of chest rise during manual ventilation efforts"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Ventilator Alarm and Failure",
        "Sudden Loss of Ventilation",
        "Emergency Manual Ventilation"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately disconnect the patient from the ventilator breathing circuit.",
        "Manually ventilate with 100% oxygen using a self-inflating bag (Ambu).",
        "Observe chest rise and feel the compliance/resistance in the bag.",
        "If manual ventilation is easy, search for a leak, disconnection, or ventilator failure in the machine."
      ],
      "relatedAlgorithms": [
        {
          "id": "equipment_failure",
          "titleTr": "Equipment Failure"
        },
        {
          "id": "hypoxemia",
          "titleTr": "Hypoxemia Algorithm"
        },
        {
          "id": "high_pressure",
          "titleTr": "High Airway Pressure"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "oxygen",
          "titleTr": "Oxygen"
        },
        {
          "id": "salbutamol_if_bronchospasm",
          "titleTr": "Salbutamol"
        }
      ],
      "doNotMiss": [
        "When a ventilator fails, do not waste time troubleshooting the machine; disconnect the patient immediately and manually ventilate"
      ],
      "whenToEscalate": [
        "If manual ventilation is also impossible and SpO2 falls rapidly, assume complete ETT obstruction or tension pneumothorax; perform ETT exchange or needle decompression immediately"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "ASA Practice Advisory for Airway Management. 2022."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "post_extubation_hfnc_niv",
    "category": "clinical_scenarios",
    "keywords": [
      "cpap",
      "ekstübasyon",
      "extubation",
      "hfnc",
      "niv",
      "post",
      "sonrası"
    ],
    "question_tr": "Ekstübasyon sonrası hfnc",
    "question_en": "Post extubation cpap",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Seçim hastanın temel problemine bağlıdır. HFNC; oksijenasyon desteği, konfor, hafif-orta hipoksemi ve yüksek riskli ekstübasyon sonrası iyi seçenek olabilir. NIV/CPAP; KOAH/obezite hipoventilasyon, hiperkapni, kardiyojenik pulmoner ödem veya belirgin alveoler ventilasyon desteği gereken hastada daha uygun olabilir. Kontrendikasyonlar: bilinç bozukluğu, aktif kusma/aspirasyon riski, sekresyonu temizleyememe, ciddi şok, yüz travması veya acil entübasyon ihtiyacı. Kötüleşen hastada noninvaziv destek reentübasyonu geciktirilmelidir.",
      "immediateRedFlags": [
        "Cihaz desteğine rağmen solunum işinin giderek artması, yorgunluk ve SpO2 desatürasyonu.",
        "Hastada bulantı, aktif kusma gelişmesi ve mide içeriğinin akciğere kaçması (Aspirasyon).",
        "Karbondioksit birikimine bağlı bilincin giderek gerilemesi (letarji)."
      ],
      "missingCriticalInformation": [
        "Hastanın bazal akciğer ve kalp yetmezliği öyküsü",
        "Arter kan gazındaki güncel karbondioksit (PaCO2) ve pH düzeyi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Ekstübasyon Sonrası Non-invaziv Destek",
        "HFNC ve NIV Seçimi",
        "Postoperatif Solunum Yetmezliği Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "KOAH veya obezite hipoventilasyon öyküsü olan, karbondioksiti yüksek hastalarda öncelikle NIV/CPAP (maske) tercih edin.",
        "Hipoksemik solunum yetmezliği olan veya maskeyi tolere edemeyen hastalarda HFNC (yüksek akışlı burun kanülü) uygulayın.",
        "Non-invaziv destek altındaki hastanın solunum sayısını ve SpO2 değerini anlık izleyin.",
        "Hastada kusma veya bilinç bulanıklığı geliştiğinde cihazı hemen durdurun."
      ],
      "relatedAlgorithms": [
        {
          "id": "post_extubation_support",
          "titleTr": "Ekstübasyon Sonrası Destek"
        },
        {
          "id": "niv_management",
          "titleTr": "NIV Yönetimi"
        },
        {
          "id": "hfnc_management",
          "titleTr": "HFNC Yönetimi"
        }
      ],
      "relatedCalculators": [
        {
          "id": "abg_interpretation",
          "titleTr": "Kan Gazı"
        },
        {
          "id": "pf_ratio_calculator",
          "titleTr": "P/F Oranı"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Kötüleşen, yorulan veya letarjisi artan bir solunum yetmezliği hastasında NIV veya HFNC ile ısrar etmenin reentübasyonu geciktirerek mortaliteyi artıracağını"
      ],
      "whenToEscalate": [
        "Cihaz desteğine rağmen solunum sayısı > 35/dk ise, pH < 7.25 düzeyine inmişse veya solunum arresti gelişirse, gecikmeden acil reentübasyon planlayın"
      ],
      "referencesToShow": [
        "ATS/CHEST Guidelines on Noninvasive Ventilation. 2017.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Choice depends on the primary problem. HFNC is useful for oxygenation support, comfort, mild-to-moderate hypoxemia, and high-risk extubation. NIV/CPAP may be better for COPD/obesity hypoventilation, hypercapnia, cardiogenic pulmonary edema, or need for more ventilatory support. Contraindications include altered consciousness, active vomiting/aspiration risk, inability to clear secretions, severe shock, facial trauma, or need for immediate intubation. Noninvasive support must not delay reintubation in a deteriorating patient.",
      "immediateRedFlags": [
        "Worsening work of breathing, tachypnea, and desaturation despite high-level support.",
        "Nausea or active vomiting under mask/HFNC, risking massive pulmonary aspiration.",
        "Progressive obtundation or lethargy indicating CO2 narcosis."
      ],
      "missingCriticalInformation": [
        "The patient's history of chronic lung disease or congestive heart failure",
        "The current arterial blood gas (ABG) values showing PaCO2 and pH trend"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Post-Extubation Non-Invasive Support",
        "HFNC and NIV Selection",
        "Postoperative Respiratory Failure Management"
      ],
      "suggestedNextStepsGeneral": [
        "Select NIV/CPAP as the primary choice for hypercapnic patients with a history of COPD or obesity hypoventilation.",
        "Apply HFNC (High-Flow Nasal Cannula) for hypoxemic respiratory failure or patients unable to tolerate tight masks.",
        "Monitor the respiratory rate and oxygen saturation continuously under non-invasive support.",
        "Immediately discontinue non-invasive support if the patient vomits or becomes obtunded."
      ],
      "relatedAlgorithms": [
        {
          "id": "post_extubation_support",
          "titleTr": "Post-extubation Support"
        },
        {
          "id": "niv_management",
          "titleTr": "NIV Management"
        },
        {
          "id": "hfnc_management",
          "titleTr": "HFNC Management"
        }
      ],
      "relatedCalculators": [
        {
          "id": "abg_interpretation",
          "titleTr": "ABG Interpretation"
        },
        {
          "id": "pf_ratio_calculator",
          "titleTr": "P/F Ratio"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Delaying necessary reintubation by stubbornly persisting with non-invasive therapies in a deteriorating patient increases mortality"
      ],
      "whenToEscalate": [
        "If the patient remains severely tachypneic (RR > 35), has progressive acidosis (pH < 7.25), or develops respiratory arrest, immediately secure the airway by reintubation"
      ],
      "referencesToShow": [
        "ATS/CHEST Guidelines on Noninvasive Ventilation. 2017.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    }
  },
