  {
    "id": "clinical_followup_last_protocol_alternatives_0",
    "category": "clinical_followups",
    "keywords": [
      "alternatives",
      "anesthetic",
      "bupivakain",
      "clinical_followup_last_protocol_alternatives_0",
      "followup",
      "last",
      "local",
      "toksisite",
      "toxic",
      "var0"
    ],
    "question_tr": "Lipid tedavisinin alternatif kurtarma adımları nelerdir?",
    "question_en": "What are the alternative rescue steps for last?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🔄 Lipid tedavisi ve standart CPR başarısız olursa, kardiyopulmoner baypas (ECMO - Ekstrakorporal Membran Oksijenasyonu) derhal devreye sokulmalıdır. Toksin vücuttan elimine edilene kadar kardiyak destek sürdürülür. Propofol bir lipid taşıyıcısı olsa da, ciddi kardiyak depresyon yapacağı için lipid kurtarmada alternatif olamaz.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🔄 If lipid rescue and high-quality CPR fail, initiation of cardiopulmonary bypass (ECMO) should be arranged immediately. ECMO maintains perfusion until the anesthetic toxin is metabolized. Note: Propofol, though formulated in lipid, is NOT an alternative due to severe myocardial depressant effects.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    }
  },
