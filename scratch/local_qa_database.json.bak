          "titleTr": "Epinephrine"
        }
      ],
      "doNotMiss": [
        "Unexpected or progressive leg weakness in a patient with an epidural is a medical emergency and requires ruling out epidural hematoma immediately"
      ],
      "whenToEscalate": [
        "In case of progressive motor deficit, loss of bowel/bladder control, or severe back pain, order an emergency spine MRI and consult neurosurgery immediately"
      ],
      "referencesToShow": [
