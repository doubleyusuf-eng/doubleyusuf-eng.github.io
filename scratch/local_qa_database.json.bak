  {
    "id": "eras_opioid_sparing_analgesia",
    "category": "clinical_scenarios",
    "keywords": [
      "analgesia",
      "analjezi",
      "azaltıcı",
      "eras",
      "opioid",
      "sparing"
    ],
    "question_tr": "Eras analjezi",
    "question_en": "Opioid sparing",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "ERAS analjezi yönetiminde temel hedef; solunumsal baskılanmayı, bulantı-kusmayı, ileus süresini ve kognitif yan etkileri en aza indirirken, hastanın erken mobilize olmasını ve derin nefes alabilmesini sağlayacak düzeyde ağrı kontrolüdür. Bu amaca ulaşmak için 'multimodal opioid azaltıcı' (opioid-sparing) analjezi rejimleri uygulanır. Temel analjezi rejimi: düzenli parasetamol ve kontrendikasyonu olmayan hastalarda NSAİİ veya seçici COX-2 inhibitörleridir. Bunlara ek olarak cerrahiye uygun bölgesel bloklar (örn. TAP blok, rektus kılıfı bloğu, epidural anestezi veya lokal yara infiltrasyonu) mutlaka plana dahil edilmelidir. Seçilmiş hastalarda intraoperatif düşük doz ketamin, deksmedetomidin veya IV lidokain infüzyonları multimodal rejimin adjuvanları olarak düşünülebilir. Opioidler tamamen yasak değildir; sadece şiddetli veya kurtarıcı ağrılarda (breakthrough pain) minimum dozlarda tercih edilmelidir.",
      "immediateRedFlags": [
        "Yüksek doz opioid alımına bağlı gelişen solunum depresyonu (solunum sayısı < 8-10/dk) ve SpO2 düşüşü.",
        "Aşırı sedasyon (hastanın uyandırılamaması) ve havayolu obstrüksiyonu bulguları.",
        "Yetersiz analjezi nedeniyle hastanın derin nefes alamaması ve mobilize olamaması."
      ],
      "missingCriticalInformation": [
        "Hastanın bazal karaciğer ve böbrek fonksiyonları (parasetamol ve NSAİİ güvenliği için)",
        "Hastanın obstrüktif uyku apnesi (OSAS) veya KOAH gibi solunumsal ek risk faktörleri"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Multimodal Analjezi ve ERAS",
        "Opioid Azaltıcı Rejimler",
        "Postoperatif Ağrı Kontrolü"
      ],
      "suggestedNextStepsGeneral": [
        "Postoperatif analjezide parasetamol ve uygun hastada NSAİİ'yi saatlik düzenli planlayın.",
        "Cerrahi kesisine ve bölgesel anatomiye uygun bir rejyonal sinir bloğu uygulayın.",
        "Kurtarıcı (rescue) opioidleri sadece hastanın şiddetli ağrısı olduğunda minimal dozda uygulayın.",
        "Yaşlı veya OSAS'lı hastalarda opioid dozlarını belirgin şekilde kısıtlayın ve yakın izleyin."
      ],
      "relatedAlgorithms": [
        {
          "id": "postop_pain_ladder",
          "titleTr": "Postoperatif Ağrı Yönetimi"
        },
        {
          "id": "opioid_respiratory",
          "titleTr": "Opioid Solunum Depresyonu"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "morphine",
          "titleTr": "Morfin Monografı"
        }
      ],
      "doNotMiss": [
        "Opioidlerin barsak motilitesini (ileus) doğrudan baskıladığını ve taburculuğu geciktiren en önemli yan etkilerden biri olduğunu"
      ],
      "whenToEscalate": [
        "Ağır solunum depresyonu veya opioid aşırı dozuna bağlı havayolu kaybı durumunda, havayolunu açın, balona başlayın ve yavaşça nalokson (0.04-0.4 mg IV) uygulayın"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Acute Pain Management. 2021.",
        "ERAS Society Consensus Guidelines on Perioperative Analgesia. 2020."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "The primary objective of analgesia within an ERAS pathway is to provide excellent pain relief to femergencyitate early mobilization and deep breathing, while minimizing opioid-related side effects such as respiratory depression, nausea, vomiting, prolonged ileus, and cognitive dysfunction. To achieve this, a 'multimodal opioid-sparing' regimen is utilized. The cornerstone of the regimen is scheduled non-opioids: paracetamol combined with an NSAID or selective COX-2 inhibitor, unless contraindicated. These are integrated with targeted regional anesthesia (e.g., TAP block, rectus sheath block, epidural, or local wound infiltration). Intraoperative adjuvants such as low-dose ketamine, dexmedetomidine, or IV lidocaine infusions may be considered for selected cases. Opioids are reserved only for moderate-to-severe breakthrough pain at the lowest effective doses.",
      "immediateRedFlags": [
        "Opioid-induced respiratory depression (respiratory rate < 8-10 bpm) and declining SpO2.",
        "Severe sedation (inability to arouse the patient) and signs of upper airway obstruction.",
        "Inadequate pain control preventing the patient from coughing, deep breathing, or mobilizing."
      ],
      "missingCriticalInformation": [
        "The patient's baseline liver and renal function panels (to guide paracetamol and NSAID dosing)",
        "Co-existing respiratory risk factors such as severe OSA or advanced COPD"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Multimodal Analgesia and ERAS",
        "Opioid-Sparing Regimens",
        "Postoperative Pain Control"
      ],
      "suggestedNextStepsGeneral": [
        "Prescribe regular, scheduled paracetamol and NSAIDs postoperatively unless contraindicated.",
        "Perform a targeted regional nerve block or local infiltration tailored to the surgical incision.",
        "Utilize rescue opioids only for severe breakthrough pain and in small, titrated boluses.",
        "Restrict opioid dosages strictly in older, frail, or OSA patients and monitor respiratory status."
      ],
      "relatedAlgorithms": [
        {
          "id": "postop_pain_ladder",
          "titleTr": "Postoperative Pain Management"
        },
        {
          "id": "opioid_respiratory",
          "titleTr": "Opioid Respiratory Depression"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "morphine",
          "titleTr": "Morphine Monograph"
        }
      ],
      "doNotMiss": [
        "Opioids directly inhibit bowel motility; opioid-sparing pathways are crucial to minimize postoperative ileus and femergencyitate early discharge"
      ],
      "whenToEscalate": [
        "In the event of severe respiratory depression or airway obstruction secondary to opioids, secure the airway, assist ventilation, and administer titrated IV naloxone (0.04-0.4 mg)"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Acute Pain Management. 2021.",
        "ERAS Society Consensus Guidelines on Perioperative Analgesia. 2020."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "surgery_postponement_optimization",
    "category": "clinical_scenarios",
    "keywords": [
      "ameliyat",
      "erteleme",
      "optimizasyon",
      "optimization",
      "postponement",
      "surgery"
    ],
    "question_tr": "Erteleme",
    "question_en": "Optimization postponement",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Preoperatif değerlendirmede cerrahiyi erteleme kararı, hastada risk saptandığında otomatik olarak verilmemelidir. Karar verilirken: saptanan riskin kısa sürede optimize edilebilir (düzeltilebilir) olup olmadığı, cerrahi girişimin aciliyet derecesi (acil, öncelikli, elektif) ve ameliyatın ertelenmesinin getireceği ek patolojik risk dengelenmelidir. Elektif cerrahinin ertelenmesi ve medikal optimizasyon planlanması gereken durumlar şunlardır: aktif kardiyak durum varlığı (örn. yeni MI, instabil anjina), uç organ hasarı veya semptomla giden kontrolsüz ciddi hipertansiyon (örn. KB > 180/110 mmHg), dekompanse kalp yetmezliği bulguları, oda havasında SpO2 < %90 ile seyreden ciddi hipoksemi, aktif alt solunum yolu enfeksiyonu (pnömoni, ağır bronşit), kontrolsüz metabolik krizler (DKA/HHS), öglisemik DKA şüphesi, düzeltilemeyen ağır elektrolit bozuklukları (örn. K < 2.5 veya K > 6.0), açıklanamayan ciddi anemi (Hb < 8 g/dL), aktif kontrolsüz sepsis, yeni geçirilmiş nörolojik olaylar (son 3 ayda inme), ağır koagülopati durumları veya hastanın güvenli postoperatif bakım/yoğun bakım planının olmamasıdır. Acil cerrahide ise erteleme mümkün olmadığından, risk azaltma, invaziv monitörizasyon ve yoğun bakım hazırlığı önceliklidir.",
      "immediateRedFlags": [
        "Elektif ameliyat sabahı hastada saptanan solunum yetmezliği, göğüs ağrısı veya şok tablosu.",
        "Diyabetik hastada glukoz > 300 mg/dL ile birlikte derin asidoz ve ketozis varlığı.",
        "Geri dönüşümsüz ağır koagülopati ile birlikte aktif kanama bulguları."
      ],
      "missingCriticalInformation": [
        "Cerrahi girişimin net aciliyet derecesi (elektif vs. acil)",
        "Eşlik eden patolojinin medikal tedaviyle ne kadar sürede optimize edilebileceği"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Cerrahi Erteleme Kararı",
        "Preoperatif Optimizasyon Kriterleri",
        "Perioperatif Risk Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Cerrahiyi ertelemeden önce girişimin elektif olup olmadığını cerrahi ekiple kesinleştirin.",
        "Düzeltilebilir riskleri (anemi, hipertansiyon, glisemik kontrol vb.) saptayıp erteleme süresini planlayın.",
        "Acil cerrahide erteleme yapmayın; invaziv monitörizasyon ve yoğun bakım desteği planlayın.",
        "Risk optimizasyonu için ilgili branşlardan (kardiyoloji, endokrin vb.) hedefe yönelik konsültasyon isteyin."
      ],
      "relatedAlgorithms": [
        {
          "id": "geriatric_anesthesia",
          "titleTr": "Geriyatrik Anestezi"
        },
        {
          "id": "myocardial_ischemia",
          "titleTr": "Miyokard İskemisi Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "Konsültasyonların amacının cerrahiye 'onay almak' değil, hastanın perioperatif risklerini belirleyip bunları optimize etmek olduğunu"
      ],
      "whenToEscalate": [
        "Akut hayati tehlike oluşturan bir patoloji (akut MI, aort rüptürü, ağır sepsis) saptandığında elektif cerrahiyi derhal iptal edin ve hastayı acil resüsitasyon/yoğun bakım alanına sevk edin"
      ],
      "referencesToShow": [
        "ASA physical status classification system guidelines. 2022.",
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "The decision to postpone elective surgery should not be automatic simply because a clinical risk factor exists. The clinician must balance the modifiability of the risk within a short timeframe, the urgency of the surgical procedure (emergency, urgent, time-sensitive, vs. elective), and the progression risk of the primary surgical pathology if delayed. Postponement and active optimization are indicated for: active cardiac conditions (e.g., recent MI, unstable angina), severe uncontrolled hypertension with acute end-organ damage or symptoms (typically BP > 180/110 mmHg), decompensated heart failure, severe hypoxemia (SpO2 < 90% on room air), active lower respiratory tract infection, uncontrolled diabetic crises (DKA/HHS), suspected euglycemic DKA, severe uncorrected electrolyte abnormalities (e.g., K < 2.5 or K > 6.0 mEq/L), unexplained severe anemia (Hb < 8 g/dL), active uncontrolled sepsis, recent stroke within 3 months, severe unreversed coagulopathy, or the lack of a secure postoperative care/ICU plan. In emergency surgery, postponement is impossible; prioritize rapid risk mitigation, invasive monitoring, and ICU preparation.",
      "immediateRedFlags": [
        "The patient presenting with acute respiratory failure, active chest pain, or shock on the morning of elective surgery.",
        "A diabetic patient with glucose > 300 mg/dL accompanied by profound acidosis and ketosis.",
        "Active hemorrhage in a patient with severe, unreversed coagulopathy."
      ],
      "missingCriticalInformation": [
        "The exact urgency and time-sensitivity of the planned surgical procedure",
        "The anticipated duration and feasibility of optimizing the patient's medical condition"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Surgery Postponement Decision",
        "Preoperative Optimization Criteria",
        "Perioperative Risk Management"
      ],
      "suggestedNextStepsGeneral": [
        "Confirm the exact urgency level of the procedure with the surgical team before postponing.",
        "Identify modifiable risks (anemia, blood pressure, glucose) and plan the duration of delay.",
        "Do not postpone emergency surgeries; focus on invasive monitoring and ICU standby.",
        "Obtain targeted consultations from specialists focusing on active optimization rather than generic clearance."
      ],
      "relatedAlgorithms": [
        {
          "id": "geriatric_anesthesia",
          "titleTr": "Geriatric Anesthesia"
        },
        {
          "id": "myocardial_ischemia",
          "titleTr": "Myocardial Ischemia"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "The goal of preoperative specialty consultations is not to obtain 'anesthesia clearance' but to actively risk-stratify and optimize the patient"
      ],
      "whenToEscalate": [
        "For life-threatening acute conditions (e.g., acute STEMI, ruptured aneurysm, severe septic shock), cancel elective cases immediately and transfer the patient to an ICU or emergency department"
      ],
      "referencesToShow": [
        "ASA physical status classification system guidelines. 2022.",
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "preoperative_airway_evaluation",
    "category": "clinical_scenarios",
    "keywords": [
      "airway",
      "assessment",
      "değerlendirme",
      "difficult",
      "evaluation",
      "havayolu",
      "preoperatif",
      "preoperative",
      "zor"
    ],
    "question_tr": "Havayolu değerlendirme",
    "question_en": "Airway assessment",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Havayolu değerlendirmesi tek bir teste değil, risk bulgularının birlikte yorumlanmasına dayanır. 1. Önceki zor maske, zor entübasyon veya CICO öyküsünü sorgula. 2. Ağız açıklığı, Mallampati, thyromental mesafe, mandibula protrüzyonu ve boyun hareketini değerlendir. 3. Diş yapısı, sakal, obezite, OSAS, gebelik, baş-boyun radyoterapisi, tümör, travma, enfeksiyon veya yanık öyküsünü ara. 4. Maske ventilasyonu, supraglottik airway, laringoskopi ve acil cerrahi havayolu zorluğunu ayrı ayrı düşün. 5. Beklenen zor havayolunda plan A/B/C/D ve yardım çağırma eşiği önceden belirlenmelidir. ([PMC])",
      "immediateRedFlags": [
        "Önceki anestezi kaydında 'CICO' (Cannot Intubate Cannot Oxygenate) öyküsü.",
        "Akut havayolu obstrüksiyonu bulguları (stridor, ciddi dispne, retraksiyonlar).",
        "Ciddi retrognati veya trismus (ağız açıklığı < 1.5 cm)."
      ],
      "missingCriticalInformation": [
        "Önceki anestezi kayıtları ve zor havayolu öyküsü details",
        "Hastanın güncel ağız açıklığı ve thyromental mesafe ölçümleri"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Preoperatif Havayolu Değerlendirmesi",
        "Zor Havayolu Algoritmaları",
        "Anestezi Planlaması"
      ],
      "suggestedNextStepsGeneral": [
        "Zor havayolu geçmişini sorgulayın ve eski anestezi kartlarını inceleyin.",
        "Mallampati sınıfı, thyromental mesafe ve mandibula hareketini muayene edin.",
        "Zor havayolu arabası ve videolaringoskobu ameliyathanede hazır bulundurun.",
        "Beklenen zor havayolu durumunda uyanık entübasyon endikasyonunu değerlendirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "airway_checklist",
          "titleTr": "Havayolu Kontrol Listesi"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Tek bir havayolu parametresinin zor havayolunu dışlamada tek başına asla yeterli olmadığını"
      ],
      "whenToEscalate": [
        "Ciddi üst solunum yolu enfeksiyonu, retrofaringeal apsesi veya laringeal kitle şüphesi varsa vakayı erteleyin ve KBB konsültasyonu isteyin"
      ],
      "referencesToShow": [
        "2022 ASA Practice Guidelines for Management of the Difficult Airway.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Airway assessment should not rely on a single test; interpret multiple risk factors together. Ask about previous difficult mask ventilation, difficult intubation, or CICO. Assess mouth opening, Mallampati, thyromental distance, mandibular protrusion, and neck mobility. Look for dentition issues, beard, obesity, OSA, pregnancy, head-neck radiotherapy, tumor, trauma, infection, or burns. Consider difficulty with mask ventilation, supraglottic airway, laryngoscopy, and emergency front-of-neck access separately. In anticipated difficult airway, define plan A/B/C/D and call-for-help thresholds in advance. ([PMC])",
      "immediateRedFlags": [
        "Prior history of CICO (Cannot Intubate Cannot Oxygenate).",
        "Acute airway obstruction signs (stridor, severe dyspnea, retractions).",
        "Severe retrognathia or trismus (mouth opening < 1.5 cm)."
      ],
      "missingCriticalInformation": [
        "Prior anesthesia records and detailed airway history",
        "Patient's precise mouth opening and thyromental distance measurements"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Preoperative Airway Evaluation",
        "Difficult Airway Algorithms",
        "Anesthesia Planning"
      ],
      "suggestedNextStepsGeneral": [
        "Inquire about difficult airway history and check previous anesthesia records.",
        "Examine Mallampati class, thyromental distance, and mandibular protrusion.",
        "Prepare the difficult airway cart and videolaryngoscope in the operating room.",
        "Evaluate the indication for awake intubation in anticipated difficult airways."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway"
        }
      ],
      "relatedCalculators": [
        {
          "id": "airway_checklist",
          "titleTr": "Airway Checklist"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "A single negative airway test does not exclude a difficult airway; multi-factor assessment is mandatory"
      ],
      "whenToEscalate": [
        "If there is active severe upper airway infection, retropharyngeal abscess, or suspected laryngeal mass, delay elective cases and obtain urgent ENT consultation"
      ],
      "referencesToShow": [
        "2022 ASA Practice Guidelines for Management of the Difficult Airway.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "mallampati_limitations",
    "category": "clinical_scenarios",
    "keywords": [
      "bite",
      "dudak",
