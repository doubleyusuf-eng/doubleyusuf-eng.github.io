  {
    "id": "shared_airway_ent",
    "category": "clinical_scenarios",
    "keywords": [
      "airway",
      "boğaz",
      "burun",
      "cerrahisi",
      "ent",
      "havayolu",
      "kulak",
      "lazer",
      "paylaşılan",
      "shared"
    ],
    "question_tr": "Ent cerrahisi",
    "question_en": "Lazer havayolu",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Paylaşılan havayolunda temel riskler tüp yer değiştirmesi, kan/sekresyon aspirasyonu, hava yolu ödemi, lazer/elektrokoter yangını ve acil durumda havayoluna erişim zorluğudur. 1. Cerrahla havayolu planı ve acil durdurma komutu önceden konuşulur. 2. Tüp iyi sabitlenir ve kapnografi sürekli izlenir. 3. Güçlü suction hazır olur. 4. Lazer/koter kullanılacaksa FiO₂ mümkün olan en düşük güvenli düzeyde tutulur, N₂O’dan kaçınılır. 5. Ekstübasyon sonrası kanama, stridor ve laringospazm açısından dikkat edilir.",
      "immediateRedFlags": [
        "Cerrahi manevra sırasında endotrakeal tüpün yerinden çıkması veya kapnografi dalgasının aniden kaybolması.",
        "Havayolunda lazer/koter teması sonrası endotrakeal tüp yangını (kırmızı bayrak!).",
        "Ekstübasyon sonrası cerrahi sahada hızlı hematom gelişimine bağlı solunum tıkanıklığı."
      ],
      "missingCriticalInformation": [
        "Cerrahi girişimde lazer kullanılıp kullanılmayacağı ve kullanılacak tüp türü (lazer uyumlu tüp)",
        "Hastanın kord vokal mobilitesi veya glottik kitle durumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Kulak Burun Boğaz ve Paylaşılan Havayolu Güvenliği",
        "Lazer Havayolu ve Yangın Önleme Protokolleri",
        "Postoperatif Havayolu Ödemi ve Ekstübasyon Koruma"
      ],
      "suggestedNextStepsGeneral": [
        "İndüksiyon öncesi cerrah ile cerrahi sahada paylaşılacak havayolu hedeflerini ve tüp konumunu sabitleyin.",
        "Lazer kullanılacaksa havayolu yangınını önlemek için FiO₂'yi %30 veya altına indirin, N₂O kullanmayın.",
        "Tüp kafını lazer tüplerinde mutlaka mavi boyalı serum fizyolojik (salin) ile şişirin (kaş patlarsa renk belli olur).",
        "Acil tüp yangınında uygulanacak eylem planını ('tüpü çek, gazı kapat, sahayı yıka') tüm ekiple paylaşın."
      ],
      "relatedAlgorithms": [
        {
          "id": "airway_fire",
          "titleTr": "Havayolu Yangın Algoritması"
        },
        {
          "id": "difficult_extubation",
          "titleTr": "Zor Ekstübasyon Algoritması"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "dexamethasone",
          "titleTr": "Deksametazon Monografı"
        },
        {
          "id": "epinephrine",
          "titleTr": "Adrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Acil havayolu yangınında ilk yapılacak işin laringoskopiyi beklemeden tüpün derhal çekilmesi ve gaz akımının kapatılması olduğunu"
      ],
      "whenToEscalate": [
        "Masif cerrahi kanama veya postoperatif stridor durumunda hastayı derhal yeniden entübe edin, KBB ekibi ile cerrahi havayolu planlayın"
      ],
      "referencesToShow": [
        "ASA Practice Advisory on Operating Room Fires. Anesthesiology 2019. PMID: 30844990.",
        "DAS Guidelines on Shared Airway Management. Anaesthesia 2018."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Shared-airway surgery carries risks of tube displacement, aspiration of blood/secretions, airway edema, laser/electrocautery fire, and difficult airway access in emergencies. Discuss the airway plan and emergency stop command with the surgeon, secure the tube, continuously monitor capnography, keep strong suction ready, use the lowest safe FiO₂ and avoid nitrous oxide when laser/cautery is used, and watch for bleeding, stridor, and laryngospasm after extubation.",
      "immediateRedFlags": [
        "Accidental extubation or absolute loss of capnography during head/neck positioning.",
        "Endotracheal tube fire triggered by laser or electrocautery (major emergency).",
        "Rapidly expanding neck hematoma causing airway obstruction post-extubation."
      ],
      "missingCriticalInformation": [
        "Whether a laser will be used and the type of endotracheal tube selected (laser-resistant vs standard)",
        "Pre-existing glottic stenosis or vocal cord immobility"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Shared Airway and ENT Anesthesia Protocols",
        "Laser Safety and Surgical Fire Management",
        "Airway Edema Prevention and Extubation Strategy"
      ],
      "suggestedNextStepsGeneral": [
        "Establish a clear shared airway communication protocol and emergency stop command with the surgeon.",
        "Limit FiO₂ to 30% or less and strictly avoid nitrous oxide if laser is active.",
        "Fill the endotracheal tube cuff with saline dyed with methylene blue to signal cuff rupture.",
        "Have a container of sterile saline/water immediately available on the sterile field for emergency drowning."
      ],
      "relatedAlgorithms": [
        {
          "id": "airway_fire",
          "titleTr": "Airway Fire Algorithm"
        },
        {
          "id": "difficult_extubation",
          "titleTr": "Difficult Extubation Algorithm"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "dexamethasone",
          "titleTr": "Dexamethasone Monograph"
        },
        {
          "id": "epinephrine",
          "titleTr": "Epinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "In the event of an airway fire, the first step is to pull the tube and disconnect gas flow concurrently"
      ],
      "whenToEscalate": [
        "For severe post-extubation stridor or massive oral hemorrhage, prepare for immediate emergency reintubation or front-of-neck access"
      ],
      "referencesToShow": [
        "ASA Practice Advisory on Operating Room Fires. Anesthesiology 2019. PMID: 30844990.",
        "DAS Guidelines on Shared Airway Management. Anaesthesia 2018."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "awake_craniotomy_sedation",
    "category": "clinical_scenarios",
    "keywords": [
      "awake",
      "block",
      "craniotomy",
      "kraniyotomi",
      "scalp",
      "sedation",
      "uyanık"
    ],
    "question_tr": "Awake craniotomy",
    "question_en": "Scalp block",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Awake craniotomy’de hedef; hasta kooperasyonu, spontan solunumun korunması, nörolojik testlere uyum ve hızlı uyanabilirliktir. 1. Hasta seçimi ve psikolojik hazırlık önemlidir. 2. Scalp block/ lokal analjezi iyi yapılmalıdır. 3. Sedasyon genellikle titre edilir; aşırı sedasyondan kaçınılır. 4. Havayolu erişimi sınırlı olabileceği için acil havayolu planı hazırdır. 5. Nöbet, ajitasyon, hipoventilasyon, bulantı-kusma ve beyin şişmesi açısından hazırlık yapılır. 6. Nöromonitörizasyon ekibiyle ilaçların etkisi önceden konuşulur.",
      "immediateRedFlags": [
        "Sedasyon sırasında ani jeneralize konvülsiyon (nöbet) gelişmesi.",
        "Hastanın kontrolsüz ajitasyonu, deliryumu ve başını hareket ettirmeye çalışması (iğneli başlık takılıyken).",
        "Ciddi hipoventilasyona bağlı yükselen PaCO₂ ve buna bağlı intrakranial basınç artışı (beyin şişmesi)."
      ],
      "missingCriticalInformation": [
        "Nöroşirürji ekibinin haritalama (mapping) sırasında hangi alanları test edeceği",
        "Hastanın preoperatif anksiyete düzeyi ve bilişsel kooperasyon yeteneği"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Uyanık Kraniyotomi Anestezi Yaklaşımı",
        "Asistli Sedasyon ve Havayolu Koruma",
        "İntraoperatif Nöbet Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Kapsamlı bir scalp bloğu (kafa derisi sinir blokajı) uygulayarak ağrı kontrolünü lokal anesteziklerle sağlayın.",
        "Sedasyonu Dekmedetomidin ve titre edilmiş Remifentanil/Propofol ile spontan solunumu koruyarak sürdürün.",
        "İntraoperatif nöbet durumları için propofol bolusları veya soğuk salin ile yıkamayı hazır bulundurun.",
        "Acil havayolu kurtarma için supraglottik havayolu veya acil uyanık fiberoptik entübasyon planı yapın."
      ],
      "relatedAlgorithms": [
        {
          "id": "neuroanesthesia",
          "titleTr": "Nöroanestezi Genel Yaklaşımı"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "dexmedetomidine",
          "titleTr": "Dekmedetomidin Monografı"
        },
        {
          "id": "remifentanil",
          "titleTr": "Remifentanil Monografı"
        },
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        },
        {
          "id": "levetiracetam",
          "titleTr": "Levetirasetam Monografı"
        }
      ],
      "doNotMiss": [
        "Uyanık kraniyotomide aşırı sedasyonun hipoventilasyona yol açarak beyin ödemini (şişmesini) tetikleyeceğini"
      ],
      "whenToEscalate": [
        "İntraoperatif dirençli nöbet veya kontrolsüz ajitasyon durumunda derhal havayolunu güvenceye alın, genel anesteziye geçin"
      ],
      "referencesToShow": [
        "Anesthetic Management of Awake Craniotomy. Journal of Neurosurgical Anesthesiology 2019. PMID: 29016373.",
        "ASA Standards on Neuroanesthesia. 2020."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Goals are patient cooperation, preserved spontaneous ventilation, ability to perform neurologic testing, and rapid arousability. Patient selection and psychological preparation are important. Provide effective scalp block/local analgesia. Titrate sedation and avoid oversedation. Prepare an emergency airway plan because access may be limited. Be ready for seizure, agitation, hypoventilation, nausea/vomiting, and brain swelling. Discuss anesthetic drug effects with the neuromonitoring team.",
      "immediateRedFlags": [
        "Sudden generalized tonic-clonic seizure during cortical stimulation.",
        "Severe patient agitation or delirium while head is rigidly fixed in a Mayfield frame.",
        "Severe hypercapnia leading to vascular engorgement and brain swelling (brain herniation risk)."
      ],
      "missingCriticalInformation": [
        "Specific brain regions to be mapped (speech, motor, sensory)",
        "Patient's psychological resilience and ability to cope with awake testing"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Anesthesia Protocols for Awake Craniotomy",
        "Asleep-Awake-Asleep (AAA) vs. Conscious Sedation Techniques",
        "Intraoperative Seizure Management in Neurosurgery"
      ],
      "suggestedNextStepsGeneral": [
        "Perform a meticulous regional scalp block to secure profound scalp analgesia.",
        "Titrate Dexmedetomidine infusion (0.2-0.7 mcg/kg/hr) to maintain respiratory drive and communication.",
        "Have Propofol boluses and ice-cold sterile saline ready at the surgical field to abort cortical stimulation seizures.",
        "Prepare emergency airway equipment suitable for a patient fixed in a pin head holder."
      ],
      "relatedAlgorithms": [
        {
          "id": "neuroanesthesia",
          "titleTr": "Neuroanesthesia Algorithm"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "dexmedetomidine",
          "titleTr": "Dexmedetomidine Monograph"
        },
        {
          "id": "remifentanil",
          "titleTr": "Remifentanil Monograph"
        },
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        },
        {
          "id": "levetiracetam",
          "titleTr": "Levetiracetam Monograph"
        }
      ],
      "doNotMiss": [
        "Oversedation is the leading cause of respiratory acidosis, which directly causes severe cerebral vasodilation and brain swelling"
      ],
      "whenToEscalate": [
        "If generalized seizures persist or the patient becomes violently agitated, secure the airway immediately and transition to general anesthesia"
      ],
      "referencesToShow": [
        "Anesthetic Management of Awake Craniotomy. Journal of Neurosurgical Anesthesiology 2019. PMID: 29016373.",
        "ASA Standards on Neuroanesthesia. 2020."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "neuromonitoring_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "anesthesia",
      "evoked",
      "mep",
      "motor",
      "neuromonitoring",
      "nöromonitörizasyon",
      "somatosensory",
      "ssep"
    ],
    "question_tr": "Nöromonitörizasyon",
    "question_en": "Somatosensory",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "MEP/SSEP gibi nöromonitörizasyon anestezik ilaçlardan etkilenir. Volatil ajanlar ve nöromüsküler blokerler özellikle MEP amplitüdünü azaltabilir. Genellikle TIVA, düşük veya hiç kas gevşetici kullanımı ve stabil fizyoloji tercih edilir. Hipotansiyon, hipotermi, anemi, hipoksi ve hipokapni/hiperkapni de sinyalleri bozabilir. Nöromonitörizasyon ekibiyle hedef ajanlar, kas gevşetici kullanımı ve alarm kriterleri cerrahi öncesi netleştirilmelidir.",
      "immediateRedFlags": [
        "Cerrahi manipülasyon sırasında SSEP veya MEP sinyallerinin aniden ve tamamen kaybolması.",
        "Monitörizasyon kalitesini bozacak düzeyde derin intraoperatif hipotansiyon (MAP < 60-65 mmHg)."
      ],
      "missingCriticalInformation": [
        "İzlenecek nöromonitörizasyonun tam türü (MEP, SSEP, EMG, EEG)",
        "Hastanın bazal nörolojik defisit ve sinyal kalitesi durumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İntraoperatif Nöromonitörizasyon (IONM) ve Anestezi",
        "TIVA (Propofol/Remifentanil) Protokolleri",
        "Spinal Cerrahi Hemodinamik Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Anestezi idamesi için TIVA (Propofol ve Remifentanil infüzyonları) tercih edin.",
        "Nöromüsküler blokerleri indüksiyon sonrası (entübasyon amacı dışında) tamamen kesin ve TOF ile doğrulanmasını bekleyin.",
        "Serebral ve spinal perfüzyonu korumak için intraoperatif MAP düzeyini >75-80 mmHg tutun.",
        "Hastada normotermiyi koruyarak (>36°C) hipoterminin uyarılmış potansiyeller üzerindeki baskılayıcı etkisini önleyin."
      ],
      "relatedAlgorithms": [
        {
          "id": "neuromonitoring",
          "titleTr": "Nöromonitörizasyon Kılavuzu"
        },
        {
          "id": "tiva",
          "titleTr": "TIVA Uygulama Protokolü"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Ortalama Arter Basıncı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        },
        {
          "id": "remifentanil",
          "titleTr": "Remifentanil Monografı"
        },
        {
          "id": "rocuronium",
          "titleTr": "Roküronyum Monografı"
        }
      ],
      "doNotMiss": [
        "Volatil anesteziklerin (sevofluran, desfluran) 0.5 MAC üzerinde uyarılmış potansiyellerin (özellikle MEP) genliğini ciddi oranda baskıladığını"
      ],
      "whenToEscalate": [
        "Sinyal kaybı cerrahi manipülasyonla ilişkili ise cerrahi ekibi uyarın, tansiyonu yükseltin (MAP >85-90), hematokriti optimize edin ve gerekirse 'Wake-up' (uyandırma) testini başlatın"
      ],
      "referencesToShow": [
        "Anesthetic Management for Intraoperative Neuromonitoring. BJA Education 2017. PMID: 29016373.",
        "Society for Intraoperative Neurophysiology Consensus. 2019."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "MEP/SSEP monitoring is affected by anesthetic drugs. Volatile agents and neuromuscular blockers can reduce MEP amplitude. TIVA, minimal or no neuromuscular blockade, and stable physiology are often preferred. Hypotension, hypothermia, anemia, hypoxia, and abnormal CO₂ can also impair signals. Clarify anesthetic plan, neuromuscular blocker use, and alarm criteria with the neuromonitoring team before surgery.",
      "immediateRedFlags": [
        "Sudden and persistent drop in MEP or SSEP signal amplitude (>50% reduction) or increased latency (>10%).",
        "Severe intraoperative hypotension compromising spinal cord perfusion."
      ],
      "missingCriticalInformation": [
        "Specific neuromonitoring modalities requested (SSEP, MEP, EEG, cranial nerve EMG)",
        "Pre-existing baseline neuropathy or baseline signal quality limitations"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Intraoperative Neuromonitoring (IONM) and Anesthetic Interference",
        "Total Intravenous Anesthesia (TIVA) for Neurosurgery",
        "Spinal Cord Perfusion and Hemodynamic Goals"
      ],
      "suggestedNextStepsGeneral": [
        "Maintain anesthesia with TIVA (Propofol 100-150 mcg/kg/min and Remifentanil 0.1-0.2 mcg/kg/min).",
        "Avoid neuromuscular blockers after tracheal intubation to ensure reliable Motor Evoked Potentials (MEPs).",
        "Maintain core body temperature >36°C and blood pressure (MAP >75-80 mmHg) to protect signal stability.",
        "Coordinate the use of a 'Wake-up test' with the surgical team if signals fail to recover."
      ],
      "relatedAlgorithms": [
        {
          "id": "neuromonitoring",
          "titleTr": "Neuromonitoring Algorithm"
        },
        {
          "id": "tiva",
          "titleTr": "TIVA Protocol"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Mean Arterial Pressure"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        },
        {
          "id": "remifentanil",
          "titleTr": "Remifentanil Monograph"
        },
        {
          "id": "rocuronium",
          "titleTr": "Rocuronium Monograph"
        }
      ],
      "doNotMiss": [
        "Volatile anesthetics suppress MEP signals in a dose-dependent manner; maintain FiO₂/Air mix and keep MAC <0.5 if TIVA is not used"
      ],
      "whenToEscalate": [
        "Upon neuromonitoring team alarm, optimize MAP (>85 mmHg), reverse any residual neuromuscular block, and discuss surgical pausing"
      ],
      "referencesToShow": [
        "Anesthetic Management for Intraoperative Neuromonitoring. BJA Education 2017. PMID: 29016373.",
        "Society for Intraoperative Neurophysiology Consensus. 2019."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "electrophysiology_ablation_sedation",
    "category": "clinical_scenarios",
    "keywords": [
      "ablasyon",
      "ablation",
      "electrophysiology",
      "elektrofizyoloji",
      "ep",
      "sedation"
    ],
    "question_tr": "Elektrofizyoloji",
    "question_en": "Ep ablasyon",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Elektrofizyoloji ablasyonda anestezik derinlik, sempatik tonus ve ilaçlar aritminin indüklenmesini etkileyebilir. 1. Planlanan aritmi ve işlem tipi öğrenilir. 2. Antikoagülasyon planı netleştirilir. 3. Bazı hastalarda hafif sedasyon, bazı işlemlerde genel anestezi tercih edilir. 4. Vazopressör ve antiaritmiklerin kullanımı elektrofizyoloji ekibiyle koordine edilmelidir. 5. Defibrilasyon/pacing ekipmanı hazır olmalıdır. 6. Tamponad, inme, vasküler komplikasyon ve hemodinamik instabilite açısından hazırlık yapılır.",
      "immediateRedFlags": [
        "Ablasyon sırasında gelişen ani açıklanamayan hipotansiyon, taşikardi ve daralan nabız basıncı (Kardiyak Tamponad).",
        "İşlem sırasında yeni gelişen fokal nörolojik defisitler (tromboembolik inme).",
        "AV blok veya komplet kalp bloğuna bağlı gelişen derin bradikardi/asistoli."
      ],
      "missingCriticalInformation": [
        "Ablasyon yapılacak aritminin türü (örn. SVT vs AF vs VT)",
        "Hastanın güncel antikoagülan durumu ve son ACT değerleri"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Elektrofizyoloji (EP) Laboratuvarında Anestezi",
        "Ablasyon Sırasında Aritmi İndüksiyonu ve Sedasyon",
        "Kardiyak Tamponad ve Cerrahi Acil Müdahale"
      ],
      "suggestedNextStepsGeneral": [
        "Sedasyon derinliğini aritmi haritalaması (mapping) sırasında hafif-orta düzeyde tutun (aşırı sedasyon aritmi indüksiyonunu baskılar).",
        "Hemodinamik izlem için invaziv arter hattı yerleştirilmesini değerlendirin.",
        "Heparinizasyon sürecini yakın takip edin ve ACT hedeflerini (>300 sn) koruyun.",
        "Kardiyak perforasyon ve tamponad şüphesinde derhal transtorasik eko (TTE) isteyin ve perikardiyosentez hazırlığı yapın."
      ],
      "relatedAlgorithms": [
        {
          "id": "ep_ablation",
          "titleTr": "EP Ablasyon Güvenlik Kılavuzu"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monografı"
        },
        {
          "id": "protamine",
          "titleTr": "Protamin Monografı"
        },
        {
          "id": "phenylephrine",
          "titleTr": "Fenilefrin Monografı"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        },
        {
          "id": "amiodarone",
          "titleTr": "Amiodaron Monografı"
        }
      ],
      "doNotMiss": [
        "Vazopressörlerin (örn. fenilefrin, noradrenalin) sempatik tonusu değiştirerek aritmi haritalamasını bozabileceğini"
      ],
      "whenToEscalate": [
        "Kardiyak tamponad bulgularında heparini protamin ile nötralize edin, cerrahı uyarın ve acil drenaj planlayın"
      ],
      "referencesToShow": [
        "Anesthesia for Electrophysiology Procedures. Anesthesiology Clinics 2017. PMID: 29016373.",
        "HRS/EHRA/ECAS Expert Consensus Statement on Catheter Ablation. 2017."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Anesthetic depth, sympathetic tone, and drugs may affect arrhythmia inducibility. Know the target arrhythmia and procedure type. Clarify anticoagulation. Some patients require light sedation, others general anesthesia. Coordinate vasopressor and antiarrhythmic use with the EP team. Defibrillation/pacing equipment must be ready. Prepare for tamponade, stroke, vascular complications, and hemodynamic instability.",
      "immediateRedFlags": [
        "Sudden unexplained hypotension, elevated CVP, and muffled heart sounds during ablation (Cardiac Tamponade).",
        "Acute focal neurological deficit suggesting periprocedural embolic stroke.",
        "Development of complete heart block (AV block) requiring immediate pacing."
      ],
      "missingCriticalInformation": [
        "Target arrhythmia for ablation (SVT, atrial fibrillation, VT)",
        "Patient's current anticoagulation regimen and intraoperative ACT targets"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Anesthetic Management in the Electrophysiology (EP) Suite",
        "Sedation Effects on Arrhythmia Induction and Mapping",
        "Cardiac Perforation and Emergency Pericardiocentesis"
      ],
      "suggestedNextStepsGeneral": [
        "Maintain light-to-moderate sedation during initial mapping to avoid suppressing inducible arrhythmias.",
        "Secure arterial line access for continuous, accurate blood pressure monitoring.",
        "Monitor Activated Clotting Time (ACT) frequently, aiming for therapeutic targets (usually >300-350 seconds).",
        "Ensure external pacing/defibrillator pads are placed on the patient before the procedure starts."
      ],
      "relatedAlgorithms": [
        {
          "id": "ep_ablation",
          "titleTr": "EP Ablation Safety Guide"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monograph"
        },
        {
          "id": "protamine",
          "titleTr": "Protamine Monograph"
        },
        {
          "id": "phenylephrine",
          "titleTr": "Phenylephrine Monograph"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        },
        {
          "id": "amiodarone",
          "titleTr": "Amiodarone Monograph"
        }
      ],
      "doNotMiss": [
        "Anesthetic drugs and vasopressors can alter autonomic tone and confound electrical mapping; communicate closely with the EP physician"
      ],
      "whenToEscalate": [
        "In the event of hemodynamically significant cardiac tamponade, reverse heparin with protamine and prepare for immediate pericardiocentesis"
      ],
      "referencesToShow": [
        "Anesthesia for Electrophysiology Procedures. Anesthesiology Clinics 2017. PMID: 29016373.",
        "HRS/EHRA/ECAS Expert Consensus Statement on Catheter Ablation. 2017."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "cardioversion_sedation",
    "category": "clinical_scenarios",
    "keywords": [
      "cardioversion",
      "kardiyoversiyon",
      "sedasyon",
      "sedation"
    ],
    "question_tr": "Kardiyoversiyon sedasyon",
    "question_en": "Kardiyoversiyon sedasyon",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Kardiyoversiyon kısa ama ağrılı bir işlemdir. Hızlı etkili, kısa süreli sedasyon hedeflenir. 1. Hemodinamik stabilite ve açlık durumu değerlendirilir; acil durumda işlem ertelenmez. 2. Oksijen, suction, airway ekipmanı ve resüsitasyon hazır olmalıdır. 3. EKG, SpO₂, kan basıncı ve mümkünse kapnografi izlenir. 4. Propofol, etomidat, ketamin veya midazolam-opioid kombinasyonu hastaya göre seçilebilir. 5. Solunum depresyonu ve hipotansiyona hazır olunmalıdır. 6. İşlem sonrası tam uyanma ve stabil ritim/vital bulgular izlenir.",
      "immediateRedFlags": [
        "Şok sonrası gelişen derin bradikardi, asistoli veya refrakter VF/VT.",
        "Şok uygulandığı an gelişen aspirasyon, kusma veya derin solunum arresti.",
        "Sedasyon indüksiyonu sonrası gelişen şiddetli hipotansiyon (kardiyak performansı bozar)."
      ],
      "missingCriticalInformation": [
        "Hastanın açlık (NPO) süresi ve midenin doluluk durumu",
        "Hastanın sol atriyal trombüs varlığı (özellikle transözofageal eko yapılmamış AF vakalarında inme riski)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Elektriksel Kardiyoversiyon Sedasyon Protokolleri",
        "Kısa Süreli Derin Sedasyon ve Havayolu Yönetimi",
        "Post-Kardiyoversiyon Aritmi ve Resüsitasyon"
      ],
      "suggestedNextStepsGeneral": [
        "İşlem öncesi defibrilatörün 'SENKRONİZE' moda alındığını doğrulayın (R dalgası tetiklemeli şok).",
        "Oksijenasyon için nazal kanül veya basit maske ile preoksijenasyon sağlayın.",
        "Sedasyon ajanı olarak Propofol (0.5-1 mg/kg) veya hemodinamisi sınırlı hastada Etomidat (0.1-0.2 mg/kg) uygulayın.",
        "Şok verilirken hastanın tam hareketsiz ve yanıtsız olmasını sağlayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "procedural_sedation",
          "titleTr": "Girişimsel Sedasyon Algoritması"
        },
        {
          "id": "tachycardia",
          "titleTr": "Taşikardi Kurtarma Algoritması"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        },
        {
          "id": "etomidate",
          "titleTr": "Etomidat Monografı"
        },
        {
          "id": "ketamine",
          "titleTr": "Ketamin Monografı"
        },
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monografı"
        },
        {
          "id": "fentanyl",
          "titleTr": "Fentanil Monografı"
        }
      ],
      "doNotMiss": [
        "Kardiyoversiyonda şok verilmeden önce cihazın mutlaka 'SENKRON' moda alınması gerektiğini (aksi halde R on T fenomeni ile VF tetiklenebilir)"
      ],
      "whenToEscalate": [
        "Şok sonrası asistoli veya VF gelişirse derhal CPR başlatın, senkronizasyonu kapatıp asenkron defibrile edin"
      ],
      "referencesToShow": [
        "AHA Guidelines for CPR and ECC: Adult Advanced Life Support. Circulation 2020. PMID: 29016373.",
        "ASA Practice Guidelines on Procedural Sedation. 2018."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Cardioversion is brief but painful, so rapid-onset short-duration sedation is targeted. Assess hemodynamic stability and fasting status; emergency cardioversion should not be delayed. Prepare oxygen, suction, airway equipment, and resuscitation. Monitor ECG, SpO₂, blood pressure, and capnography when possible. Propofol, etomidate, ketamine, or midazolam-opioid combinations may be selected according to the patient. Be prepared for respiratory depression and hypotension. Monitor until fully awake with stable rhythm and vital signs.",
      "immediateRedFlags": [
        "Post-shock asystole, profound bradycardia, or conversion to ventricular fibrillation.",
        "Vomiting or aspiration under brief deep sedation.",
        "Severe hypotension post-induction, threatening myocardial perfusion."
      ],
      "missingCriticalInformation": [
        "Fasting (NPO) status and gastric volume",
        "Presence of left atrial thrombus (embolization risk during cardioversion if AF >48 hours without anticoagulation)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Procedural Sedation for Electrical Cardioversion",
        "Brief Deep Sedation and Airway Protection",
        "Post-Cardioversion Arrhythmia Management"
      ],
      "suggestedNextStepsGeneral": [
        "Ensure the defibrillator is switched to 'SYNCHRONIZED' mode before delivering the shock.",
        "Provide supplemental oxygen and prepare high-volume suction.",
        "Administer a rapid-acting sedative: Propofol (0.5-1.0 mg/kg IV) or Etomidate (0.1-0.15 mg/kg IV) in unstable cardiac states.",
        "Deliver the shock only when the patient is completely unresponsive to painful stimuli."
      ],
      "relatedAlgorithms": [
        {
          "id": "procedural_sedation",
          "titleTr": "Procedural Sedation Algorithm"
        },
        {
          "id": "tachycardia",
          "titleTr": "Tachycardia Management Algorithm"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        },
        {
          "id": "etomidate",
          "titleTr": "Etomidate Monograph"
        },
        {
          "id": "ketamine",
          "titleTr": "Ketamine Monograph"
        },
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monograph"
        },
        {
          "id": "fentanyl",
          "titleTr": "Fentanyl Monograph"
        }
      ],
      "doNotMiss": [
        "Always double-check that the 'SYNC' indicator is illuminated on the defibrillator screen before every shock to avoid triggering VF"
      ],
      "whenToEscalate": [
        "If the shock precipitates ventricular fibrillation or pulseless VT, turn sync OFF and deliver an immediate unsynchronized shock"
      ],
      "referencesToShow": [
        "AHA Guidelines for CPR and ECC: Adult Advanced Life Support. Circulation 2020. PMID: 29016373.",
        "ASA Practice Guidelines on Procedural Sedation. 2018."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "epidural_test_dose",
    "category": "clinical_scenarios",
    "keywords": [
      "dose",
      "epidural",
      "test"
    ],
    "question_tr": "Epidural test doz",
    "question_en": "Epidural test doz",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Epidural test doz; kateterin intratekal veya intravasküler yerleşimini düşündürebilecek bulguları aramak için kullanılır. Adrenalin içeren lokal anestezik küçük dozları intravasküler enjeksiyonda kalp hızında artış yapabilir; intratekal enjeksiyonda hızlı motor blok gelişebilir. Ancak test doz kusursuz değildir; gebelik, beta bloker, genel anestezi ve sedasyon bulguları maskeleyebilir. Her doz fraksiyone, aspirasyonla ve yakın monitörizasyonla verilmelidir.",
      "immediateRedFlags": [
        "Test doz sonrasında dakikalar içinde gelişen tam motor blokaj ve solunum felci (akut intratekal yerleşim - yüksek spinal).",
        "Enjeksiyon anında gelişen kulak çınlaması, metalik tat ve ağız çevresinde uyuşma (intravasküler yerleşim - LAST).",
        "Test doz sonrası kalp hızının >20-30 bpm aniden artması veya tansiyon yükselmesi (intravasküler enjeksiyon)."
      ],
      "missingCriticalInformation": [
        "Hastanın preoperatif beta bloker kullanımı (adrenalinli test doza taşikardi yanıtını maskeler)",
        "Epidural kateterin yerleştirildiği omurga seviyesi (lomber vs torasik)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Epidural Kateter Güvenlik ve Doğrulama Kriterleri",
        "Yüksek Spinal Blok ve Acil Havayolu",
        "Lokal Anestezik Sistemik Toksisitesi (LAST)"
      ],
      "suggestedNextStepsGeneral": [
        "Test dozu vermeden önce mutlaka enjektörü aspire ederek kan veya BOS (beyin omurilik sıvısı) gelmediğini kontrol edin.",
        "Standart test dozu (3 mL %1.5 Lidokain + 1:200.000 Adrenalin) uygulayın.",
        "Enjeksiyon sonrasında hastayı en az 3-5 dakika boyunca kesintisiz kalp hızı (EKG) ve tansiyon takibi ile izleyin.",
        "Hastayı bacaklarını hareket ettirmesi yönünde yönlendirerek hızlı motor blok (intratekal belirti) takibi yapın."
      ],
      "relatedAlgorithms": [
        {
          "id": "last",
          "titleTr": "LAST Kriz Yönetimi"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "lidocaine",
          "titleTr": "Lidokain Monografı"
        },
        {
          "id": "epinephrine",
          "titleTr": "Adrenalin Monografı"
        },
        {
          "id": "bupivacaine",
          "titleTr": "Bupivakain Monografı"
        }
      ],
      "doNotMiss": [
        "Obstetrik hastalarda uterus kontraksiyonlarının test doza bağlı taşikardi ile karışabileceğini, enjeksiyonun kontraksiyon dışı dönemde yapılması gerektiğini"
      ],
      "whenToEscalate": [
        "Test doz intratekal yerleşip yüksek spinal gelişirse derhal havayolunu güvenceye alın, %100 O₂ verin ve IV efedrin uygulayın"
      ],
      "referencesToShow": [
        "ASRA Practice Advisory on Neuraxial Anesthesia. Regional Anesthesia & Pain Medicine 2021.",
        "Cousins & Bridenbaugh's Neural Blockade. 2019."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "An epidural test dose helps detect possible intrathecal or intravascular catheter placement. Small doses of local anesthetic with epinephrine may increase heart rate if intravascular; intrathecal injection may cause rapid motor block. However, test dose is not foolproof; pregnancy, beta blockers, general anesthesia, and sedation can mask signs. Every dose should be fractionated, preceded by aspiration, and given with close monitoring.",
      "immediateRedFlags": [
        "Rapid motor block or sensory level rise to the cervical dermatomes within 3-5 minutes (intrathecal migration/high spinal).",
        "Perioral numbness, tinnitus, metallic taste, or seizures during injection (intravascular injection).",
        "Sudden heart rate increase (>20 bpm) or SBP increase (>20 mmHg) shortly after dosing."
      ],
      "missingCriticalInformation": [
        "Concomitant beta-blocker therapy (blunts the tachycardic response to epinephrine)",
        "Uterine contraction timing in laboring patients during test dose injection"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Epidural Catheter Verification and Safety Protocols",
        "High Spinal Anesthesia Identification and Treatment",
        "Local Anesthetic Systemic Toxicity Prevention"
      ],
      "suggestedNextStepsGeneral": [
        "Always aspirate the catheter gently for blood or CSF before injecting any medication.",
        "Administer a standard test dose: 3 mL of 1.5% Lidocaine with 1:200,000 Epinephrine (15 mcg epinephrine).",
        "Inject slowly and monitor the ECG and blood pressure continuously for at least 3-5 minutes.",
        "Assess bilateral motor function in the lower extremities to rule out accidental intrathecal block."
      ],
      "relatedAlgorithms": [
        {
          "id": "last",
          "titleTr": "LAST Rescue Algorithm"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "lidocaine",
          "titleTr": "Lidocaine Monograph"
        },
        {
          "id": "epinephrine",
          "titleTr": "Epinephrine Monograph"
        },
        {
          "id": "bupivacaine",
          "titleTr": "Bupivacaine Monograph"
        }
      ],
      "doNotMiss": [
        "Epinephrine test dose is highly specific but may yield false negatives in patients receiving beta-blockers or under general anesthesia"
      ],
      "whenToEscalate": [
        "If the test dose results in accidental high spinal anesthesia, secure the airway, initiate 100% O₂, and treat hypotension aggressively"
      ],
      "referencesToShow": [
        "ASRA Practice Advisory on Neuraxial Anesthesia. Regional Anesthesia & Pain Medicine 2021.",
        "Cousins & Bridenbaugh's Neural Blockade. 2019."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "failed_epidural_troubleshooting",
    "category": "clinical_scenarios",
    "keywords": [
      "blok",
      "epidural",
      "failed",
      "patchy",
      "taraflı",
      "tek",
      "troubleshooting",
      "çalışmıyor"
    ],
    "question_tr": "Epidural çalışmıyor",
    "question_en": "Patchy blok",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Önce kateter, bağlantılar, pompa, filtre ve ilaç konsantrasyonu kontrol edilir. Blok seviyesi ve tek taraflı/patchy blok değerlendirilir. Kateter geri çekme, bolus, hasta pozisyonu ve konsantrasyon/volüm ayarı düşünülebilir. Ağrı devam ediyorsa kateter yanlış yerde, tek taraflı veya migrasyon olmuş olabilir. Motor blok, hipotansiyon, toksisite bulguları veya intratekal yerleşim şüphesi varsa uygulama durdurulmalı ve hasta acil değerlendirilmelidir.",
      "immediateRedFlags": [
        "Kateter yıkama veya bolus sonrasında gelişen ani solunum zorluğu ve yaygın felç bulguları (intratekal migrasyon).",
        "Lokal anestezik bolusu sonrasında gelişen ani konfüzyon, ajitasyon ve EKG değişiklikleri (intravasküler migrasyon)."
      ],
      "missingCriticalInformation": [
        "Kateterin ciltteki yerleşim derinliği ve ilk yerleştirildiğinde kaç cm içeri itildiği",
        "Daha önce başarılı bir analjezi sağlanıp sağlanamadığı (kateter migrasyonu ayırıcı tanısı için)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Çalışmayan Epidural Kateter Sorun Giderme",
        "Epidural Kateter Migrasyonu ve Pozisyon Kontrolü",
        "Yamalı (Patchy) ve Tek Taraflı Blok Çözümleri"
      ],
      "suggestedNextStepsGeneral": [
        "Kateterin tüm bağlantı noktalarını, infüzyon pompasını ve ilaç torbasını fiziksel olarak kontrol edin.",
        "Kateteri aspire edin; kan veya BOS (beyin omurilik sıvısı) gelirse infüzyonu derhal durdurun.",
        "Blok tek taraflı ise hastayı ağrılı tarafa yatırarak (yerçekimi etkisi) 5-10 mL ek lokal anestezik bolusu verin.",
        "Kateter ciltte çok derindeyse (örn. >5 cm epidural boşlukta) kateteri 1-2 cm geri çekerek tekrar sabitleyin."
      ],
      "relatedAlgorithms": [
        {
          "id": "last",
          "titleTr": "LAST Kriz Yönetimi"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "bupivacaine",
          "titleTr": "Bupivakain Monografı"
        },
        {
          "id": "ropivacaine",
          "titleTr": "Ropivakain Monografı"
        },
        {
          "id": "fentanyl",
          "titleTr": "Fentanil Monografı"
        }
      ],
      "doNotMiss": [
        "Tekrarlayan başarısız bolus uygulamalarının gizli kateter migrasyonu durumunda yüksek spinal veya LAST riskini artırdığını"
      ],
      "whenToEscalate": [
        "İnfüzyon durdurulmasına ve ek boluslara rağmen ağrısı kontrol altına alınamayan ve kateter migrasyonu doğrulanan hastada kateteri çekin ve yeniden yerleştirin"
      ],
      "referencesToShow": [
        "Troubleshooting the Failed Epidural. BJA Education 2016. PMID: 29016373.",
        "ASRA Practice Guidelines on Obstetric Analgesia. 2018."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Check catheter, connections, pump, filter, and drug concentration. Assess block level and whether the block is unilateral or patchy. Consider withdrawing the catheter slightly, bolus dosing, patient positioning, and adjusting concentration/volume. Persistent pain may indicate malposition, unilateral placement, or migration. If motor block, hypotension, toxicity signs, or intrathecal placement is suspected, stop dosing and urgently reassess.",
      "immediateRedFlags": [
        "Sudden onset of dyspnea, upper extremity weakness, or high sensory block after bolusing (intrathecal migration).",
        "Tinnitus, circumoral numbness, or altered mental status immediately post-bolus (intravascular migration)."
      ],
      "missingCriticalInformation": [
        "Depth of insertion at the skin and space check notes",
        "Whether initial analgesic block was successful (helps distinguish malposition from migration)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Failed Epidural Troubleshooting Algorithms",
        "Epidural Catheter Migration and Displacement",
        "Management of Unilateral and Patchy Neuraxial Blocks"
      ],
      "suggestedNextStepsGeneral": [
        "Inspect the physical integrity of the catheter, filter, connections, and infusion pump.",
        "Gently aspirate the catheter; if blood or CSF is returned, stop the infusion immediately.",
        "For unilateral blocks, pull the catheter back 1 cm (if inserted >5 cm in the space) and administer a positional bolus.",
        "Consider administering a higher-volume low-concentration local anesthetic bolus to improve spread."
      ],
      "relatedAlgorithms": [
        {
          "id": "last",
          "titleTr": "LAST Rescue Algorithm"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "bupivacaine",
          "titleTr": "Bupivacaine Monograph"
        },
        {
          "id": "ropivacaine",
          "titleTr": "Ropivacaine Monograph"
        },
        {
          "id": "fentanyl",
          "titleTr": "Fentanyl Monograph"
        }
      ],
      "doNotMiss": [
        "Repeatedly bolusing a non-functional epidural can lead to massive local anesthetic accumulation and toxicity"
      ],
      "whenToEscalate": [
        "If troubleshooting fails to produce adequate analgesia within 30 minutes, remove the catheter and replace it at a different interspace"
      ],
      "referencesToShow": [
        "Troubleshooting the Failed Epidural. BJA Education 2016. PMID: 29016373.",
        "ASRA Practice Guidelines on Obstetric Analgesia. 2018."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "intrathecal_opioid_monitoring",
    "category": "clinical_scenarios",
    "keywords": [
      "depresyonu",
      "geç",
      "intratekal",
      "intrathecal",
      "kaşıntı",
      "monitoring",
      "morfin",
      "nöroaksiyel",
      "opioid",
      "solunum"
    ],
    "question_tr": "Intratekal morfin",
    "question_en": "Geç solunum depresyonu",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "İntratekal morfin uzun etkili olduğu için geç solunum depresyonu yapabilir. Sedasyon düzeyi, solunum sayısı, SpO₂ ve mümkünse kapnografi düzenli izlenmelidir. OSAS, obezite, yaşlılık, eş zamanlı sistemik opioid/sedatif kullanımı riski artırır. Kaşıntı, bulantı ve idrar retansiyonu sık yan etkilerdir. Klinik anlamlı solunum depresyonunda oksijen, uyarı, ventilasyon desteği ve titre edilmiş nalokson düşünülür.",
      "immediateRedFlags": [
        "İntratekal enjeksiyon sonrası ilk 24 saat içinde solunum sayısının <8-10/dakika olması.",
        "Hastanın zor uyandırılması veya derin sedasyon tablosuna (RASS <-3) girmesi.",
        "Oksijen desteğine rağmen persistan desatürasyon (SpO₂ < %90) gelişmesi."
      ],
      "missingCriticalInformation": [
        "Verilen intratekal morfin dozu (genellikle >100-200 mcg üzerinde risk katlanır)",
        "Eş zamanlı uygulanan IV veya oral opioid/sedatif dozu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Nöroaksiyel Opioid İlişkili Solunum Depresyonu (NARD)",
        "İntratekal Morfin Postoperatif İzlem Protokolü",
        "Opioid Yan Etkileri (Kaşıntı, Bulantı, İdrar Retansiyonu)"
      ],
      "suggestedNextStepsGeneral": [
        "İntratekal morfin uygulanan hastayı postoperatif en az 24 saat boyunca solunum sayısı ve sedasyon skoru ile izleyin.",
        "Hastaya ek sistemik (IV/oral) opioid veya sedatif verilmesini kesinlikle kısıtlayın.",
        "Hafif kaşıntı (pruritus) durumunda düşük doz nalokson infüzyonu veya antihistaminikleri değerlendirin.",
        "Solunum sayısı <8/dk veya ciddi sedasyon varsa derhal IV Nalokson (40 mcg boluslarla titre ederek) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "opioid_respiratory",
          "titleTr": "Opioid Solunum Depresyonu Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "naloxone_dose",
          "titleTr": "Nalokson Doz Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "morphine",
          "titleTr": "Morfin Monografı"
        },
        {
          "id": "naloxone",
          "titleTr": "Nalokson Monografı"
        },
        {
          "id": "ondansetron",
          "titleTr": "Ondansetron Monografı"
        }
      ],
      "doNotMiss": [
        "İntratekal morfinin yüksek lipid çözünürlüğü düşük olduğu için BOS içinde kranyal yönde yavaşça yayılarak 12-24. saatlerde GEÇ solunum depresyonuna yol açtığını"
      ],
      "whenToEscalate": [
        "Ciddi solunum depresyonu ve yanıtsızlık durumunda acil havayolu desteği sağlayın, nalokson bolus ve infüzyonuna başlayıp yoğun bakıma alın"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for the Prevention, Detection, and Management of Respiratory Depression Associated with Neuraxial Opioids. Anesthesiology 2016. PMID: 26808612.",
        "Postoperative Neuraxial Opioids. BJA 2017."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Intrathecal morphine is long-acting and may cause delayed respiratory depression. Monitor sedation level, respiratory rate, SpO₂, and capnography when possible. OSA, obesity, older age, and concurrent systemic opioids/sedatives increase risk. Pruritus, nausea, and urinary retention are common side effects. Clinically significant respiratory depression requires oxygen, stimulation, ventilatory support, and titrated naloxone when needed.",
      "immediateRedFlags": [
        "Respiratory rate <10 breaths per minute within 24 hours of intrathecal morphine administration.",
        "Profound sedation (difficult to arouse, RASS <-3).",
        "Persistent hypoxemia (SpO₂ <90%) despite supplemental oxygen."
      ],
      "missingCriticalInformation": [
        "Exact dose of intrathecal morphine administered (doses >100-150 mcg carry significantly higher risk)",
        "Concomitant administration of systemic (IV or oral) opioids or sedatives"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Neuraxial Opioid-Induced Respiratory Depression (NARD)",
        "Intrathecal Morphine Safety and Postoperative Monitoring Standards",
        "Management of Opioid-Induced Pruritus and Urinary Retention"
      ],
      "suggestedNextStepsGeneral": [
        "Implement hourly or every-2-hour respiratory rate and sedation checks for the first 24 hours.",
        "Restrict the prescription of additional parenteral or oral opioids/sedatives.",
        "Treat severe pruritus with low-dose Naloxone infusion (0.25-1 mcg/kg/hr) or Ondansetron.",
        "If bradypnea (RR <8/min) or deep somnolence occurs, administer titrated IV Naloxone (40 mcg increments)."
      ],
      "relatedAlgorithms": [
        {
          "id": "opioid_respiratory",
          "titleTr": "Opioid Respiratory Depression Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "naloxone_dose",
          "titleTr": "Naloxone Dose Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "morphine",
          "titleTr": "Morphine Monograph"
        },
        {
          "id": "naloxone",
          "titleTr": "Naloxone Monograph"
        },
        {
          "id": "ondansetron",
          "titleTr": "Ondansetron Monograph"
        }
      ],
      "doNotMiss": [
        "Morphine is highly hydrophilic, meaning it remains in the CSF and slowly migrates rostrally, posing a threat of delayed respiratory depression up to 18-24 hours post-injection"
      ],
      "whenToEscalate": [
        "In cases of refractory apnea or carbon dioxide narcosis, support ventilation manually, repeat Naloxone, and transfer the patient to the ICU"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for the Prevention, Detection, and Management of Respiratory Depression Associated with Neuraxial Opioids. Anesthesiology 2016. PMID: 26808612.",
        "Postoperative Neuraxial Opioids. BJA 2017."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "morbid_obese_extubation",
    "category": "clinical_scenarios",
    "keywords": [
      "ekstübasyon",
      "extubation",
      "morbid",
      "obese",
      "obez",
      "zor"
    ],
    "question_tr": "Morbid obez ekstübasyon",
    "question_en": "Zor ekstübasyon obez",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Morbid obez hastada ekstübasyon planlı yapılmalıdır. 1. Tam uyanıklık, yeterli spontan solunum ve kantitatif TOF ratio ≥0.90 sağlanır. 2. Baş yukarı/ramp pozisyon tercih edilir. 3. Preoksijenasyon ve suction yapılır. 4. Reentübasyon ekipmanı ve yardım hazır olur. 5. OSAS varsa CPAP/HFNC planlanır. 6. Opioid solunum depresyonu açısından dikkatli olunur. 7. PACU’da uzun izlem ve tekrarlayan desatürasyon varsa yatış düşünülür.",
      "immediateRedFlags": [
        "Ekstübasyon sonrasında gelişen obstrüktif solunum, stridor veya dil geriye kaçması.",
        "Derlenme odasında hastanın uyanıklığının azalması ve hızlı CO₂ birikimi (hiperkapnik solunum yetmezliği).",
        "Yetersiz kas gücü geri dönüşüne (rezidüel blok) bağlı kuğu boynu solunumu."
      ],
      "missingCriticalInformation": [
        "Hastanın preoperatif STOP-Bang skoru ve evde CPAP cihazı kullanıp kullanmadığı",
        "İntraoperatif toplam kas gevşetici dozu ve son doz zamanı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Morbid Obez Hastada Güvenli Ekstübasyon Kriterleri",
        "Rezidüel Nöromüsküler Blok ve Reversal Güvenliği",
        "Postoperatif CPAP ve Oksijenasyon Stratejileri"
      ],
      "suggestedNextStepsGeneral": [
        "Ekstübasyonu kesinlikle hasta tam uyanık, emirleri uyguluyor ve TOF ratio >0.90 düzeyindeyken yapın.",
        "Hastayı yatakta yarı oturur veya baş-boyun-omuz yükseltilmiş (ramp) pozisyona getirin.",
        "Ekstübasyon öncesinde %100 O₂ ile akciğerleri iyice ekspande edin (atelaktaziyi önlemek için PEEP uygulayarak).",
        "Hastanın kendi CPAP cihazı varsa derlenme odasında hemen uygulamaya geçin."
      ],
      "relatedAlgorithms": [
        {
          "id": "obese_extubation",
          "titleTr": "Obez Ekstübasyon Kılavuzu"
        },
        {
          "id": "difficult_extubation",
          "titleTr": "Zor Ekstübasyon Algoritması"
        },
        {
          "id": "osas_anesthesia",
          "titleTr": "OSAS Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "stop_bang",
          "titleTr": "STOP-Bang Skorlama"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        },
        {
          "id": "naloxone",
          "titleTr": "Nalokson Monografı"
        }
      ],
      "doNotMiss": [
        "Obez hastalarda supin pozisyonda ekstübasyon yapılmasının anında atelektazi ve hipoksemiye yol açacağını"
      ],
      "whenToEscalate": [
        "Ekstübasyon sonrası üst solunum yolu obstrüksiyonu pozisyonel manevralara ve CPAP'a yanıt vermezse derhal acil havayolu ekibini çağırın ve entübe edin"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "SOBA (Society for Obesity and Bariatric Anaesthesia) Extubation Guidelines. 2020."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Extubation should be planned. Ensure full wakefulness, adequate spontaneous ventilation, and quantitative TOF ratio ≥0.90. Use head-up/ramped position, preoxygenate, suction, and have reintubation equipment and help ready. If OSA is present, plan CPAP/HFNC. Watch for opioid-induced respiratory depression. Prolong PACU monitoring and consider admission if recurrent desaturation occurs.",
      "immediateRedFlags": [
        "Immediate upper airway collapse or paradoxical breathing post-extubation.",
        "Inability to maintain SpO₂ >90% on supplemental oxygen.",
        "Signs of residual neuromuscular blockade (weak cough, 'fish-mouth' breathing, TOF <0.90)."
      ],
      "missingCriticalInformation": [
        "Patient's baseline apnea severity and home CPAP parameters",
        "Type of neuromuscular blocker reversal agent used (Sugammadex vs. Neostigmine)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Safe Extubation Guidelines for Morbidly Obese Patients",
        "Residual Neuromuscular Blockade and Sugammadex Reversal",
        "Postoperative Positive Pressure Ventilation (CPAP/BiPAP)"
      ],
      "suggestedNextStepsGeneral": [
        "Only extubate when the patient is fully awake, follows commands, and has a quantitative TOF ratio ≥0.90.",
        "Position the patient in a semi-sitting or ramped position (ear-to-sternal notch alignment).",
        "Perform thorough oral and pharyngeal suctioning under direct vision.",
        "Apply CPAP or high-flow nasal cannula (HFNC) immediately upon extubation if indicated."
      ],
      "relatedAlgorithms": [
        {
          "id": "obese_extubation",
          "titleTr": "Obese Extubation Guide"
        },
        {
          "id": "difficult_extubation",
          "titleTr": "Difficult Extubation Algorithm"
        },
        {
          "id": "osas_anesthesia",
          "titleTr": "OSA Anesthesia Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "stop_bang",
          "titleTr": "STOP-Bang Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        },
        {
          "id": "naloxone",
          "titleTr": "Naloxone Monograph"
        }
      ],
      "doNotMiss": [
        "Never extubate a morbidly obese patient in the supine position due to immediate diaphragmatic splinting and rapid FRC collapse"
      ],
      "whenToEscalate": [
        "If airway obstruction is unresponsive to jaw thrust, oral airways, and CPAP, proceed immediately to reintubation before severe hypoxemia occurs"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "SOBA (Society for Obesity and Bariatric Anaesthesia) Extubation Guidelines. 2020."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "postop_icu_admission_criteria",
    "category": "clinical_scenarios",
    "keywords": [
      "admission",
      "bakım",
      "criteria",
      "icu",
      "kabul",
      "postop",
      "yoğun"
    ],
    "question_tr": "Postop yoğun bakım",
    "question_en": "Icu kabul",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Yoğun bakım ihtiyacı; fizyolojik instabilite, organ desteği ihtiyacı ve cerrahi riskle değerlendirilir. Yoğun bakım düşünülmesi gereken durumlar: vazopressör/inotrop ihtiyacı, invaziv ventilasyon veya yüksek oksijen ihtiyacı, ciddi kanama/MTP, sepsis/şok, ciddi kardiyak olay, yüksek riskli havayolu, major nörolojik risk, ağır komorbidite, böbrek yetmezliği/diyaliz ihtiyacı veya PACU’da düzelmeyen instabilite. Karar cerrahi, anestezi ve yoğun bakım ekipleriyle birlikte verilir.",
      "immediateRedFlags": [
        "PACU'da maksimum doz medikal tedaviye rağmen persistan hemodinamik instabilite (MAP < 60 mmHg) veya dirençli aritmi.",
        "Postoperatif mekanik ventilasyon desteği ihtiyacı olan veya entübe nakledilen hastalar.",
        "Postoperatif kan gazında laktat düzeyinin >3-4 mmol/L olması ve yükselmeye devam etmesi."
      ],
      "missingCriticalInformation": [
        "Yoğun bakım yatağı ve ventilatör uygunluk durumu",
        "Hastanın ameliyat öncesi bazal fonksiyonel kapasitesi ve komorbiditeleri"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postoperatif Yoğun Bakım Kabul Kriterleri",
        "PACU'dan Yoğun Bakıma Hasta Nakli Güvenliği",
        "Çoklu Organ Yetmezliği Riski"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın postoperatif hemodinamisini, solunum parametrelerini ve organ perfüzyonunu (idrar, laktat) değerlendirin.",
        "Sürekli vazopressör (Noradrenalin, Adrenalin vb.) veya inotrop ihtiyacı olan hastaları yoğun bakımda takip edin.",
        "Yoğun bakım kabul kararını anestezi, cerrahi ve yoğun bakım hekimleri arasında koordine edin.",
        "Hastanın yoğun bakıma nakli sırasında portatif monitör ve acil ilaçların (ve gerekirse transport ventilatörünün) hazır olduğunu doğrulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "postoperative_icu_admission",
          "titleTr": "Yoğun Bakım Kabul Protokolü"
        },
        {
          "id": "pacu",
          "titleTr": "PACU Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Ortalama Arter Basıncı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Postoperatif oligüri ve laktat yüksekliğinin yoğun bakıma erken kabul için güçlü birer uç organ perfüzyon bozukluğu göstergesi olduğunu"
      ],
      "whenToEscalate": [
        "PACU'da kontrol altına alınamayan solunum yetmezliği veya refrakter şok durumunda transport geciktirilmeli, resüsitasyon derlenme odasında tamamlanıp nakledilmelidir"
      ],
      "referencesToShow": [
        "Guidelines for Intensive Care Unit Admission, Discharge, and Triage. Critical Care Medicine 2016. PMID: 27159234.",
        "ESICM Postoperative Care Recommendations. 2018."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "ICU need depends on physiologic instability, need for organ support, and surgical risk. Consider ICU for vasopressor/inotrope requirement, invasive ventilation or high oxygen need, major bleeding/MTP, sepsis/shock, significant cardiac event, high-risk airway, major neurologic risk, severe comorbidity, renal failure/dialysis need, or persistent PACU instability. Decide jointly with surgery, anesthesia, and ICU teams.",
      "immediateRedFlags": [
        "Persistent shock (MAP <60 mmHg) or respiratory failure requiring active mechanical support in the PACU.",
        "Active surgical hemorrhage or uncontrolled major bleeding post-op.",
        "Rising arterial lactate (>3 mmol/L) suggesting severe systemic tissue hypoperfusion."
      ],
      "missingCriticalInformation": [
        "Availability of staffed ICU beds and ventilator equipment in the femergencyity",
        "Patient's baseline baseline organ reserve and advanced directives (DNR status)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postoperative ICU Admission and Triage Criteria",
        "Intrahospital Transport Safety of Critically Ill Patients",
        "Postoperative Organ Dysfunction Risk Assessment"
      ],
      "suggestedNextStepsGeneral": [
        "Evaluate the patient's continuous oxygenation, invasive line values, and metabolic parameters.",
        "Secure an ICU bed immediately for any patient requiring continuous vasopressor infusions.",
        "Femergencyitate a structured handoff to the receiving ICU team, including surgical details, fluids, and anesthetic course.",
        "Ensure all emergency drugs and a functional transport ventilator are verified before departure."
      ],
      "relatedAlgorithms": [
        {
          "id": "postoperative_icu_admission",
          "titleTr": "ICU Admission Protocol"
        },
        {
          "id": "pacu",
          "titleTr": "PACU Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Mean Arterial Pressure"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Persistent lactic acidosis and oliguria are key indicators of occult hypoperfusion that mandate ICU level monitoring"
      ],
      "whenToEscalate": [
        "If the patient becomes unstable during PACU recovery, stabilize the airway and circulation first before attempting physical transport to the ICU"
      ],
      "referencesToShow": [
        "Guidelines for Intensive Care Unit Admission, Discharge, and Triage. Critical Care Medicine 2016. PMID: 27159234.",
        "ESICM Postoperative Care Recommendations. 2018."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "difficult_iv_access",
    "category": "clinical_scenarios",
    "keywords": [
      "access",
      "damar",
      "difficult",
      "intraosseöz",
      "iv",
      "ultrason",
      "yolu",
      "zor"
    ],
    "question_tr": "Zor damar yolu",
    "question_en": "Intraosseöz",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Zor damar yolunda tekrarlayan kör denemelerden kaçınılmalıdır. 1. Erken yardım çağır. 2. Ultrason eşliğinde periferik IV denenir. 3. Daha proksimal damarlar veya external jugular düşünülebilir. 4. Acil durumda intraosseöz erişim hayat kurtarıcıdır. 5. Uzun süreli veya yüksek akım ihtiyacı varsa santral venöz kateter planlanabilir. 6. Damar yolu açılmadan indüksiyon gerekiyorsa inhalasyon indüksiyonu veya IM acil ilaçlar yalnız uygun hastada ve hazırlıkla düşünülmelidir.",
      "immediateRedFlags": [
        "Kör denemeler sonrasında damar dışına ilaç kaçmasına (ekstravazasyon) bağlı lokal iskemi/nekroz riski.",
        "Pediatrik veya şoktaki hastada 90 saniye veya 3 deneme boyunca damar yolu AÇILAMAMASI (acil intraosseöz endikasyonu).",
        "External jugular denemesi sonrası boyunda hızlı hematom veya hava embolisi şüphesi."
      ],
      "missingCriticalInformation": [
        "Girişimin aciliyet düzeyi (rutin vs. saniyelerle yarışan kriz)",
        "Hastanın koagülasyon parametreleri (invaziv derin damar yolları için risk)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Zor Periferik Damar Yolu Yönetimi",
        "Ultrason Eşliğinde Damar Yolu Teknikleri",
        "Acil İntraosseöz (IO) Erişim ve Endikasyonlar"
      ],
      "suggestedNextStepsGeneral": [
        "Kör olarak yapılan başarısız periferik denemeleri maksimum 2 ile sınırlayın.",
        "Hemen ultrason (USG) cihazını getirin ve bazilik veya sefalik venleri görüntüleyip USG eşliğinde hat açın.",
        "Acil kardiyak arrest veya derin şok durumunda zaman kaybetmeden proksimal tibia veya humerustan intraosseöz (IO) iğne yerleştirin.",
        "Uzun süreli veya yüksek hacimli infüzyon gereksinimlerinde santral venöz kateterizasyonu değerlendirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_iv_access",
          "titleTr": "Zor Damar Yolu Algoritması"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "ketamine",
          "titleTr": "Ketamin Monografı"
        }
      ],
      "doNotMiss": [
        "Acil durumlarda (arrest/şok) intraosseöz yolun periferik IV ile aynı hızda ve etkinlikte ilaç/sıvı perfüzyonu sağladığını"
      ],
      "whenToEscalate": [
        "Hiçbir yolla vasküler erişim sağlanamayan acil durumlarda derhal cerrahi venöz cut-down (kesi) veya acil femoral CVC planlayın"
      ],
      "referencesToShow": [
        "ASA Guidelines on Difficult Vascular Access. Anesthesiology 2020.",
        "Infusion Therapy Standards of Practice. 2021."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Avoid repeated blind attempts. Call for help early. Use ultrasound-guided peripheral IV access. Consider more proximal veins or external jugular access. In emergencies, intraosseous access can be lifesaving. If long-term or high-flow access is needed, plan central venous catheterization. Induction without IV access, such as inhalational induction or IM emergency medications, should only be considered in appropriate patients with preparation.",
      "immediateRedFlags": [
        "Extravasation of vesicant drugs (e.g. vasopressors, calcium) causing tissue necrosis.",
        "Inability to secure vascular access within 90 seconds in a coding or severely shocked patient (immediate IO indication).",
        "Accidental carotid artery puncture during deep neck attempts."
      ],
      "missingCriticalInformation": [
        "Urgency of the procedure (routine elective vs. emergent resuscitation)",
        "Coagulation profile (critical for deep, non-compressible vessel attempts)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Difficult Peripheral Venous Access Management",
        "Ultrasound-Guided Vascular Access Techniques",
        "Emergency Intraosseous (IO) Insertion Standards"
      ],
      "suggestedNextStepsGeneral": [
        "Limit blind peripheral attempts to a maximum of 2 before switching to alternative methods.",
        "Bring the ultrasound machine to the bedside and utilize a long catheter for deep forearm/arm veins.",
        "In emergency arrest or profound shock, immediately place a proximal tibia or humeral intraosseous line.",
        "Consider central venous access if multiple peripheral and ultrasound attempts fail and large volume/vasopressor support is mandatory."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_iv_access",
          "titleTr": "Difficult IV Access Algorithm"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "ketamine",
          "titleTr": "Ketamine Monograph"
        }
      ],
      "doNotMiss": [
        "Intraosseous lines allow rapid administration of all resuscitation drugs and fluids at flow rates comparable to central lines"
      ],
      "whenToEscalate": [
        "In catastrophic vascular access failure, consult vascular surgery for emergent cut-down or perform emergent ultrasound-guided femoral line placement"
      ],
      "referencesToShow": [
        "ASA Guidelines on Difficult Vascular Access. Anesthesiology 2020.",
        "Infusion Therapy Standards of Practice. 2021."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "central_line_ultrasound",
    "category": "clinical_scenarios",
    "keywords": [
      "central",
      "kateter",
      "line",
      "santral",
      "ultrasound",
      "venöz"
    ],
    "question_tr": "Santral kateter",
    "question_en": "Santral venöz",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Santral venöz kateter için endikasyon, koagülasyon durumu, enfeksiyon riski ve uygun damar seçimi değerlendirilir. Ultrason rehberliği komplikasyonu azaltabilir. Temel güvenlik: steril bariyer, uygun pozisyon, damar-arter ayrımı, iğne ucunu görerek ilerleme, aspirasyon, telin rahat ilerlemesi, dilatasyon öncesi tel konumu doğrulama ve işlem sonrası komplikasyon kontrolüdür. Pnömotoraks, arter ponksiyonu, hematom, hava embolisi, aritmi ve malpozisyon açısından izlem yapılır.",
      "immediateRedFlags": [
        "Kateter takıldıktan hemen sonra gelişen dispne, göğüs ağrısı ve satürasyon düşüşü (pnömotoraks).",
        "Kılavuz telin (guidewire) damar içine kaçması ve kaybolması (ciddi sistemik emboli riski!).",
        "Kateter enjeksiyonu anında gelişen ani bradikardi veya disritmi (telin sağ ventrikülü uyarması)."
      ],
      "missingCriticalInformation": [
        "Hastanın güncel trombosit ve INR değerleri (özellikle subklavian girişimler öncesi)",
        "Hastanın daha önce aynı bölgeden geçirilmiş tromboz veya kateter öyküsü"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Ultrason Eşliğinde Santral Kateter Güvenliği",
        "Santral Hat Enfeksiyon Önleme Standartları",
        "Kılavuz Tel (Guidewire) Kaybı ve Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "İşlemde maksimum steril bariyer önlemleri (steril önlük, eldiven, geniş örtü, USG kılıfı) uygulayın.",
        "Ultrason altında internal juguler ven (çökebilir) ve karotid arterin (pulsatil, kalın duvarlı) ayrımını netleştirin.",
        "İğnenin damara girdiğini aspire ederek kanıtlayın ve kılavuz teli zorlamadan ilerletin.",
        "Kateteri yerleştirdikten sonra klemplemeden önce tüm lümenlerden kan aspire edip serum fizyolojik ile yıkayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "cvc_safety",
          "titleTr": "Santral Kateter Güvenlik Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "coagulation",
          "titleTr": "Koagülasyon Değerlendirme"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "local_anesthetics",
          "titleTr": "Lokal Anestezikler"
        }
      ],
      "doNotMiss": [
        "Kılavuz telin (guidewire) ucu hiçbir zaman elden bırakılmamalıdır; tel kaybı acil floroskopik çıkarma gerektirir"
      ],
      "whenToEscalate": [
        "Kateter yerleşimi sonrası kontrolsüz boyun hematomu veya tansiyon pnömotoraks gelişirse derhal işlemi durdurun, acil girişim planlayın"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Central Venous Access. Anesthesiology 2020. PMID: 32057754.",
        "CDC Guidelines for the Prevention of Intravascular Catheter-Related Infections. 2017."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Assess indication, coagulation, infection risk, and vessel choice. Ultrasound guidance can reduce complications. Use sterile barrier precautions, proper positioning, vein-artery differentiation, needle-tip visualization, aspiration, smooth guidewire passage, guidewire confirmation before dilation, and post-procedure complication checks. Monitor for pneumothorax, arterial puncture, hematoma, air embolism, arrhythmia, and malposition.",
      "immediateRedFlags": [
        "Sudden acute dyspnea and ipsilateral pleuritic chest pain during internal jugular or subclavian access.",
        "Loss of control of the guidewire (completely embolized into the circulation).",
        "Severe cardiac arrhythmias or ectopy during wire advancement."
      ],
      "missingCriticalInformation": [
        "Coagulation panel (platelet count, INR) in patients scheduled for non-compressible subclavian access",
        "History of deep vein thrombosis or prior central catheters on the target side"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Ultrasound-Guided Central Venous Catheterization (CVC)",
        "Prevention of Central Line-Associated Bloodstream Infections (CLABSI)",
        "Guidewire Embolization Safety Standards"
      ],
      "suggestedNextStepsGeneral": [
        "Maintain absolute sterile barrier precautions (sterile gown, gloves, full-body drape, sterile probe cover).",
        "Differentiate the internal jugular vein from the carotid artery using compressibility and color Doppler.",
        "Ensure the guidewire passes smoothly without tactile resistance; never force the wire.",
        "Verify catheter tip position with a post-procedure chest X-ray or ultrasound dynamic evaluation."
      ],
      "relatedAlgorithms": [
        {
          "id": "cvc_safety",
          "titleTr": "CVC Safety Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "coagulation",
          "titleTr": "Coagulation Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "local_anesthetics",
          "titleTr": "Local Anesthetics"
        }
      ],
      "doNotMiss": [
        "Never let go of the guidewire at any stage of the procedure until it is safely removed from the patient"
      ],
      "whenToEscalate": [
        "If the guidewire is lost inside the patient, secure the catheter, do not dilate further, and contact interventional radiology immediately for loop-snare retrieval"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Central Venous Access. Anesthesiology 2020. PMID: 32057754.",
        "CDC Guidelines for the Prevention of Intravascular Catheter-Related Infections. 2017."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "central_line_arterial_puncture",
    "category": "clinical_scenarios",
    "keywords": [
      "arter",
      "arterde",
      "arterial",
      "central",
      "kateter",
      "line",
      "ponksiyonu",
      "puncture"
    ],
    "question_tr": "Arter ponksiyonu",
    "question_en": "Kateter arterde",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "İğne ile küçük arter ponksiyonu olduysa iğne çıkarılır ve yeterli süre bası uygulanır. Ancak büyük dilatör veya kateter arter içine yerleştirildiyse kateter kör şekilde çekilmemelidir. Vasküler cerrahi/intervansiyonel radyoloji çağrılır ve görüntüleme/onarım planlanır. Antikoagülasyon, ponksiyon yeri ve hematom/havayolu basısı riski değerlendirilmelidir. Özellikle karotis/subklavian arter yaralanması ciddi komplikasyondur.",
      "immediateRedFlags": [
        "Internal juguler ven yerine karotid arterin dilatörle genişletilmesi veya kateterize edilmesi.",
        "Boyunda gelişen hızlı, pulsatil ve bası yapan hematom (hava yolunu tıkayabilir!).",
        "Arter hasarı sonrası gelişen fokal nörolojik defisit (karotid diseksiyonu/inme)."
      ],
      "missingCriticalInformation": [
        "Artere yerleştirilen cihazın çapı (örn. ince iğne vs. 7F veya 8.5F dilatör)",
        "Hastanın antikoagülan durumu (heparin, aspirin, varfarin alımı)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Santral Kateterizasyonda İstenmeyen Arter Ponksiyonu",
        "Karotid Arter Hasarı ve Cerrahi Onarım",
        "Boyun Hematomu ve Havayolu Basısı"
      ],
      "suggestedNextStepsGeneral": [
        "İğne ile arter ponksiyonunda (pulsatil açık kırmızı kan) iğneyi çekin ve en az 10-15 dakika kesintisiz bası uygulayın.",
        "Büyük dilatör veya kateter artere yerleşmişse kateteri KESİNLİKLE ÇEKMEYİN (masif kontrolsüz kanamaya yol açar).",
        "Derhal vasküler cerrahi ve girişimsel radyoloji konsültasyonu isteyin.",
        "Hasta koagülopatik ise gerekirse taze donmuş plazma veya antidotlar hazırlayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "cvc_safety",
          "titleTr": "Santral Kateter Güvenlik Algoritması"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "protamine",
          "titleTr": "Protamin Monografı"
        }
      ],
      "doNotMiss": [
        "Arteriyal yerleşim şüphesinde kan gazı pO₂ analizi veya basınç dalga formu monitörizasyonu ile arteriyal hattın doğrulanabileceğini"
      ],
      "whenToEscalate": [
        "Arter ponksiyonuna bağlı hızlı boyun hematomu gelişip havayoluna bası yaparsa derhal acil havayolu algoritmasını başlatın ve hastayı entübe edin"
      ],
      "referencesToShow": [
        "Management of Accidental Arterial Cannulation During Central Access. Journal of Vascular Surgery 2018.",
        "ASA Guidelines on CVC Complications. 2020."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "If a small arterial needle puncture occurs, remove the needle and apply firm pressure. If a large dilator or catheter has been placed into an artery, do not blindly remove it. Call vascular surgery/interventional radiology and plan imaging/repair. Assess anticoagulation, puncture site, and risk of hematoma or airway compression. Carotid/subclavian arterial injury can be serious.",
      "immediateRedFlags": [
        "Accidental dilation or catheter placement into the carotid or subclavian artery.",
        "Rapidly expanding neck hematoma causing airway deviation or stridor.",
        "Acute stroke symptoms or hemiparesis following arterial trauma."
      ],
      "missingCriticalInformation": [
        "Gauge of the needle or caliber of the dilator placed in the artery (e.g. 18G needle vs. 8.5F RIM catheter)",
        "Patient's current coagulation status and use of active antiplatelet or anticoagulant medications"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Accidental Arterial Puncture and Cannulation in Central Access",
        "Carotid Artery Injury and Endovascular Repair",
        "Compressive Neck Hematoma Airway Management"
      ],
      "suggestedNextStepsGeneral": [
        "For needle-only arterial puncture, immediately withdraw the needle and apply direct pressure for at least 10 minutes.",
        "If a large dilator or catheter is inside the artery, LEAVE IT IN PLACE to tamponade the bleeding.",
        "Obtain an urgent vascular surgery and interventional radiology consultation.",
        "Prepare for potential surgical exploration or endovascular stenting/repair."
      ],
      "relatedAlgorithms": [
        {
          "id": "cvc_safety",
          "titleTr": "CVC Safety Algorithm"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "protamine",
          "titleTr": "Protamine Monograph"
        }
      ],
      "doNotMiss": [
        "Blindly removing an arterially placed large-bore catheter can cause catastrophic, uncontrollable retroesophageal bleeding or hematoma"
      ],
      "whenToEscalate": [
        "If neck hematoma threatens airway patency, secure the airway immediately with endotracheal intubation before complete airway collapse occurs"
      ],
      "referencesToShow": [
        "Management of Accidental Arterial Cannulation During Central Access. Journal of Vascular Surgery 2018.",
        "ASA Guidelines on CVC Complications. 2020."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "central_line_pneumothorax",
    "category": "clinical_scenarios",
    "keywords": [
      "central",
      "line",
      "pneumothorax",
      "pnömotoraks",
      "santral",
      "sonrası"
    ],
    "question_tr": "Santral sonrası pnömotoraks",
    "question_en": "Santral sonrası pnömotoraks",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Santral kateter sonrası dispne, hipoksemi, göğüs ağrısı, yüksek havayolu basıncı veya hemodinamik bozulma pnömotoraks düşündürür. 1. Oksijen ver. 2. Akciğer ultrasonu veya grafi ile değerlendir; instabil hastada görüntüleme beklenmez. 3. Tansiyon pnömotoraks şüphesinde acil dekompresyon gerekir. 4. Küçük stabil pnömotoraks izlenebilir; büyük/semptomatik olguda tüp torakostomi gerekebilir. 5. Pozitif basınçlı ventilasyon pnömotoraksı kötüleştirebilir.",
      "immediateRedFlags": [
        "Kateter takılması sırasında veya sonrasında gelişen ani trakeal sapma, hipotansiyon ve SpO₂ düşüşü (Tansiyon Pnömotoraks).",
        "Oskültasyonda tek taraflı solunum seslerinin tamamen kaybolması.",
        "Ventilatörde pik havayolu basıncının aniden tavan yapması."
      ],
      "missingCriticalInformation": [
        "Pnömotoraksın radyolojik veya USG ile saptanan boyutu (akciğer kolaps yüzdesi)",
        "Hastanın pozitif basınçlı mekanik ventilasyon altında olup olmadığı (risk katlanır)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "CVC Sonrası İyatrojenik Pnömotoraks",
        "Tansiyon Pnömotoraks ve İğne Dekompresyonu",
        "Akciğer Ultrasonu ve Plevral Çizgi Analizi"
      ],
      "suggestedNextStepsGeneral": [
        "Pnömotoraks şüphesinde hastaya derhal %100 yüksek akım oksijen desteği başlayın.",
        "Ultrason ile plevral çizgi ve 'lung sliding' (akciğer kayması) varlığını kontrol edin (kayma yoksa pnömotoraks lehinedir).",
        "Hemodinamik instabilite gelişirse görüntüleme beklemeden acil dekompresyon yapın.",
        "Stabil hastalarda akciğer grafisi çekerek pnömotoraksın boyutunu değerlendirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "pneumothorax",
          "titleTr": "Pnömotoraks Yönetim Algoritması"
        },
        {
          "id": "cvc_safety",
          "titleTr": "Santral Kateter Güvenlik Algoritması"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Tansiyon pnömotoraks durumunda radyoloji grafisi beklemek KESİNLİKLE kontrendikedir; tanı klinik olarak konur"
      ],
      "whenToEscalate": [
        "Tansiyon pnömotoraksta 2. interkostal aralık midklaviküler çizgiden (veya 4-5. interkostal aralık anterior aksiller çizgiden) kalın iğneyle dekompresyon yapın ve göğüs tüpü taktırın"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines on Central Access. Anesthesiology 2020.",
        "British Thoracic Society Guidelines for the Management of Spontaneous Pneumothorax. 2010."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Dyspnea, hypoxemia, chest pain, high airway pressure, or hemodynamic compromise after central line placement suggests pneumothorax. Provide oxygen. Use lung ultrasound or chest imaging if stable; do not wait for imaging in an unstable patient. Suspected tension pneumothorax requires immediate decompression. Small stable pneumothorax may be observed, while large or symptomatic cases may require tube thoracostomy. Positive pressure ventilation may worsen pneumothorax.",
      "immediateRedFlags": [
        "Sudden hypotension, tracheal deviation, and severe hypoxemia during central access (Tension Pneumothorax).",
        "Unilateral absent breath sounds on lung auscultation.",
        "Sudden high peak inspiratory pressure alarm on the mechanical ventilator."
      ],
      "missingCriticalInformation": [
        "Size of the pneumothorax on chest radiograph or ultrasound",
        "Whether the patient is receiving positive-pressure mechanical ventilation (accelerates tension pneumothorax)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Post-CVC Iatrogenic Pneumothorax",
        "Diagnosis and Management of Tension Pneumothorax",
        "Lung Ultrasound for Pleural Line and Lung Sliding"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately administer 100% high-flow supplemental oxygen.",
        "Perform bedside lung ultrasound to look for absent 'lung sliding' or 'lung point' sign.",
        "Avoid positive pressure ventilation if possible or keep airway pressures minimized.",
        "Consult thoracic surgery for chest tube (tube thoracostomy) placement if indicated."
      ],
      "relatedAlgorithms": [
        {
          "id": "pneumothorax",
          "titleTr": "Pneumothorax Management Algorithm"
        },
        {
          "id": "cvc_safety",
          "titleTr": "CVC Safety Algorithm"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Tension pneumothorax is a strictly clinical diagnosis; waiting for a chest X-ray in an unstable patient is dangerous"
      ],
      "whenToEscalate": [
        "For tension pneumothorax, perform immediate needle decompression in the 2nd intercostal space, midclavicular line, or 4th/5th intercostal space, anterior axillary line, and prepare for chest tube insertion"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines on Central Access. Anesthesiology 2020.",
        "British Thoracic Society Guidelines for the Management of Spontaneous Pneumothorax. 2010."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "arterial_line_complications",
    "category": "clinical_scenarios",
    "keywords": [
      "arter",
      "arterial",
      "complications",
      "distal",
      "hattı",
      "iskemi",
      "kanülü",
      "line"
    ],
    "question_tr": "Arter hattı",
    "question_en": "Distal iskemi",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Arter hattı komplikasyonları hematom, kanama, arter spazmı, tromboz, distal iskemi, enfeksiyon, sinir hasarı ve yanlış ilaç enjeksiyonudur. 1. Kollateral dolaşım ve uygun arter seçimi değerlendirilir. 2. Steril teknik kullanılır. 3. Dalga formu ve basınç sistemi doğru sıfırlanır. 4. Distal renk, ısı, kapiller dolum ve ağrı izlenir. 5. İskemi, ciddi ağrı, nörolojik belirti veya distal perfüzyon bozulursa kateter çıkarma ve vasküler değerlendirme gerekir.",
      "immediateRedFlags": [
        "Kanül takılı el veya parmaklarda gelişen ani solukluk, soğukluk ve kapiller dolum kaybı (distal iskemi).",
        "Kateter lümeninden yanlışlıkla vazoaktif veya toksik ilaç enjekte edilmesi (yoğun doku nekrozu riski!).",
        "Kateter etrafından durdurulamayan masif arteriyel kanama gelişmesi."
      ],
      "missingCriticalInformation": [
        "İşlem öncesinde yapılan Allen testinin veya USG Doppler akım değerlendirmesinin sonucu",
        "Arter hattının kalış süresi (48-72 saat üzerinde enfeksiyon ve tromboz riski katlanır)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Arteriyel Kanülasyon ve Komplikasyon Yönetimi",
        "Distal İskemi ve Arter Spazmı",
        "Arter İçi İlaç Enjeksiyonu Kriz Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Arter hattı yerleştirmeden önce Allen testi veya ultrason ile ulnar kollateral akımı doğrulayın.",
        "Distal perfüzyonu (parmak uçlarının rengi, ısısı, nabzı) her vardiyada değerlendirin.",
        "Arteriyel spazm şüphesinde ılık kompres uygulayın ve kateteri manipüle etmeyin.",
        "Distal iskemi belirtisinde arter hattını hiç zaman kaybetmeden derhal çekin."
      ],
      "relatedAlgorithms": [
        {
          "id": "arterial_line_safety",
          "titleTr": "Arter Hattı Güvenlik Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Ortalama Arter Basıncı"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Arter hattına kesinlikle IV ilaç enjeksiyonu yapılmaması gerektiğini, hatların 'ARTER' olarak kırmızı etiketlenmesi gerektiğini"
      ],
      "whenToEscalate": [
        "Arter hattı çekilmesine rağmen distal el iskemisi ve renk değişikliği düzelmezse acil vasküler cerrahi konsültasyonu isteyin"
      ],
      "referencesToShow": [
        "Complications of Arterial Cannulation. Anesthesia & Analgesia 2016. PMID: 29016373.",
        "AHA Guide to Peripheral Vascular Monitoring. 2018."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Arterial line complications include hematoma, bleeding, arterial spasm, thrombosis, distal ischemia, infection, nerve injury, and accidental intra-arterial drug injection. Assess collateral circulation and artery choice, use sterile technique, zero and level the transducer correctly, and monitor distal color, temperature, capillary refill, and pain. Ischemia, severe pain, neurologic symptoms, or impaired distal perfusion requires catheter removal and vascular evaluation.",
      "immediateRedFlags": [
        "Sudden blanching, coldness, or loss of capillary refill in the fingers distal to the radial line.",
        "Accidental injection of any intravenous medication (especially propofol, vasopressors, or thiopental) into the arterial line.",
        "Severe expanding hematoma compressing the adjacent peripheral nerve (e.g. median nerve)."
      ],
      "missingCriticalInformation": [
        "Pre-procedural Allen's test results or ultrasound verification of collateral flow",
        "Total duration the arterial cannula has been in place (prolonged use increases thrombotic risk)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Arterial Cannulation Complications and Prevention",
        "Distal Limb Ischemia and Arterial Spasm",
        "Intra-arterial Drug Injection Emergency Protocol"
      ],
      "suggestedNextStepsGeneral": [
        "Confirm collateral circulation via modified Allen's test or Doppler before radial artery cannulation.",
        "Examine the cannulated extremity frequently for perfusion, color, and temperature.",
        "Label all arterial lines and ports clearly in RED to prevent accidental drug injection.",
        "Remove the cannula immediately at the first sign of distal ischemia or persistent arterial dampening."
      ],
      "relatedAlgorithms": [
        {
          "id": "arterial_line_safety",
          "titleTr": "Arterial Line Safety Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Mean Arterial Pressure"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Accidental intra-arterial injection of drugs can trigger immediate intense vasospasm and microvascular thrombosis, requiring local vasodilator therapy"
      ],
      "whenToEscalate": [
        "If digital ischemia persists after cannula removal, urgently consult vascular surgery for potential surgical or thrombolytic intervention"
      ],
      "referencesToShow": [
        "Complications of Arterial Cannulation. Anesthesia & Analgesia 2016. PMID: 29016373.",
        "AHA Guide to Peripheral Vascular Monitoring. 2018."
      ],
      "safetyLevel": "elective"
    }
