  {
    "id": "clinical_followup_anticoagulant_regional_complications_0",
    "category": "clinical_followups",
    "keywords": [
      "anticoagulant",
      "antikoagülan",
      "clinical_followup_anticoagulant_regional_complications_0",
      "complications",
      "epidural",
      "followup",
      "hematom",
      "hematoma",
      "spinal",
      "var0"
    ],
    "question_tr": "Antikoagülan uyumsuzluğunun komplikasyonları nelerdir?",
    "question_en": "What are the complications of anticoagulant non-compliance?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 En korkulan komplikasyon spinal epidural hematomdur. Bel ağrısı, bacaklarda ani başlayan motor/duyusal kayıp ve idrar kaçırma en önemli belirtileridir. Şüphe durumunda ilk 8 saat içinde derhal acil laminektomi (dekompresyon) yapılmazsa felç kalıcı hale gelir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 The most feared complication is a spinal epidural hematoma. Key signs include back pain, rapid motor/sensory block progression, and bowel/bladder dysfunction. Urgent surgical decompression (laminectomy) is mandatory within 8 hours to prevent permanent paraplegia.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    }
  },
