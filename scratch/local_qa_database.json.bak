  {
    "id": "clinical_followup_spinal_hypotension_contraindications_0",
    "category": "clinical_followups",
    "keywords": [
      "blok",
      "clinical_followup_spinal_hypotension_contraindications_0",
      "contraindications",
      "followup",
      "hipotansiyon",
      "hypotension",
      "post",
      "spinal",
      "var0"
    ],
    "question_tr": "Vazopressörlerin kontrendikasyonları nelerdir?",
    "question_en": "What are the contraindications of vasopressors?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "⚠️ Fenilefrin, refleks bradikardi yaptığı için ciddi bradikardisi (<50 bpm) olan hastalarda kaçınılmalıdır. Efedrin ise güçlü beta-mimetik etkisiyle taşikardi yapacağından, taşiaritmisi veya ciddi koroner arter hastalığı olanlarda kontrendikedir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "⚠️ Phenylephrine should be avoided in severe bradycardia (<50 bpm) due to its propensity to induce reflex bradycardia. Ephedrine is contraindicated in patients with severe tachyarrhythmias or unstable coronary syndromes due to tachycardia risk.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
