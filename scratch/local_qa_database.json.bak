  {
    "id": "ercp_prone_sedation_safety",
    "category": "clinical_scenarios",
    "keywords": [
      "ercp",
      "prone",
      "safety",
      "sedasyon",
      "sedation",
      "yüzüstü"
    ],
    "question_tr": "Ercp sedasyon",
    "question_en": "Ercp prone",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Prone ERCP’de hava yoluna erişim zordur; sedasyon derinleşirse ventilasyon ve entübasyon gecikebilir. Aspirasyon riski, pankreatobiliyer hastalık, sepsis, yaşlılık ve kardiyopulmoner komorbidite değerlendirilmelidir. Kapnografi çok değerlidir. Yüksek riskli hastada genel anestezi ve entübasyon daha güvenli olabilir. Sedasyon seçilirse hasta pozisyonu, ağızlık, suction, acil supin çevirme ve ileri havayolu planı önceden netleştirilmelidir.",
      "immediateRedFlags": [
        "Prone pozisyondayken gelişen ani solunum arresti, derin desatürasyon veya obstrüksiyon.",
        "ERCP esnasında gelişen masif kusma (prone pozisyonda aspirasyon riski katlanır).",
        "Sepsise bağlı olarak gelişen ani hemodinamik şok tablosu (MAP < 60 mmHg)."
      ],
      "missingCriticalInformation": [
        "Hastanın bazal pulmoner rezervi ve eşlik eden kardiyak hastalıkları",
        "Hastanın acil durumda supin pozisyona çevrilmesini zorlaştıracak anatomik veya ortopedik kısıtlılıklar"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Prone Pozisyonda ERCP Sedasyonu",
        "Ameliyathane Dışı Anestezi (NORA) Güvenliği",
        "Prone Pozisyonda Acil Havayolu Kurtarma"
      ],
      "suggestedNextStepsGeneral": [
        "Yüksek riskli (morbid obez, ağır KOAH, aktif kolanjit/sepsis) hastada sedasyon yerine entübe ederek genel anestezi tercih edin.",
        "Sedasyon uygulanacaksa, acil durumda hastayı hızla sırtüstü çevirebilmek için yatak mekanizmasını ve transfer tahtasını hazır bulundurun.",
        "Prone pozisyonda solunumsal baskılanmayı tespit etmek için nazal kapnografi (EtCO₂) takibini zorunlu kılın.",
        "Ağızlığın (bite block) yerleşimini ve havayolu açıklığını her cerrahi manevrada manuel kontrol edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "nora_safety",
          "titleTr": "NORA Güvenlik Protokolü"
        },
        {
          "id": "aspiration",
          "titleTr": "Aspirasyon Önleme Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "sedation_score",
          "titleTr": "Sedasyon Derinliği Skoru"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        },
        {
          "id": "ketamine",
          "titleTr": "Ketamin Monografı"
        },
        {
          "id": "dexmedetomidine",
          "titleTr": "Dekmedetomidin Monografı"
        }
      ],
      "doNotMiss": [
        "Prone pozisyondayken acil entübasyon yapmanın son derece zor olduğunu, bu nedenle havayolu şüphesi olan hastada baştan entübasyon planlanması gerektiğini"
      ],
      "whenToEscalate": [
        "Prone pozisyonda solunum depresyonu gelişirse ve çene itme (jaw thrust) ile düzelmiyorsa, derhal işlemi durdurun, hastayı supin çevirin ve entübe edin"
      ],
      "referencesToShow": [
        "Anesthesia for ERCP. Anesthesiology Clinics 2017. PMID: 29016373.",
        "ASA Guidelines on Moderate Procedural Sedation. 2018."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "In prone ERCP, airway access is difficult; if sedation deepens, ventilation and intubation may be delayed. Assess aspiration risk, pancreatobiliary disease, sepsis, older age, and cardiopulmonary comorbidity. Capnography is very valuable. In high-risk patients, general anesthesia with intubation may be safer. If sedation is chosen, clarify positioning, bite block, suction, emergency turn-supine plan, and advanced airway plan in advance.",
      "immediateRedFlags": [
        "Sudden apnea or persistent desaturation while positioned in prone.",
        "Vomiting or regurgitation under prone sedation (catastrophic aspiration risk).",
        "Septic shock crisis (precipitous MAP drop) secondary to biliary manipulation."
      ],
      "missingCriticalInformation": [
        "Patient's baseline oxygenation on room air and presence of gastric outlet obstruction",
        "Ability of the table and staff to perform an emergency rapid supine flip"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Prone ERCP Sedation Risks",
        "Non-Operating Room Anesthesia (NORA) Safety",
        "Emergency Airway Management in Prone Position"
      ],
      "suggestedNextStepsGeneral": [
        "Have a low threshold for endotracheal general anesthesia in high-risk patients (obese, severe OSA, active sepsis).",
        "Confirm a coordinated emergency plan with the staff for a rapid supine flip, keeping a transfer board ready.",
        "Mandate continuous nasal capnography (EtCO₂) to identify hypoventilation in prone.",
        "Maintain a moderate sedation level and ensure high-volume suction is within arm's reach."
      ],
      "relatedAlgorithms": [
        {
          "id": "nora_safety",
          "titleTr": "NORA Safety Protocol"
        },
        {
          "id": "aspiration",
          "titleTr": "Aspiration Protocol"
        }
      ],
      "relatedCalculators": [
        {
          "id": "sedation_score",
          "titleTr": "RASS/Sedation Score"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        },
        {
          "id": "ketamine",
          "titleTr": "Ketamine Monograph"
        },
        {
          "id": "dexmedetomidine",
          "titleTr": "Dexmedetomidine Monograph"
        }
      ],
      "doNotMiss": [
        "Emergency intubation in the prone position is extremely hazardous; do not hesitate to secure the airway pre-procedure if risk is high"
      ],
      "whenToEscalate": [
        "In case of unmanageable airway obstruction or aspiration in prone, stop the procedure, immediately flip the patient supine, and secure the airway"
      ],
      "referencesToShow": [
        "Anesthesia for ERCP. Anesthesiology Clinics 2017. PMID: 29016373.",
        "ASA Guidelines on Moderate Procedural Sedation. 2018."
      ],
      "safetyLevel": "elective"
    }
