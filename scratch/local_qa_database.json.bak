    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Clopidogrel is generally held for 5–7 days before neuraxial procedures. In urgent cases, bleeding risk, surgical urgency, alternative anesthesia options, and thrombotic risk must be weighed together. If an epidural catheter is present, timing of antiplatelet restart and catheter removal should follow ASRA/institutional protocols.",
      "immediateRedFlags": [
        "Performing neuraxial procedures or epidural catheter removal without stopping Clopidogrel carries high risk of spinal hematoma.",
        "Premature cessation of Clopidogrel in patients with drug-eluting coronary stents can trigger catastrophic acute stent thrombosis."
      ],
      "missingCriticalInformation": [
        "Exact timing of the last Clopidogrel dose",
        "History of coronary artery stenting and the date of stent placement"
      ],
      "likelyClinicalCategoriesToConsider": [
