  {
    "id": "ultrasound_guided_block",
    "category": "clinical_scenarios",
    "keywords": [
      "block",
      "blok",
      "enjeksiyon",
      "eşliğinde",
      "fractionated",
      "fraksiyone",
      "guided",
      "injection",
      "iğne",
