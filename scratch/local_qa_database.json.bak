    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "⚠️ Phenylephrine should be avoided in severe bradycardia (<50 bpm) due to its propensity to induce reflex bradycardia. Ephedrine is contraindicated in patients with severe tachyarrhythmias or unstable coronary syndromes due to tachycardia risk.",
      "immediateRedFlags": [],
