      ],
      "whenToEscalate": [
        "Blok sonrasında beklenenden uzun süren (>24-48 saat) kalıcı nörolojik defisit varlığında nöroloji konsültasyonu ve EMG planlayın"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Femoral Block.",
        "Miller's Anesthesia, 9th Edition."
      ],
