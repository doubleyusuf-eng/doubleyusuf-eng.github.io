      "relatedDrugCards": [],
      "doNotMiss": [
        "Normal Mallampati sınıfı (Sınıf I-II) olan hastaların da ciddi zor entübasyon olabileceğini"
      ],
      "whenToEscalate": [
        "Hasta ciddi retrognatikse ve Mallampati IV ise elektif cerrahi öncesi uyanık entübasyon veya alternatif plan hazırlayın"
      ],
      "referencesToShow": [
        "Mallampati Clinical Airway Assessment Validation. 1985.",
        "2022 ASA Practice Guidelines for Management of the Difficult Airway."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "No. Mallampati alone does not reliably predict difficult intubation. A high Mallampati score may increase risk, but a normal Mallampati does not exclude difficulty. Assessment should include mouth opening, thyromental distance, upper lip bite test, neck mobility, mandibular movement, dentition, obesity, OSA, and previous airway history. Clinically, the most valuable information is often a prior anesthesia record documenting difficult mask ventilation or intubation.",
      "immediateRedFlags": [
        "Mallampati Class IV accompanied by microcephaly, retrognathia, or trismus.",
        "Upper airway masses, abscesses, or active stridor.",
        "Total cervical spine immobility (e.g., ankylosing spondylitis)."
      ],
      "missingCriticalInformation": [
        "Prior anesthesia records",
        "The patient's thyromental distance, mandibular protrusion, and mouth opening measurements"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Mallampati Limitations",
        "Difficult Airway Predictors",
        "Preoperative Evaluation"
      ],
      "suggestedNextStepsGeneral": [
        "Do not rely on Mallampati score in isolation for ruling out difficult airway.",
        "Combine multiple airway assessment tests and thorough history.",
        "Ensure a videolaryngoscope is immediately available in the room if high clinical suspicion exists.",
        "Obtain and review previous anesthesia charts if available."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway"
        }
      ],
      "relatedCalculators": [
        {
          "id": "airway_checklist",
          "titleTr": "Airway Checklist"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Normal Mallampati class (Class I-II) can still lead to difficult intubation"
      ],
      "whenToEscalate": [
        "For patients with retrognathia and Mallampati IV, plan awake intubation or alternative strategies for elective surgery"
      ],
      "referencesToShow": [
        "Mallampati Clinical Airway Assessment Validation. 1985.",
        "2022 ASA Practice Guidelines for Management of the Difficult Airway."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "mouth_opening_thyromental",
    "category": "clinical_scenarios",
    "keywords": [
      "açıklığı",
      "ağız",
      "mouth",
      "opening",
      "thyromental",
      "tiromental"
    ],
    "question_tr": "Thyromental",
    "question_en": "Mouth opening",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Ağız açıklığı laringoskop, videolaringoskop, supraglottik airway ve fiberoptik ekipmanın yerleştirilmesini etkiler. Ciddi kısıtlı ağız açıklığında standart laringoskopi ve bazı supraglottik airway seçenekleri başarısız olabilir. Thyromental mesafe, mandibular alan ve dilin yer değiştirebilme kapasitesi hakkında fikir verir. Kısa mesafe laringoskopi zorluğu ile ilişkili olabilir. Ancak bu ölçümler tek başına kesin karar verdirmez; baş-boyun hareketi, mandibula protrüzyonu, patoloji ve önceki havayolu öyküsüyle birlikte yorumlanmalıdır.",
      "immediateRedFlags": [
        "Ağız açıklığının < 1.5 - 2 cm (interinsizör mesafe) olması.",
        "Thyromental mesafenin < 6 cm olması.",
        "Trismus veya temporomandibuler eklem (TME) ankilozu."
      ],
      "missingCriticalInformation": [
        "Kısıtlı ağız açıklığının nedeni (akut spazm, tümör, radyasyon fibrozu veya eklem ankilozu)",
        "Hastanın boyun fleksiyon/ekstansiyon açısı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Ağız Açıklığı ve Thyromental Mesafe",
        "Havayolu Anatomik Değerlendirmesi",
        "Laringoskopi Zorluğu"
      ],
      "suggestedNextStepsGeneral": [
        "Ağız açıklığını interinsizör mesafeyi santimetre olarak ölçerek kaydedin.",
        "Thyromental mesafeyi baş tam ekstansiyondayken tiroid çentikten mentuma kadar ölçün.",
        "Kısıtlı ağız açıklığı olan hastada standart laringoskopi yerine videolaringoskop veya uyanık fiberoptik hazırlayın.",
        "Servikal hareket kısıtlılığını değerlendirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "airway_checklist",
          "titleTr": "Havayolu Kontrol Listesi"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Kısıtlı ağız açıklığında laringoskobun yanı sıra supraglottik havayolu (LMA) yerleştirilmesinin de son derece zor veya imkansız olabileceğini"
      ],
      "whenToEscalate": [
        "Ağız açıklığı < 1.5 cm olan ve major cerrahi planlanan hastalarda zor havayolu protokolünü aktive edin ve uyanık entübasyon planı yapın"
      ],
      "referencesToShow": [
        "2022 ASA Practice Guidelines for Management of the Difficult Airway.",
        "Anesthesiologist's Manual of Surgical Procedures."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Mouth opening affects insertion of laryngoscopes, videolaryngoscopes, supraglottic airways, and fiberoptic equipment. Severe limitation may make standard laryngoscopy and some supraglottic devices fail. Thyromental distance gives an idea of mandibular space and tongue displacement. A short distance may be associated with difficult laryngoscopy. These measurements alone are not definitive; interpret them with neck mobility, mandibular protrusion, pathology, and previous airway history.",
      "immediateRedFlags": [
        "Mouth opening < 1.5 - 2 cm (interincisor distance).",
        "Thyromental distance < 6 cm.",
        "Trismus or temporomandibular joint (TMJ) ankylosis."
      ],
      "missingCriticalInformation": [
        "The exact etiology of limited mouth opening (spasm, tumor, radiation fibrosis, or joint ankylosis)",
        "The patient's cervical range of motion"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Mouth Opening and Thyromental Distance",
        "Airway Anatomical Assessment",
        "Laryngoscopy Difficulty"
      ],
      "suggestedNextStepsGeneral": [
        "Measure and document the interincisor mouth opening in centimeters.",
        "Measure thyromental distance from the thyroid notch to the mentum with head fully extended.",
        "In patients with limited mouth opening, prepare videolaryngoscopy or awake fiberoptic rather than standard direct laryngoscopy.",
        "Evaluate cervical spine range of motion."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway"
        }
      ],
      "relatedCalculators": [
        {
          "id": "airway_checklist",
          "titleTr": "Airway Checklist"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "In patients with limited mouth opening, supraglottic airway (LMA) insertion may also be extremely difficult or impossible"
      ],
      "whenToEscalate": [
        "For patients with mouth opening < 1.5 cm requiring major surgery, activate difficult airway protocol and plan awake intubation"
      ],
      "referencesToShow": [
        "2022 ASA Practice Guidelines for Management of the Difficult Airway.",
        "Anesthesiologist's Manual of Surgical Procedures."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "awake_intubation_indications",
    "category": "clinical_scenarios",
    "keywords": [
      "awake",
      "entübasyon",
      "indications",
      "intubation",
      "uyanık"
    ],
    "question_tr": "Uyanık entübasyon",
    "question_en": "Awake intubation",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Uyanık entübasyon; entübasyon zor bekleniyorsa ve indüksiyon sonrası maske/SAD ventilasyonu veya acil cerrahi havayolu da zor olabilir diye düşünülüyorsa güçlü şekilde değerlendirilmelidir. Endikasyon örnekleri: ciddi ağız açıklığı kısıtlılığı, baş-boyun tümörü, radyoterapi sonrası fibrozis, servikal immobilizasyon, büyük obezite/OSAS ile zor ventilasyon riski, mediastinal kitle, trismus, üst havayolu obstrüksiyonu veya önceki ciddi zor havayolu. Amaç hastanın spontan solunumunu ve havayolu tonusunu koruyarak güvenli trakeal yerleşim sağlamaktır. DAS awake trakeal entübasyon kılavuzu karar, hazırlık ve uygulama için yapılandırılmış yaklaşım önerir. ([PMC])",
      "immediateRedFlags": [
        "Ciddi retrognati ve ağız açıklığı < 1.5 cm olan ve indüksiyonla havayolu kollapsı beklenen hastalar.",
        "Üst havayolu lümenini daraltan büyük tümör, hematom veya apse varlığı.",
        "Boyun hareketinin sıfır olması (örn. servikal instabilite veya rijit fiksatör)."
      ],
      "missingCriticalInformation": [
        "Hastanın mental durumu ve kooperasyon yeteneği",
        "Lokal anestezik toksisite riski (kiloya göre maksimum doz hesabı yapılmalı)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Uyanık Entübasyon Endikasyonları",
        "Zor Havayolu Yönetimi",
        "Havayolu Güvenliği"
      ],
      "suggestedNextStepsGeneral": [
        "Zor entübasyon ve zor maske kombinasyonu beklenen her hastada uyanık entübasyonu ilk seçenek olarak düşünün.",
        "Hastayı işlem hakkında bilgilendirerek kooperasyonunu artırın.",
        "Topikal lokal anestezi (topikalizasyon) için gerekli ekipmanı ve ilaçları hazırlayın.",
        "Hafif sedasyon eşliğinde fiberoptik veya videolaringoskop kullanarak uyanık entübasyonu gerçekleştirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "airway_checklist",
          "titleTr": "Havayolu Kontrol Listesi"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "lidocaine",
          "titleTr": "Lidokain Monografı"
        },
        {
          "id": "dexmedetomidine",
          "titleTr": "Deksmedetomidin Monografı"
        }
      ],
      "doNotMiss": [
        "Genel anestezi indüksiyonu sonrası solunum durmasıyla 'Cannot Intubate Cannot Oxygenate' (CICO) riski yüksek olan hastada uyanık entübasyonun hayat kurtarıcı olduğunu"
      ],
      "whenToEscalate": [
        "Hastanın uyanık entübasyon şüphesi olan havayoluna sahip olmasına rağmen kooperasyon kurulamıyorsa (örn. ajite, çocuk) alternatif kurtarma havayolları ve cerrahi ekip hazırda bekletilerek indüksiyon planlayın"
      ],
      "referencesToShow": [
        "Difficult Airway Society guidelines for awake tracheal intubation. Anaesthesia 2020.",
        "2022 ASA Practice Guidelines for Management of the Difficult Airway."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Awake intubation should be strongly considered when intubation is expected to be difficult and mask/SAD ventilation or emergency front-of-neck access may also be difficult after induction. Examples include severe limited mouth opening, head-neck tumor, post-radiotherapy fibrosis, cervical immobilization, severe obesity/OSA with difficult ventilation risk, mediastinal mass, trismus, upper airway obstruction, or prior severe difficult airway. The goal is to secure the trachea while preserving spontaneous breathing and airway tone. ([PMC])",
      "immediateRedFlags": [
        "Severe retrognathia and mouth opening < 1.5 cm with high risk of airway collapse upon induction.",
        "Large tumor, hematoma, or abscess narrowing the upper airway lumen.",
        "Zero neck mobility (e.g., cervical instability or rigid neck fixator)."
      ],
      "missingCriticalInformation": [
        "The patient's mental status and ability to cooperate",
        "Risk of local anesthetic systemic toxicity (maximum weight-based lidocaine dose)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Awake Intubation Indications",
        "Difficult Airway Management",
        "Airway Safety"
      ],
      "suggestedNextStepsGeneral": [
        "Consider awake intubation as the primary choice whenever difficult intubation and difficult ventilation are both anticipated.",
        "Educate the patient about the procedure to optimize cooperation.",
        "Prepare all equipment and drugs required for top-class airway topicalization.",
        "Perform awake intubation under light sedation using fiberoptic scope or videolaryngoscope."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway"
        }
      ],
      "relatedCalculators": [
        {
          "id": "airway_checklist",
          "titleTr": "Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "lidocaine",
          "titleTr": "Lidocaine Monograph"
        },
        {
          "id": "dexmedetomidine",
          "titleTr": "Dexmedetomidine Monograph"
        }
      ],
      "doNotMiss": [
        "Awake intubation is a life-saving technique in patients who carry a high risk of 'Cannot Intubate Cannot Oxygenate' (CICO) after induction"
      ],
      "whenToEscalate": [
        "If the patient has a clear indication for awake intubation but is completely uncooperative (e.g., severe agitation, pediatric), plan controlled induction with alternative rescue devices and ENT surgery standby in the room"
      ],
      "referencesToShow": [
        "Difficult Airway Society guidelines for awake tracheal intubation. Anaesthesia 2020.",
        "2022 ASA Practice Guidelines for Management of the Difficult Airway."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "awake_fiberoptic_preparation",
    "category": "clinical_scenarios",
    "keywords": [
      "awake",
      "entübasyon",
      "fiberoptic",
      "fiberoptik",
      "intubation",
      "lidocaine",
      "lidokain",
      "preparation",
      "topical",
      "topicalization",
      "topikal",
      "topikalizasyon"
    ],
    "question_tr": "Awake fiberoptik",
    "question_en": "Topical lidocaine",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Başarı hazırlığa bağlıdır. 1. Hastaya işlem açıklanır ve kooperasyon sağlanır. 2. Antisekretuar ilaç düşünülebilir. 3. Nazal/oral yol, tüp boyutu ve plan B belirlenir. 4. Topikal lokal anestezi dikkatle yapılır; toplam lidokain dozu takip edilir. 5. Sedasyon hafif ve titre olmalıdır; solunum obstrüksiyonu yaratmamalıdır. 6. Oksijenasyon sürekli sağlanır. 7. Fiberoptik, suction, videolaringoskop, SAD, cerrahi havayolu ve deneyimli yardım hazır olur. 8. Başarısızlıkta “ısrar” yerine alternatif plana geçilir.",
      "immediateRedFlags": [
        "Lokal anestezik topikalizasyon sırasında gelişen nörolojik semptomlar (kulak çınlaması, metalik tat, ajitasyon) veya konvülsiyon (LAST).",
        "Sedasyon sırasında apne gelişmesi, SpO2 düşüşü ve solunum durması.",
        "Sekresyonların aspire edilmesi ve havayolunun tamamen tıkanması."
      ],
      "missingCriticalInformation": [
        "Hastanın vücut ağırlığı (lokal anestezik limitini belirlemek için)",
        "Hastanın burun veya ağız anatomisindeki kanamaya yatkınlık (ör. koagülopati)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Awake Fiberoptik Hazırlığı",
        "Topikal Anestezi Teknikleri",
        "Sedasyon ve Oksijenasyon"
      ],
      "suggestedNextStepsGeneral": [
        "İşlemden 30 dk önce glikopirolat veya atropin ile sekresyonları azaltın.",
        "Nazal yolda vazokonstriktör (örn. ksilometazolin) ile kanama riskini azaltın.",
        "Lidokain dozunu 5-9 mg/kg'ı aşmayacak şekilde hesaplayarak topikal olarak uygulayın (sprey, gargara, 'spray-as-you-go').",
        "Sedasyon için deksmedetomidin infüzyonu veya titre remifentanil tercih edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        },
        {
          "id": "last",
          "titleTr": "Lokal Anestezik Sistemik Toksisite"
        }
      ],
      "relatedCalculators": [
        {
          "id": "airway_checklist",
          "titleTr": "Havayolu Kontrol Listesi"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "lidocaine",
          "titleTr": "Lidokain Monografı"
        },
        {
          "id": "dexmedetomidine",
          "titleTr": "Deksmedetomidin Monografı"
        }
      ],
      "doNotMiss": [
        "Topikal anestezinin yetersiz olmasının uyanık entübasyonda en sık başarısızlık nedeni olduğunu; acele etmeyip topikalizasyona yeterli süre (15-20 dk) verilmesi gerektiğini"
      ],
      "whenToEscalate": [
        "Ciddi kanama veya laringospazm gelişirse uyanık fiberoptik denemesini sonlandırın, %100 O2 ile maskeleyin ve acil alternatif havayolunu (SAD veya cerrahi) devreye alın"
      ],
      "referencesToShow": [
        "Difficult Airway Society guidelines for awake tracheal intubation. Anaesthesia 2020.",
        "2022 ASA Practice Guidelines for Management of the Difficult Airway."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Success depends on preparation. Explain the procedure and obtain cooperation. Consider antisialagogue. Decide nasal/oral route, tube size, and plan B. Apply topical local anesthesia carefully and track total lidocaine dose. Sedation should be light and titrated without causing obstruction. Maintain oxygenation continuously. Prepare fiberoptic scope, suction, videolaryngoscope, SAD, invasive airway equipment, and experienced help. If unsuccessful, avoid repeated attempts and move to the alternative plan.",
      "immediateRedFlags": [
        "Neurological symptoms (tinnitus, metallic taste, agitation) or convulsions during local anesthetic topicalization (LAST).",
        "Apnea, SpO2 drop, or respiratory arrest during sedation.",
        "Aspiration of secretions or sudden complete airway obstruction."
      ],
      "missingCriticalInformation": [
        "The patient's actual body weight (to calculate toxic limit for local anesthetics)",
        "History of coagulopathy or anatomical factors predisposing to nasal bleeding"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Awake Fiberoptic Preparation",
        "Topical Anesthesia Techniques",
        "Sedation and Oxygenation"
      ],
      "suggestedNextStepsGeneral": [
        "Administer glycopyrrolate or atropine 30 min prior to reduce secretions.",
        "For nasal access, apply a topical vasoconstrictor (e.g., xylometazoline) to reduce bleeding.",
        "Calculate and limit the total lidocaine dose to 5-9 mg/kg for topicalization (nebulizer, gargle, spray-as-you-go).",
        "Use dexmedetomidine infusion or titrated remifentanil for cooperative, awake sedation."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway"
        },
        {
          "id": "last",
          "titleTr": "Local Anesthetic Systemic Toxicity"
        }
      ],
      "relatedCalculators": [
        {
          "id": "airway_checklist",
          "titleTr": "Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "lidocaine",
          "titleTr": "Lidocaine Monograph"
        },
        {
          "id": "dexmedetomidine",
          "titleTr": "Dexmedetomidine Monograph"
        }
      ],
      "doNotMiss": [
        "Inadequate topical anesthesia is the most common cause of awake intubation failure; do not rush the topicalization process (allocate 15-20 min)"
      ],
      "whenToEscalate": [
        "In case of severe bleeding or laryngospasm, abort the awake fiberoptic attempt, ventilate with 100% O2, and immediately proceed to alternative airway management (SAD or surgical)"
      ],
      "referencesToShow": [
        "Difficult Airway Society guidelines for awake tracheal intubation. Anaesthesia 2020.",
        "2022 ASA Practice Guidelines for Management of the Difficult Airway."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "awake_intubation_sedation_complication",
    "category": "clinical_scenarios",
    "keywords": [
      "awake",
      "complication",
      "during",
      "entübasyonda",
      "intubation",
      "sedasyon",
