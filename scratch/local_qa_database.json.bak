      "dapt",
      "dual",
      "followup",
      "koroner",
      "stent",
      "var3"
    ],
    "question_tr": "Anestezi stentli hastada perioperatif yönetim nasıl yapılır?",
    "question_en": "Anesthesia how to manage dapt perioperatively in stented patients?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🛡️ Acil olmayan cerrahiler DES sonrası en az 3-6 ay, BMS sonrası en az 4 hafta ertelenmelidir. Cerrahiye giden hastalarda **Aspirin (75-100 mg)** tedavisine perioperatif dönemde kesintisiz devam edilmelidir. P2Y12 inhibitörü (Klopidogrel) ise cerrahiden 5 gün önce kesilmelidir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🛡️ Postpone elective surgery for at least 3-6 months after DES, and at least 4 weeks after BMS. For patients undergoing surgery, **Aspirin (75-100 mg)** must be continued uninterrupted throughout the perioperative period. The P2Y12 inhibitor (e.g. Clopidogrel) should be stopped 5 days prior to surgery.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
