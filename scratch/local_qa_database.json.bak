  {
    "id": "clinical_followup_spinal_hypotension_alternatives_0",
    "category": "clinical_followups",
    "keywords": [
      "alternatives",
      "blok",
      "clinical_followup_spinal_hypotension_alternatives_0",
      "followup",
      "hipotansiyon",
      "hypotension",
      "post",
      "spinal",
      "var0"
    ],
    "question_tr": "Efedrin veya fenilefrine dirençli spinal hipotansiyonda alternatif nedir?",
    "question_en": "What is the alternative in refractory spinal hypotension?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🔄 Efedrin veya Fenilefrine yanıt vermeyen dirençli vakalarda, düşük doz Noradrenalin infüzyonu (0.02 - 0.1 mcg/kg/dk) veya acil durumlarda Adrenalin (10-20 mcg IV bolus) uygulanabilir. Ek olarak bacakların elevasyonu ve agresif kristaloid/kolloid resüsitasyonu yapılmalıdır.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🔄 In refractory cases failing Ephedrine or Phenylephrine, initiate low-dose Norepinephrine infusion (0.02 - 0.1 mcg/kg/min) or rescue Epinephrine boluses (10-20 mcg IV). Elevate the patient's legs and increase crystalloid/colloid infusion rate aggressively.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
