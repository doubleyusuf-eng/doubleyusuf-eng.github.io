        },
        {
          "id": "airway_checklist",
          "titleTr": "Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ketamine",
          "titleTr": "Ketamine"
        },
        {
          "id": "etomidate",
          "titleTr": "Etomidate"
        },
        {
