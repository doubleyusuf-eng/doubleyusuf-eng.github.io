    "question_tr": "Aspirasyon oldu",
    "question_en": "After aspiration",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Aspirasyon sonrası klinik spektrum hafif öksürükten ağır hipoksemi/ARDS’ye kadar değişir. 1. SpO₂, solunum sayısı, solunum işi, ETCO₂, oskültasyon ve hemodinami izlenir. 2. Bronkospazm varsa tedavi edilir. 3. Hipoksemi varsa oksijen, CPAP/NIV veya entübasyon gerekebilir. 4. ABG ve akciğer görüntüleme klinik duruma göre yapılır. 5. Ateş, lökositoz ve infiltrasyon erken kimyasal pnömonitte de görülebilir; antibiyotik kararı klinik enfeksiyon bulgularına göre verilir. 6. Ağır aspirasyonda yoğun bakım izlemi ve akciğer koruyucu ventilasyon gerekebilir.",
      "immediateRedFlags": [
        "Aspirasyon sonrası 2 saat içinde gelişen ciddi solunum sıkıntısı ve PaO2/FiO2 oranının < 200 olması (ARDS).",
        "Akciğer oskültasyonunda yaygın raller, hırıltı ve pembe köpüklü balgam bulguları.",
        "Hızla bozulan hemodinami ve vazopressör ihtiyacı."
      ],
      "missingCriticalInformation": [
        "Aspire edilen sıvının pH'ı ve hacmi (pH < 2.5 ve volüm > 0.4 ml/kg kimyasal pnömoni için kritiktir)",
        "Hastanın bazal solunum fonksiyonları"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Aspirasyon Sonrası Yönetim",
        "Aspirasyon Pnömonisi vs Pnömoniti",
        "ARDS Akciğer Koruyucu Ventilasyon"
      ],
      "suggestedNextStepsGeneral": [
        "Aspirasyon geçiren tüm hastaları postoperatif en az 2-4 saat boyunca yakın solunum takibine alın.",
        "Bronkospazm gelişirse inhale beta-2 agonist (örn. salbutamol) uygulayın.",
        "Aspirasyon sonrası erken dönemde (ilk 24 saat) rutin profilaktik antibiyotik kullanımından kaçının.",
        "Hipoksemiyi yönetmek için PEEP/CPAP desteği sağlayın; gerekirse entübe edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "aspiration_risk",
          "titleTr": "Aspirasyon Yönetimi"
        },
        {
          "id": "ards_ventilation",
          "titleTr": "ARDS Koruyucu Ventilasyon"
        },
        {
          "id": "hypoxemia",
          "titleTr": "Hipoksemi Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "pf_ratio_calculator",
          "titleTr": "P/F Oranı"
        },
        {
          "id": "abg_interpretation",
          "titleTr": "Kan Gazı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol"
        }
      ],
      "doNotMiss": [
        "Aspirasyon sonrası gelişen tablonun başlangıçta enfeksiyon değil asidik kimyasal yanık (Mendelson sendromu/pnömoniti) olduğunu, bu nedenle hemen antibiyotik veya steroid başlanmasının yararsız olduğunu"
      ],
      "whenToEscalate": [
        "Hastada PaO2/FiO2 < 150 olan ağır hipoksemi ve bilateral infiltratlar gelişirse yoğun bakıma yatırın, düsük tidal volüm (6 ml/kg) ve yüksek PEEP ile mekanik ventilasyonu sürdürün"
      ],
      "referencesToShow": [
        "2023 American Society of Anesthesiologists Practice Guidelines for Preoperative Fasting.",
        "Mendelson's Syndrome Clinical Review."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Post-aspiration severity ranges from mild cough to severe hypoxemia/ARDS. Monitor SpO₂, work of breathing, ETCO₂, auscultation, and hemodynamics. Treat bronchospasm if present. Hypoxemia may require oxygen, CPAP/NIV, or intubation. ABG and chest imaging depend on clinical status. Fever, leukocytosis, and infiltrates can occur early in chemical pneumonitis; antibiotics should be based on clinical infection evidence rather than automatic use. Severe aspiration may require ICU care and lung-protective ventilation.",
      "immediateRedFlags": [
        "Progressive respiratory failure within 2 hours of aspiration, with PaO2/FiO2 ratio < 200 (ARDS).",
        "Widespread bilateral crackles, severe wheezing, or pink frothy secretions.",
        "Refractory hypotension or shock requiring vasopressor support."
      ],
      "missingCriticalInformation": [
        "The estimated pH and volume of the aspirate (pH < 2.5 and volume > 0.4 mL/kg are thresholds for chemical injury)",
        "The patient's baseline pulmonary reserve"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Post-Aspiration Management",
        "Aspiration Pneumonitis vs. Pneumonia",
        "ARDS Lung-Protective Ventilation"
      ],
      "suggestedNextStepsGeneral": [
        "Observe all patients with suspected aspiration closely for at least 2-4 hours in a monitored setting.",
        "Administer inhaled bronchodilators (e.g., salbutamol) if bronchospasm occurs.",
        "Avoid routine prophylactic antibiotics in the first 24 hours (unless clinical signs of bacterial infection develop later).",
        "Provide PEEP/CPAP to maintain oxygenation; intubate if respiratory distress increases."
      ],
      "relatedAlgorithms": [
        {
          "id": "aspiration_risk",
          "titleTr": "Aspiration Management"
        },
        {
          "id": "ards_ventilation",
          "titleTr": "ARDS Protective Ventilation"
        },
        {
          "id": "hypoxemia",
          "titleTr": "Hypoxemia Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "pf_ratio_calculator",
          "titleTr": "P/F Ratio"
        },
        {
          "id": "abg_interpretation",
          "titleTr": "ABG Interpretation"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol"
        }
      ],
      "doNotMiss": [
        "Initial post-aspiration injury is an acidic chemical burn (pneumonitis), not a bacterial infection; immediate steroids or prophylactic antibiotics are not indicated"
      ],
      "whenToEscalate": [
        "If the patient develops severe hypoxemia (PaO2/FiO2 < 150) and bilateral infiltrates, transfer to the ICU and initiate lung-protective ventilation (6 mL/kg ideal body weight, high PEEP)"
      ],
      "referencesToShow": [
        "2023 American Society of Anesthesiologists Practice Guidelines for Preoperative Fasting.",
        "Mendelson's Syndrome Clinical Review."
      ],
      "safetyLevel": "urgent"
    }
