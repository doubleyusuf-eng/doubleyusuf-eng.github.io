  {
    "id": "clinical_followup_mtp_protocol_why_0",
    "category": "clinical_followups",
    "keywords": [
      "bleeding",
      "clinical_followup_mtp_protocol_why_0",
      "followup",
      "kanama",
      "massive",
      "mtp",
      "transfusion",
      "transfüzyon",
      "var0",
      "why"
    ],
    "question_tr": "Neden masif kanamada dengeli oran (1:1:1) uygulamalıyız?",
    "question_en": "Why use a balanced ratio (1:1:1) in massive bleeding?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 Ağır kanaması olan hastalara sadece Eritrosit Süspansiyonu ve kristaloid verilmesi, pıhtılaşma faktörlerini ve trombositleri seyrelterek 'dilüsyonel koagülopatiye' yol açar. 1:1:1 dengeli oranı (Eritrosit:Taze Donmuş Plazma:Trombosit) tam kan yapısını taklit ederek ölümcül koagülopati üçgenini (asidoz, hipotermi, koagülopati) engeller.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 Transfusing only packed red blood cells (PRBCs) and crystalloids dilutes endogenous clotting factors and platelets, leading to 'dilutional coagulopathy'. A balanced 1:1:1 ratio (PRBC:FFP:Platelets) reconstructs whole blood, preventing the lethal triad (acidosis, hypothermia, coagulopathy).",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
