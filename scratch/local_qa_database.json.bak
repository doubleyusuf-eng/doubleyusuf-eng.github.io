        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "St. John's Wort is a highly potent inducer of CYP3A4, which can rapidly accelerate clearance and reduce efficacy of Fentanyl and midazolam"
      ],
      "whenToEscalate": [
        "For persistent postoperative obtundation or severe bleeding refractory to standard blood products, consult ICU and toxicology if appropriate"
      ],
      "referencesToShow": [
        "ASA Practice Advisory on Alternative Medicine and Anesthesia. Anesthesiology 2018. PMID: 29016373.",
        "Ang-Lee MK, et al. JAMA 2001. PMID: 11451274."
