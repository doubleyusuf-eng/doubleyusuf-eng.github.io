  {
    "id": "clinical_followup_last_protocol_how_0",
    "category": "clinical_followups",
    "keywords": [
      "anesthetic",
      "bupivakain",
      "clinical_followup_last_protocol_how_0",
      "followup",
      "last",
      "local",
      "toksisite",
      "toxic",
      "var0"
    ],
    "question_tr": "Lipid tedavisi tam olarak nasıl uygulanır?",
    "question_en": "How exactly is lipid rescue administered?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "💉 %20 Lipid emülsiyonu: 1.5 mL/kg IV bolus olarak 1 dakikada uygulanır (yaklaşık 100 mL). Ardından 0.25 mL/kg/dk hızında sürekli infüzyona başlanır. Dirençli durumlarda bolus tekrarlanabilir ve infüzyon hızı 0.5 mL/kg/dk'ya çıkarılabilir. Maksimum kümülatif doz: 12 mL/kg.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "💉 20% Lipid Emulsion: Administer 1.5 mL/kg IV bolus over 1 minute (approx. 100 mL for an average adult). Immediately start continuous IV infusion at 0.25 mL/kg/min. In persistent instability, repeat the bolus and double infusion to 0.5 mL/kg/min. Maximum recommended cumulative dose: 12 mL/kg.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    }
