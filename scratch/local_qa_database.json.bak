      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🛡️ The only safe general anesthesia technique in MH-susceptible patients is **TIVA (Total Intravenous Anesthesia)**. Propofol, Remifentanil, opioids, local anesthetics, non-depolarizing muscle relaxants (e.g. Rocuronium), and nitrous oxide (N2O) are completely safe. The anesthesia machine must be flushed with carbon filters before the case.",
      "immediateRedFlags": [],
