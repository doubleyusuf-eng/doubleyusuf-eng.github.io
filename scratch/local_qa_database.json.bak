  {
    "id": "peak_pressure_high_plateau_normal",
    "category": "clinical_scenarios",
    "keywords": [
      "basıncı",
      "basınç",
      "high",
      "normal",
      "peak",
      "plateau",
      "plato",
      "pressure"
    ],
    "question_tr": "Peak basınç",
    "question_en": "Plato basıncı normal",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Peak basınç yüksek, plato basıncı normal veya çok artmamışsa sorun daha çok hava yolu direnciyle ilişkilidir. Olası nedenler: endotrakeal tüp kıvrılması, sekresyon/tıkaç, bronkospazm, devre tıkanıklığı, ısırma, küçük tüp, yüksek inspiratuvar akım veya yabancı cisim. Yaklaşım: devreyi ve tüpü kontrol et, suction yap, oskültasyon yap, kapnografi dalga formuna bak, bronkospazmı tedavi et, tüp pozisyonunu ve endobronşiyal entübasyonu dışla. Ani hemodinamik bozulma varsa tansiyon pnömotoraks da düşünülmelidir.",
      "immediateRedFlags": [
        "Peak basınçta ani ve devasa artış (> 40 cmH2O) ile ventilasyon kaybı.",
        "Hastanın tüpü ısırması veya ağır bronkospazma bağlı solunum seslerinin duyulmaması (sessiz akciğer).",
        "Akut desatürasyon ve EKG'de taşiaritmi gelişimi."
      ],
      "missingCriticalInformation": [
        "Tüpün içinden suction kateterinin rahat geçip geçmediği",
        "Kapnografide bronkospazmı gösteren 'köpekbalığı yüzgeci' (shark-fin) görünümü"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Peak Basınç Yüksekliği",
        "Hava Yolu Direnci Artışı",
        "Bronkospazm Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle tüpün bükülüp bükülmediğini ve hastanın tüpü ısırıp ısırmadığını fiziksel olarak kontrol edin.",
        "Hemen tüpün içinden suction kateteri geçirerek sekresyonları temizleyin.",
        "Akciğerleri dinleyerek wheezing varlığını ve solunum seslerinin bilateral eşitliğini kontrol edin.",
        "Bronkospazm varsa hızlı etkili inhale bronkodilatör uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "high_pressure",
          "titleTr": "Yüksek Havayolu Basıncı"
        },
        {
          "id": "bronchospasm",
          "titleTr": "Bronkospazm Algoritması"
        },
        {
          "id": "tube_obstruction",
          "titleTr": "Tüp Obstrüksiyonu"
        }
      ],
      "relatedCalculators": [
        {
          "id": "peak_plateau_gradient",
          "titleTr": "Peak-Plato Gradyanı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol"
        },
        {
          "id": "ipratropium",
          "titleTr": "İpratropium Bromür"
        },
        {
          "id": "epinephrine_if_severe",
          "titleTr": "Adrenalin"
        }
      ],
      "doNotMiss": [
        "Peak-plato basınç farkının (gradyanının) > 5-10 cmH2O olmasının tipik olarak direnç artışını gösterdiğini, oysa kompliyans sorunlarında farkın korunduğunu"
      ],
      "whenToEscalate": [
        "Ağır, ilaçlara yanıt vermeyen bronkospazm veya tam tüp tıkanıklığı varlığında hastayı manuel ventile edin, derin anestezi uygulayın ve gerekirse tüpü değiştirin"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Standard Operating Procedures in Anesthesia."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "If peak pressure is high while plateau pressure is normal or minimally increased, the problem is usually increased airway resistance. Causes include kinked endotracheal tube, secretions/plugging, bronchospasm, circuit obstruction, biting, small tube, high inspiratory flow, or foreign body. Check the circuit and tube, suction, auscultate, assess capnography waveform, treat bronchospasm, and exclude tube malposition or endobronchial intubation. If sudden hemodynamic compromise occurs, also consider tension pneumothorax.",
      "immediateRedFlags": [
        "Sudden massive rise in peak pressure (> 40 cmH2O) with failure to deliver tidal volumes.",
        "Patient biting the ETT or severe bronchospasm with absence of breath sounds (silent chest).",
        "Acute oxygen desaturation and tachyarrhythmias on the monitor."
      ],
      "missingCriticalInformation": [
        "Ease of passage of a suction catheter through the ETT",
        "The presence of a 'shark-fin' expiratory upstroke on waveform capnography"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Elevated Peak Pressure",
        "Increased Airway Resistance",
        "Bronchospasm Management"
      ],
      "suggestedNextStepsGeneral": [
        "Physically inspect the ETT for kinking or patient biting (use a bite block).",
        "Perform immediate tracheal suctioning to clear plugs or secretions.",
        "Auscultate bilateral lungs to evaluate for wheezing or asymmetric breath sounds.",
        "Administer inhaled bronchodilators if bronchospasm is identified."
      ],
      "relatedAlgorithms": [
        {
          "id": "high_pressure",
          "titleTr": "High Airway Pressure"
        },
        {
          "id": "bronchospasm",
          "titleTr": "Bronchospasm"
        },
        {
          "id": "tube_obstruction",
          "titleTr": "Tube Obstruction"
        }
      ],
      "relatedCalculators": [
        {
          "id": "peak_plateau_gradient",
          "titleTr": "Peak-Plateau Gradient"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol"
        },
        {
          "id": "ipratropium",
          "titleTr": "Ipratropium Bromide"
        },
        {
          "id": "epinephrine_if_severe",
          "titleTr": "Epinephrine"
        }
      ],
      "doNotMiss": [
        "A peak-to-plateau gradient > 5-10 cmH2O highlights airway resistance pathology; a normal plateau confirms no change in lung compliance"
      ],
      "whenToEscalate": [
        "For status asthmaticus or complete tube occlusion, manually ventilate, deepen anesthesia, and immediately prepare for ETT exchange if suction fails"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Standard Operating Procedures in Anesthesia."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "peak_plateau_both_high",
    "category": "clinical_scenarios",
    "keywords": [
      "both",
      "hem",
