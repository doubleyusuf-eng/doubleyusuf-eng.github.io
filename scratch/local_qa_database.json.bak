  {
    "id": "nasal_intubation",
    "category": "clinical_scenarios",
    "keywords": [
      "burundan",
      "entübasyon",
      "forceps",
      "forseps",
      "intubation",
      "magill",
      "nasal",
      "nasotracheal",
      "nazal"
    ],
    "question_tr": "Nazal entübasyon",
    "question_en": "Magill forceps",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Nazal entübasyon özellikle oral/maksillofasiyal cerrahilerde gerekebilir. 1. Koagülopati, bazal kafatası kırığı, ciddi nazal patoloji veya obstrüksiyon varsa dikkat/kaçınma gerekir. 2. Daha geniş patent nostril seçilir. 3. Vazokonstriktör ve lubrikasyon kanamayı azaltabilir. 4. Tüp ısıtılarak yumuşatılabilir. 5. Kanama, türbinat travması, submukozal geçiş ve bakteriyemi riski vardır. 6. Magill forseps kullanılırsa cuff hasarı ve travma önlenmelidir. 7. Kapnografi ve bilateral ventilasyonla doğrulama yapılır.",
      "immediateRedFlags": [
        "Nazal tüp ilerletilirken gelişen masif ve durdurulamayan nazal kanama (epistaksis).",
        "Kribriform plaka hasarı veya intrakraniyal tüp geçişi şüphesi (özellikle kafa tabanı kırığı olan travma hastalarında).",
        "Tüpün submukozal yalancı pasaj oluşturması ve farenkste şişlik yaratması."
      ],
      "missingCriticalInformation": [
        "Hastanın pıhtılaşma parametreleri (INR, trombosit düzeyi)",
        "Kafa tabanı kırığı şüphesi olup olmadığı (kesin kontrendikasyondur)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Nazal Entübasyon",
        "Maksillofasiyal Anestezi",
        "Havayolu Yaralanmaları"
      ],
      "suggestedNextStepsGeneral": [
        "Nazal mukozayı büzüştürmek ve kanamayı önlemek için vazokonstriktör damla (örn. oksimetazolin) uygulayın.",
        "Tüpün geçişini kolaylaştırmak için tüpü ılık steril su içinde bekleterek yumuşatın.",
        "Tüpü nazal tabana paralel olarak, nazikçe ve döndürerek ilerletin; yukarı doğru itmeyin.",
        "Vokal kordları geçerken gerekirse Magill forseps ve laringoskop yardımı alın; kafı forsepsle sıkıştırmayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "tube_size_calculator",
          "titleTr": "Tüp Boyutu Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "oxymetazoline",
          "titleTr": "Oksimetazolin"
        },
        {
          "id": "lidocaine",
          "titleTr": "Lidokain Monografı"
        }
      ],
      "doNotMiss": [
        "Bazal kafatası kırığı (ör. kribriform plaka hasarı) olan hastalarda nazal entübasyonun kesin olarak kontrendike olduğunu, tüpün beyin dokusuna ilerleyebileceğini"
      ],
      "whenToEscalate": [
        "Masif epistaksis veya havayolunu tıkayan kanama gelişirse, derhal nazal tüpü çekin, anterior/posterior tampon yerleştirin ve oral havayolunu güvenceye alın"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Oxford Handbook of Anaesthesia."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Nasal intubation may be required for oral/maxillofacial surgery. Use caution or avoid it in coagulopathy, basilar skull fracture, major nasal pathology, or obstruction. Choose the more patent nostril. Vasoconstrictor and lubrication may reduce bleeding. Warming the tube can soften it. Risks include bleeding, turbinate trauma, submucosal passage, and bacteremia. If Magill forceps are used, avoid cuff damage and trauma. Confirm with capnography and bilateral ventilation.",
      "immediateRedFlags": [
        "Massive, uncontrollable epistaxis during nasal ETT advancement.",
        "Suspected intracranial passage of the ETT (especially in trauma patients with basilar skull fractures).",
        "Submucosal false passage creation presenting as posterior pharyngeal swelling."
      ],
      "missingCriticalInformation": [
        "The patient's coagulation profile (INR, platelets)",
        "Presence or suspicion of basilar skull fractures (absolute contraindication)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Nasal Intubation",
        "Maxillofacial Anesthesia",
        "Airway Trauma Prevention"
      ],
      "suggestedNextStepsGeneral": [
        "Apply topical vasoconstrictor drops (e.g., oxymetazoline) to the chosen nostril 10 min prior.",
        "Soften the ETT in warm sterile saline to decrease mucosal trauma.",
        "Insert the ETT perpendicular to the face along the nasal floor; do not direct it upward.",
        "If Magill forceps are required, grasp the ETT proximal to the cuff to avoid puncturing it."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway"
        }
      ],
      "relatedCalculators": [
        {
          "id": "tube_size_calculator",
          "titleTr": "Tube Size Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "oxymetazoline",
          "titleTr": "Oxymetazoline"
        },
        {
          "id": "lidocaine",
          "titleTr": "Lidocaine Monograph"
        }
      ],
      "doNotMiss": [
        "Nasal intubation is strictly contraindicated in patients with suspected basilar skull fractures due to the risk of accidental intracranial entry"
      ],
      "whenToEscalate": [
        "In the event of severe, airway-compromising epistaxis, immediately abort nasal access, pack the nasal cavity, and secure the airway orally"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Oxford Handbook of Anaesthesia."
      ],
      "safetyLevel": "elective"
    }
