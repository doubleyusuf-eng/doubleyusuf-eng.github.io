  {
    "id": "cico",
    "category": "clinical_scenarios",
    "keywords": [
      "cannot",
      "cico",
      "edemiyorum",
      "entübe",
      "intubate",
      "oxygenate",
      "ventile"
    ],
    "question_tr": "Cico",
    "question_en": "Ventile edemiyorum",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "CICO bir havayolu acilidir. Zaman kaybetmeden yüksek sesle “CICO” ilan et.\\n1. %100 oksijen ver.\\n2. Son bir kez maske/SAD optimizasyonu yap; başarısızsa bekleme.\\n3. Acil front-of-neck access / krikotirotomiye geç.\\n4. Neşter-bougie-tüp tekniği erişkinlerde standart acil yaklaşım olarak tercih edilir.\\n5. Tüp yerini kapnografi ile doğrula.\\n6. Oksijenasyon sağlandıktan sonra hemodinami, hipoksi süresi ve komplikasyonları değerlendir.",
      "immediateRedFlags": [
        "CICO durumunda her saniye beynin oksijensiz kalma süresini artırır; cerrahi havayolu kararı geciktirilmemelidir.",
        "Kapnografi dalgası görülmeden cerrahi havayolundan solutulmaya başlanması özofagus veya pretrakeal hava verilmesi riskini taşır."
      ],
      "missingCriticalInformation": [
        "Hastanın anatomik boyun yapısı (tiroid kıkırdak palpe edilebiliyor mu?)",
        "Ekipte cerrahi/KBB uzman desteğinin varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Cannot Intubate Cannot Oxygenate (CICO) Kriterleri",
        "Acil Front-of-Neck Access (FONA)",
        "Neşter-Bougie-Tüp Krikotirotomi Tekniği"
      ],
      "suggestedNextStepsGeneral": [
        "Yüksek sesle ekibe 'CICO Durumu' bildirin ve cerrahi havayolu setini açtırın.",
        "Larenks palpasyonu yapın (krikotiroid membran tespiti için).",
        "Krikotiroid membrandan yatay insizyon yapın, bougie yerleştirin ve üzerinden 6.0 mm kaflı tüp kaydırın."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Erişkinlerde CICO durumunda iğne krikotirotomi yerine neşter-bougie-tüp tekniği altın standarttır"
      ],
      "whenToEscalate": [
        "Cerrahi havayolu sağlanamadığında veya hipoksiye bağlı kardiyak arrest gelişirse derhal CPR ve ACLS protokolüne geçiş"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "Difficult Airway Society 2015 Guidelines. Anaesthesia 2015. PMID: 26558482."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "CICO is an airway emergency. Declare “CICO” loudly. Provide 100% oxygen. Make one final optimized attempt at mask/SAD oxygenation only if immediately feasible. If unsuccessful, proceed without delay to emergency front-of-neck access. In adults, the scalpel-bougie-tube technique is commonly recommended. Confirm placement with capnography and reassess hemodynamics, hypoxic injury risk, and complications.",
      "immediateRedFlags": [
        "Every second of delay in CICO increases brain hypoxia; surgical airway decision must not be postponed.",
        "Ventilating through a surgical airway without capnographic confirmation carries a high risk of pretracheal or esophageal insufflation."
      ],
      "missingCriticalInformation": [
        "Patient neck anatomy (is the cricothyroid membrane palpable?)",
        "Availability of surgical or ENT backup at the scene"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Cannot Intubate Cannot Oxygenate (CICO) Status",
        "Emergency Front-of-Neck Access (FONA)",
        "Scalpel-Bougie-Tube Cricothyrotomy Technique"
      ],
      "suggestedNextStepsGeneral": [
        "Loudly declare 'CICO Status' to the team and open the surgical airway kit.",
        "Palpate the larynx to identify the cricothyroid membrane.",
        "Make a horizontal incision over the membrane, insert a bougie, and pass a 6.0 mm cuffed tube over it."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "In adults, the scalpel-bougie-tube technique is the gold standard for CICO, rather than needle cricothyrotomy"
      ],
      "whenToEscalate": [
        "If surgical airway placement fails or hypoxic cardiac arrest occurs, immediately initiate CPR and ACLS"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "Difficult Airway Society 2015 Guidelines. Anaesthesia 2015. PMID: 26558482."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "desaturation",
    "category": "clinical_scenarios",
    "keywords": [
      "desaturation",
      "düş",
      "falling",
      "hipoksemi",
      "satürasyon",
      "spo2"
    ],
    "question_tr": "Satürasyon düş",
    "question_en": "Falling spo2",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Hipoksemide önce oksijenasyonu kurtar, sonra nedeni ayır.\\n1. FiO₂’yi 1.0 yap.\\n2. Manuel ventilasyona geç ve akciğer kompliyansını hisset.\\n3. Devre, oksijen kaynağı, vaporizatör, ventilatör ve kaçakları kontrol et.\\n4. Tüp yerini kontrol et: kapnografi, oskültasyon, göğüs hareketi, derinlik.\\n5. Endobronşiyal entübasyon, tüp tıkanıklığı, bronkospazm, laringospazm, aspirasyon, pnömotoraks ve pulmoner emboliyi düşün.\\n6. PEEP/recruitment ve hemodinamik optimizasyon uygula.\\n7. Düzelmezse yardım çağır, cerrahiyi durdurmayı düşün ve kriz algoritmasını sürdür.",
      "immediateRedFlags": [
        "Aniden sıfıra inen ETCO₂ ile birlikte desatürasyon, tüp çıkması veya total devre tıkanıklığı/kopması bulgusudur.",
        "Tek taraflı solunum sesi kaybı ve yüksek havayolu basıncı, tansiyon pnömotoraksın kritik bir kırmızı bayrağıdır."
      ],
      "missingCriticalInformation": [
        "ETCO₂ dalga yapısı ve sayısal değeri",
        "Hastanın önceki akciğer patolojileri (örn. KOAH, astım, akciğer kisti)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İntraoperatif Akut Desatürasyon ve Hipoksemi",
        "Ventilatör Devre ve Oksijen Kaynağı Arızaları",
        "Tansiyon Pnömotoraks ve Endobronşiyal Entübasyon"
      ],
      "suggestedNextStepsGeneral": [
        "Derhal FiO₂'yi 1.0 (%100 O₂) yapın.",
        "Ventilatörden manuel solutma balonuna geçerek akciğer sertliğini (kompliyans) hissedin.",
        "Göğsü iki taraflı oskülte edin ve tüp derinliğini (endobronşiyal kaçış yönünden) kontrol edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Oksijen kaynağı arızasından şüpheleniliyorsa, hemen devre bağlantısı kesilmeli ve yedek oksijen tüpü/balon (Ambu) kullanılmalıdır"
      ],
      "whenToEscalate": [
        "Dirençli hipoksemi, bradikardi ve kardiyovasküler kollaps geliştiğinde acil resüsitasyon (ACLS) adımlarına geçiş"
      ],
      "referencesToShow": [
        "ASA Standards of Basic Anesthetic Monitoring. 2020.",
        "AHA Guidelines for CPR and ECC. 2020. PMID: 33081529."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "First rescue oxygenation, then diagnose. Set FiO₂ to 1.0, switch to manual ventilation, assess compliance, check circuit/oxygen source/ventilator/leaks, confirm tube position with capnography and auscultation, and consider endobronchial intubation, tube obstruction, bronchospasm, laryngospasm, aspiration, pneumothorax, and pulmonary embolism. Apply PEEP/recruitment and optimize hemodynamics. If unresolved, call for help and consider stopping surgery.",
      "immediateRedFlags": [
        "Sudden drop of ETCO₂ to zero along with desaturation indicates tube extubation or circuit disconnection.",
        "Unilateral loss of breath sounds combined with high airway pressure is a critical flag for tension pneumothorax."
      ],
      "missingCriticalInformation": [
        "ETCO₂ waveform profile and numerical value",
        "Prior lung pathologies of the patient (e.g., COPD, asthma, lung blebs)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Intraoperative Acute Desaturation and Hypoxemia",
        "Ventilator Circuit and Oxygen Source Failures",
        "Tension Pneumothorax and Endobronchial Intubation"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately increase FiO₂ to 1.0 (100% O₂).",
        "Switch from the ventilator to manual bag ventilation to feel lung compliance.",
        "Auscultate both lung fields and verify tube depth to rule out mainstem intubation."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "If an oxygen pipeline failure is suspected, disconnect the circuit immediately and use an auxiliary oxygen cylinder (Ambu bag)"
      ],
      "whenToEscalate": [
        "In case of refractory hypoxemia, bradycardia, and cardiovascular collapse, proceed immediately to ACLS resuscitation"
      ],
      "referencesToShow": [
        "ASA Standards of Basic Anesthetic Monitoring. 2020.",
        "AHA Guidelines for CPR and ECC. 2020. PMID: 33081529."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "high_pressure",
    "category": "clinical_scenarios",
    "keywords": [
      "airway",
      "basınç",
      "havayolu",
      "high",
      "peak",
      "plateau",
      "pressure",
      "yüksek"
    ],
    "question_tr": "Yüksek havayolu",
    "question_en": "Peak airway",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Yüksek peak basınçta önce ventilasyonu manuel değerlendir.\\nPeak yüksek, plateau normal ise direnç problemi düşün: tüp kıvrılması, sekresyon, tüp tıkanıklığı, bronkospazm, devre problemi.\\nPeak ve plateau birlikte yüksekse kompliyans problemi düşün: pnömoperitoneum, Trendelenburg, obezite, atelektazi, pulmoner ödem, ARDS, pnömotoraks.\\nAcil yaklaşım: FiO₂ 1.0, manuel ventilasyon, tüp/devre kontrolü, suction, oskültasyon, kapnografi dalgası, gerekirse bronkodilatör, pnömotoraks şüphesinde acil dekompresyon.",
      "immediateRedFlags": [
        "Tansiyon pnömotoraks durumunda pik basınç aniden yükselirken tansiyon ve kalp debisi hızla düşer (acil iğne dekompresyonu!).",
        "Total endotrakeal tüp tıkanıklığı (kaf fıtıklaşması veya mukus tıkacı) ventilasyonu tamamen engeller."
      ],
      "missingCriticalInformation": [
        "Plato basıncı değeri (Plateau pressure - ventilatörde inspiratuar bekletme ile ölçülür)",
        "Tüpün aspirasyon sondası geçişine izin verip vermediği (suction testi)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Yüksek Peak Havayolu Basıncı Diferansiyel Tanısı",
        "Akciğer Kompliyansı ve Direnci Farkları",
        "Tansiyon Pnömotoraks Tanı ve Tedavisi"
      ],
      "suggestedNextStepsGeneral": [
        "Manuel ventilasyona geçin ve devrede bükülme/tıkanma olmadığını doğrulayın.",
        "Hızlıca bir suction kateterini tüpün içine iterek tıkanıklığı test edin.",
        "EKG, tansiyon ve ETCO₂ dalgasını pnömotoraks yönünden takip edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Plateau basıncı normal ama peak basınç yüksekse sorun akciğerde değil, tüp veya devrededir (artan direnç)"
      ],
      "whenToEscalate": [
        "Tansiyon pnömotoraks varlığında 2. veya 5. interkostal aralıktan acil iğne torakostomisi ve ardından göğüs tüpü yerleştirilmesi"
      ],
      "referencesToShow": [
        "ASA Standards of Basic Anesthetic Monitoring. 2020.",
        "AHA Guidelines for CPR and ECC. 2020. PMID: 33081529."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Switch to manual ventilation and assess compliance. High peak with normal plateau suggests increased resistance: kinked tube, secretions, tube obstruction, bronchospasm, or circuit problem. High peak and high plateau suggest reduced compliance: pneumoperitoneum, Trendelenburg, obesity, atelectasis, pulmonary edema, ARDS, or pneumothorax. Immediate actions: FiO₂ 1.0, manual ventilation, check tube/circuit, suction, auscultation, capnography, bronchodilator if needed, and decompression if tension pneumothorax is suspected.",
      "immediateRedFlags": [
        "In tension pneumothorax, peak pressure rises while blood pressure and cardiac output drop rapidly (urgent decompression needed!).",
        "Total endotracheal tube obstruction (cuff herniation or mucus plug) blocks ventilation entirely."
      ],
      "missingCriticalInformation": [
        "Plateau pressure value (measured with inspiratory hold on the ventilator)",
        "Whether the tube allows passage of a suction catheter (suction test)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "High Peak Airway Pressure Differential Diagnosis",
        "Compliance vs Resistance Lung Mechanics",
        "Tension Pneumothorax Detection and Decompression"
      ],
      "suggestedNextStepsGeneral": [
        "Switch to manual ventilation and verify no kinks or blockages in the circuit.",
        "Pass a suction catheter down the ETT to rule out mechanical obstruction.",
        "Assess EKG, BP, and ETCO₂ for signs of tension pneumothorax."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "If plateau pressure is normal but peak is high, the issue is resistance (e.g., tube/circuit), not lung compliance"
      ],
      "whenToEscalate": [
        "In tension pneumothorax, perform immediate needle thoracostomy at the 2nd or 5th intercostal space followed by chest tube"
      ],
      "referencesToShow": [
        "ASA Standards of Basic Anesthetic Monitoring. 2020.",
        "AHA Guidelines for CPR and ECC. 2020. PMID: 33081529."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "bronchospasm",
    "category": "clinical_scenarios",
    "keywords": [
      "bronchospasm",
      "bronkospazm",
      "wheezing"
    ],
    "question_tr": "Bronkospazm",
    "question_en": "Wheezing",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Bronkospazm; wheezing, uzamış ekspirasyon, yüksek peak basınç, yükselen ETCO₂ ve zor manuel ventilasyon ile kendini gösterebilir.\\n\\n1. FiO₂ 1.0 yap.\\n2. Manuel ventilasyona geç; tüp tıkanıklığı/endobronşiyal entübasyonu dışla.\\n3. Anestezi derinliğini artır.\\n4. İnhale salbutamol ver; gerekirse ipratropium ekle.\\n5. Şiddetli bronkospazm veya anafilaksi şüphesinde adrenalin düşün.\\n6. Steroid ve magnezyum sülfat dirençli olgularda düşünülebilir.\\n7. Ventilatörde düşük frekans, uzun ekspirasyon süresi ve hava hapsinden kaçınma hedeflenir.",
      "immediateRedFlags": [
        "'Sessiz akciğer' (silent chest) ağır bronkospazmda hava akımının tamamen durduğunu gösteren ölümcül bir işarettir.",
        "Kapnografide köpek balığı yüzgeci (shark-fin) dalga şekli ilerleyici ekspiratuar obstrüksiyonu belgeler."
      ],
      "missingCriticalInformation": [
        "Hastanın astım/KOAH geçmişi ve mevcut alerji durumu",
        "Plateau basıncı ve driving pressure değerleri"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İntraoperatif Akut Bronkospazm Yönetimi",
        "Ventilatörde Hava Hapsi (Auto-PEEP) ve Dinamik Hiperenflasyon",
        "Anafilaksinin Solunumsal Bulguları"
      ],
      "suggestedNextStepsGeneral": [
        "Derhal %100 O₂ verin ve anestezi derinliğini artırarak (örn. Sevofluran/İzofluran konsantrasyonunu yükselterek) bronkodilasyon sağlayın.",
        "Tüpten 8-10 puf Salbutamol uygulayın.",
        "Dirençli olgularda Magnezyum Sülfat 2 g IV (20 dakikada) veya yavaş Adrenalin (10-20 mcg IV bolus) düşünün."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Bronkospazm sırasında ventilatörde I:E oranını 1:3 veya 1:4 yaparak ekspirasyon süresi uzatılmalı, auto-PEEP önlenmelidir"
      ],
      "whenToEscalate": [
        "Kardiyovasküler kollaps veya total hava yolu obstrüksiyonu geliştiğinde acil Krikotirotomi/ACLS protokollerine geçiş"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "AHA Guidelines for CPR and ECC. 2020. PMID: 33081529."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Bronchospasm may present with wheeze, prolonged expiration, high peak pressure, rising ETCO₂, and difficult manual ventilation. Set FiO₂ to 1.0, switch to manual ventilation, exclude tube obstruction/endobronchial intubation, deepen anesthesia, administer inhaled salbutamol, add ipratropium if needed, consider epinephrine if severe or associated with anaphylaxis, and consider steroids or magnesium in refractory cases. Adjust ventilation to allow prolonged expiration and avoid air trapping.",
      "immediateRedFlags": [
        "'Silent chest' in severe bronchospasm indicates complete cessation of airflow and is a critical red flag.",
        "A 'shark-fin' ETCO₂ waveform confirms progressive expiratory airway obstruction."
      ],
      "missingCriticalInformation": [
        "History of asthma/COPD or active allergy/atopy",
        "Plateau pressure and driving pressure values"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Intraoperative Acute Bronchospasm Management",
        "Air Trapping (Auto-PEEP) and Dynamic Hyperinflation",
        "Respiratory Presentation of Anaphylaxis"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately deliver 100% O₂ and deepen anesthesia (e.g., increase Sevoflurane/Isoflurane) to promote bronchodilation.",
        "Administer 8-10 puffs of Salbutamol through the ETT.",
        "In refractory cases, consider Magnesium Sulfate 2 g IV (over 20 min) or slow Epinephrine (10-20 mcg IV bolus)."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "During bronchospasm, adjust the ventilator I:E ratio to 1:3 or 1:4 to prolong exhalation and prevent auto-PEEP"
      ],
      "whenToEscalate": [
        "In case of cardiovascular collapse or complete airway obstruction, proceed immediately to FONA/ACLS guidelines"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "AHA Guidelines for CPR and ECC. 2020. PMID: 33081529."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "laryngospasm",
    "category": "clinical_scenarios",
    "keywords": [
      "laringospazm",
      "laryngospasm"
    ],
    "question_tr": "Laringospazm",
    "question_en": "Laryngospasm",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Laringospazmda hızlı ve basamaklı yaklaş:\\n1. Cerrahi uyarıyı durdur, yardım çağır.\\n2. %100 oksijen ver, CPAP ve jaw thrust uygula.\\n3. Sekresyon/kan varsa aspire et.\\n4. Hafif/parsiyel ise anestezi derinliğini artır; propofol düşünülebilir.\\n5. Tam laringospazm, desatürasyon veya ventilasyon yoksa süksinilkolin ver ve entübasyona hazırlan.\\n6. Negatif basınçlı pulmoner ödem açısından postop takip et.",
      "immediateRedFlags": [
        "Total laringospazm sırasında solunum çabasına rağmen göğüs hareketlerinin paradoksal (stridor/sessiz) olması total tıkanma işaretidir.",
        "Progresif bradikardi, pediatrik laringospazmda hipoksiye bağlı durma öncesi son kırmızı bayraktır."
      ],
      "missingCriticalInformation": [
        "Hastanın uyanıklık düzeyi ve yutkunma/öksürme reflekslerinin aktifliği",
        "Süksinilkolin dozu için hastanın tam kilosu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Post-ekstübasyon Laringospazmı Acil Yönetimi",
        "Larson Manevrası (Laringospazm Çentiği Basısı)",
        "Negatif Basınçlı Pulmoner Ödem (NPPE) Komplikasyonu"
      ],
      "suggestedNextStepsGeneral": [
        "%100 O₂ ile 15-20 cmH₂O CPAP (sürekli pozitif havayolu basıncı) uygulayın.",
        "Larson manevrasını (mandibula çentiği arkasına iki taraflı güçlü bası) uygulayın.",
        "Spazm çözülmezse Propofol (0.5 mg/kg) veya Süksinilkolin (0.5-1 mg/kg IV) uygulayarak spazmı kırın."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        },
        {
          "id": "succinylcholine",
          "titleTr": "Süksinilkolin Monografı"
        }
      ],
      "doNotMiss": [
        "Laringospazm çözülmeden hastanın güçlü soluma çabası intraplevral negatif basıncı artırarak akciğer ödemine (NPPE) yol açar"
      ],
      "whenToEscalate": [
        "Süksinilkolin sonrası düzelmeyen total spazmda derhal endotrakeal entübasyon veya acil cerrahi havayolu"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "AHA Guidelines for CPR and ECC. 2020. PMID: 33081529."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Stop stimulation and call for help. Provide 100% oxygen, apply CPAP and jaw thrust, suction secretions or blood. If partial, deepen anesthesia; propofol may help. If complete laryngospasm, desaturation, or inability to ventilate occurs, administer succinylcholine and prepare for intubation. Monitor postoperatively for negative-pressure pulmonary edema.",
      "immediateRedFlags": [
        "Paradoxical chest wall movement with no airflow (stridor/silent) during attempts to breathe indicates complete obstruction.",
        "Progressive bradycardia is the final pre-arrest warning in pediatric laryngospasm due to hypoxia."
      ],
      "missingCriticalInformation": [
        "Patient depth of anesthesia and status of airway protective reflexes",
        "Exact patient weight for emergency succinylcholine dosing"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Post-Extubation Laryngospasm Emergency Management",
        "Larson's Maneuver (Laryngospasm Notch Pressure)",
        "Negative-Pressure Pulmonary Edema (NPPE) Risk"
      ],
      "suggestedNextStepsGeneral": [
        "Deliver 100% O₂ with 15-20 cmH₂O CPAP.",
        "Apply Larson's maneuver (firm bilateral pressure applied behind the ear lobe at the jaw notch).",
        "If unresolved, administer Propofol (0.5 mg/kg) or Succinylcholine (0.5-1 mg/kg IV) to break the spasm."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        },
        {
          "id": "succinylcholine",
          "titleTr": "Succinylcholine Monograph"
        }
      ],
      "doNotMiss": [
        "Strong inspiratory efforts against a closed glottis generate extreme negative intrapleural pressure, triggering NPPE"
      ],
      "whenToEscalate": [
        "If complete spasm persists despite succinylcholine, perform immediate tracheal intubation or surgical access"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "AHA Guidelines for CPR and ECC. 2020. PMID: 33081529."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "hypotension",
    "category": "clinical_scenarios",
    "keywords": [
      "düştü",
      "düşük",
      "hipotansiyon",
      "hypotension",
      "tansiyon"
    ],
    "question_tr": "Hipotansiyon",
    "question_en": "Tansiyon düştü",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Hipotansiyonda önce ölçümü doğrula ve perfüzyonu değerlendir.\\nOlası nedenler: anestezi derinliği, vazodilatasyon, hipovolemi/kanama, miyokard depresyonu, aritmi, anafilaksi, yüksek spinal, pulmoner emboli, tansiyon pnömotoraks.\\n\\nYaklaşım:\\n1. Kan basıncı ölçümünü doğrula.\\n2. FiO₂, ETCO₂, EKG, nabız, kanama ve cerrahi alanı kontrol et.\\n3. Anestezi derinliğini azaltmayı düşün.\\n4. Sıvı bolusu ver; kanama varsa kan ürünlerini hazırla.\\n5. Bradikardik hipotansiyonda efedrin/atropin; taşikardik vazodilatasyonda fenilefrin/noradrenalin düşünülebilir.\\n6. Refrakter veya şok tablosunda arter hattı, vazopressör infüzyonu ve altta yatan nedenin tedavisi gerekir.",
      "immediateRedFlags": [
        "Anestezi indüksiyonu sonrası aniden gelişen şiddetli hipotansiyon ve nabızsızlık, anafilaksi veya yüksek spinal blok belirtisi olabilir.",
        "Hipotansiyonla birlikte ETCO₂'nin dramatik düşüşü, pulmoner emboli veya kardiyak arrest habercisidir."
      ],
      "missingCriticalInformation": [
        "Hastanın bazal (preoperatif) kan basıncı değerleri",
        "Mevcut idrar çıkışı ve periferal perfüzyon durumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İntraoperatif Akut Hipotansiyon Diferansiyel Tanısı",
        "Vazopressör Seçim Kriterleri (Vazoaktif İlaçlar)",
        "Sıvı Resüsitasyonu ve Hedefe Yönelik Tedavi"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle tansiyon ölçümünü tekrarlayarak doğruluğunu kontrol edin.",
        "Anestezi derinliğini azaltın (volatil anestezik konsantrasyonunu düşürün).",
        "250-500 mL kristalloid sıvı bolusu uygulayın.",
        "Bradikardi eşlik ediyorsa Efedrin (5-10 mg IV) veya Atropin (0.5 mg IV); taşikardi eşlik ediyorsa Fenilefrin (50-100 mcg IV) tercih edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Efedrin Monografı"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Sadece tansiyon değerine değil, perfüzyon göstergesi olan Ortalama Arter Basıncına (OAB >65 mmHg) odaklanılmalıdır"
      ],
      "whenToEscalate": [
        "Sıvı ve bolus vazopressörlere dirençli hipotansiyonda derhal invaziv arter izlemi ve sürekli Noradrenalin infüzyonu başlatın"
      ],
      "referencesToShow": [
        "Practice Guidelines for Basic Anesthetic Monitoring. Anesthesiology 2015. PMID: 25416285.",
        "AHA Guidelines. 2020. PMID: 33081529."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Confirm the measurement and assess perfusion. Consider anesthetic depth, vasodilation, hypovolemia/bleeding, myocardial depression, arrhythmia, anaphylaxis, high spinal, pulmonary embolism, or tension pneumothorax. Verify BP, check FiO₂/ETCO₂/ECG/pulse/bleeding, reduce anesthetic depth if appropriate, give fluid bolus, prepare blood products if bleeding, use ephedrine/atropine for bradycardic hypotension and phenylephrine/norepinephrine for vasodilatory hypotension. Refractory shock requires invasive monitoring, vasopressor infusion, and treatment of the cause.",
      "immediateRedFlags": [
        "Sudden severe hypotension with pulselessness right after induction strongly suggests anaphylaxis or a high spinal block.",
        "Hypotension paired with a dramatic drop in ETCO₂ points toward pulmonary embolism or impending cardiac arrest."
      ],
      "missingCriticalInformation": [
        "Patient's baseline (preoperative) blood pressure values",
        "Current urine output and peripheral perfusion status"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Intraoperative Acute Hypotension Differential Diagnosis",
        "Vasopressor Choice Criteria (Vasoactive Drugs)",
        "Fluid Resuscitation and Goal-Directed Therapy"
      ],
      "suggestedNextStepsGeneral": [
        "First, repeat the BP measurement to verify its accuracy.",
        "Reduce anesthetic depth (titrate down volatile anesthetics).",
        "Deliver a 250-500 mL crystalloid fluid bolus.",
        "Administer Ephedrine (5-10 mg IV) or Atropine (0.5 mg IV) if bradycardic; choose Phenylephrine (50-100 mcg IV) if tachycardic."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine Monograph"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Focus on the Mean Arterial Pressure (MAP >65 mmHg) as the primary indicator of organ perfusion, not just systolic BP"
      ],
      "whenToEscalate": [
        "In hypotension refractory to fluids and bolus vasopressors, initiate invasive arterial line monitoring and continuous Norepinephrine infusion"
      ],
      "referencesToShow": [
        "Practice Guidelines for Basic Anesthetic Monitoring. Anesthesiology 2015. PMID: 25416285.",
        "AHA Guidelines. 2020. PMID: 33081529."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "anaphylaxis",
    "category": "clinical_scenarios",
    "keywords": [
      "alerji",
      "allergy",
      "anafilaksi",
      "anaphylaxis"
    ],
    "question_tr": "Anafilaksi",
    "question_en": "Allergy",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Anafilaksi; hipotansiyon, bronkospazm, döküntü/ürtiker, ödem veya kardiyovasküler kollaps ile gelebilir.\\n\\n1. Tetikleyici ajanı durdur.\\n2. Yardım çağır, %100 oksijen ver.\\n3. Adrenalin ilk seçenektir; klinik ağırlığa göre filtre edilir.\\n4. Agresif kristalloid resüsitasyonu uygula.\\n5. Bronkospazm varsa salbutamol/ipratropium ekle.\\n6. Antihistaminik ve steroidler destek tedavisidir, adrenalinin yerine geçmez.\\n7. Triptaz için uygun zamanda kan örneği al ve olayı ayrıntılı belgeleyip alerji değerlendirmesine yönlendir.",
      "immediateRedFlags": [
        "Şiddetli bronkospazm eşliğinde derin hipotansiyon (OAB <50 mmHg) anafilaktik şokun en kritik kırmızı bayrağıdır.",
        "Havayolu ödemine bağlı progresif ventilasyon zorluğu havayolu kaybı riski taşır."
      ],
      "missingCriticalInformation": [
        "Uygulanan son ilaçlar (kas gevşeticiler, antibiyotikler, kolloidler ve lateks maruziyeti)",
        "Hastanın kilosu ve kardiyak ek hastalıkları"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İntraoperatif Akut Anafilaksi ve Alerji Yönetimi",
        "Adrenalin Doz Titrasyonu ve İnfüzyon Protokolü",
        "Serum Triptaz Düzeyi Takibi"
      ],
      "suggestedNextStepsGeneral": [
        "Şüpheli tüm ajanları (antibiyotik, kas gevşetici, lateks) hemen durdurun.",
        "Adrenalin: Hafif reaksiyonda 10-20 mcg IV; belirgin hipotansiyonda 50-100 mcg IV; kollapsta 1 mg IV/IO uygulayın.",
        "Hızlıca 2-4 litre kristalloid sıvı resüsitasyonu başlatın."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        },
        {
          "id": "ephedrine",
          "titleTr": "Efedrin Monografı"
        }
      ],
      "doNotMiss": [
        "Antihistaminikler ve steroidler anafilakside ikincil ilaçlardır, hayati adrenalin tedavisini kesinlikle geciktirmemelidir"
      ],
      "whenToEscalate": [
        "Dirençli şok tablosunda sürekli Adrenalin infüzyonuna (0.05-0.1 mcg/kg/dk) geçilmesi ve yoğun bakım transferi"
      ],
      "referencesToShow": [
        "Scandinavian Clinical Practice Guidelines on Anaphylaxis during Anaesthesia. Acta Anaesthesiol Scand 2007. PMID: 17567439.",
        "AHA Resuscitation Guidelines, 2020."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Anaphylaxis may present with hypotension, bronchospasm, rash/urticaria, edema, or cardiovascular collapse. Stop the suspected trigger, call for help, give 100% oxygen, administer epinephrine as the first-line drug titrated to severity, provide aggressive crystalloid resuscitation, add salbutamol/ipratropium for bronchospasm, and use antihistamines/steroids only as adjuncts. Obtain timed tryptase samples when possible and document the event for allergy workup.",
      "immediateRedFlags": [
        "Profound hypotension (MAP <50 mmHg) accompanied by severe bronchospasm is a critical red flag for anaphylactic shock.",
        "Progressive airway edema threatens rapid loss of airway access."
      ],
      "missingCriticalInformation": [
        "Recently administered drugs (neuromuscular blockers, antibiotics, colloids, or latex exposure)",
        "Patient weight and cardiovascular co-morbidities"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Intraoperative Acute Anaphylaxis and Allergy Management",
        "Epinephrine Dose Titration and Infusion Protocol",
        "Serum Tryptase Level Monitoring"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately stop all suspected triggers (antibiotics, muscle relaxants, latex).",
        "Epinephrine: Administer 10-20 mcg IV for mild reactions; 50-100 mcg IV for moderate hypotension; 1 mg IV/IO for collapse.",
        "Initiate rapid fluid resuscitation with 2-4 liters of crystalloids."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        },
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine Monograph"
        }
      ],
      "doNotMiss": [
        "Antihistamines and steroids are secondary agents and must never delay life-saving Epinephrine administration"
      ],
      "whenToEscalate": [
        "In refractory shock, start continuous Epinephrine infusion (0.05-0.1 mcg/kg/min) and arrange ICU transfer"
      ],
