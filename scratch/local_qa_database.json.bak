    "question_tr": "Anestezi cerrahi havayolunun komplikasyonları nelerdir?",
    "question_en": "Anesthesia what are the complications of surgical airway?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 Akut komplikasyonlar arasında şiddetli kanama, özofagus perforasyonu, yanlış lümene yerleştirme (subkutan amfizem), pnömotoraks ve tiroid bezi hasarı yer alır. Geç dönemde subglottik stenoz ve ses kısıklığı en sık görülen sekeller arasındadır.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 Acute complications include severe hemorrhage, esophageal perforation, false passage placement (subcutaneous emphysema), pneumothorax, and thyroid gland damage. Long-term sequelae include subglottic stenosis and persistent hoarseness.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
