      "vomiting"
    ],
    "question_tr": "Ondansetrona yanıt vermeyen hastada alternatif kurtarıcı nedir?",
    "question_en": "What is the alternative rescue drug for ondansetron failure?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🔄 Ondansetron profilaksisine rağmen ilk 6 saatte gelişen bulantıda, Ondansetron tekrar dozunun faydası yoktur. Alternatif olarak farklı bir reseptör yolağını hedefleyen **Droperidol (0.625-1.25 mg IV)**, **Metoklopramid (10 mg IV)** veya düşük doz **Propofol (10-20 mg IV)** kurtarıcı olarak verilmelidir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🔄 If a patient experiences PONV within 6 hours of receiving Ondansetron prophylaxis, repeating Ondansetron is ineffective. Instead, use an agent targeting a different receptor pathway, such as **Droperidol (0.625-1.25 mg IV)**, **Metoclopramide (10 mg IV)**, or sub-hypnotic **Propofol (10-20 mg IV)**.",
      "immediateRedFlags": [],
