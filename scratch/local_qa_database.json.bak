  {
    "id": "clinical_followup_coronary_stent_why_0",
    "category": "clinical_followups",
    "keywords": [
      "antiplatelet",
      "clinical_followup_coronary_stent_why_0",
      "coronary",
      "dapt",
      "dual",
      "followup",
      "koroner",
      "stent",
      "var0",
      "why"
    ],
    "question_tr": "Neden dapt tedavisini erken kesmemeliyiz?",
    "question_en": "Why should dapt not be discontinued early?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 İlaç Salınımlı Stent (DES) veya Çıplak Metal Stent (BMS) yerleştirilmesinden sonra, stent yüzeyi endotelle kaplanana kadar tromboza son derece açıktır. Çiftli Antiplatelet Tedavisinin (DAPT: Aspirin + Klopidogrel vb.) erken kesilmesi, akut stent trombozuna ve buna bağlı %20'yi aşan mortaliteye sahip devasa miyokard enfarktüslerine yol açar.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 After drug-eluting (DES) or bare-metal stent (BMS) placement, the stent surface remains highly thrombogenic until complete endothelialization occurs. Premature discontinuation of Dual Antiplatelet Therapy (DAPT) causes acute stent thrombosis, leading to catastrophic myocardial infarction with mortality exceeding 20%.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    }
  },
