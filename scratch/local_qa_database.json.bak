      "doNotMiss": [
        "RSI uygularken başarısız bir deneme sonrasında hipoksemiyi önlemek için nazik, düşük basınçlı ventilasyonun (< 20 cmH2O) hayat kurtarıcı olabileceğini (modifiye RSI)"
      ],
      "whenToEscalate": [
        "Entübasyon başarısız olur ve hasta ventile edilemezse, derhal zor havayolu / CICO protokolünü aktive edin, yardım isteyin ve supraglottik havayolu yerleştirin"
      ],
      "referencesToShow": [
        "2022 ASA Practice Guidelines for Management of the Difficult Airway.",
        "Preoxygenation and Rapid Sequence Induction Guidelines. 2021."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "RSI is used for rapid controlled intubation in high aspiration-risk patients. Define risk and plan B/C/D. Prepare help, suction, videolaryngoscope, bougie/SAD, and CICO equipment. Perform effective preoxygenation; consider head-up/ramped position. Choose induction agent and neuromuscular blocker according to hemodynamic risk. Minimize apnea time; consider nasal oxygen/apneic oxygenation. Confirm intubation with capnography. If unsuccessful, avoid repeated attempts and move to an oxygenation-focused difficult airway algorithm.",
      "immediateRedFlags": [
        "Active vomiting or regurgitation during the induction sequence.",
        "Rapid, deep hypoxemia (SpO2 < 85%) during the apneic phase despite preoxygenation.",
        "Inability to ventilate or intubate (CICO) after neuromuscular blocker administration."
      ],
      "missingCriticalInformation": [
        "The patient's actual fasting status and hemodynamic stability (hypovolemic patients are at high risk for circulatory collapse)",
        "Anticipated difficulty with mask ventilation or intubation"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Rapid Sequence Induction (RSI)",
        "Full Stomach Anesthesia Induction",
        "Airway Emergencies"
      ],
      "suggestedNextStepsGeneral": [
        "Preoxygenate with 100% O2 for at least 3 minutes or until EtO2 > 90%.",
        "Administer rapid-acting induction agent and paralytic (succinylcholine or high-dose rocuronium) in rapid succession.",
        "Avoid positive pressure ventilation between drug injection and cuff inflation (classic RSI) to prevent gastric insufflation.",
        "Confirm tracheal placement with capnography before releasing cricoid pressure (if applied)."
      ],
      "relatedAlgorithms": [
