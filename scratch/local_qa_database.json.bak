        "Girişim sırasında travmatik/kanamalı ponksiyon öyküsü varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Nöroaksiyel Anestezi Sonrası Epidural Hematom Tanısı",
        "Acil Spinal Kord Dekompresyonu Zamanlaması",
        "ASRA Kanama Komplikasyonu Güvenlik Kuralları"
      ],
      "suggestedNextStepsGeneral": [
