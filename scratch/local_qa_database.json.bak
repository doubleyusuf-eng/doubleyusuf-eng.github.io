  {
    "id": "lactate_elevation",
    "category": "clinical_scenarios",
    "keywords": [
      "acidosis",
      "asidoz",
      "elevated",
      "elevation",
      "lactate",
      "lactic",
      "laktat",
      "laktik",
      "yuksekligi",
      "yüksekliği"
    ],
    "question_tr": "Laktat yüksekliği",
    "question_en": "Lactic acidosis",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Laktat yüksekliği (> 2.0 mmol/L), ciddi doku hipoperfüzyonunun, şokun veya hücresel metabolik bozukluğun en önemli erken göstergelerinden biridir. Laktik asidoz ikiye ayrılır: Tip A (yetersiz doku perfüzyonu/oksijenasyonu; sepsis, şok, mezenter iskemi, hipoksemi) ve Tip B (bozulmuş hücresel metabolizma veya ilaçlar; metformin, karaciğer yetmezliği, malignite). Tedavinin ana hedefi, perfüzyonun ve doku oksijenasyonunun (ortalama arter basıncı > 65 mmHg, optimal sıvı resüsitasyonu, inotropik destek) hızla optimize edilmesidir.",
      "immediateRedFlags": [
        "Laktat düzeyinin > 4.0 mmol/L üzerine çıkması ve agresif sıvı tedavisine rağmen düşmemesi (yüksek mortalite riski).",
        "Klinik şok bulguları olmaksızın gizli doku hipoperfüzyonu (okült şok)."
      ],
      "missingCriticalInformation": [
        "Hastanın anlık hemodinamik verileri (MAP, kalp hızı, idrar çıkışı)",
        "Şok veya enfeksiyon odak şüphesi (ateş, lökositoz, odak varlığı)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Laktat Yüksekliği Yönetimi",
        "Doku Perfüzyonu İzlemi",
        "Septik ve Kardiyojenik Şok"
      ],
      "suggestedNextStepsGeneral": [
        "Laktat değerini doğrulayın ve her 2-4 saatte bir laktat takibi yaparak klirens hızını izleyin (hedef >%10 klirens).",
        "Hastanın hemodinamisini (MAP > 65 mmHg) izotonik kristalloidler ve gerekirse Norepinefrin ile optimize edin.",
        "Kardiyak debiyi ve oksijen sunumunu (DO2) artırmak için gerekirse hematokrit ve inotropik (Dobutamin) desteği düşünün.",
        "Tip B laktat nedenlerini (özellikle metformin kullanımı, propofol infüzyon sendromu veya karaciğer yetmezliği) gözden geçirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "sepsis",
          "titleTr": "Sepsis & Şok Algoritması"
        },
        {
          "id": "hypotension",
          "titleTr": "Hipotansiyon Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        },
        {
          "id": "dobutamine",
          "titleTr": "Dobutamin Monografı"
        }
      ],
      "doNotMiss": [
        "Laktat klirensinin (laktatın düşme hızının), kritik hastalarda resüsitasyonun başarısını göstermede tek başına laktat değerinden daha güvenilir olduğunu"
      ],
      "whenToEscalate": [
        "Resüsitasyona rağmen laktatın yükselmeye devam etmesi veya mezenter iskemi, nekrotizan fasyit gibi cerrahi acillerin varlığında hastayı acilen cerrahiye ve postop yoğun bakıma yönlendirin"
      ],
      "referencesToShow": [
        "Surviving Sepsis Campaign Guidelines 2021.",
        "Marino's The ICU Book, 4th Edition."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Elevated lactate (> 2.0 mmol/L) is a critical early indicator of tissue hypoperfusion, circulatory shock, or cellular metabolic dysfunction. Lactic acidosis is classified into: Type A (due to tissue hypoperfusion or hypoxia; e.g., sepsis, shock, mesenteric ischemia, severe hypoxemia) and Type B (due to altered cellular metabolism, hepatic failure, or drugs like metformin). The primary goal of management is rapid optimization of systemic perfusion and oxygen delivery (MAP > 65 mmHg, optimal fluid resuscitation, inotropic support).",
      "immediateRedFlags": [
        "Serum lactate > 4.0 mmol/L that fails to clear despite aggressive resuscitation (associated with high mortality).",
        "Cryptic tissue hypoperfusion (occult shock) where systemic blood pressure appears normal."
      ],
      "missingCriticalInformation": [
        "The patient's current hemodynamic parameters (MAP, heart rate, urine output)",
        "Suspicion of infection or source of shock (fever, leukocytosis, focal signs)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Elevated Lactate Management",
        "Tissue Perfusion Monitoring",
        "Septic and Cardiogenic Shock"
      ],
      "suggestedNextStepsGeneral": [
        "Confirm the lactate level and perform serial lactate measurements every 2-4 hours to track clearance (target >10% clearance).",
        "Optimize systemic hemodynamics (target MAP > 65 mmHg) using isotonic crystalloids and Norepinephrine as needed.",
        "Support oxygen delivery (DO2) by optimizing hemoglobin levels and considering inotropic support (Dobutamine) if cardiac output is low.",
        "Rule out Type B causes of lactic acidosis, including chronic metformin therapy, propofol infusion syndrome, or liver failure."
      ],
      "relatedAlgorithms": [
        {
          "id": "sepsis",
          "titleTr": "Sepsis & Shock Management"
        },
        {
          "id": "hypotension",
          "titleTr": "Hypotension Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        },
        {
          "id": "dobutamine",
          "titleTr": "Dobutamine Monograph"
        }
      ],
      "doNotMiss": [
        "Lactate clearance (the rate of decline) is a highly reliable prognostic indicator and guide for successful shock resuscitation"
      ],
      "whenToEscalate": [
        "If lactate continues to rise despite aggressive resuscitation or if surgical emergencies like mesenteric ischemia are suspected, arrange immediate intervention and ICU transfer"
      ],
      "referencesToShow": [
        "Surviving Sepsis Campaign Guidelines 2021.",
        "Marino's The ICU Book, 4th Edition."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "respiratory_acidosis",
    "category": "clinical_scenarios",
    "keywords": [
      "acidosis",
      "asidoz",
      "hiperkapni",
      "hypercapnia",
      "respiratory",
      "respiratuvar"
    ],
    "question_tr": "Respiratuvar asidoz",
    "question_en": "Hypercapnia",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Respiratuvar asidoz, karbondioksit atılımının yetersiz kalması (alveoler hipoventilasyon) sonucu PaCO2'nin (> 45 mmHg) artması ve pH'ın (< 7.35) düşmesi ile karakterizedir. Nedenleri arasında anesteziye bağlı solunum merkezinin baskılanması (opioidler, inhalasyon ajanları), nöromüsküler blokajın uzaması, KOAH/Astım alevlenmesi ve mekanik ventilatörde yetersiz dakika ventilasyonu yer alır. Tedavi, dakika ventilasyonunun (solunum hızının ve/veya tidal volümün artırılması) optimize edilmesi ve altta yatan nedenin (örn. Sugammadeks veya Nalokson ile ilaçların geri döndürülmesi) düzeltilmesidir.",
      "immediateRedFlags": [
        "Akut derin solunum depresyonu ve pH < 7.15 ile birlikte gelişen miyokardiyal instabilite ve aritmi riski.",
        "Zor havayolu olan bir hastada tam havayolu obstrüksiyonuna bağlı akut hiperkapnik arrest."
      ],
      "missingCriticalInformation": [
        "Hastanın mekanik ventilatör parametreleri (Tidal volüm, solunum hızı, PEEP, plato basıncı)",
        "Kullanılan opioid ve kas gevşetici dozları ile geri döndürme ajanlarının yapılıp yapılmadığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Respiratuvar Asidoz Yönetimi",
        "Hiperkapni ve Alveoler Hipoventilasyon",
        "Ventilasyon Parametreleri Optimizasyonu"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle nöromüsküler blokajın tamamen döndürüldüğünden (TOF > 0.9) emin olun; gerekirse ek Sugammadeks/Neostigmin yapın.",
        "Ventile olan hastada dakika ventilasyonunu artırmak için solunum hızını ve/veya tidal volümü artırın (plato basıncını < 30 cmH2O tutarak).",
        "Aşırı opioid etkisinden şüpheleniliyorsa, solunumu baskılamayacak şekilde düşük doz Nalokson (titre edilerek) uygulayın.",
        "KOAH alevlenmesi veya bronkospazm varlığında kısa etkili beta-2 agonistler ve inhale steroidler başlayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "bronchospasm",
          "titleTr": "Bronkospazm Algoritması"
        },
        {
          "id": "cico",
          "titleTr": "CICO (Can't Intubate Can't Oxygenate)"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        }
      ],
      "doNotMiss": [
        "Akut respiratuvar asidozda pH'ın hızla düşeceğini, kronik respiratuvar asidozda ise (örn. stabil KOAH) böbreklerin HCO3'ü tutarak pH'ı koruduğunu (kompanse asidoz)"
      ],
      "whenToEscalate": [
        "Entübe olmayan hastada derinleşen bilinç bulanıklığı, pH < 7.25 ve ciddi solunum sıkıntısı varlığında acilen entübasyon uygulayın veya yoğun bakımda noninvaziv mekanik ventilasyon (NIV) başlatın"
      ],
      "referencesToShow": [
        "West's Respiratory Physiology: The Essentials, 11th Edition.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Respiratory acidosis is characterized by a primary elevation of PaCO2 (> 45 mmHg) and a reduction in pH (< 7.35) due to inadequate carbon dioxide elimination (alveolar hypoventilation). Causes include anesthesia-induced respiratory depression (opioids, volatile agents), residual neuromuscular blockade, COPD/asthma exacerbation, and inadequate minute ventilation on mechanical support. Treatment focuses on optimizing minute ventilation (increasing respiratory rate and/or tidal volume) and addressing the underlying cause (e.g., reversing drugs with Sugammadex or Naloxone).",
      "immediateRedFlags": [
        "Acute severe respiratory depression with pH < 7.15, increasing myocardial instability and risk of arrhythmias.",
        "Acute hypercapnic arrest due to complete airway obstruction in a patient with a difficult airway."
      ],
      "missingCriticalInformation": [
        "The patient's current mechanical ventilator settings (Tidal volume, respiratory rate, PEEP, plateau pressure)",
        "Total doses of opioids and neuromuscular blockers administered, and reversal status"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Respiratory Acidosis Management",
        "Hypercapnia and Alveolar Hypoventilation",
        "Ventilation Parameter Optimization"
      ],
      "suggestedNextStepsGeneral": [
        "Ensure complete reversal of neuromuscular blockade (TOF ratio > 0.9) using Sugammadex or Neostigmine.",
        "In mechanically ventilated patients, increase minute ventilation by adjusting respiratory rate or tidal volume (keeping plateau pressure < 30 cmH2O).",
        "If opioid overdose is suspected, titrate low-dose Naloxone carefully to avoid sudden pain crisis.",
        "In patients with broncho-obstruction or COPD flare, administer short-acting beta-2 agonists and inhaled corticosteroids."
      ],
      "relatedAlgorithms": [
        {
          "id": "bronchospasm",
          "titleTr": "Bronchospasm Algorithm"
        },
        {
          "id": "cico",
          "titleTr": "CICO (Can't Intubate Can't Oxygenate)"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        }
      ],
      "doNotMiss": [
        "Acute respiratory acidosis causes a rapid drop in pH; chronic respiratory acidosis (e.g., stable COPD) is compensated by renal HCO3 retention, presenting with a near-normal pH"
      ],
      "whenToEscalate": [
        "In non-intubated patients with worsening consciousness, pH < 7.25, and severe respiratory distress, perform immediate endotracheal intubation or initiate noninvasive ventilation (NIV) in the ICU"
      ],
      "referencesToShow": [
        "West's Respiratory Physiology: The Essentials, 11th Edition.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "respiratory_alkalosis",
    "category": "clinical_scenarios",
    "keywords": [
      "alkalosis",
      "alkaloz",
      "hiperventilasyon",
      "respiratory",
      "respiratuvar"
    ],
    "question_tr": "Respiratuvar alkaloz",
    "question_en": "Hiperventilasyon",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Respiratuvar alkaloz, aşırı solunum (alveoler hiperventilasyon) sonucu PaCO2'nin (< 35 mmHg) düşmesi ve pH'ın (> 7.45) yükselmesi durumudur. Perioperatif dönemde en sık nedenleri ağrı, anksiyete, ateş, hafif hipoksemi kompansasyonu, cerrahi uyarana yanıt veya mekanik ventilatörde aşırı dakika ventilasyonudur. Tedavi kesinlikle altta yatan nedenin düzeltilmesidir: Yeterli analjezi sağlanması, anksiyetenin yatıştırılması veya mekanik ventilatörde solunum frekansının/tidal volümün azaltılması hemodinamik stabiliteyi korur.",
      "immediateRedFlags": [
        "Ciddi alkalemi (pH > 7.55) sonucu gelişen serebral vazokonstriksiyon ve koroner vazospazm riski.",
        "İyonize kalsiyumun düşmesine bağlı tetani, laringospazm ve nöbet gelişmesi."
      ],
      "missingCriticalInformation": [
        "Hastanın ağrı skoru ve hemodinamik parametreleri (tansiyon, kalp hızı)",
        "Güncel mekanik ventilasyon ayarları (frekans, tidal volüm)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Respiratuvar Alkaloz Yönetimi",
        "Hiperventilasyon Kontrolü",
        "Postoperatif Analjezi Stratejileri"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle ağrı kontrolünü optimize edin; yeterli analjezi (opioid veya rejyonal boluslar) sağlayın.",
        "Ventile olan hastada dakika ventilasyonunu azaltmak için solunum hızını veya tidal volümü düşürün.",
        "Alkalemiye bağlı iyonize hipokalsemi bulgularını (tetani, parestezi) ve EKG'de QT uzamasını izleyin.",
        "Hastada anksiyete hakimse hafif sedasyon (örn. düşük doz midazolam veya deksmedetomidin) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "desaturation",
          "titleTr": "Hipoksemi Algoritması"
        },
        {
          "id": "postop_pain_ladder",
          "titleTr": "Ağrı Tedavisi"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "dexmedetomidine",
          "titleTr": "Deksmedetomidin Monografı"
        }
      ],
      "doNotMiss": [
        "Akut respiratuvar alkalozun iyonize kalsiyumu düşürerek nöromüsküler irritabiliteye (Trousseau ve Chvostek belirtileri) neden olabileceğini"
      ],
      "whenToEscalate": [
        "İnatçı hiperventilasyona eşlik eden kontrolsüz serebral ödem riski veya nörolojik bulgular varlığında derhal yoğun bakım ekibiyle iletişime geçin, ventilatörde kontrollü hipoventilasyon sağlayın"
      ],
      "referencesToShow": [
        "Marino's The ICU Book, 4th Edition.",
        "Rose & Post's Clinical Physiology of Acid-Base and Electrolyte Disorders, 6th Edition."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Respiratory alkalosis is characterized by a primary decrease in PaCO2 (< 35 mmHg) and an elevation in pH (> 7.45) due to hyperventilation. In the perioperative setting, the most common triggers are pain, anxiety, fever, compensatory hyperventilation for mild hypoxemia, surgical stimulation, or excessive minute ventilation on a mechanical ventilator. Treatment targets the primary cause: optimizing analgesia, calming anxiety, or reducing mechanical ventilation rate/tidal volume.",
      "immediateRedFlags": [
        "Severe alkalemia (pH > 7.55) leading to cerebral vasoconstriction and coronary vasospasm.",
        "Acute decrease in ionized calcium causing tetany, laryngospasm, and seizures."
      ],
      "missingCriticalInformation": [
        "The patient's current pain score and hemodynamic parameters",
        "Mechanical ventilator settings (Respiratory rate, tidal volume)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Respiratory Alkalosis Management",
        "Hyperventilation Control",
        "Postoperative Analgesia Strategies"
      ],
      "suggestedNextStepsGeneral": [
        "Optimize pain management by administering appropriate analgesics (opioids or regional boluses).",
        "In mechanically ventilated patients, decrease minute ventilation by reducing the respiratory rate or tidal volume.",
        "Monitor for signs of ionized hypocalcemia (tetany, paresthesias) and EKG changes (QT prolongation).",
        "If anxiety is the driving cause, consider mild sedation (e.g., low-dose midazolam or dexmedetomidine)."
      ],
      "relatedAlgorithms": [
        {
          "id": "desaturation",
          "titleTr": "Hypoxemia Algorithm"
        },
        {
          "id": "postop_pain_ladder",
          "titleTr": "Postoperative Pain Management"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "dexmedetomidine",
          "titleTr": "Dexmedetomidine Monograph"
        }
      ],
      "doNotMiss": [
        "Acute respiratory alkalosis shifts ionized calcium onto albumin, causing functional hypocalcemia and neuromuscular irritability (Trousseau and Chvostek signs)"
      ],
      "whenToEscalate": [
        "For persistent hyperventilation associated with severe intracranial hypertension or neurological deterioration, consult neurology/ICU and implement controlled mechanical ventilation"
      ],
      "referencesToShow": [
        "Marino's The ICU Book, 4th Edition.",
        "Rose & Post's Clinical Physiology of Acid-Base and Electrolyte Disorders, 6th Edition."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "metabolic_alkalosis",
    "category": "clinical_scenarios",
    "keywords": [
      "alkalosis",
      "alkaloz",
      "metabolic",
      "metabolik"
    ],
    "question_tr": "Metabolik alkaloz",
    "question_en": "Metabolic alkalosis",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Metabolik alkaloz, birincil olarak bikarbonat artışı (HCO3 > 26 mEq/L) ve pH artışı (> 7.45) ile karakterizedir. Vücut solunumu baskılayarak kompansasyon yapmaya çalışır (PaCO2 hafif yükselir). Klinik olarak iki sınıfa ayrılır: Klorür duyarlı (en sık; kusma, nasogastrik aspirasyon, diüretik tedavisi; idrar klorürü < 20 mEq/L) ve Klorür dirençli (mineralokortikoid fazlalığı; idrar klorürü > 20 mEq/L). Tedavi, klorür duyarlı asidozda normal salin (%0.9 NaCl) ile hidrasyon, potasyum replasmanı ve altta yatan nedenin düzeltilmesidir.",
      "immediateRedFlags": [
        "Ciddi alkalemi (pH > 7.55) ile birlikte solunum dürtüsünün baskılanması ve sekonder derin hipoksemi gelişimi.",
        "Kompansatuvar hipoventilasyonun karbondioksit retansiyonunu tetiklemesi."
      ],
      "missingCriticalInformation": [
        "Serum klor ve potasyum düzeyleri",
        "İdrar klor konsantrasyonu (klorür duyarlı vs. klorür dirençli ayrımı için)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Metabolik Alkaloz Yönetimi",
        "Sıvı-Elektrolit Bozuklukları Düzeltilmesi",
        "Klorür ve Potasyum Eksikliği"
      ],
      "suggestedNextStepsGeneral": [
        "Serum klor ve potasyum düzeylerini strictly ölçün ve eksiklikleri (potasyum klorür ile) tamamlayın.",
        "Klorür duyarlı hastalarda intravasküler volümü %0.9 NaCl (normal salin) infüzyonu ile yerine koyun.",
        "Diüretik tedavisine bağlı alkaloz geliştiyse diüretikleri kesin veya asetazolamid (karbonik anhidraz inhibitörü) düşünün.",
        "Kompansatuvar hipoventilasyona bağlı hipoksemiyi izlemek için nabız oksimetre takibi yapın."
      ],
      "relatedAlgorithms": [
        {
          "id": "desaturation",
          "titleTr": "Hipoksemi Algoritması"
        },
        {
          "id": "renal_failure_anesthesia",
          "titleTr": "Böbrek Yetmezliği"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monografı"
        }
      ],
      "doNotMiss": [
        "Metabolik alkalozun sıklıkla hipokalemi ile birlikte seyrettiğini ve potasyum verilmeden alkalozun düzeltilemeyeceğini (böbrek potasyumu korumak için H+ atar)"
      ],
      "whenToEscalate": [
        "pH > 7.55 altına düşmeyen, diyaliz ihtiyacı olan böbrek yetmezliği hastalarında veya ciddi nörolojik semptomlar varlığında nefroloji konsültasyonu isteyin"
      ],
      "referencesToShow": [
        "Rose & Post's Clinical Physiology of Acid-Base and Electrolyte Disorders, 6th Edition.",
        "Marino's The ICU Book, 4th Edition."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Metabolic alkalosis is characterized by a primary elevation of bicarbonate (HCO3 > 26 mEq/L) and a rise in pH (> 7.45). Compensatory hypoventilation occurs, causing a modest increase in PaCO2. It is clinically divided into: Chloride-responsive (most common; due to vomiting, nasogastric suction, diuretics; urine chloride < 20 mEq/L) and Chloride-resistant (due to mineralocorticoid excess; urine chloride > 20 mEq/L). Treatment for chloride-responsive alkalosis is intravenous hydration with normal saline (0.9% NaCl), potassium replacement, and treating the cause.",
      "immediateRedFlags": [
        "Severe alkalemia (pH > 7.55) depressing respiratory drive and causing secondary profound hypoxemia.",
        "Worsening compensatory hypoventilation leading to severe carbon dioxide retention."
      ],
      "missingCriticalInformation": [
        "Serum chloride and potassium levels",
        "Urine chloride concentration (to differentiate chloride-responsive vs. resistant etiologies)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Metabolic Alkalosis Management",
        "Fluid and Electrolyte Resuscitation",
        "Chloride and Potassium Replacement"
      ],
      "suggestedNextStepsGeneral": [
        "Measure serum chloride and potassium levels, and correct deficiencies (preferably using potassium chloride).",
        "In chloride-responsive patients, restore intravascular volume using 0.9% NaCl (normal saline) infusion.",
        "If loop diuretics are causing the alkalosis, hold the diuretic or consider administering acetazolamide.",
        "Monitor oxygen saturation closely to detect hypovolemia-induced or compensatory hypoventilation-induced hypoxemia."
      ],
      "relatedAlgorithms": [
        {
          "id": "desaturation",
          "titleTr": "Hypoxemia Algorithm"
        },
        {
          "id": "renal_failure_anesthesia",
          "titleTr": "Renal Failure"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monograph"
        }
      ],
      "doNotMiss": [
        "Metabolic alkalosis is heavily linked with hypokalemia; correcting potassium is mandatory to correct the alkalosis (kidneys secrete H+ to retain K+)"
      ],
      "whenToEscalate": [
        "For refractory alkalosis (pH > 7.55) in patients with severe renal failure requiring emergent dialysis or presenting with neurological signs, consult nephrology urgently"
      ],
      "referencesToShow": [
        "Rose & Post's Clinical Physiology of Acid-Base and Electrolyte Disorders, 6th Edition.",
        "Marino's The ICU Book, 4th Edition."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "hypoxemia_aa_gradient",
    "category": "clinical_scenarios",
    "keywords": [
      "aa",
      "gradient",
      "gradyanı",
      "hypoxemia",
      "oksijen"
    ],
    "question_tr": "Aa gradient",
    "question_en": "Oksijen gradyanı",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Hipokseminin ayırıcı tanısında Alveolo-arteriyel (A-a) oksijen gradyanı hesaplanması kritik bir adımdır. Formül: A-a Gradyanı = PAO2 - PaO2. Burada PAO2 = FiO2 x (713) - (PaCO2 / 0.8) olarak hesaplanır (deniz seviyesinde). Normal gradyan yaşa bağlıdır ve kabaca [Yaş / 4] + 4 olarak hesaplanır. Yüksek A-a gradyanı; akciğer içi şant (ARDS, PE, atelektazi, pnömoni) veya ventilasyon-perfüzyon (V/Q) uyumsuzluğunu gösterir. Normal A-a gradyanı ise hipokseminin alveoler hipoventilasyon (örn. opioid aşırı dozu) veya düşük FiO2 (yüksek irtifa) kaynaklı olduğunu gösterir.",
      "immediateRedFlags": [
        "Ciddi hipoksemiyle (PaO2 < 60 mmHg) birlikte A-a gradyanının aşırı yüksek olması (ciddi PE veya ARDS şüphesi).",
        "Normal gradyanı olan bir hastada derin alveoler hipoventilasyona bağlı ani solunum durması."
      ],
      "missingCriticalInformation": [
        "Hastanın aldığı FiO2 ve deniz seviyesinden yükseklik barometrik basıncı",
        "Güncel arterial kan gazındaki PaCO2 ve PaO2 değerleri"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Hipoksemi Ayırıcı Tanısı",
        "A-a Gradyanı Hesaplama",
        "Akciğer Parankim Hastalıkları"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle kan gazından PaO2 ve PaCO2 değerleri ile hastanın FiO2 düzeyini eş zamanlı kaydedin.",
        "Alveoler gaz denklemini kullanarak PAO2 değerini hesaplayın ve ardından A-a gradyanını bulun.",
        "A-a gradyanı yüksekse akciğer parankim patolojilerini (PE, ARDS, pnömoni) ekarte etmek için akciğer grafisi/BT anjiyo planlayın.",
        "A-a gradyanı normalse hipokseminin yetersiz solunuma (hipoventilasyon) bağlı olduğunu saptayıp solunumsal desteği/reversal ajanları uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "desaturation",
          "titleTr": "Hipoksemi Algoritması"
        },
        {
          "id": "respiratory_acidosis",
          "titleTr": "Respiratuvar Asidoz"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        }
      ],
      "doNotMiss": [
        "Oksijen tedavisi altında (yüksek FiO2) hesaplanan A-a gradyanının fizyolojik olarak artacağını ve en güvenilir gradyan hesabının oda havasında yapıldığını"
      ],
      "whenToEscalate": [
        "İnatçı şant fizyolojisi, ciddi PE şüphesi veya PaO2/FiO2 < 150 (ARDS) durumunda hastayı entübe edin, PEEP ve FiO2'yi optimize edin, yoğun bakım planlayın"
      ],
      "referencesToShow": [
        "West's Respiratory Physiology: The Essentials, 11th Edition.",
        "Nunn's Applied Respiratory Physiology, 8th Edition."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "The Alveolar-arterial (A-a) oxygen gradient is a vital tool for diagnosing the etiology of hypoxemia. Formula: A-a Gradient = PAO2 - PaO2, where PAO2 = [FiO2 x (713)] - [PaCO2 / 0.8] (at sea level). The normal gradient varies by age and is estimated as [Age / 4] + 4. An elevated A-a gradient indicates intrinsic lung pathology: intrapulmonary shunt (e.g., ARDS, PE, atelectasis, pneumonia) or V/Q mismatch. A normal A-a gradient indicates hypoxemia caused by alveolar hypoventilation (e.g., opioid overdose) or low FiO2 (high altitude).",
      "immediateRedFlags": [
        "Profound hypoxemia (PaO2 < 60 mmHg) with an extremely elevated A-a gradient, raising high concern for massive PE or ARDS.",
        "Sudden apnea in a patient with normal A-a gradient due to severe hypoventilation."
      ],
      "missingCriticalInformation": [
        "The exact FiO2 at the time of arterial blood gas collection",
        "Concomitant PaCO2 and PaO2 values from the same ABG panel"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Hypoxemia Differential Diagnosis",
        "A-a Gradient Calculation",
        "Pulmonary Parenchymal Disease"
      ],
      "suggestedNextStepsGeneral": [
        "Obtain simultaneous arterial PaO2, PaCO2, and exact FiO2 at the time of sampling.",
        "Use the alveolar gas equation to calculate PAO2, then compute the A-a gradient.",
        "If the gradient is elevated, rule out pulmonary embolism, ARDS, or pneumonia with chest imaging.",
        "If the gradient is normal, target treatment at reversing hypoventilation (e.g., reversing sedation or increasing respiratory rate)."
      ],
      "relatedAlgorithms": [
        {
          "id": "desaturation",
          "titleTr": "Hypoxemia Algorithm"
        },
        {
          "id": "respiratory_acidosis",
          "titleTr": "Respiratory Acidosis"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        }
      ],
      "doNotMiss": [
        "Supplemental oxygen (high FiO2) physiologically widens the A-a gradient; the calculation is most accurate when performed on room air"
      ],
      "whenToEscalate": [
        "In persistent shunt physiology, suspected massive PE, or PaO2/FiO2 ratio < 150 (severe ARDS), intubate, optimize PEEP/FiO2, and transfer to ICU"
      ],
      "referencesToShow": [
        "West's Respiratory Physiology: The Essentials, 11th Edition.",
        "Nunn's Applied Respiratory Physiology, 8th Edition."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "oliguria",
    "category": "clinical_scenarios",
    "keywords": [
      "cikisi",
      "dusuk",
      "düşük",
      "idrar",
      "oliguri",
      "oliguria",
      "oligüri",
      "çıkışı"
    ],
    "question_tr": "Oligüri",
    "question_en": "Idrar cikisi dusuk",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Oligüri, idrar çıkışının ardışık 2 saat boyunca < 0.5 mL/kg/saat olması durumudur ve perioperatif böbrek hasarının en erken habercisidir. Ayırıcı tanıda üç kategori incelenir: 1. Prerenal (%70-80; renal perfüzyon kaybı, hipovolemi, hipotansiyon). 2. Renal (akut tübüler nekroz, nefrotoksik hasar). 3. Postrenal (üriner kateter tıkanıklığı, kateter bükülmesi). Yaklaşım: İlk olarak postrenal nedeni (kateteri yıkayarak) dışlayın. Hemodinamiyi (MAP > 65 mmHg) optimize edin. Sadece net volüm yüklenmesi saptanmadıkça körlemesine yüksek doz diüretik vermeyin.",
      "immediateRedFlags": [
        "İdrar çıkışının tam anüri (< 50 mL/gün) düzeyine inmesi (akut tam tıkanıklık veya kortikal nekroz).",
        "Derin oligüriye eşlik eden refrakter hiperkalemi ve metabolik asidoz tablosu."
      ],
      "missingCriticalInformation": [
        "Hastanın net perioperatif sıvı dengesi (giriş-çıkış) ve kan basıncı trendi",
        "Kreatinin düzeyi ve bazal böbrek fonksiyonları"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Oligüri Ayırıcı Tanısı",
        "Perioperatif Renal Perfüzyon",
        "Böbrek Hasarı Önleme"
      ],
      "suggestedNextStepsGeneral": [
        "İlk iş olarak üriner kateterin tıkalı veya bükülmüş olmadığını doğrulamak için kateteri steril salinle yıkayın.",
        "Hastanın hemodinamik durumunu değerlendirin; MAP < 65 mmHg ise vazopressör veya inotrop ile perfüzyon basıncını düzeltin.",
        "Hipovolemi şüphesinde 250-500 ml izotonik kristalloid ile sıvı bolus yanıtını izleyin.",
        "Nefrotoksik ilaçları (NSAID'ler, aminoglikozitler) strictly kesin; kontrast maruziyetini sınırlayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "hypotension",
          "titleTr": "Hipotansiyon Algoritması"
        },
        {
          "id": "sepsis",
          "titleTr": "Sepsis & Şok Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "Oligüriyi tedavi etmek için intravasküler volümü değerlendirmeden yapılan 'körlemesine' diüretiklerin (örn. Furosemid) prerenal böbrek hasarını daha da kötüleştireceğini"
      ],
      "whenToEscalate": [
        "İnatçı anüri, refrakter hiperkalemi (K > 6.0 mEq/L), akciğer ödemi ve ciddi metabolik asidoz varlığında acil nefroloji konsültasyonu isteyin ve CRRT planlayın"
      ],
      "referencesToShow": [
        "KDIGO Clinical Practice Guideline for Acute Kidney Injury. Kidney Int 2012.",
        "Perioperative Medicine: Managing Surgical Patients with Kidney Disease. 2020."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Oliguria is defined as urine output < 0.5 mL/kg/h for at least 2 consecutive hours and is the earliest warning sign of perioperative kidney injury. The differential includes: 1. Prerenal (70-80% of cases; decreased renal perfusion, hypovolemia, hypotension). 2. Renal (acute tubular necrosis, nephrotoxic injury). 3. Postrenal (urinary catheter obstruction or kinking). Clinical approach: Rule out postrenal causes by flushing the catheter first. Optimize systemic hemodynamics (target MAP > 65 mmHg). Do not blindly administer high-dose diuretics unless there is clear fluid overload.",
      "immediateRedFlags": [
        "Total anuria (< 50 mL/day), indicating complete mechanical obstruction or bilateral renal cortical necrosis.",
        "Profound oliguria accompanied by refractory hyperkalemia and metabolic acidosis."
      ],
      "missingCriticalInformation": [
        "The patient's cumulative perioperative fluid balance and mean arterial pressure trends",
        "Recent serum creatinine and baseline renal function"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Oliguria Differential Diagnosis",
        "Perioperative Renal Perfusion",
        "Kidney Injury Prevention"
      ],
      "suggestedNextStepsGeneral": [
        "First, flush the urinary catheter with sterile saline to rule out mechanical obstruction or kinking.",
        "Evaluate hemodynamic status; if MAP is < 65 mmHg, optimize perfusion pressure with fluids or vasopressors.",
        "Perform a fluid challenge with 250-500 mL of isotonic crystalloid if hypovolemia is suspected, and assess response.",
        "Discontinue all nephrotoxic agents (NSAIDs, aminoglycosides) and minimize contrast exposure."
      ],
      "relatedAlgorithms": [
        {
          "id": "hypotension",
          "titleTr": "Hypotension Algorithm"
        },
        {
          "id": "sepsis",
          "titleTr": "Sepsis & Shock Management"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Blindly administering loop diuretics (e.g., Furosemide) for oliguria without confirming volume status worsens prerenal acute kidney injury"
      ],
      "whenToEscalate": [
        "In the event of persistent anuria, refractory hyperkalemia (K > 6.0 mEq/L), pulmonary edema, or severe acidosis, consult nephrology immediately for urgent renal replacement therapy"
      ],
      "referencesToShow": [
        "KDIGO Clinical Practice Guideline for Acute Kidney Injury. Kidney Int 2012.",
        "Perioperative Medicine: Managing Surgical Patients with Kidney Disease. 2020."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "aki_prevention",
    "category": "clinical_scenarios",
    "keywords": [
      "aki",
      "akut",
      "bobrek",
      "böbrek",
      "hasari",
      "hasarı",
      "onleme",
      "prevention",
      "önleme"
    ],
    "question_tr": "Aki önleme",
    "question_en": "Akut bobrek hasari onleme",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Perioperatif Akut Böbrek Hasarının (AKI) önlenmesi, hastanın risk profilinin belirlenmesi ve intraoperatif fizyolojinin optimize edilmesi üzerine kuruludur. KDIGO kılavuzlarına göre temel ilkeler: 1. Preoperatif risk belirleme (ileri yaş, kronik böbrek hastalığı, DM, kalp yetmezliği). 2. İntraoperatif hipotansiyondan (strictly MAP > 65 mmHg) kaçınma. 3. Övoleminin sürdürülmesi ve dengeli kristalloidlerin (salin yerine Plazma-Lyte veya Ringer Laktat) tercih edilmesi. 4. Nefrotoksik ilaçların (NSAID, aminoglikozit) perioperatif kısıtlanması. 5. Kontrast maruziyetinin en aza indirilmesi.",
      "immediateRedFlags": [
        "İntraoperatif dönemde MAP < 55 mmHg değerinin >10 dakikadan uzun sürmesi (böbrek hasarı eşiği).",
        "Bilinmeyen preoperatif renal disfonksiyonu olan hastada agresif nefrotoksik ilaç kullanımı."
      ],
      "missingCriticalInformation": [
        "Hastanın bazal kreatinin ve glomerüler filtrasyon hızı (GFR)",
        "Ameliyatın böbrek hasarı açısından risk derecesi (örn. major vasküler vs. yüzeyel cerrahi)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Böbrek Hasarı Önleme Stratejileri",
        "İntraoperatif Hemodinami Koruma",
        "KDIGO Kılavuz İlkeleri"
      ],
      "suggestedNextStepsGeneral": [
        "Preoperatif dönemde hastanın böbrek fonksiyonlarını (kreatinin, GFR) ve komorbiditelerini strictly değerlendirin.",
        "Ameliyat boyunca ortalama arter basıncını (MAP) strictly 65 mmHg üzerinde tutun; gerekirse Norepinefrin infüzyonu başlayın.",
        "Böbrek asidozunu ve hiperkloremiyi önlemek için sıvı tedavisinde dengeli kristalloidleri tercih edin.",
        "Perioperatif dönemde NSAID kullanımını yüksek riskli renal hastalarda kesinlikle sınırlandırın."
      ],
      "relatedAlgorithms": [
        {
          "id": "oliguria",
          "titleTr": "Oligüri Yönetimi"
        },
        {
          "id": "hypotension",
          "titleTr": "Hipotansiyon Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "İntraoperatif tek bir hipotansiyon epizodunun bile (MAP < 65 mmHg) böbrek hasarı riskini anlamlı derecede artırabileceğini ve yakın arteriyel monitörizasyon gerektirdiğini"
      ],
      "whenToEscalate": [
        "Hastanın postoperatif kreatinin değerinde bazale göre >1.5 kat artış veya oligürisi saptandığında nefroloji takibini başlatın ve ilaç dozlarını kreatinin klirensine göre yeniden ayarlayın"
      ],
      "referencesToShow": [
        "KDIGO Clinical Practice Guideline for Acute Kidney Injury. Kidney Int 2012.",
        "Anesthesiology: Perioperative Kidney Injury. 2021."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Prevention of perioperative Acute Kidney Injury (AKI) relies heavily on identifying high-risk patients and optimizing intraoperative physiology. According to KDIGO guidelines, core strategies include: 1. Preoperative risk stratification (elderly, chronic kidney disease, DM, heart failure). 2. Avoiding intraoperative hypotension (strictly maintain MAP > 65 mmHg). 3. Maintenance of euvolemia, prioritizing balanced crystalloids (e.g., Plasma-Lyte, Ringer's Lactate) over normal saline. 4. Restricting nephrotoxins (NSAIDs, aminoglycosides) perioperatively. 5. Minimizing contrast exposure.",
      "immediateRedFlags": [
        "Intraoperative MAP < 55 mmHg lasting more than 10 minutes (critical threshold for ischemia).",
        "Aggressive administration of nephrotoxic drugs in a patient with unrecognized pre-existing renal impairment."
      ],
      "missingCriticalInformation": [
        "The patient's baseline creatinine and glomerular filtration rate (GFR)",
        "The renal risk level of the planned surgical procedure (e.g., major vascular vs. minor surgery)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Kidney Injury Prevention Strategies",
        "Intraoperative Hemodynamic Preservation",
        "KDIGO Guidelines Implementation"
      ],
      "suggestedNextStepsGeneral": [
        "Evaluate baseline renal function (creatinine, GFR) and identify risk factors during the preoperative assessment.",
        "Strictly maintain MAP > 65 mmHg during anesthesia; initiate Norepinephrine infusion early if hypotension persists.",
        "Use balanced crystalloids rather than normal saline for maintenance and resuscitation to avoid hyperchloremic acidosis.",
        "Hold NSAIDs and other nephrotoxins in patients identified as high risk for renal injury."
      ],
      "relatedAlgorithms": [
        {
          "id": "oliguria",
          "titleTr": "Oliguria Management"
        },
        {
          "id": "hypotension",
          "titleTr": "Hypotension Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Even a brief episode of intraoperative hypotension (MAP < 65 mmHg) significantly increases the risk of postoperative AKI; prioritize prompt treatment"
      ],
      "whenToEscalate": [
        "If serum creatinine increases by >1.5 times baseline postoperatively or persistent oliguria develops, consult nephrology and adjust all drug doses according to clearance"
      ],
      "referencesToShow": [
        "KDIGO Clinical Practice Guideline for Acute Kidney Injury. Kidney Int 2012.",
        "Anesthesiology: Perioperative Kidney Injury. 2021."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "contrast_nephropathy",
    "category": "clinical_scenarios",
    "keywords": [
      "bobrek",
      "böbrek",
      "contrast",
      "kontrast",
      "nefropatisi",
      "nephropathy"
    ],
    "question_tr": "Kontrast nefropatisi",
    "question_en": "Kontrast bobrek",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Kontrast Nefropatisi (CI-AKI), kontrast madde maruziyetinden sonraki 24-72 saat içinde kreatinin düzeyinde bazale göre >%25 veya >0.5 mg/dL artış olmasıdır. En kanıta dayalı önleme stratejisi, kontrast maruziyeti öncesi ve sonrasında strictly hidrasyondur. Önerilen protokol: İntravasküler volümü desteklemek amacıyla işlemden 3-12 saat önce ve 6-12 saat sonra 1-1.5 mL/kg/saat hızında izotonik kristalloid (%0.9 NaCl) veya %1.4 sodyum bikarbonat infüzyonudur. Kontrast hacmi en aza indirilmeli ve işlem öncesi tüm nefrotoksik ajanlar kesilmelidir.",
      "immediateRedFlags": [
        "Ciddi dehidratasyonu olan böbrek hastalarında yüksek volümlü kontrast madde maruziyeti.",
        "Kontrast enjeksiyonundan sonraki 24 saat içinde gelişen derin oligüri."
      ],
      "missingCriticalInformation": [
        "Hastanın bazal GFR değeri ve kontrast verilecek işlemin aciliyeti",
        "Kullanılacak kontrast maddenin tipi (osmolalitesi) ve planlanan hacmi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Kontrast Nefropatisi Risk Azaltma",
        "Renal Koruma Protokolleri",
        "Hidrasyon Tedavisi"
      ],
      "suggestedNextStepsGeneral": [
        "GFR < 30 mL/dk olan hastalarda (veya GFR < 45 olup risk faktörü taşıyanlarda) strictly hidrasyon protokolü başlatın.",
        "Hidrasyonda izotonik kristalloidi tercih edin; hacim yüklenme riskine karşı idrar çıkışını ve solunum seslerini izleyin.",
        "İşlem öncesinde NSAID, diüretik ve metformin gibi riskli ilaçları en az 24-48 saat önce kesin.",
        "Klinik kanıtı zayıf olsa da çok yüksek riskli durumlarda N-asetilsistein kullanımını düşünebilirsiniz (rutin önerilmez)."
      ],
      "relatedAlgorithms": [
        {
          "id": "aki_prevention",
          "titleTr": "Böbrek Hasarı Önleme"
        },
        {
          "id": "oliguria",
          "titleTr": "Oligüri Yönetimi"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monografı"
        }
      ],
      "doNotMiss": [
        "Hidrasyon uygularken hastanın kardiyak fonksiyonlarını değerlendirmeyi ve kalp yetmezliği olanlarda hızı strictly düşürerek yakın takip yapılması gerektiğini"
      ],
      "whenToEscalate": [
        "İşlem sonrasında böbrek fonksiyonlarında hızlı bozulma (kreatinin artışı) veya akciğer ödemi gelişmesi durumunda nefroloji ve kardiyoloji konsültasyonunu acilen planlayın"
      ],
      "referencesToShow": [
        "ESUR Guidelines on Contrast Agents. 2018.",
        "KDIGO Clinical Practice Guideline for Acute Kidney Injury. 2012."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Contrast-Induced Acute Kidney Injury (CI-AKI) is defined as an increase in serum creatinine by >25% or >0.5 mg/dL within 24-72 hours of contrast media exposure. The most evidence-based preventive strategy is strict intravenous hydration before and after exposure. Recommended protocol: 1-1.5 mL/kg/h of isotonic crystalloid (0.9% NaCl) or 1.4% sodium bicarbonate starting 3-12 hours prior and continuing 6-12 hours after the procedure. Minimize contrast volume and hold all nephrotoxic agents beforehand.",
      "immediateRedFlags": [
        "High-volume contrast exposure in a severely dehydrated patient with pre-existing renal impairment.",
        "Development of profound oliguria within 24 hours of contrast administration."
      ],
      "missingCriticalInformation": [
        "The patient's baseline GFR and the urgency of the contrast-requiring procedure",
        "The type (osmolality) and planned volume of the contrast media"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Contrast Nephropathy Risk Reduction",
        "Renal Preservation Protocols",
        "Hydration Therapy Management"
      ],
      "suggestedNextStepsGeneral": [
        "Initiate the strict hydration protocol in patients with GFR < 30 mL/min (or GFR < 45 with co-existing risk factors).",
        "Prefer isotonic crystalloid for hydration; monitor urine output and lung sounds to avoid volume overload.",
        "Hold high-risk medications including NSAIDs, diuretics, and Metformin at least 24-48 hours before the procedure.",
        "Avoid relying solely on N-acetylcysteine, as clinical evidence is weak; prioritize volume optimization instead."
      ],
      "relatedAlgorithms": [
        {
          "id": "aki_prevention",
          "titleTr": "AKI Prevention"
        },
        {
          "id": "oliguria",
          "titleTr": "Oliguria Management"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monograph"
        }
      ],
      "doNotMiss": [
        "Evaluate the patient's cardiac function before initiating aggressive hydration; reduce infusion rates strictly in heart failure patients to prevent pulmonary edema"
      ],
      "whenToEscalate": [
        "If serum creatinine rises sharply or severe volume overload develops post-procedure, arrange urgent nephrology and cardiology consultation"
      ],
      "referencesToShow": [
        "ESUR Guidelines on Contrast Agents. 2018.",
        "KDIGO Clinical Practice Guideline for Acute Kidney Injury. 2012."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "rhabdomyolysis",
    "category": "clinical_scenarios",
    "keywords": [
      "myoglobinuri",
      "myoglobinüri",
      "rabdomiyoliz",
      "rhabdomyolysis"
    ],
    "question_tr": "Rabdomiyoliz",
    "question_en": "Myoglobinuri",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Rabdomiyoliz, çizgili kas hasarı sonucu hücre içeriğinin (myoglobin, potasyum, fosfat) dolaşıma katılmasıyla oluşan klinik bir tablodur. Myoglobin tübüllerde çökerek akut böbrek hasarına yol açar. Temel hedefler: Böbrek perfüzyonunu korumak, idrar çıkışını yüksek tutmak ve hiperkalemiyi önlemektir. Tedavinin köşe taşı agresif izotonik sıvı resüsitasyonudur (idrar çıkışı hedefi 200-300 mL/saat). İdrar pH'ını > 6.5 üzerinde tutmak amacıyla sodyum bikarbonat ile idrar alkalizasyonu düşünülebilir. Eş zamanlı potasyum ve kalsiyum takibi hayati önem taşır.",
      "immediateRedFlags": [
        "Serum potasyumunun > 6.0 mEq/L üzerine çıkmasıyla gelişen ölümcül aritmiler ve EKG değişiklikleri.",
        "Derin çizgili kas yıkımına bağlı olarak gelişen kompartman sendromu bulguları (nabızsızlık, şiddetli ağrı)."
      ],
      "missingCriticalInformation": [
        "Serum Kreatin Kinaz (CK) düzeyi ve anlık serum potasyumu",
        "Hastanın anlık idrar çıkışı ve idrar rengi (koyu çay/kola rengi idrar)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Rabdomiyoliz Yönetimi",
        "Myoglobinürik Böbrek Hasarı Önleme",
        "Hiperkalemi ve Elektrolit Acilleri"
      ],
      "suggestedNextStepsGeneral": [
        "Hızla intravenöz damar yolu sağlayıp saatte 200-500 mL izotonik sıvı infüzyonu başlatın (idrar hedefi strictly 200-300 mL/saat).",
        "Serum potasyumunu strictly yakın takip edin; potasyum yüksekse kalsiyum glukonat ve insülin-glukoz infüzyonu başlayın.",
        "İdrar pH'ını izleyin; asidoz veya myoglobinürinin tübüler çökmesini azaltmak için sodyum bikarbonat infüzyonu ekleyin.",
        "Kreatin kinaz (CK) trendini izleyin; CK > 5000 U/L ise renal hasar riski strictly yüksektir."
      ],
      "relatedAlgorithms": [
        {
          "id": "hyperkalemia",
          "titleTr": "Hiperkalemi Algoritması"
        },
        {
          "id": "oliguria",
          "titleTr": "Oligüri Yönetimi"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monografı"
        }
      ],
      "doNotMiss": [
        "Hipokalseminin rabdomiyolizin erken fazında sık görüldüğünü ancak myoglobin yıkımı düzelirken kalsiyumun rebound olarak yükselebileceğini, bu nedenle semptomatik olmadıkça kalsiyum replasmanından kaçınılması gerektiğini"
      ],
      "whenToEscalate": [
        "İnatçı anüri, refrakter hiperkalemi, akciğer ödemi veya ekstremitede kompartman sendromu geliştiğinde acilen nefroloji, ortopedi/cerrahi ekiplerini çağırın, fasyotomi veya CRRT planlayın"
      ],
      "referencesToShow": [
        "New England Journal of Medicine: Rhabdomyolysis. 2015.",
        "Marino's The ICU Book, 4th Edition."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Rhabdomyolysis is a clinical syndrome resulting from skeletal muscle breakdown, causing intracellular contents (myoglobin, potassium, phosphate) to leak into the systemic circulation. Myoglobin precipitates in the renal tubules, leading to acute kidney injury. Primary goals: Maintain renal perfusion, optimize urine output, and prevent hyperkalemia. The cornerstone of treatment is aggressive isotonic fluid resuscitation (urine output target: 200-300 mL/h). Urinary alkalinization using sodium bicarbonate to maintain urine pH > 6.5 may be considered. Continuous potassium and calcium monitoring is vital.",
      "immediateRedFlags": [
        "Lethal arrhythmias and EKG changes due to rapid potassium elevation (> 6.0 mEq/L).",
        "Development of compartment syndrome in affected limbs (loss of pulses, excruciating pain)."
      ],
      "missingCriticalInformation": [
        "Serum Creatine Kinase (CK) level and serial potassium levels",
        "Current hourly urine output and presence of dark (tea/cola-colored) urine"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Rhabdomyolysis Management",
        "Myoglobinuric AKI Prevention",
        "Hyperkalemia and Electrolyte Emergencies"
      ],
      "suggestedNextStepsGeneral": [
        "Establish robust IV access and initiate aggressive fluid resuscitation at 200-500 mL/h (target urine output 200-300 mL/h).",
        "Monitor serum potassium strictly; if hyperkalemia is present, administer calcium gluconate and insulin-glucose.",
        "Monitor urine pH; consider administering sodium bicarbonate to keep urine pH > 6.5, preventing myoglobin cast formation.",
        "Track CK levels: levels > 5000 U/L are strongly associated with a high risk of acute kidney injury."
      ],
      "relatedAlgorithms": [
        {
          "id": "hyperkalemia",
          "titleTr": "Hyperkalemia Algorithm"
        },
        {
          "id": "oliguria",
          "titleTr": "Oliguria Management"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monograph"
        }
      ],
      "doNotMiss": [
        "Hypocalcemia is common in the early phase of rhabdomyolysis but resolves spontaneously; avoid calcium replacement unless symptomatic to prevent rebound hypercalcemia in the recovery phase"
      ],
      "whenToEscalate": [
        "For persistent anuria, refractory hyperkalemia, fluid overload, or signs of limb compartment syndrome, consult orthopedics/surgery and nephrology immediately for fasciotomy or CRRT"
      ],
      "referencesToShow": [
        "New England Journal of Medicine: Rhabdomyolysis. 2015.",
        "Marino's The ICU Book, 4th Edition."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "ponv_rescue",
    "category": "clinical_scenarios",
    "keywords": [
      "bulanti",
      "bulantı",
      "kurtarici",
      "kurtarma",
      "kurtarıcı",
      "kusma",
      "ponv",
      "rescue"
    ],
    "question_tr": "Ponv rescue",
    "question_en": "Bulanti kusma kurtarici",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Postoperatif Bulantı ve Kusma (PONV) kurtarma (rescue) tedavisinde temel kural, profilakside kullanılmayan farklı sınıftan bir ajanın seçilmesidir. Fourth Consensus Guidelines'a göre: 1. Eğer indüksiyonda veya cerrahi sırasında 5-HT3 antagonisti (örn. Ondansetron) verildiyse ve ilk 6 saatte PONV geliştiyse, Ondansetron dozunu tekrarlamayın; kurtarıcı olarak farklı sınıftan bir ajan (Deksmedetomidin, Alizaprid, Droperidol/Haloperidol, Metoklopramid veya PACU'da sub-hipnotik doz Propofol 10-20 mg) uygulayın. 2. 6 saatten sonra gelişen PONV durumunda profilaksi ajanları (Ondansetron dahil) tekrarlanabilir. Multimodal analjezi ile opioid tüketimini azaltın ve hidrasyonu optimize edin.",
      "immediateRedFlags": [
        "Kontrolsüz fışkırır tarzda kusmaya bağlı dikiş hattı açılması, özofagus yırtılması (Boerhaave sendromu) veya aspirasyon riski.",
        "Kurtarıcı olarak kullanılan nöroleptik ajanlara bağlı akut distoni veya QT uzaması."
      ],
      "missingCriticalInformation": [
        "Hastanın ameliyat sırasında aldığı PONV profilaksisi ilaçları ve bunların zamanlaması",
        "Hastanın Apfel skoru ve mevcut ağrı kontrol düzeyi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "PONV Kurtarma Tedavisi",
        "Fourth Consensus Guidelines Uygulaması",
        "Postoperatif Konfor ve Güvenlik"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle ameliyat sırasında uygulanan profilaksi ajanlarını kontrol edin; aynı sınıftan ilaçları strictly tekrarlamayın.",
        "5-HT3 antagonisti verilmiş hastalarda ilk 6 saatte gelişen PONV için Droperidol (0.625 mg) veya Haloperidol (0.5-1 mg) veya Metoklopramid (10 mg) uygulayın.",
        "PACU'da inatçı PONV varlığında, monitörize koşullarda çok düşük doz Propofol (10-20 mg yavaş IV) bolusunu düşünün.",
        "Hastanın postoperatif hidrasyonunu (kristalloid infüzyonu) sürdürün ve ağrı tedavisinde opioid dışı ajanlara (rejyonal bloklar, Parasetamol, NSAID) öncelik verin."
      ],
      "relatedAlgorithms": [
        {
          "id": "ponv",
          "titleTr": "PONV Profilaksi Algoritması"
        },
        {
          "id": "aspiration",
          "titleTr": "Aspirasyon Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "dexmedetomidine",
          "titleTr": "Deksmedetomidin Monografı"
        }
      ],
      "doNotMiss": [
        "Deksametazonun çok etkili bir profilaktik ajan olduğunu (4-8 mg IV) ancak akut gelişen PONV tablosunda etki başlangıcının yavaş olması nedeniyle bir kurtarıcı (rescue) ajan olarak kullanılmaması gerektiğini"
      ],
      "whenToEscalate": [
        "Tüm multimodal kurtarma tedavilerine rağmen durdurulamayan, intrakraniyal basınç artışı veya cerrahi dikiş açılması riski taşıyan dirençli PONV durumunda, nöroşirürji/cerrahi ekibiyle temasa geçin ve yakın monitörize takip yapın"
      ],
      "referencesToShow": [
        "Fourth Consensus Guidelines for the Management of Postoperative Nausea and Vomiting. Anesth Analg 2020.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "In Postoperative Nausea and Vomiting (PONV) rescue therapy, the fundamental rule is to choose an agent from a different drug class than the prophylactic agent used. According to the Fourth Consensus Guidelines: 1. If a 5-HT3 antagonist (e.g., Ondansetron) was administered during induction/surgery and PONV occurs within the first 6 hours postoperatively, do not repeat the dose; rescue with a different class (e.g., Droperidol/Haloperidol, Metoclopramide, Dexmedetomidine, or sub-hypnotic Propofol 10-20 mg in the PACU). 2. Prophylactic agents (including Ondansetron) may be repeated only if PONV occurs > 6 hours postoperatively. Optimize hydration and limit opioids.",
      "immediateRedFlags": [
        "Uncontrolled projectile vomiting risking surgical wound dehiscence, esophageal rupture (Boerhaave's), or airway aspiration.",
        "Acute dystonic reactions or severe QT prolongation secondary to rescue neuroleptic agents."
      ],
      "missingCriticalInformation": [
        "Specific antiemetics administered intraoperatively and their exact timing of administration",
        "The patient's Apfel score and current pain/opioid consumption status"
      ],
      "likelyClinicalCategoriesToConsider": [
        "PONV Rescue Management",
        "Fourth Consensus Guidelines Implementation",
        "Postoperative Comfort and Safety"
      ],
      "suggestedNextStepsGeneral": [
        "Review the intraoperative anesthesia record for antiemetics administered; do not repeat agents from the same drug class.",
        "For PONV occurring within 6 hours of a prophylactic 5-HT3 antagonist, administer Droperidol (0.625 mg), Haloperidol (0.5-1 mg), or Metoclopramide (10 mg).",
        "Consider administering sub-hypnotic Propofol (10-20 mg slow IV bolus) in the PACU for persistent, severe symptoms.",
        "Maintain adequate postoperative hydration with IV crystalloids and optimize opioid-sparing multimodal analgesia."
      ],
      "relatedAlgorithms": [
        {
          "id": "ponv",
          "titleTr": "PONV Prophylaxis"
        },
        {
          "id": "aspiration",
          "titleTr": "Aspiration Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "dexmedetomidine",
          "titleTr": "Dexmedetomidine Monograph"
        }
      ],
      "doNotMiss": [
        "Dexamethasone is an excellent prophylactic agent (4-8 mg IV) but should not be used for rescue due to its slow onset of action"
      ],
      "whenToEscalate": [
        "For intractable PONV refractory to all rescue modalities that threatens surgical integrity or raises intracranial pressure, coordinate with the surgical team and optimize monitoring"
      ],
      "referencesToShow": [
        "Fourth Consensus Guidelines for the Management of Postoperative Nausea and Vomiting. Anesth Analg 2020.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "postop_pain_ladder",
    "category": "clinical_scenarios",
    "keywords": [
      "agri",
      "ağrı",
      "ladder",
      "merdiveni",
      "pain",
      "postop",
      "postoperatif",
      "postoperative"
    ],
    "question_tr": "Postoperatif ağrı",
    "question_en": "Postoperative pain",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Postoperatif ağrı yönetiminde temel felsefe, opioidlerin yan etkilerini (solunum depresyonu, bulantı, ileus) en aza indiren multimodal analjezidir. Ağrı şiddetine ve cerrahiye göre özelleştirilmiş basamak tedavisi uygulanır: 1. Hafif ağrı: Parasetamol (1g IV) ve/veya nonsteroid antiinflamatuar ilaçlar (NSAID'ler; örn. Tenoksikam, Ketorolak). 2. Orta ağrı: Hafif ağrı tedavisine ek olarak zayıf opioidler (Tramadol) veya rejyonal teknikler (infiltrasyon, sinir blokları). 3. Şiddetli ağrı: Nöroaksiyel analjezi (epidural), hasta kontrollü analjezi (PCA morfin/fentanil) ve adjuvanlar (Lidokain, Ketamin infüzyonları).",
      "immediateRedFlags": [
        "Ağrı tedavisi alan hastada derin sedasyon (sedasyon skoru > 2) ve solunum hızının < 8/dk altına düşmesi (opioid toksisitesi).",
        "Uyumsuz ani ağrı artışının cerrahi komplikasyonları (örn. kompartman sendromu, anastomoz kaçağı) maskelemesi."
      ],
      "missingCriticalInformation": [
        "Hastanın mevcut ağrı şiddeti (VAS skoru) ve cerrahi tipi",
        "Hastanın opioid tolerans durumu ve bazal karaciğer/böbrek fonksiyonları"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Multimodal Analjezi Protokolleri",
        "Opioid Azaltıcı Stratejiler",
        "Bireyselleştirilmiş Ağrı Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Ağrı değerlendirmesini (VAS) düzenli yapın ve ağrı gelişmeden önce Parasetamol (6 saatte bir 1g IV) ve NSAID'leri düzenli uygulayın.",
        "Mümkün olan her cerrahide lokal anesteziyle yara yeri infiltrasyonu veya ultrason eşliğinde periferik sinir blokları planlayın.",
        "Şiddetli ağrıda opioid naif hastalarda bazal infüzyonsuz PCA (Morphine) başlatın; sedasyon ve solunumu izleyin.",
        "Multimodal adjuvanlar olarak intraoperatif magnezyum, ketamin veya lidokain infüzyonlarını değerlendirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "opioid_respiratory",
          "titleTr": "Opioid Solunum Depresyonu"
        },
        {
          "id": "ponv",
          "titleTr": "PONV Profilaksi Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        }
      ],
      "doNotMiss": [
        "Ağrıyı tek başına opioidlerle dindirmeye çalışmanın derin sedasyon ve ileus riskini artıracağını, opioid dışı bazal analjezinin strictly kurulması gerektiğini"
      ],
      "whenToEscalate": [
        "Çoklu multimodal tedavilere ve PCA'e rağmen kontrol altına alınamayan şiddetli ağrı varlığında, kateter tıkanıklığını ekarte edin ve akut ağrı servisi/anestezi konsültasyonu isteyin"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Acute Pain Management. Anesthesiology 2016.",
        "PROSPECT Guidelines (Procedure Specific Postoperative Pain Management)."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "The cornerstone of postoperative pain management is multimodal analgesia, designed to minimize opioid-related side effects (respiratory depression, PONV, ileus). Treatment is tailored based on pain severity and surgical type: 1. Mild pain: Scheduled Paracetamol (1g IV) and/or NSAIDs (e.g., Tenoxicam, Ketorolac). 2. Moderate pain: Add weak opioids (Tramadol), wound infiltration, or peripheral nerve blocks to the baseline regimen. 3. Severe pain: Regional/epidural analgesia, Patient-Controlled Analgesia (PCA with morphine/fentanyl), and adjuvant infusions (Ketamine, IV Lidocaine).",
      "immediateRedFlags": [
        "Deep sedation (sedation score > 2) and respiratory rate < 8 bpm in a patient receiving opioid analgesics.",
        "Sudden, severe pain out of proportion to the surgery, potentially masking complications like compartment syndrome or anastomotic leak."
      ],
      "missingCriticalInformation": [
        "The patient's current pain intensity (VAS score) and surgical procedure details",
        "Opioid tolerance status and baseline renal/hepatic function"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Multimodal Analgesia Protocols",
        "Opioid-Sparing Strategies",
        "Tailored Acute Pain Management"
      ],
      "suggestedNextStepsGeneral": [
        "Assess pain regularly using the VAS score and administer Paracetamol (1g IV q6h) and NSAIDs on a scheduled basis.",
        "Perform surgical wound infiltration or ultrasound-guided regional nerve blocks whenever anatomically feasible.",
        "For severe pain, initiate IV PCA (e.g., Morphine) with no basal infusion in opioid-naïve patients; monitor sedation and respiration.",
        "Consider intraoperative multimodal adjuvants such as intravenous Ketamine, Lidocaine, or Magnesium infusions."
      ],
      "relatedAlgorithms": [
        {
          "id": "opioid_respiratory",
          "titleTr": "Opioid Respiratory Depression"
        },
        {
          "id": "ponv",
          "titleTr": "PONV Prophylaxis"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        }
      ],
      "doNotMiss": [
        "Relying solely on opioids for severe pain increases the risk of deep sedation and bowel ileus; establish a robust non-opioid baseline first"
      ],
      "whenToEscalate": [
        "In the event of severe, intractable pain despite multiple modalities and a functioning PCA, check for catheter displacement and consult the acute pain service urgently"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Acute Pain Management. Anesthesiology 2016.",
        "PROSPECT Guidelines (Procedure Specific Postoperative Pain Management)."
      ],
