      "mh",
      "var0"
    ],
    "question_tr": "Dantrolen uygulaması hangi komplikasyonlara yol açar?",
    "question_en": "What complications can arise from dantrolene?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 Dantrolen uygulaması sonrasında geçici kas güçsüzlüğü, solunum yetmezliği, venöz irritasyon, tromboflebit, gastrointestinal irritasyon ve aşırı sedasyon görülebilir. Ek olarak, yüksek hacimli sulandırma nedeniyle sıvı yüklenmesine dikkat edilmelidir. Postoperatif yoğun bakımda solunum yakından takip edilmelidir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 Complications after Dantrolene include transient muscle weakness, respiratory insufficiency, venous irritation, thrombophlebitis, gastrointestinal upset, and marked somnolence. Fluid overload is also a risk due to the high volume of sterile water required for reconstitution. Monitor ventilation closely in the ICU postoperatively.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
