          "id": "magnesium_sulfate",
          "titleTr": "Magnezyum Sülfat Monografı"
        },
        {
          "id": "labetalol",
          "titleTr": "Labetalol Monografı"
        },
        {
          "id": "hydralazine",
          "titleTr": "Hidralazin Monografı"
        },
        {
          "id": "tranexamic_acid",
          "titleTr": "Traneksamik Asit Monografı"
        }
      ],
      "doNotMiss": [
        "HELLP sendromlu gebelerin glottik ödem nedeniyle zor entübasyon riski taşıdığını ve tok hasta kabul edildiğini"
      ],
      "whenToEscalate": [
        "İntraoperatif cerrahi sahada yaygın mikrovasküler kanama (DIC) gelişirse derhal Masif Transfüzyon Protokolünü (MTP) aktif hale getirin"
      ],
      "referencesToShow": [
        "ACOG Practice Bulletin No. 222: Gestational Hypertension and Preeclampsia. 2020.",
        "SOAP Consensus Guidelines. 2021."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "HELLP involves hemolysis, elevated liver enzymes, and thrombocytopenia. Platelets may fall rapidly. Neuraxial anesthesia decisions require recent platelet count, trend, coagulation status, bleeding signs, and urgency. If general anesthesia is required, prepare for difficult airway, aspiration, hypertensive response to intubation, bleeding, and magnesium sulfate effects. Plan blood products, antihypertensives, magnesium, large-bore access, and ICU support.",
      "immediateRedFlags": [
        "Sudden severe right upper quadrant/epigastric pain and shock suggesting hepatic capsule rupture.",
        "Signs of acute pulmonary edema or severe laryngeal angioedema."
      ],
      "missingCriticalInformation": [
        "Platelet count within the last 2 hours and complete coagulation profile",
        "Infusion status and cumulative dose of Magnesium Sulfate, and hourly urine output"
      ],
      "likelyClinicalCategoriesToConsider": [
        "HELLP Syndrome Anesthesia Management",
        "Hypertensive Crisis Control in Preeclampsia",
        "Magnesium Sulfate Pharmacology and Toxicity"
      ],
      "suggestedNextStepsGeneral": [
        "Obtain a fresh platelet count (drawn within the last 2 hours) before making neuraxial decisions.",
        "For general anesthesia, prevent severe hypertensive response to laryngoscopy using labetalol or remifentanil.",
        "Reduce dose of non-depolarizing neuromuscular blockers, as magnesium significantly potentiates blockade; monitor with TOF.",
        "Verify immediate availability of blood products and plan postoperative ICU placement."
      ],
      "relatedAlgorithms": [
        {
          "id": "hellp",
          "titleTr": "HELLP Anesthesia Algorithm"
        },
        {
          "id": "preeclampsia",
          "titleTr": "Preeclampsia Guidelines"
        },
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "platelet_trend",
          "titleTr": "Platelet Trend Tracker"
        },
        {
          "id": "map",
          "titleTr": "Mean Arterial Pressure"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "magnesium_sulfate",
          "titleTr": "Magnesium Sulfate Monograph"
        },
        {
          "id": "labetalol",
          "titleTr": "Labetalol Monograph"
        },
        {
          "id": "hydralazine",
          "titleTr": "Hydralazine Monograph"
        },
        {
          "id": "tranexamic_acid",
          "titleTr": "Tranexamic Acid Monograph"
        }
      ],
      "doNotMiss": [
        "Airway edema is typically severe in HELLP; always prepare smaller endotracheal tube sizes (e.g. 6.0 and 6.5)"
      ],
      "whenToEscalate": [
        "In the event of severe diffuse hemorrhage or suspected DIC, immediately activate the Massive Transfusion Protocol (MTP)"
      ],
      "referencesToShow": [
        "ACOG Practice Bulletin No. 222: Gestational Hypertension and Preeclampsia. 2020.",
        "SOAP Consensus Guidelines. 2021."
      ],
      "safetyLevel": "urgent"
    }
