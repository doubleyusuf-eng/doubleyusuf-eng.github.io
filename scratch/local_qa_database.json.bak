      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "💉 For moderate-risk patients (Apfel score 2), use a dual combination: Dexamethasone 4-8 mg IV (at induction) plus Ondansetron 4 mg IV (at the end of surgery). For high-risk patients (Apfel score 3-4), add total intravenous anesthesia (TIVA) with Propofol as an additional primary preventive.",
      "immediateRedFlags": [],
