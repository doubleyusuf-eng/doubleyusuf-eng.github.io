  {
    "id": "clinical_followup_last_protocol_complications_0",
    "category": "clinical_followups",
    "keywords": [
      "anesthetic",
      "bupivakain",
      "clinical_followup_last_protocol_complications_0",
      "complications",
      "followup",
      "last",
      "local",
      "toksisite",
      "toxic",
      "var0"
    ],
    "question_tr": "Lipid tedavisinin komplikasyonları nelerdir?",
    "question_en": "What are the complications of lipid rescue?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 Komplikasyonlar arasında akut pankreatit, hipertriglisidemi, yağ embolisi, laboratuvar testlerinde (hemoglobin, elektrolit) parazitlenme ve geçici akut akciğer hasarı (ARDS) yer alabilir. İlaç eliminasyonu ve organ perfüzyonu yoğun bakımda izlenmelidir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 Potential complications include acute pancreatitis, severe hypertriglyceridemia, fat embolism, laboratory assay interference (with hemoglobin or electrolytes), and transient acute lung injury (ARDS). Monitor organ perfusion and clearance closely in the ICU.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
