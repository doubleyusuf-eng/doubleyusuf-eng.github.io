      "var0"
    ],
    "question_tr": "Stent trombozu riski çok yüksek hastada alternatif köprüleme nedir?",
    "question_en": "What is the alternative bridging for very high-risk stent thrombosis?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🔄 Son 1 ayda stent takılmış ve cerrahisi ertelenemeyen aşırı yüksek riskli hastalarda, P2Y12 inhibitörü kesildikten sonra yarı ömrü çok kısa olan intravenöz antiplatelet ajanlar (örn. **Tirofiban** veya **Eptifibatid**) ile ameliyata kadar hastanede yatırılarak köprüleme tedavisi uygulanabilir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🔄 In extremely high-risk patients who underwent coronary stenting within 1 month and require urgent surgery, bridging therapy using short-acting intravenous antiplatelet agents (e.g. **Tirofiban** or **Eptifibatide**) can be administered in-hospital up until a few hours before incision.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
