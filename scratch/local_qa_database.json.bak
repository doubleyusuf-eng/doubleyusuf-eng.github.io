  {
    "id": "cricoid_pressure",
    "category": "clinical_scenarios",
    "keywords": [
      "bası",
      "cricoid",
      "krikoid",
      "pressure"
    ],
    "question_tr": "Krikoid bası",
    "question_en": "Cricoid pressure",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Krikoid bası geleneksel olarak aspirasyon riskini azaltmak için kullanılır; ancak etkinliği ve doğru uygulanması tartışmalıdır. Yanlış veya aşırı bası laringoskopi görüntüsünü, ventilasyonu veya tüp geçişini zorlaştırabilir. Uygulanacaksa eğitimli kişi tarafından doğru kuvvet ve anatomik noktaya uygulanmalı; entübasyonu veya ventilasyonu bozuyorsa gevşetilmeli ya da bırakılmalıdır. Krikoid bası, iyi preoksijenasyon, suction, uygun pozisyon ve hızlı entübasyon hazırlığının yerine geçmez. Güncel değerlendirmeler krikoid basının fayda-zarar dengesinin klinik bağlama göre düşünülmesi gerektiğini vurgular. ([Springer Nature Link])",
      "immediateRedFlags": [
        "Krikoid bası uygulandığında laringoskopi görüntüsünün (Cormack-Lehane derecesi) belirgin şekilde kötüleşmesi.",
        "Bası nedeniyle trakeal tüpün veya bougie'nin vokal kordlardan geçememesi.",
        "Bası esnasında maske ventilasyonunun tamamen imkansız hale gelmesi (havayolu obstrüksiyonu)."
      ],
      "missingCriticalInformation": [
        "Krikoid bası uygulayan personelin bu konuda eğitimli olup olmadığı",
        "Krikoid bası kuvvetinin derecesi (uygun kuvvet uyanıkken 10 N, bilinç kaybından sonra 30 N'dur)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Krikoid Bası (Sellick Manevrası)",
        "RSI Teknik Detayları",
        "Havayolu Obstrüksiyonu"
      ],
      "suggestedNextStepsGeneral": [
        "Krikoid basıyı sadece krikoid kıkırdak üzerine, posterior yönde dikey olarak uygulayın.",
        "Hasta uyanıkken hafif kuvvet (10 Newton / 1 kg), bilinç kaybolduğunda tam kuvvet (30 Newton / 3 kg) uygulayın.",
        "Laringoskopi veya ventilasyon zorlaştığında basıyı hemen gevşetin veya tamamen kaldırın.",
        "Krikoid basının preoksijenasyon veya iyi pozisyonun (ramp pozisyonu) yerine geçmediğini unutmayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "rsi",
          "titleTr": "RSI Algoritması"
        },
        {
          "id": "aspiration_risk",
          "titleTr": "Aspirasyon Riski"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Krikoid basının özofagusu her zaman tam olarak kapatmadığını ve yanlış uygulandığında trakeayı sıkıştırarak entübasyonu zorlaştırabileceğini"
      ],
      "whenToEscalate": [
        "Entübasyon denemesi başarısız olduğunda ve maskeyle ventile etmeye çalışırken zorluk yaşanıyorsa, krikoid basıyı derhal sonlandırın"
      ],
      "referencesToShow": [
        "Sellick HP: Cricoid pressure to control regurgitation. Lancet 1961.",
        "The Role of Cricoid Pressure in Rapid Sequence Induction. Springer 2024."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Cricoid pressure is traditionally used to reduce aspiration risk, but its effectiveness and correct application are debated. Incorrect or excessive pressure may worsen laryngoscopic view, ventilation, or tube passage. If used, it should be applied by a trained person with appropriate force and correct anatomy; if it impairs intubation or ventilation, it should be released or removed. Cricoid pressure does not replace good preoxygenation, suction, positioning, and rapid intubation preparation. ([Springer Nature Link])",
      "immediateRedFlags": [
        "Worsening of the laryngoscopic view (Cormack-Lehane grade) immediately upon applying cricoid pressure.",
        "Inability to pass the endotracheal tube or bougie despite a seemingly reasonable view.",
        "Complete obstruction of bag-mask ventilation when pressure is applied."
      ],
      "missingCriticalInformation": [
        "Training and experience level of the assistant applying cricoid pressure",
        "The exact force applied in Newtons (should be 10 N awake, increasing to 30 N upon loss of consciousness)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Cricoid Pressure (Sellick Maneuver)",
        "RSI Technical Details",
        "Airway Obstruction"
      ],
      "suggestedNextStepsGeneral": [
        "Apply cricoid pressure strictly over the cricoid cartilage, in a backward/posterior direction.",
        "Use a force of 10 Newtons while awake, and increase to 30 Newtons only after consciousness is lost.",
        "Release or reduce the pressure immediately if laryngoscopy, tube passage, or mask ventilation is compromised.",
        "Remember that cricoid pressure is secondary to high-quality preoxygenation and optimal positioning."
      ],
      "relatedAlgorithms": [
        {
          "id": "rsi",
          "titleTr": "RSI Algorithm"
        },
        {
          "id": "aspiration_risk",
          "titleTr": "Aspiration Risk"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Cricoid pressure often laterally displaces the esophagus rather than occluding it, and excessive force can deform the larynx, complicating intubation"
      ],
      "whenToEscalate": [
        "In any 'cannot ventilate' scenario or during active rescue airway placement (e.g., LMA), cricoid pressure must be released immediately"
      ],
      "referencesToShow": [
        "Sellick HP: Cricoid pressure to control regurgitation. Lancet 1961.",
        "The Role of Cricoid Pressure in Rapid Sequence Induction. Springer 2024."
      ],
      "safetyLevel": "urgent"
    }
  },
