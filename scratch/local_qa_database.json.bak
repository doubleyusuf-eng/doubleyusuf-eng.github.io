    ],
    "question_tr": "Malign hipertermi",
    "question_en": "Malignant hyperthermia",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Malign hipertermi acilidir. Erken bulgular: beklenmeyen ETCO₂ artışı, taşikardi, rijidite, hipertermi, asidoz, hiperkalemi ve rabdomiyoliz.\\n\\n1. Volatil ajanları ve süksinilkolini kes.\\n2. Yardım çağır ve MH protokolünü başlat.\\n3. %100 oksijen ve yüksek taze gas akımı kullan.\\n4. Dantrolen 2.5 mg/kg IV başla; klinik yanıta göre tekrarla.\\n5. Aktif soğutma uygula.\\n6. Hiperkalemi, asidoz, aritmi ve miyoglobinüriyi tedavi et.\\n7. Yoğun bakım izlemi gerekir.",
      "immediateRedFlags": [
        "İndüksiyon sonrası aniden gelişen şiddetli masseter spazmı (çene kilitlenmesi) MH'nin en önemli erken uyarısıdır.",
        "Vücut sıcaklığının her 5 dakikada bir >1°C artması hızlı hücresel yıkımın (hipertermi) göstergesidir."
      ],
      "missingCriticalInformation": [
        "Hastanın ailede volatil ajan veya süksinilkolin ile kötü hikaye varlığı",
        "Mevcut kan gazı değerleri (asidoz ve potasyum seviyesi)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Malign Hipertermi (MH) Patofizyolojisi ve Kriz Yönetimi",
        "Dantrolen Hazırlama ve Dozlama Kılavuzu",
        "Aktif Perioperatif Soğutma Protokolleri"
      ],
      "suggestedNextStepsGeneral": [
        "Tüm volatil ajanları (Sevofluran vb.) ve Süksinilkolini derhal durdurun.",
        "Taze gaz akışını >10 L/dk yapın ve devredeki karbondioksit absorberini (soda lime) değiştirin.",
        "Dantrolen 2.5 mg/kg IV bolus uygulayın. Her flakonu (20 mg) 60 mL steril distile su ile eritin."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "dantrolene_rescue",
          "titleTr": "Dantrolen Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Süksinilkolin Monografı"
        }
      ],
      "doNotMiss": [
        "Dantrolen uygulanırken kalsiyum kanal blokerleri (örn. Diltiazem) kesinlikle kullanılmamalıdır (şiddetli hiperkalemi ve asistoli riski!)"
      ],
      "whenToEscalate": [
        "Dirençli aritmi, ağır laktik asidoz ve refrakter hiperkalemi varlığında acil diyaliz veya hemodiyaliz hazırlığı"
      ],
      "referencesToShow": [
        "MHAUS (Malignant Hyperthermia Association of the United States) Guidelines. 2021.",
        "Glauber V, et al. PMID: 32986423."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Malignant hyperthermia is an emergency. Early signs include unexpected ETCO₂ rise, tachycardia, rigidity, hyperthermia, acidosis, hyperkalemia, and rhabdomyolysis. Stop volatile agents and succinylcholine, call for help, start the MH protocol, give 100% oxygen with high fresh gas flow, administer dantrolene 2.5 mg/kg IV and repeat as needed, actively cool the patient, treat hyperkalemia/acidosis/arrhythmias/myoglobinuria, and transfer to ICU.",
      "immediateRedFlags": [
        "Sudden severe masseter spasm (trismus) after succinylcholine administration is a critical early warning for MH.",
        "Body temperature rising >1°C every 5 minutes indicates hypermetabolic cellular destruction (hyperthermia)."
      ],
      "missingCriticalInformation": [
        "Family history of adverse reactions to volatile anesthetics or succinylcholine",
        "Current arterial blood gas values (acidosis severity and potassium level)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Malignant Hyperthermia (MH) Pathophysiology and Crisis Management",
        "Dantrolene Reconstitution and Dosing Guide",
        "Active Perioperative Cooling Protocols"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately discontinue all volatile agents and Succinylcholine.",
        "Set fresh gas flow to >10 L/min and replace the carbon dioxide absorber (soda lime).",
        "Administer Dantrolene 2.5 mg/kg IV bolus. Reconstitute each 20 mg vial with 60 mL sterile preservative-free water."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "dantrolene_rescue",
          "titleTr": "Dantrolene Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Succinylcholine Monograph"
        }
      ],
      "doNotMiss": [
        "Do not administer calcium channel blockers (e.g., Diltiazem) with Dantrolene due to severe risk of hyperkalemia and cardiac arrest"
      ],
      "whenToEscalate": [
        "In case of refractory hyperkalemia, severe lactic acidosis, or intractable arrhythmias, prepare immediately for dialysis"
      ],
      "referencesToShow": [
        "MHAUS (Malignant Hyperthermia Association of the United States) Guidelines. 2021.",
        "Glauber V, et al. PMID: 32986423."
      ],
      "safetyLevel": "emergency"
    }
