    "question_tr": "Asa sınıf",
    "question_en": "Physical status",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "ASA fiziksel durum sınıflaması hastanın sistemik hastalık yükünü gösterir; cerrahi risk skoru değildir.\\n\\nASA I: Sağlıklı hasta.\\nASA II: Hafif sistemik hastalık; örn. kontrollü HT, hafif astım, sigara kullanımı, gebelik.\\nASA III: Ciddi sistemik hastalık; örn. kontrolsüz DM/HT, KOAH, morbid obezite, stabil koroner arter hastalığı.\\nASA IV: Yaşamı sürekli tehdit eden ciddi hastalık; örn. yakın dönem MI, dekompanse kalp yetmezliği, sepsis, ağır kapak hastalığı.\\nASA V: Ameliyatsız yaşaması beklenmeyen moribund hasta.\\nASA VI: Organ donörü beyin ölümü olan hasta.\\n\\nAcil cerrahi varsa sınıfa “E” eklenir.",
      "immediateRedFlags": [
        "ASA IV ve V hastalarında anestezi ve cerrahiye bağlı mortalite oranları son derece yüksektir.",
        "Acil cerrahi (E) modifikasyonu mortalite riskini bağımsız olarak katlar."
      ],
      "missingCriticalInformation": [
        "Hastanın sistemik hastalıklarının kontrol derecesi ve uç organ hasarı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "ASA I: Sağlıklı hasta",
        "ASA II: Hafif sistemik hastalık",
        "ASA III: Ciddi sistemik hastalık",
        "ASA IV: Yaşamı tehdit eden ciddi hastalık"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın laboratuvar parametrelerini detaylıca sorgulayın.",
        "Girişim acil ise sınıflamanın sonuna 'E' (Emergency) ekini ekleyin (örn. ASA III-E)."
      ],
      "relatedAlgorithms": [
        {
          "id": "preop_cardiac_rcri",
          "titleTr": "Preoperatif Kardiyak Risk Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "asa_ps",
          "titleTr": "ASA PS Sınıflama Kılavuzu"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Gebelerin ve sağlıklı yenidoğanların otomatik olarak en az ASA II kabul edildiği gerçeği"
      ],
      "whenToEscalate": [
        "Acil cerrahi kararı alınan stabil olmayan hastalarda preoperatif hazırlık"
      ],
      "referencesToShow": [
        "ASA Physical Status Classification System: An Update. American Society of Anesthesiologists Standard Guidelines, 2020.",
        "Mayhew D, et al. PMID: 30206941."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "ASA physical status reflects systemic disease burden; it is not a surgical risk score.\\n\\nASA I: Healthy patient.\\nASA II: Mild systemic disease.\\nASA III: Severe systemic disease.\\nASA IV: Severe disease that is a constant threat to life.\\nASA V: Moribund patient not expected to survive without surgery.\\nASA VI: Brain-dead organ donor.\\n\\nAdd “E” for emergency surgery.",
      "immediateRedFlags": [
        "ASA IV and V patients carry extremely high perioperative mortality risk.",
        "Emergency surgery (E) modifier independently multiplies mortality risk."
      ],
      "missingCriticalInformation": [
        "Control status of systemic diseases and end-organ damage"
      ],
      "likelyClinicalCategoriesToConsider": [
        "ASA I: Healthy patient",
        "ASA II: Mild systemic disease",
        "ASA III: Severe systemic disease",
        "ASA IV: Life-threatening disease"
      ],
      "suggestedNextStepsGeneral": [
        "Evaluate patient history and laboratory parameters thoroughly.",
        "Add 'E' for emergency surgery (e.g., ASA III-E)."
      ],
      "relatedAlgorithms": [
        {
          "id": "preop_cardiac_rcri",
          "titleTr": "Preoperative Cardiac Risk Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "asa_ps",
          "titleTr": "ASA PS Classification Guide"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Pregnant patients and healthy neonates are automatically classified as ASA II at least"
      ],
      "whenToEscalate": [
        "Preoperative preparation for unstable patients scheduled for emergency surgery"
      ],
      "referencesToShow": [
        "ASA Physical Status Classification System: An Update. American Society of Anesthesiologists Standard Guidelines, 2020.",
        "Mayhew D, et al. PMID: 30206941."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "npo",
    "category": "clinical_scenarios",
    "keywords": [
      "aç",
      "açlık",
      "fasting",
      "npo",
      "yemek"
    ],
    "question_tr": "Açlık",
    "question_en": "Preoperative Fasting Guidelines (NPO)",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Elektif, aspirasyon riski düşük hastalarda genel kural:\\nBerrak sıvı: 2 saat\\nAnne sütü: 4 saat\\nMama / non-human milk / hafif öğün: 6 saat\\nYağlı/ağır öğün: 8 saat veya daha fazla\\n\\nAcil cerrahi, gebelik, barsak obstrüksiyonu, gastroparezi, ciddi reflü, diyabetik otonom nöropati, opioid kullanımı veya tok hasta durumunda standart NPO süresi yeterli kabul edilmemelidir. Bu hastalarda aspirasyon riski yüksek kabul edilir ve RSI, hava yolu hazırlığı ve aspirasyon önlemleri düşünülür.",
      "immediateRedFlags": [
        "Aktif bağırsak tıkanıklığı, ileus, akut karın veya gastroparezi durumunda standart NPO sürelerine güvenilemez.",
        "Acil tok cerrahi vakalarında NPO süresi beklenemez; hastaya RSI uygulanmalıdır."
      ],
      "missingCriticalInformation": [
        "En son yemek alım saeti ve yenilen besinin türü",
        "Mide boşalmasını geciktiren ek patolojiler (opioid alımı, ağrı)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "ASA 2-4-6-8 Saat Açlık Kılavuzu standartları",
        "Gastroözofageal Reflü ve Gastrik Boşalma Gecikmesi",
        "Hızlı Ardışık İndüksiyon (RSI) Kriterleri"
      ],
      "suggestedNextStepsGeneral": [
        "Berrak sıvılar için en az 2 saat, anne sütü için 4 saat, mama için 6 saat açlık süresini doğrulayın.",
        "Yağlı, kızartılmış veya ağır katı yemekler için en az 8 saat açlık süresini zorunlu tutun."
      ],
      "relatedAlgorithms": [
        {
          "id": "preop_npo_evaluation",
          "titleTr": "NPO & Açlık Algoritması"
        },
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Beklenmeyen Zor Entübasyon"
        }
      ],
      "relatedCalculators": [
        {
          "id": "npo_fasting",
          "titleTr": "NPO Açlık Sayacı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Süksinilkolin Monografı"
        }
      ],
      "doNotMiss": [
        "Diyabetiklerde midenin tamamen dolu olabileceği ve açlık süresi tam olsa dahi RSI planlanması gerektiği"
      ],
      "whenToEscalate": [
        "Mide içeriği aspirasyonu durumunda derhal havayolu kontrolü ve koruyucu akciğer ventilasyonuna geçiş"
      ],
      "referencesToShow": [
        "Practice Guidelines for Preoperative Fasting. Anesthesiology 2023; 138(2):105-128. PMID: 36622802.",
        "ESA Guidelines on Preoperative Fasting. Eur J Anaesthesiol 2011. PMID: 21540671."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "For elective low-aspiration-risk patients, a practical fasting rule is:\\nClear fluids: 2 hours\\nBreast milk: 4 hours\\nFormula / non-human milk / light meal: 6 hours\\nFatty or heavy meal: 8 hours or more\\n\\nIn emergency surgery, pregnancy, bowel obstruction, gastroparesis, severe reflux, diabetic autonomic neuropathy, opioid use, or a full-stomach patient, standard fasting times may not be sufficient. Treat as increased aspiration risk and consider RSI and airway precautions.",
      "immediateRedFlags": [
        "In active bowel obstruction, ileus, acute abdomen, or gastroparesis, standard fasting times are unreliable.",
        "In emergency full-stomach patients, fasting time cannot be awaited; RSI must be performed."
      ],
      "missingCriticalInformation": [
        "Exact time of last oral intake and type of food ingested",
        "Co-existing factors delaying gastric emptying (opioid use, severe pain)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "ASA 2-4-6-8 Hour Fasting Standards",
        "Gastroesophageal Reflux and Gastric Emptying Delay",
        "Rapid Sequence Induction (RSI) Criteria"
      ],
      "suggestedNextStepsGeneral": [
        "Confirm at least 2 hours for clear liquids, 4 hours for breast milk, and 6 hours for formula.",
        "Mandate at least 8 hours of fasting for fatty, fried, or heavy solid meals."
      ],
      "relatedAlgorithms": [
        {
          "id": "preop_npo_evaluation",
          "titleTr": "NPO & Fasting Algorithm"
        },
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Unexpected Difficult Intubation"
        }
      ],
      "relatedCalculators": [
        {
          "id": "npo_fasting",
          "titleTr": "NPO Fasting Timer"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Succinylcholine Monograph"
        }
      ],
      "doNotMiss": [
        "Diabetic patients may have a full stomach even with completed fasting times; consider RSI"
      ],
      "whenToEscalate": [
        "In case of gastric aspiration, proceed immediately to airway control and protective lung ventilation"
      ],
      "referencesToShow": [
        "Practice Guidelines for Preoperative Fasting. Anesthesiology 2023; 138(2):105-128. PMID: 36622802.",
        "ESA Guidelines on Preoperative Fasting. Eur J Anaesthesiol 2011. PMID: 21540671."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "rsi",
    "category": "clinical_scenarios",
    "keywords": [
      "ardışık",
      "hızlı",
      "indüksiyon",
      "rapid",
      "rsi",
      "sequence"
    ],
    "question_tr": "Rsi",
    "question_en": "Rapid Sequence Induction (RSI)",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "RSI; aspirasyon riski yüksek, tok, acil cerrahi, gebelik, barsak obstrüksiyonu, aktif kusma, ciddi reflü, gastroparezi veya travma hastasında düşünülür.\\n\\nYaklaşım:\\n1. Yardım ve aspirasyon ekipmanı hazırla.\\n2. Preoksijenasyon yap.\\n3. İndüksiyon ajanı ve hızlı etkili nöromüsküler bloker hazırla.\\n4. Maske ventilasyonunu hastaya göre minimal veya kontrollü uygula.\\n5. İlk geçişte başarılı entübasyon hedefle; videolaringoskop hazır olsun.\\n6. Entübasyon sonrası kapnografi ile doğrula.\\n7. Başarısız entübasyonda zor havayolu algoritmasına geç.",
      "immediateRedFlags": [
        "Aktif fışkırır tarzda kusma durumunda krikoid basısı mide rüptürüne yol açabilir.",
        "RSI sırasında zor havayolu ile karşılaşılması durumunda hipoksi süresi hızla ilerler."
      ],
      "missingCriticalInformation": [
        "Havayolu zorluğu öngörücüleri (Mallampati, tiromental mesafe)",
        "Damar yolu açıklığı ve yedek laringoskop ekipmanı varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Hızlı Ardışık İndüksiyon (RSI) Protokolü",
        "Mendelson Sendromu ve Gastrik Hacim Yönetimi",
        "Sellick Manevrası (Krikoid Bası) Uygulama Standartları"
      ],
      "suggestedNextStepsGeneral": [
        "İndüksiyon öncesi aspiratörün çalışır durumda olduğunu kontrol edin.",
        "Klinik duruma göre uygun indüksiyon ajanı (örn. Propofol veya Etomidat) ve kas gevşetici (tipik olarak Süksinilkolin 1-1.5 mg/kg veya Roküronyum 0.6-1.2 mg/kg IV) dozlarını hasta bazında ayarlayarak uygulayın.",
        "Tüp kafı şişirilip doğrulanana kadar Sellick manevrasını (krikoid bası) sürdürün; ancak krikoid bası laringeal görüşü veya ventilasyonu bozarsa basıyı gevşetmeyi veya yönünü değiştirmeyi değerlendirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "preop_npo_evaluation",
          "titleTr": "NPO & Açlık Algoritması"
        },
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Beklenmeyen Zor Entübasyon"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Süksinilkolin Monografı"
        },
        {
          "id": "rocuronium",
          "titleTr": "Roküronyum Monografı"
        }
      ],
      "doNotMiss": [
        "RSI sırasında pozitif basınçlı maske ventilasyonundan kaçınılmalıdır (mide şişmesini önlemek için)"
      ],
      "whenToEscalate": [
        "Entübasyon başarısız olduğunda derhal zor havayolu ve 'Cannot Intubate Cannot Oxygenate' (CICO) algoritmasına geçiş"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "Sellick BJ. PMID: 13749964."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Consider RSI in full-stomach patients, emergency surgery, pregnancy, bowel obstruction, active vomiting, severe reflux, gastroparesis, or trauma.\\n\\nApproach: prepare suction and help, preoxygenate, prepare induction agent and rapid-onset neuromuscular blocker, use minimal or controlled mask ventilation depending on risk, aim for first-pass success, confirm with capnography, and switch to the difficult airway algorithm if intubation fails.",
      "immediateRedFlags": [
        "In active projectile vomiting, cricoid pressure can cause esophageal or gastric rupture.",
        "Encountering a difficult airway during RSI accelerates hypoxia rapidly due to lack of ventilation."
      ],
      "missingCriticalInformation": [
        "Airway difficulty predictors (Mallampati, thyromental distance)",
        "IV line patency and backup videolaryngoscopy availability"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Rapid Sequence Induction (RSI) Protocol",
        "Mendelson Syndrome and Gastric Volume Management",
        "Sellick Maneuver (Cricoid Pressure) Standards"
      ],
      "suggestedNextStepsGeneral": [
        "Ensure suction is on and functioning before induction.",
        "Select and adjust appropriate induction agents (e.g., Propofol or Etomidate) and neuromuscular blockers (typically Succinylcholine 1-1.5 mg/kg or Rocuronium 0.6-1.2 mg/kg IV) based on patient-specific clinical requirements.",
        "Maintain cricoid pressure (Sellick maneuver) until the endotracheal tube cuff is inflated and verified; however, if cricoid pressure impairs laryngeal visualization or ventilation, consider reducing or releasing the pressure."
      ],
      "relatedAlgorithms": [
        {
          "id": "preop_npo_evaluation",
          "titleTr": "NPO & Fasting Algorithm"
        },
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Unexpected Difficult Intubation"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Succinylcholine Monograph"
        },
        {
          "id": "rocuronium",
          "titleTr": "Rocuronium Monograph"
        }
      ],
      "doNotMiss": [
        "Avoid positive-pressure mask ventilation during RSI to prevent gastric insufflation"
      ],
      "whenToEscalate": [
        "If intubation fails, immediately proceed to the difficult airway and CICO pathways"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "Sellick BJ. PMID: 13749964."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "difficult_airway",
    "category": "clinical_scenarios",
    "keywords": [
      "airway",
      "awake",
      "difficult",
      "entübasyon",
      "havayolu",
      "intubation",
      "uyanık",
      "zor"
    ],
    "question_tr": "Zor havayolu",
    "question_en": "Difficult airway",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Beklenen zor havayolunda temel karar: Hasta uyutulabilir mi, yoksa uyanık entübasyon mu daha güvenli?\\nUyanık entübasyon; zor maske ventilasyonu, zor supraglottik airway, hızlı desatürasyon riski, aspirasyon riski veya acil cerrahi havayolu zorluğu bekleniyorsa düşünülmelidir.\\nHazırlık: deneyimli yardım çağır, videolaringoskop/fiberoptik hazırla, supraglottik airway ve cerrahi havayolu setini hazır bulundur, oksijenasyonu kesintisiz sürdür, başarısız deneme sayısını sınırla ve CICO planını ekipçe paylaş.",
      "immediateRedFlags": [
        "Zor maske ventilasyonu + zor entübasyon birlikteliği hayatı tehdit eden CICO krizinin habercisidir.",
        "Uyutulmuş hastada kas gevşetici verildikten sonra havayolu kaybedilirse mortalite riski tavan yapar."
      ],
      "missingCriticalInformation": [
        "Hastanın anatomik havayolu öngörücüleri (retrognati, sınırlı çene açıklığı, boyun mobilitesi)",
        "Uyanık fiberoptik entübasyon için hastanın koopere olup olamayacağı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "ASA 2022 Beklenen Zor Havayolu Kılavuzu",
        "Uyanık Fiberoptik Entübasyon (AFOI) Prensipleri",
        "Cerrahi Havayolu / Krikotirotomi Hazırlığı"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle 'Uyanık Entübasyon' endikasyonunu değerlendirin (özellikle ciddi kitle, ankilozan spondilit durumunda).",
        "Genel anestezi uygulanacaksa, videolaringoskop ve farklı boylarda supraglottik havayolu (SGA) araçlarını başucunda hazır bulundurun.",
        "Maksimum entübasyon deneme sayısını 3 ile sınırlandırın (SGA ile oksijenasyon sağlanıyorsa)."
      ],
      "relatedAlgorithms": [
        {
          "id": "expected_difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Zor havayolu planında her zaman en son aşama olan cerrahi krikotirotomi kitinin açılmış ve hazır olması gerektiği"
      ],
      "whenToEscalate": [
        "Entübasyon ve ventilasyon tamamen başarısız olduğunda zaman kaybetmeden 'CICO' ilan edin ve cerrahi havayoluna geçin"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022; 136(1):31-81. PMID: 34762285.",
        "Difficult Airway Society guidelines. Anaesthesia 2015. PMID: 26558482."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "The key decision is whether the patient can be safely induced or whether awake intubation is safer. Awake intubation should be considered when difficult mask ventilation, difficult supraglottic airway placement, rapid desaturation, aspiration risk, or difficult emergency invasive airway access is expected. Prepare experienced help, videolaryngoscopy/fiberoptic equipment, supraglottic airway devices, invasive airway equipment, continuous oxygenation, limited attempts, and a shared CICO plan.",
      "immediateRedFlags": [
        "Co-existing difficult mask ventilation and difficult intubation predicts a life-threatening CICO crisis.",
        "Losing the airway in an induced patient after neuromuscular blockade carries extreme mortality risk."
      ],
      "missingCriticalInformation": [
        "Anatomical airway predictors (retrognathia, limited mouth opening, neck mobility)",
        "Patient cooperation status for awake fiberoptic intubation"
      ],
      "likelyClinicalCategoriesToConsider": [
        "ASA 2022 Anticipated Difficult Airway Guidelines",
        "Awake Fiberoptic Intubation (AFOI) Principles",
        "Invasive Airway / Cricothyrotomy Preparedness"
      ],
      "suggestedNextStepsGeneral": [
        "Evaluate the indication for 'Awake Intubation' first (especially with airway masses or severe ankylosing spondylitis).",
        "If inducing, have a videolaryngoscope and multiple sizes of supraglottic airway (SGA) devices at bedside.",
        "Limit intubation attempts to a maximum of 3 (if SGA oxygenation is possible)."
      ],
      "relatedAlgorithms": [
        {
          "id": "expected_difficult_airway",
          "titleTr": "Expected Difficult Airway Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Always ensure the surgical cricothyrotomy kit is open and ready at the bedside in a difficult airway case"
      ],
      "whenToEscalate": [
        "If both intubation and ventilation fail, declare 'CICO' immediately and initiate front-of-neck access"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022; 136(1):31-81. PMID: 34762285.",
        "Difficult Airway Society guidelines. Anaesthesia 2015. PMID: 26558482."
      ],
      "safetyLevel": "urgent"
    }
  },
