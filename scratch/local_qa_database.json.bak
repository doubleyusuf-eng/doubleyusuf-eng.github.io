  {
    "id": "geriatric_anesthetic_dosing",
    "category": "clinical_scenarios",
    "keywords": [
      "anestezi",
      "anesthesia",
      "anesthetic",
      "dosing",
      "drug",
      "geriatric",
      "geriyatrik",
      "older",
      "yaşlı"
    ],
    "question_tr": "Geriyatrik anestezi",
    "question_en": "Geriatric anesthesia",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Yaşlı hastalarda yaşlanmayla ilişkili fizyolojik değişiklikler (kardiyak debinin azalması, yağ oranının artması, böbrek ve karaciğer kan akımının düşmesi, beyindeki reseptör duyarlılığının artması) nedeniyle anestezik ilaçlara duyarlılık belirgin şekilde artar. Bu durum sedatifler, opioidler, hipnotikler ve kas gevşeticilerin farmakokinetik ve farmakodinamik profilini kökten değiştirir. Güvenli doz yaklaşımı: 1. Çok daha düşük başlangıç dozları tercih edin ve dozları yavaşça titre edin (genellikle indüksiyon dozları %30-50 oranında azaltılmalıdır). 2. İlaçların etki yerine ulaşma süresinin (effect-site equilibration) uzayacağını unutmayın; üst üste hızlı tekrarlayan bolus enjeksiyonlardan (dose stacking) kaçının. 3. Hastanın böbrek ve karaciğer fonksiyon testlerini (CrCl/eGFR) kontrol edin. 4. Antikolinerjik ve benzodiazepin kullanımını en aza indirin (deliryum ve kognitif hasarı önlemek için). 5. Rezidüel nöromüsküler blok riskini önlemek için mutlaka objektif ve kantitatif TOF monitörizasyonu kullanın. 6. Hipotansiyon, solunum depresyonu, deliryum ve gecikmiş uyanma açısından yakın izlem sağlayın.",
      "immediateRedFlags": [
        "Standart doz propofol sonrasında gelişen derin ve dirençli vazoplejik şok tablosu.",
        "Kas gevşetici etkisi geçmeden hastanın ekstübe edilmesi sonucu gelişen solunum sıkıntısı ve hipoksemi (rezidüel kürarizasyon).",
        "Düşük doz sedatifler sonrasında gelişen uzamış apne ve uyanamama tablosu."
      ],
      "missingCriticalInformation": [
        "Hastanın güncel kreatinin düzeyi ve böbrek fonksiyonu (ilaç eliminasyon hızını belirler)",
        "Hastanın kognitif rezervi ve eşlik eden kardiyovasküler (örn. aort darlığı, KAH) patolojileri"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Geriyatrik Anestezik Doz Ayarı",
        "Yaşlı Hastada Farmakoloji",
        "Perioperatif İlaç Güvenliği"
      ],
      "suggestedNextStepsGeneral": [
        "İndüksiyon ajanlarının (propofol vb.) dozlarını yaşa göre ayarlayarak en az %40 azaltın.",
        "Bolus dozlar arasında en az 90-120 saniye bekleyerek ilacın beyindeki tam etkisini görün.",
        "Rezidüel nöromüsküler bloğu önlemek için sugammadeks dozunu kantitatif TOF sonucuna göre uygulayın.",
        "Mümkünse benzodiazepin (örn. midazolam) premedikasyonundan tamamen kaçının."
      ],
      "relatedAlgorithms": [
        {
          "id": "geriatric_anesthesia",
          "titleTr": "Geriyatrik Anestezi"
        },
        {
          "id": "delayed_emergence",
          "titleTr": "Gecikmiş Uyanma Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "morphine",
          "titleTr": "Morfin Monografı"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        }
      ],
      "doNotMiss": [
        "Yaşlılarda beyindeki MAC ihtiyacının her dekadda yaklaşık %6-8 oranında azaldığını ve inhalasyon anestezik dozlarının buna göre düşürülmesi gerektiğini"
      ],
      "whenToEscalate": [
        "Hastada uyanma odasında dirençli solunum baskılanması, derin hipotansiyon veya TOF oranı < %90 iken solunum yetmezliği gelişirse derhal geri döndürücü ajanları (sugammadeks) optimize edin ve gerekirse tekrar entübe edin"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Stoelting's Anesthesia and Co-Existing Disease, 8th Edition."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Older patients exhibit significantly increased sensitivity to anesthetic agents due to age-related physiological changes (decreased cardiac output, increased body fat ratio, reduced hepatic and renal blood flow, and increased brain receptor sensitivity). This fundamentally alters the pharmacokinetic and pharmacodynamic profiles of sedatives, opioids, hypnotics, and neuromuscular blockers. Safe dosing strategies: 1. Use significantly lower starting doses and titrate slowly (induction doses should generally be reduced by 30% to 50%). 2. Allow extra time for drugs to reach their site of action (prolonged effect-site equilibration); avoid rapid repeated bolus injections (dose stacking). 3. Always check baseline renal and hepatic function (eGFR/CrCl). 4. Minimize or completely avoid benzodiazepine and anticholinergic drug burden to prevent postoperative delirium and cognitive decline. 5. Always utilize quantitative TOF monitoring to prevent residual neuromuscular blockade. 6. Monitor closely for hypotension, respiratory depression, delirium, and delayed emergence.",
      "immediateRedFlags": [
        "Profound, refractory vasoplegic shock developing after standard-dose propofol induction.",
        "Respiratory distress and hypoxemia secondary to extubating a patient with residual neuromuscular blockade (residual curarization).",
        "Prolonged apnea and inability to arouse following low-dose sedatives."
      ],
      "missingCriticalInformation": [
        "The patient's current serum creatinine and calculated eGFR/CrCl (critical for predicting drug clearance)",
        "The patient's baseline cognitive reserve and co-existing cardiac pathologies (e.g., aortic stenosis, CAD)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Geriatric Anesthetic Dosing",
        "Geriatric Pharmacology",
        "Perioperative Medication Safety"
      ],
      "suggestedNextStepsGeneral": [
        "Reduce induction agent (e.g., propofol) doses by at least 40% and administer slowly.",
        "Allow at least 90-120 seconds between bolus doses to observe the full clinical effect.",
        "Reverse neuromuscular blockade guided by quantitative TOF to ensure a recovery ratio > 90%.",
        "Avoid benzodiazepine (e.g., midazolam) premedication to preserve cognitive function."
      ],
      "relatedAlgorithms": [
        {
          "id": "geriatric_anesthesia",
          "titleTr": "Geriatric Anesthesia"
        },
        {
          "id": "delayed_emergence",
          "titleTr": "Delayed Emergence"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "morphine",
          "titleTr": "Morphine Monograph"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        }
      ],
      "doNotMiss": [
        "MAC requirements for volatile anesthetics decrease by approximately 6% to 8% per decade of life after age 40; adjust vaporizers accordingly"
      ],
      "whenToEscalate": [
        "In the event of persistent respiratory depression, severe hypotension, or respiratory distress in the PACU with a TOF ratio < 90%, immediately optimize reversal agents and prepare for reintubation if necessary"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Stoelting's Anesthesia and Co-Existing Disease, 8th Edition."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "functional_capacity_mets",
