      "referencesToShow": [
        "Anesthesiology: Perioperative Fever and Hypothermia. 2018.",
        "MHAUS Guidelines for Perioperative Hyperthermia. 2024."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Perioperative fever (temperature >38.0°C) is divided into intraoperative and postoperative causes. Intraoperative causes include Malignant Hyperthermia (MH), thyroid storm, blood transfusion reactions (acute hemolytic reaction), sepsis/infection, excessive active warming devices, and drugs like atropine. Early postoperative fever (first 24 hours) is usually due to surgical inflammatory response, atelectasis, or aspiration. Management: turn off warming devices, initiate cooling measures, administer antipyretics (paracetamol), obtain blood cultures if indicated, and treat the specific underlying cause (MH vs. transfusion reaction).",
      "immediateRedFlags": [
        "Precipitous rise in core temperature (>39°C) within minutes intraoperatively (highly suggestive of MH or thyroid storm).",
        "Fever occurring during blood transfusion accompanied by hypotension or dark urine (hemoglobinuria)."
      ],
      "missingCriticalInformation": [
        "Exact onset time of fever (post-induction vs. recovery room) and rate of increase",
        "Transfusion history and baseline infectious markers"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Perioperative Fever and Hyperthermia Management",
        "Transfusion Reaction Differential Diagnosis",
        "Postoperative Inflammatory Fever and Atelectasis"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately turn off all active patient warming devices (forced-air blankets).",
        "Establish continuous core temperature monitoring (esophageal, nasopharyngeal, or bladder).",
        "If a blood transfusion is running, stop it immediately, discard the tubing, and return the unit to the blood bank.",
        "Draw an ABG to rule out metabolic acidosis (MH) and administer IV Paracetamol (1g) if appropriate."
      ],
      "relatedAlgorithms": [
        {
          "id": "malignant_hyperthermia",
          "titleTr": "Malignant Hyperthermia Protocol"
        },
        {
          "id": "thyroid_storm",
          "titleTr": "Thyroid Storm Algorithm"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "paracetamol",
          "titleTr": "Paracetamol Monograph"
        },
        {
          "id": "dantrolene",
          "titleTr": "Dantrolene Monograph"
        }
      ],
      "doNotMiss": [
        "Fever within the first 24 hours postoperatively is most commonly non-infectious, driven by surgical stress and atelectasis"
      ],
      "whenToEscalate": [
        "If the fever is associated with severe hypercapnia, muscle rigidity, and metabolic acidosis, immediately administer Dantrolene (2.5 mg/kg IV) for suspected MH"
      ],
      "referencesToShow": [
        "Anesthesiology: Perioperative Fever and Hypothermia. 2018.",
        "MHAUS Guidelines for Perioperative Hyperthermia. 2024."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "smoke_inhalation_injury",
    "category": "clinical_scenarios",
    "keywords": [
      "duman",
      "hasarı",
      "inhalasyon",
      "inhalasyonu",
      "inhalation",
      "injury",
      "smoke",
      "solunum",
      "yanığı"
    ],
    "question_tr": "Duman inhalasyonu",
    "question_en": "Solunum yanığı",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Duman inhalasyonu hasarında ilk ve en önemli basamak havayolunun güvenceye alınmasıdır! Isı hasarı glottis üstünde sınırlı kalırken, kimyasal hasar alt solunum yollarına ve alveollere yayılır. Üst havayolu ödemi (larenks ödemi) saatler içinde hızla ilerleyebilir ve tam havayolu tıkanıklığına yol açabilir. Stridor, ses kısıklığı, yüz/boyun yanıkları, burun kıllarında kömürleşme ve kurum veya karbonlu balgam varlığı acil entübasyon endikasyonudur. Entübasyon için gecikilmemelidir; ödem oturduktan sonra entübasyon imkansız hale gelebilir (CICO).",
      "immediateRedFlags": [
        "Stridor, ses kısıklığı veya solunum sıkıntısı olan inhalasyon yaralanmalı hastada entübasyonun geciktirilmesi.",
        "Havayolu ödemi ilerlemiş hastada körlemesine veya hazırlıksız entübasyon denenmesi."
      ],
      "missingCriticalInformation": [
        "Yangın ortamının kapalı mı açık mı olduğu (kapalı alan CO/Siyanür riskini artırır)",
        "Hastanın bazal oksijenasyonu ve güncel akciğer grafisi/bronkoskopi bulguları"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Duman İnhalasyonu ve Akut Havayolu Ödemi",
        "Kimyasal Akciğer Hasarı ve Bronkospazm",
        "Erken Entübasyon Endikasyonları Yanık"
      ],
      "suggestedNextStepsGeneral": [
        "Havayolunu değerlendirin; stridor, ses kısıklığı veya karbondan zengin balgam varsa derhal entübasyon hazırlığı yapın.",
        "Entübasyonda glottik ödem nedeniyle beklenenden daha küçük tüp boyutları (örn. 6.0 - 6.5) tercih edin ve fiberoptik rehberliği düşünün.",
        "%100 nemlendirilmiş O₂ verin ve bronkospazm için agresif beta-mimetik (Salbutamol) nebül uygulayın.",
        "Eş zamanlı Karbonmonoksit ve Siyanür zehirlenmesi olasılığını mutlaka değerlendirin (kan gazı, laktat seviyesi)."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        },
        {
          "id": "bronchospasm",
          "titleTr": "Bronkospazm Tedavi Kılavuzu"
        }
      ],
      "relatedCalculators": [
        {
          "id": "burn_fluid_parkland",
          "titleTr": "Parkland Sıvı Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol Monografı"
        },
        {
          "id": "dexamethasone",
          "titleTr": "Deksametazon Monografı"
        }
      ],
      "doNotMiss": [
        "Üst havayolu ödeminin yaralanmadan sonraki ilk 12-24 saat içinde progresif olarak artarak tam obstrüksiyona yol açacağını"
      ],
      "whenToEscalate": [
        "İlerleyici stridoru olan ve laringeal ödem nedeniyle entübe edilemeyen (CICO) hastada acil cerrahi havayolu (krikotirotomi) uygulayın"
      ],
      "referencesToShow": [
        "Practice Guidelines for the Management of Burn Injury. J Burn Care Res 2018.",
        "ASA Practice Guidelines on Difficult Airway. 2022."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "In smoke inhalation injury, the first and most critical step is securing the airway! Thermal injury is usually limited to structures above the glottis, whereas chemical injury propagates to the lower airways and alveoli. Upper airway edema (laryngeal edema) can progress rapidly over hours, leading to complete airway obstruction. Stridor, hoarseness, facial/neck burns, singed nasal hairs, and carbonaceous sputum are indications for immediate prophylactic intubation. Do not delay intubation; once airway edema is established, intubation may become impossible (CICO).",
      "immediateRedFlags": [
        "Delaying intubation in a patient with stridor, voice changes, or progressive accessory muscle use.",
        "Attempting blind or unassisted intubation in a patient with suspected severe laryngeal burns."
      ],
      "missingCriticalInformation": [
        "Whether the fire occurred in an enclosed space (high risk for CO and cyanide co-poisoning)",
        "Patient's current arterial blood gas (ABG) and carboxyhemoglobin (COHb) level"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Smoke Inhalation Injury and Airway Edema",
        "Chemical Pneumonitis and Severe Bronchospasm",
        "Prophylactic Intubation Criteria in Burns"
      ],
      "suggestedNextStepsGeneral": [
        "Evaluate airway patency; have a very low threshold for early intubation if carbonaceous sputum, hoarseness, or stridor is present.",
        "Prepare smaller endotracheal tubes (e.g. 6.0 and 6.5) and have a video laryngoscope or fiberoptic scope ready.",
        "Provide 100% humidified oxygen and administer aggressive inhaled bronchodilators (e.g. albuterol).",
        "Screen for co-existing Carbon Monoxide and Cyanide poisoning (check lactate and COHb)."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Algorithm"
        },
        {
          "id": "bronchospasm",
          "titleTr": "Bronchospasm Rescue Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "burn_fluid_parkland",
          "titleTr": "Parkland Fluid Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "salbutamol",
          "titleTr": "Albuterol Monograph"
        },
        {
          "id": "dexamethasone",
          "titleTr": "Dexamethasone Monograph"
        }
      ],
      "doNotMiss": [
        "Upper airway swelling is highly progressive over the first 12-24 hours; an airway that looks patent now can completely close shortly"
      ],
      "whenToEscalate": [
        "If airway edema prevents standard intubation and mask ventilation fails (CICO), execute an emergent surgical cricothyrotomy"
      ],
      "referencesToShow": [
        "Practice Guidelines for the Management of Burn Injury. J Burn Care Res 2018.",
        "ASA Practice Guidelines on Difficult Airway. 2022."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "carbon_monoxide_poisoning",
    "category": "clinical_scenarios",
    "keywords": [
      "carbon",
      "co",
      "cohb",
      "hbo",
      "hiperbarik",
      "karbonmonoksit",
      "monoxide",
      "poisoning",
      "zehirlenmesi"
    ],
    "question_tr": "Karbonmonoksit",
    "question_en": "Cohb",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Karbonmonoksit (CO) zehirlenmesinde CO, hemoglobine oksijene göre 200 kat daha güçlü bağlanarak Karboksilemoglobin (COHb) oluşturur ve doku hipoksine yol açar. CDC ve AHA kılavuzlarına göre ilk tedavi %100 Oksijen vermektir (%100 O₂, COHb yarı ömrünü havada 4-5 saatten 1-1.5 saate indirir). CDC hiperbarik oksijen (HBO) tedavisi endikasyonlarını şu durumlarda önerir: COHb > %25-30, kardiyak tutulum/miyokard iskemisi (EKG değişikliği/troponin artışı), ciddi metabolik asidoz (pH < 7.20), bilinç kaybı, nörolojik bozukluk veya gebelerde COHb > %15-20. Nabız oksimetreler COHb ve HbO₂'yi ayırt edemez, yanıltıcı olarak yüksek (%100) SpO2 gösterebilir; mutlaka Co-oksimetri ile COHb ölçülmelidir.",
      "immediateRedFlags": [
        "CO zehirlenmesinde standart nabız oksimetrenin %100 göstermesine aldanarak oksijen tedavisinin kesilmesi veya verilmemesi.",
        "Gebede hafif semptomlar olmasına rağmen HBO yönünden değerlendirilmemesi (fetal hemoglobin CO'yu daha çok tutar)."
      ],
      "missingCriticalInformation": [
        "Co-oksimetre ile ölçülen net COHb yüzdesi",
        "Hastanın nörolojik durumu, bilinç kaybı öyküsü ve EKG/Troponin sonuçları"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Karbonmonoksit Toksisitesi ve COHb Takibi",
        "Hiperbarik Oksijen (HBO) Endikasyonları CDC",
        "Co-oksimetri ve Yalancı SpO2 Yüksekliği"
      ],
      "suggestedNextStepsGeneral": [
        "Şüpheli tüm hastalarda derhal rezervuarlı maske ile %100 normobarik oksijen tedavisi başlatın.",
        "Tanı için mutlaka Co-oksimetrik kan gazı isteyin; standart parmak probu SpO2 değerine kesinlikle güvenmeyin.",
        "EKG çekin ve Troponin isteyerek miyokard iskemisi (kardiyak tutulum) varlığını ekarte edin.",
        "COHb >%25-30 veya gebede >%15, ya da bilinç kaybı/asidoz varsa hastayı en yakın HBO merkezine sevk edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "sepsis",
          "titleTr": "Toksikoloji Genel Protokolü"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Ortalama Arter Basıncı"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Standart puls oksimetrelerin COHb varlığında yalancı olarak normal/yüksek (%98-100) SpO2 göstereceğini"
      ],
      "whenToEscalate": [
        "Ciddi miyokardiyal iskemi, dirençli şok veya derin koma tablosu gelişirse, entübe ederek solunum desteği sağlayın ve HBO transferini koordine edin"
      ],
      "referencesToShow": [
        "CDC Case Definitions: Carbon Monoxide Poisoning. 2021.",
        "AHA/ACMT Clinical Guidance on CO Toxicity. Annals of Emergency Medicine 2017."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "In carbon monoxide (CO) poisoning, CO binds to hemoglobin with 200 times higher affinity than oxygen, forming carboxyhemoglobin (COHb) and causing tissue hypoxia. According to CDC and AHA guidelines, first-line treatment is 100% normobaric oxygen (reduces COHb half-life from 4-5 hours on room air to 60-90 minutes). CDC recommends Hyperbaric Oxygen (HBO) therapy for: COHb >25-30%, cardiac involvement/ischemia (EKG changes/troponin rise), severe metabolic acidosis (pH <7.20), loss of consciousness, neurological deficits, or pregnant patients with COHb >15-20%. Standard pulse oximeters cannot differentiate COHb and HbO2, showing false-normal SpO2; measure COHb via Co-oximetry.",
      "immediateRedFlags": [
        "Withholding oxygen therapy based on a normal standard pulse oximeter reading (SpO2 98-100%) in a suspected CO patient.",
        "Failing to evaluate a pregnant patient for HBO when COHb is >15% (fetal hemoglobin has even higher affinity for CO)."
      ],
      "missingCriticalInformation": [
        "Carboxyhemoglobin (COHb) level measured by fractional co-oximetry",
        "Neurological status, history of syncope/loss of consciousness, and EKG/troponin results"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Carbon Monoxide Toxicity and COHb Clearance",
        "CDC Hyperbaric Oxygen (HBO) Indications",
        "Co-oximetry and Pulse Oximetry Limitations"
      ],
      "suggestedNextStepsGeneral": [
        "Administer 100% normobaric oxygen immediately via a non-rebreather mask or high-flow nasal cannula.",
        "Obtain an ABG with fractional co-oximetry to verify the exact COHb level.",
        "Perform an EKG and check troponin levels to evaluate for occult myocardial ischemia.",
        "Arrange for urgent transfer to an HBO chamber if COHb >25-30% (>15% in pregnancy), or if syncope/acidosis is present."
      ],
      "relatedAlgorithms": [
        {
          "id": "sepsis",
          "titleTr": "Toxicology General Protocol"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Mean Arterial Pressure"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Standard two-wavelength pulse oximeters measure COHb as oxyhemoglobin, falsely reading near 100% saturation"
      ],
      "whenToEscalate": [
        "In cases of refractory cardiovascular instability, deep coma, or status epilepticus, intubate the patient and expedite HBO chamber access"
      ],
      "referencesToShow": [
        "CDC Case Definitions: Carbon Monoxide Poisoning. 2021.",
        "AHA/ACMT Clinical Guidance on CO Toxicity. Annals of Emergency Medicine 2017."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "cyanide_poisoning",
    "category": "clinical_scenarios",
    "keywords": [
      "cyanide",
      "cyanokit",
      "hidroksokobalamin",
      "poisoning",
      "siyanür"
    ],
    "question_tr": "Siyanür",
    "question_en": "Hidroksokobalamin",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Siyanür zehirlenmesi, özellikle kapalı alan yangınlarında duman inhalasyonuyla birlikte sık gelişen, hücresel solunumu (sitokrom c oksidazı) bloke ederek laktik asidoz ve ani ölüme yol açan katastrofik bir durumdur. Belirtiler: derin asidoz, şok, koma ve çok yüksek serum laktat seviyesidir (> 8-10 mmol/L). Tedavide ilk tercih spesifik antidot olan Hidroksokobalamindir (Cyanokit). Hidroksokobalamin siyanüre bağlanarak siyanokobalamin (B12 vitamini) oluşturur ve idrarla atılır. Dozu yetişkinlerde 5 g IV infüzyondur (15 dakikada), yanıt alınamazsa 5 g daha tekrarlanabilir. Diğer antidotlar (sodyum tiyosülfat, sodyum nitrit) ikinci basamakta düşünülür.",
      "immediateRedFlags": [
        "Kapalı alan yangınında duman inhalasyonu olan ve derin laktik asidozu (laktat > 10) olan hastada siyanür zehirlenmesinin atlanması.",
        "Siyanür zehirlenmesi olan hastaya nitrit antidotlarının (sodyum nitrit) karbonmonoksit varlığında verilmesi (methemoglobinemiyi artırarak oksijen sunumunu tamamen çökertebilir)."
      ],
      "missingCriticalInformation": [
        "Serum laktat seviyesi ve arter kan gazı parametreleri",
        "Eş zamanlı karbonmonoksit (COHb) düzeyi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Siyanür Zehirlenmesi ve Laktik Asidoz",
        "Hidroksokobalamin (Cyanokit) Antidot Tedavisi",
        "Duman İnhalasyonunda Multitoksikoloji"
      ],
      "suggestedNextStepsGeneral": [
        "Kapalı alanda dumana maruz kalmış, açıklanamayan laktik asidozu ve koması olan hastada siyanürden şüphelenin.",
        "Derhal %100 Oksijen tedavisi başlatın.",
        "Spesifik antidot olan Hidroksokobalamini (Cyanokit) 5 g IV infüzyon olarak 15 dakikada uygulayın.",
        "Böbrek yetmezliği veya eş zamanlı CO zehirlenmesi varsa nitrit türevi antidotlardan kesinlikle kaçının."
      ],
      "relatedAlgorithms": [
        {
          "id": "sepsis",
          "titleTr": "Toksikoloji Protokolü"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Ortalama Arter Basıncı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "hydroxocobalamin",
          "titleTr": "Hidroksokobalamin Monografı"
        },
        {
          "id": "sodium_thiosulfate",
          "titleTr": "Sodyum Tiyosülfat Monografı"
        }
      ],
      "doNotMiss": [
        "Siyanür zehirlenmesinde hidroksokobalamin verilmesinin cildi, idrarı ve laboratuvar parametrelerini geçici olarak kırmızıya boyayabileceğini"
      ],
      "whenToEscalate": [
        "Dirençli kardiyovasküler şok ve laktat >10 mmol/L olan hastalarda agresif inotropik destek, mekanik ventilasyon ve yakın yoğun bakım takibi planlayın"
      ],
      "referencesToShow": [
        "ASA Practice Advisory on Inhalation Injuries. 2018.",
        "ACMT Guidance on Cyanide Poisoning Reversal. J Med Toxicol 2019."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Cyanide poisoning often co-occurs with carbon monoxide in house fires. It blocks cellular respiration (cytochrome c oxidase), causing lactic acidosis and rapid death. Signs include profound metabolic acidosis, shock, coma, and very high serum lactate (>8-10 mmol/L). First-line treatment is the specific antidote Hydroxocobalamin (Cyanokit). Hydroxocobalamin binds cyanide to form cyanocobalamin (vitamin B12), excreted in urine. Standard dose is 5 g IV infusion over 15 minutes, which can be repeated if clinically indicated. Other antidotes (sodium thiosulfate, sodium nitrite) are second-line.",
      "immediateRedFlags": [
        "Failing to recognize cyanide poisoning in a fire victim presenting with profound unexplained lactic acidosis (lactate >10 mmol/L).",
        "Administering sodium nitrite antidote in a patient with suspected co-existing carbon monoxide poisoning (worsens methemoglobinemia, completely collapsing oxygen delivery)."
      ],
      "missingCriticalInformation": [
        "Venous or arterial lactate levels and acid-base profile",
        "Carboxyhemoglobin level and hemodynamics"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Cyanide Poisoning and Lactic Acidosis",
        "Hydroxocobalamin (Cyanokit) Antidote Therapy",
        "Smoke Inhalation Multitoxicology"
      ],
      "suggestedNextStepsGeneral": [
        "Suspect cyanide poisoning in any smoke inhalation victim with coma, shock, and lactate >8-10 mmol/L.",
        "Administer 100% high-flow oxygen immediately.",
        "Infuse Hydroxocobalamin (Cyanokit) 5 g IV over 15 minutes as first-line therapy.",
        "Avoid nitrites if carbon monoxide co-poisoning is suspected; use Sodium Thiosulfate as a secondary agent if needed."
      ],
      "relatedAlgorithms": [
        {
          "id": "sepsis",
          "titleTr": "Toxicology Protocol"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Mean Arterial Pressure"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "hydroxocobalamin",
          "titleTr": "Hydroxocobalamin Monograph"
        },
        {
          "id": "sodium_thiosulfate",
          "titleTr": "Sodium Thiosulfate Monograph"
        }
      ],
      "doNotMiss": [
        "Hydroxocobalamin causes a benign, temporary red discoloration of the skin, urine, and bodily fluids, which may interfere with colorimetric lab assays"
      ],
      "whenToEscalate": [
        "For refractory shock and persistent severe lactic acidosis, provide aggressive vasopressor/inotropic support and immediate ICU transfer"
      ],
      "referencesToShow": [
        "ASA Practice Advisory on Inhalation Injuries. 2018.",
        "ACMT Guidance on Cyanide Poisoning Reversal. J Med Toxicol 2019."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "local_anesthetic_max_dose_details",
    "category": "clinical_scenarios",
    "keywords": [
      "anestezik",
      "anesthetic",
      "bupivakain",
      "details",
      "dose",
      "la",
      "lidokain",
      "local",
      "lokal",
      "maksimum",
      "max",
      "maximum"
    ],
    "question_tr": "Lokal anestezik maksimum",
    "question_en": "Local anesthetic max dose",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Lokal anesteziklerin (LA) maksimum güvenli dozları hastanın kilosuna, ek hastalıklarına (böbrek/karaciğer yetmezliği, yaşlılık) ve blok bölgesinin vaskülaritesine göre ayarlanmalıdır. Klasik maksimum doz limitleri (infiltrasyon/bölgesel blok için): 1) Lidokain: adrenalinsiz 4.5 mg/kg (maks 300 mg), adrenalinli 7 mg/kg (maks 500 mg). 2) Bupivakain: adrenalinsiz 2.5 mg/kg (maks 175 mg), adrenalinli 3 mg/kg (maks 225 mg). 3) Levobupivakain: 2.5 - 3 mg/kg. 4) Ropivakain: 3 mg/kg (maks 200-225 mg). Toksisiteyi (LAST) önlemek için her zaman en düşük efektif doz kullanılmalı, enjeksiyon öncesi negatif aspirasyon yapılmalı ve adrenalin içeren solüsyonlar intravasküler enjeksiyonu saptamak için tercih edilmelidir.",
      "immediateRedFlags": [
        "Hesaplanan maksimum LA dozunun üzerinde enjeksiyon yapılması (özellikle vasküler bölgelerde).",
        "Yaşlı, kaşektik veya karaciğer yetmezliği olan hastada maksimum dozların azaltılmadan standart uygulanması (LA klirensi belirgin düşüktür)."
      ],
      "missingCriticalInformation": [
        "Hastanın tam vücut ağırlığı (ideal vücut ağırlığına göre hesaplanmalıdır)",
        "Enjeksiyon yapılacak bölgenin vaskülarite derecesi (örn. interkostal vs subkutan)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Lokal Anestezik Doz Limitleri",
        "LAST Önleme ve Güvenlik Protokolleri",
        "Lokal Anestezik Farmakolojisi"
      ],
      "suggestedNextStepsGeneral": [
        "Lokal anestezi yapmadan önce hastayı tartın veya güncel kilosunu doğrulayın; kaşektik/yaşlı ise dozları %30-40 oranında azaltın.",
        "Lidokain için adrenalinsiz 4 mg/kg, adrenalinli 7 mg/kg sınırını aşmayın.",
        "Bupivakain için 2 mg/kg (maks 150-175 mg) sınırını koruyun.",
        "Enjeksiyonu yavaş ve her 3-5 mL'de bir aspire ederek yapın; hastayla sözel iletişimi sürdürün."
      ],
      "relatedAlgorithms": [
        {
          "id": "last",
          "titleTr": "LAST Tedavi Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "la_max_dose",
          "titleTr": "LA Maksimum Doz Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "lipid",
          "titleTr": "Lipid Emülsiyon Monografı"
        }
      ],
      "doNotMiss": [
        "Maksimum dozların mutlak güvenliği garanti etmediğini, hızlı intravasküler enjeksiyonla çok daha düşük dozlarda bile LAST gelişebileceğini"
      ],
      "whenToEscalate": [
        "Hastada perioral uyuşma, metalik tat, kulak çınlaması veya nöbet/aritmi gibi LAST bulguları gelişirse derhal enjeksiyonu durdurun ve LAST kriz protokolünü (%20 Lipid) başlatın"
      ],
      "referencesToShow": [
        "ASRA Practice Advisory on Local Anesthetic Systemic Toxicity. 2021.",
        "ESRA Guidelines on Regional Anesthesia Safety. 2020."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Maximum safe doses of local anesthetics (LA) must be adjusted for body weight, comorbidities (renal/hepatic impairment, extremes of age), and block site vascularity. Standard maximum dose limits (infiltration/peripheral blocks): 1) Lidocaine: 4.5 mg/kg without epinephrine (max 300 mg), 7 mg/kg with epinephrine (max 500 mg). 2) Bupivacaine: 2.5 mg/kg without epinephrine (max 175 mg), 3 mg/kg with epinephrine (max 225 mg). 3) Levobupivacaine: 2.5-3 mg/kg. 4) Ropivacaine: 3 mg/kg (max 225 mg). To prevent toxicity (LAST), use the lowest effective dose, perform incremental injections with frequent aspiration, and consider epinephrine as a vascular marker.",
      "immediateRedFlags": [
        "Exceeding calculated maximum weight-based LA limits (especially in highly vascular spaces like intercostal blocks).",
        "Failing to reduce maximum doses in elderly, cachectic, or liver failure patients (markedly reduced clearance)."
      ],
      "missingCriticalInformation": [
        "Patient's actual vs. ideal body weight (dose should be calculated based on ideal or lean body weight in obese patients)",
        "Specific anatomical block location and injection vascularity index"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Local Anesthetic Maximum Dosage Limits",
        "LAST Prevention and Injection Safety",
        "Local Anesthetic Pharmacology"
      ],
      "suggestedNextStepsGeneral": [
        "Calculate maximum doses using lean body weight for obese patients, and reduce doses by 30-50% in elderly/hepatic failure.",
        "Keep lidocaine dose below 4.5 mg/kg (plain) or 7 mg/kg (with epinephrine).",
        "Keep bupivacaine dose below 2.5 mg/kg (plain) or 3 mg/kg (with epinephrine).",
        "Perform slow, incremental injections (3-5 mL aliquots) with frequent aspiration, maintaining verbal contact."
      ],
      "relatedAlgorithms": [
        {
          "id": "last",
          "titleTr": "LAST Rescue Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "la_max_dose",
          "titleTr": "LA Max Dose Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "lipid",
          "titleTr": "Lipid Emulsion Monograph"
        }
      ],
      "doNotMiss": [
        "Maximum dose limits are guidelines only; rapid accidental intravascular injection can cause LAST even with low doses"
      ],
      "whenToEscalate": [
        "At the first sign of LAST (perioral numbness, tinnitus, metallic taste, seizures, or arrhythmias), immediately stop injection, call for help, and prepare 20% Lipid Emulsion"
      ],
      "referencesToShow": [
        "ASRA Practice Advisory on Local Anesthetic Systemic Toxicity. 2021.",
        "ESRA Guidelines on Regional Anesthesia Safety. 2020."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "regional_nerve_injury",
    "category": "clinical_scenarios",
    "keywords": [
      "block",
      "blok",
      "deficit",
      "emg",
      "hasarı",
      "injury",
      "nerve",
      "neurological",
      "regional",
      "rejyonal",
      "sinir",
      "sonrası",
      "yaralanması"
    ],
    "question_tr": "Rejyonal sinir hasarı",
    "question_en": "Nerve injury block",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Rejyonal blok sonrası nörolojik hasar nadir ama endişe verici bir durumdur. Blok sonrası motor veya duyu kaybı uzarsa sistematik bir yaklaşım uygulanmalıdır: 1) İlk 24 saat içinde bloğun çözülüp çözülmediğini ve cerrahi basıyı (sıkı alçı, turnike) değerlendirin. 2) ASRA nöroloji kılavuzuna göre iğne yerleşim yeri, enjeksiyon sırasında parestezi veya şiddetli ağrı olup olmadığı sorgulanmalıdır (intrafasiküler enjeksiyon riski). 3) Elektromiyografi (EMG) zamanlaması önemlidir; ameliyat sonrası 24-48 saat içinde yapılacak ilk EMG pre-kliniği (eski hasarı) gösterir, 6-8. haftada yapılacak ikinci EMG ise yeni hasarı doğrular. Çoğu lezyon (nörapraksi) haftalar içinde kendiliğinden düzelir.",
      "immediateRedFlags": [
        "Kateter veya blok sonrası ilerleyici motor ve duyu kaybı ile birlikte sırt ağrısı veya mesane/rektum inkontinansı (acil Epidural/Spinal Hematom - cerrahi dekompresyon süresi ilk 8 saattir!).",
        "Blok yapılan bölgede enfeksiyon bulguları ve lokal hassasiyet."
      ],
      "missingCriticalInformation": [
        "Bloğun yapılış detayları (ultrason eşliğinde mi, stimülatör kullanıldı mı, parestezi oldu mu)",
        "Nörolojik defisitin tam anatomik dermatomu ve derecesi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Rejyonal Blok Sonrası Nörolojik Hasar",
        "EMG Zamanlaması ve Tanı Kriterleri",
        "İntrafasiküler Enjeksiyon Hasarı"
      ],
      "suggestedNextStepsGeneral": [
        "Uzamış blok varlığında öncelikle cerrahi basıyı (turnike, bandaj, hematom) ekarte edin.",
        "Detaylı bir nörolojik muayene yaparak hasarın blok dermatomuyla uyumlu olup olmadığını saptayın.",
        "Tanısal netlik ve medikolegal koruma için ilk 48 saatte ve 6. haftada EMG yapılmasını planlayın.",
        "Nöroloji/Fizik Tedavi konsültasyonu isteyin ve hastaya durumun genellikle geçici (nörapraksi) olduğunu açıklayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "epidural_hematoma",
          "titleTr": "Epidural Hematom Algoritması"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Blok sırasında iğne ucunun sinire temas etmesiyle oluşan şiddetli ağrının (parestezi) sinir hasarı için en önemli risk faktörü olduğunu"
      ],
      "whenToEscalate": [
        "Uzamış blok ile birlikte hızla ilerleyen nörolojik kayıp ve sırt ağrısı varsa, acil MRG isteyin ve spinal dekompresyon için beyin cerrahisine haber verin"
      ],
      "referencesToShow": [
        "ASRA Practice Advisory on Neurological Complications in Regional Anesthesia. RAPM 2015. Reconfirmed 2021.",
        "ESRA Guidelines on Regional Block Nerve Injury. 2020."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Peripheral nerve injury (PNI) after regional block is rare. If motor or sensory blockade is prolonged beyond the expected drug duration, implement a systematic approach: 1) Within the first 24h, rule out surgical compression (tight cast, tourniquet) or positioning injury. 2) Review the block details; ask if the patient experienced severe paresthesia or pain on injection (indicator of intra-fascicular injection). 3) Electromyography (EMG) timing is key: an EMG within 48h establishes baseline (pre-existing neuropathy), whereas a follow-up EMG at 6-8 weeks confirms and localizes the new block-related injury. Most nerve injuries are neurapraxias and resolve spontaneously.",
      "immediateRedFlags": [
        "Progressive bilateral motor deficit, severe back pain, or bowel/bladder dysfunction post-neuraxial anesthesia (spinal-epidural hematoma/abscess - requires emergency surgical decompression <8 hours!).",
        "Rapidly spreading localized infection at the injection site."
      ],
      "missingCriticalInformation": [
        "Anatomical distribution and severity (motor vs. sensory) of the neurological deficit",
        "Block performance parameters (ultrasound vs. nerve stimulator, presence of high injection pressure)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Post-Block Nerve Injury Evaluation",
        "EMG Timing and Diagnostic Value",
        "Intrafascicular Local Anesthetic Injection"
      ],
      "suggestedNextStepsGeneral": [
        "Rule out non-anesthetic causes: tight bandages, direct surgical nerve traction, or prolonged tourniquet ischemia.",
        "Perform a detailed neurological exam, mapping deficits to specific peripheral nerves and dermatoms.",
        "Schedule baseline EMG within 48 hours to screen for pre-existing subclinical neuropathies.",
        "Consult neurology/physiotherapy and arrange a follow-up EMG at 6-8 weeks for definitive assessment."
      ],
      "relatedAlgorithms": [
        {
          "id": "epidural_hematoma",
          "titleTr": "Epidural Hematoma Guidelines"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Severe pain or electric shock sensation during needle advancement or injection is highly suggestive of direct nerve contact; stop the injection immediately"
      ],
      "whenToEscalate": [
        "If a central neuraxial block is followed by progressive motor weakness and severe back pain, obtain emergent MRI and summon neurosurgery immediately"
      ],
      "referencesToShow": [
        "ASRA Practice Advisory on Neurological Complications in Regional Anesthesia. RAPM 2015. Reconfirmed 2021.",
        "ESRA Guidelines on Regional Block Nerve Injury. 2020."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "compartment_syndrome_emergency",
    "category": "clinical_scenarios",
    "keywords": [
      "5p",
      "compartment",
      "emergency",
      "fasciotomy",
      "fasiyotomi",
      "germe",
      "kompartman",
      "pasif",
      "sendromu",
      "syndrome"
    ],
    "question_tr": "Kompartman sendromu",
    "question_en": "5p",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Kompartman sendromu, kapalı bir fasyal kompartmandaki doku basıncının artarak mikrovasküler dolaşımı bozması ve kas/sinir nekrozuna yol açmasıyla karakterize cerrahi bir acildir. En klasik belirti 'pasif germe ile ortaya çıkan aşırı ağrıdır' (ağrı analjeziklere yanıt vermez). Diğer bulgular 5P kuralıdır (Pain, Paresthesia, Pallor, Paralysis, Pulselessness). Rejyonal bloklar (özellikle epidural veya periferik sinir blokları) kompartman sendromunun bu klasik ağrısını maskeleyebileceği için tartışmalıdır. Yaklaşım: kompartman içi basıncın ölçülmesi (>30-40 mmHg veya delta basıncı <30 mmHg) ve acil fasiyotomidir.",
      "immediateRedFlags": [
        "Ekstremitede gelişen ve analjeziklere yanıt vermeyen şiddetli, ilerleyici ağrı.",
        "Kompartman sendromu şüphesi olan bacakta/kolda ağrıyı maskeleyecek düzeyde yoğun yoğun rejyonal blok sürdürülmesi."
      ],
      "missingCriticalInformation": [
        "Yaralanmanın türü (kırık, ezilme hasarı, sıkı bandaj)",
        "Kompartman içi ölçülen basınç değeri (mmHg) veya delta basıncı (Diyastolik BP - Kompartman Basıncı)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Akut Kompartman Sendromu Tanı ve Takibi",
        "Rejyonal Anestezi Maskeleme Tartışması",
        "Acil Fasiyotomi Endikasyonları"
      ],
      "suggestedNextStepsGeneral": [
        "Şüpheli ekstremitedeki tüm sıkı bandaj, alçı ve sargıları derhal kesin.",
        "Kompartmanı kalp seviyesinde tutun (elevasyon iskemi/perfüzyon basıncını bozabileceği için aşırı elevasyondan kaçının).",
        "Kompartman içi basıncı ölçün veya acil ortopedi/vasküler cerrahi konsültasyonu isteyin.",
        "Basınç >30 mmHg ise veya klinik şüphe yüksekse acil fasiyotomi (kompartmanın cerrahi olarak açılması) planlayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "epidural_hematoma",
          "titleTr": "Nöroaksiyel Takip Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Ortalama Arter Basıncı"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Pasif germe ile oluşan ağrının kompartman sendromunun en erken ve en güvenilir klinik belirtisi olduğunu"
      ],
      "whenToEscalate": [
        "Nabızların kaybolması (pulselessness) ve felç (paralysis) çok geç dönem bulgularıdır; bu bulgular gelişmeden fasiyotomi yapılmalıdır, aksi halde ekstremite kaybı kaçınılmazdır"
      ],
      "referencesToShow": [
        "AAOS Clinical Practice Guideline on Acute Compartment Syndrome. 2019.",
        "Regional Anesthesia and Compartment Syndrome. British Journal of Anaesthesia 2017."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Compartment syndrome is a surgical emergency characterized by increased pressure within a closed fascial space, compromising microvascular circulation and leading to muscle/nerve necrosis. The most reliable early sign is 'severe pain out of proportion to injury, exacerbated by passive stretch.' Other features follow the 5Ps (Pain, Paresthesia, Pallor, Paralysis, Pulselessness). Regional blocks (epidural or peripheral blocks) are controversial because they can mask this warning pain. Diagnostic confirmation is by intra-compartmental pressure measurement (>30-40 mmHg or delta pressure <30 mmHg), and definitive treatment is emergent fasciotomy.",
      "immediateRedFlags": [
        "Progressive, severe extremity pain that is completely unresponsive to high-dose systemic opioids.",
        "Continuing a dense sensory regional block in a high-risk extremity (e.g., tibia fracture), potentially masking compartment syndrome pain."
      ],
      "missingCriticalInformation": [
        "Type of injury (fracture, crush injury, tight casting)",
        "Intra-compartmental pressure (mmHg) and calculated delta pressure (Diastolic BP minus compartment pressure)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Acute Compartment Syndrome Diagnosis",
        "Regional Anesthesia Masking Controversy",
        "Emergent Fasciotomy Indications"
      ],
      "suggestedNextStepsGeneral": [
        "Remove all tight casts, splints, and constrictive dressings immediately.",
        "Keep the limb at heart level (avoid high elevation, which decreases perfusion pressure).",
        "Measure intra-compartmental pressure or immediately consult orthopedic/vascular surgery.",
        "If compartment pressure is >30 mmHg or delta pressure is <30 mmHg, prepare for emergency surgical fasciotomy."
      ],
      "relatedAlgorithms": [
        {
          "id": "epidural_hematoma",
          "titleTr": "Neuraxial Tracking Guidelines"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Mean Arterial Pressure"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Pain on passive stretch of the involved compartment muscles is the single most sensitive clinical indicator before necrosis"
      ],
      "whenToEscalate": [
        "Do not wait for pulselessness or paralysis to perform a fasciotomy; these are late signs indicating irreversible neuromuscular damage"
      ],
      "referencesToShow": [
        "AAOS Clinical Practice Guideline on Acute Compartment Syndrome. 2019.",
        "Regional Anesthesia and Compartment Syndrome. British Journal of Anaesthesia 2017."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "frequent_block_complications",
    "category": "clinical_scenarios",
    "keywords": [
      "block",
      "blok",
      "complication",
      "complications",
      "diyafram",
      "felci",
      "frenik",
      "frequent",
      "horner",
      "komplikasyon",
      "sinir",
      "sık"
    ],
    "question_tr": "Sık blok komplikasyon",
    "question_en": "Frequent block complication",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Sık yapılan bölgesel sinir bloklarının kendine özgü komplikasyonları vardır ve anında fark edilmelidir: 1) İnterskalen Blok: Ipsilateral frenik sinir felci (%100, diyafram parezisi - ciddi KOAH'ta kontrendike), Horner sendromu (pitozis, miyozis, anhidroz - geçici), rekürren laringeal sinir felci (ses kısıklığı). 2) Supraklaivkuler Blok: Pnömotoraks riski (solunum sıkıntısı, öksürük). 3) Aksiller Blok: Vasküler ponksiyon ve LAST riski. 4) Femoral / Safen Blok: Kuadriseps zaafiyeti ve düşme riski. 5) Epidural / Spinal: Yüksek spinal blok (solunum arresti, bradikardi, hipotansiyon), epidural hematom. Komplikasyon yönetimi destekleyici tedavi ve yakın takiptir.",
      "immediateRedFlags": [
        "İnterskalen blok sonrası ciddi KOAH veya tek taraflı diyafram felci olan hastada ağır solunum sıkıntısı gelişmesi.",
        "Supraklaviler blok sonrası ani gelişen nefes darlığı, göğüs ağrısı ve kuru öksürük (pnömotoraks).",
        "Spinal anestezi sonrası hızla yükselen duyusal blok seviyesi ve ellerde uyuşma (yüksek spinal riski)."
      ],
      "missingCriticalInformation": [
        "Uygulanan bloğun türü, lokal anestezik konsantrasyonu ve hacmi",
        "Hastanın bazal solunumsal durumu ve eşlik eden akciğer hastalıkları"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Sık Blok Komplikasyonları ve Ayırıcı Tanı",
        "Frenik Sinir Felci ve İnterskalen Blok",
        "Yüksek Spinal Blok Acil Müdahale"
      ],
      "suggestedNextStepsGeneral": [
        "İnterskalen blok uygulanan her hastada pitozis ve ses kısıklığı gelişebileceğini, bunun geçici olduğunu hastaya açıklayın.",
        "KOAH'lı veya solunum rezervi kısıtlı hastada interskalen blok yerine supraskapular/aksiller blok alternatiflerini değerlendirin.",
        "Supraklaviker blok sonrası solunum sıkıntısı gelişirse akciğer ultrasonu veya grafisi ile pnömotoraksı ekarte edin.",
        "Yüksek spinal şüphesinde hastanın başını hafifçe yükseltin (solunumu korumak için), sıvı bolusu verin, efedrin/atropin uygulayın ve gerekirse entübe edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "last",
          "titleTr": "LAST Tedavi Algoritması"
        },
        {
          "id": "hypotension",
          "titleTr": "Hipotansiyon Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "la_max_dose",
          "titleTr": "LA Maksimum Doz Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "atropine",
          "titleTr": "Atropin Monografı"
        },
        {
          "id": "epinephrine",
          "titleTr": "Adrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "İnterskalen blokta frenik sinir felcinin (diyafram parezisi) neredeyse kaçınılmaz olduğunu, bu nedenle iki taraflı asla yapılmaması gerektiğini"
      ],
      "whenToEscalate": [
        "Yüksek spinal bloğa bağlı solunum arresti ve derin bradikardi gelişirse derhal hastayı entübe edin, %100 O₂ ile ventile edin ve ACLS algoritmasını başlatın"
      ],
      "referencesToShow": [
        "NYSORA Guidelines on Regional Anesthesia Complications. 2023.",
        "ASRA Practice Advisory on Regional Anesthesia Safety. 2021."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Common regional nerve blocks have specific, predictable complications that must be recognized: 1) Interscalene Block: Ipsilateral phrenic nerve paresis (approaching 100% with high volumes - contraindicated in severe COPD), Horner's syndrome (ptosis, meiosis, anhidrosis - transient), recurrent laryngeal nerve block (hoarseness). 2) Supraclavicular Block: Pneumothorax risk (presents as chest pain, dyspnea, dry cough). 3) Axillary Block: High vascularity and LAST risk. 4) Femoral Block: Quadriceps weakness and fall risk. 5) Epidural/Spinal: High spinal block (respiratory arrest, profound bradycardia, hypotension), epidural hematoma. Complication management relies on supportive care and close monitoring.",
      "immediateRedFlags": [
        "Severe dyspnea and desaturation in a COPD patient following interscalene block.",
        "Sudden onset of dyspnea, dry cough, and pleuritic chest pain after a supraclavicular block (pneumothorax).",
        "Rapid cephalad spread of sensory block with hand numbness and difficulty breathing after spinal anesthesia (high spinal)."
      ],
      "missingCriticalInformation": [
        "Specific block performed, volume and concentration of local anesthetic used",
        "Patient's baseline pulmonary reserve and history of contralateral diaphragmatic palsy"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Regional Block Complications and Management",
        "Phrenic Nerve Paresis and Interscalene Safety",
        "High Spinal Rescue Protocol"
      ],
      "suggestedNextStepsGeneral": [
        "Reassure patients experiencing ptosis or hoarseness post-interscalene block that these side effects are transient.",
        "Avoid bilateral interscalene blocks or single-sided interscalene in patients with contralateral diaphragmatic paresis.",
        "Perform lung ultrasound or chest X-ray if dyspnea occurs post-supraclavicular block to evaluate for pneumothorax.",
        "For high spinal: elevate the head slightly, administer IV fluid bolus, give ephedrine/atropine, and secure the airway early if breathing is compromised."
      ],
      "relatedAlgorithms": [
        {
          "id": "last",
          "titleTr": "LAST Rescue Algorithm"
        },
        {
          "id": "hypotension",
          "titleTr": "Hypotension Guidelines"
        }
      ],
      "relatedCalculators": [
        {
          "id": "la_max_dose",
          "titleTr": "LA Max Dose Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "atropine",
          "titleTr": "Atropine Monograph"
        },
        {
          "id": "epinephrine",
          "titleTr": "Epinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Phrenic nerve block is nearly 100% with standard volume interscalene blocks; never perform bilateral interscalene blocks simultaneously"
      ],
      "whenToEscalate": [
        "If high spinal progresses to respiratory arrest or profound bradycardia, immediately secure the airway, ventilate with 100% O2, and support circulation with vasopressors/atropine"
      ],
      "referencesToShow": [
        "NYSORA Guidelines on Regional Anesthesia Complications. 2023.",
        "ASRA Practice Advisory on Regional Anesthesia Safety. 2021."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "pediatric_tef_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "anesthesia",
      "atresia",
      "atrezisi",
      "esophageal",
