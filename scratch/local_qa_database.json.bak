          "id": "plateau_pressure",
          "titleTr": "Plato Basıncı Hesaplayıcı"
        },
        {
          "id": "driving_pressure",
          "titleTr": "Driving Pressure Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "oxygen",
          "titleTr": "Oksijen"
        }
      ],
      "doNotMiss": [
        "Hem peak hem de plato basıncının yükselmesinin parankimal (kompliyans) veya ekstratorasik (örn. karın şişmesi) bir elastik yük artışını gösterdiğini"
      ],
      "whenToEscalate": [
        "Tansiyon pnömotoraksı saptanırsa, laringoskopi denemelerini durdurun ve hemen krikoid/interkostal aralıktan acil iğne dekompresyonu yapın"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Lung compliance and distention physiology studies."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "If both peak and plateau pressures rise, the problem is usually reduced compliance or increased elastic load. Causes include atelectasis, ARDS, pulmonary edema, aspiration, pneumothorax, endobronchial intubation, obesity, Trendelenburg, pneumoperitoneum, abdominal compartment, chest wall rigidity, or excessive tidal volume/PEEP. Assess oxygenation, auscultation, tube depth, lung ultrasound/chest imaging, surgical position, abdominal pressure, and hemodynamics. Reduce tidal volume, adjust PEEP, recruit, perform bronchoscopy, or decompress urgently depending on cause.",
      "immediateRedFlags": [
        "Simultaneous rise of both peak and plateau pressures above 35 cmH2O.",
        "Unilateral loss of breath sounds, tracheal deviation, and hypotension (Tension Pneumothorax).",
        "Rapid change or loss of ETCO2 curve."
      ],
      "missingCriticalInformation": [
        "The ETT insertion depth at the incisors (ruling out mainstem intubation)",
        "Preoperative chest imaging or intraoperative lung ultrasound findings"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Simultaneous Peak and Plateau Rise",
        "Reduced Lung Compliance",
        "Compliance Mismatch Management"
      ],
      "suggestedNextStepsGeneral": [
        "Auscultate bilateral lungs immediately to rule out endobronchial migration.",
        "Obtain urgent lung ultrasound or chest X-ray to exclude pneumothorax.",
        "Reduce tidal volume to 5-6 mL/kg based on predicted body weight (PBW).",
        "Optimize PEEP to maximize respiratory compliance and minimize driving pressure."
      ],
      "relatedAlgorithms": [
        {
          "id": "high_pressure",
          "titleTr": "High Airway Pressure"
        },
        {
          "id": "hypoxemia",
          "titleTr": "Hypoxemia Algorithm"
        },
        {
          "id": "pneumothorax",
          "titleTr": "Pneumothorax Management"
        }
      ],
      "relatedCalculators": [
        {
          "id": "plateau_pressure",
          "titleTr": "Plateau Pressure Calculator"
        },
        {
          "id": "driving_pressure",
          "titleTr": "Driving Pressure Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "oxygen",
          "titleTr": "Oxygen"
        }
      ],
      "doNotMiss": [
        "A parallel rise in peak and plateau pressures always points to a compliance problem (parenchymal or extrapulmonary) rather than an airway resistance issue"
      ],
      "whenToEscalate": [
        "If tension pneumothorax is diagnosed, perform immediate needle decompression in the 2nd intercostal space at the midclavicular line"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Lung compliance and distention physiology studies."
      ],
      "safetyLevel": "urgent"
    }
