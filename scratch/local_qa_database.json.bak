    ],
    "question_tr": "Pediatrik tüp",
    "question_en": "Pediatric tube",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Yaklaşık formüller:\\nKaflı tüp iç çapı: yaş/4 + 3.5\\nKafsız tüp iç çapı: yaş/4 + 4.0\\nTüp derinliği yaklaşık: iç çap × 3 veya yaşa/boya göre doğrulanır.\\n\\nBu formüller başlangıç tahminidir. Kaçak basıncı, kapnografi, oskültasyon, göğüs hareketi ve tüp derinliği mutlaka kontrol edilmelidir. Yenidoğan ve küçük infantlarda yaşa göre tablo kullanmak daha güvenlidir.",
      "immediateRedFlags": [
        "Pediatrik hastalarda çok geniş tüp seçilmesi trakeal mukoza iskemisine, ödeme ve postop subglottik darlığa yol açabilir.",
        "Çok küçük seçilen tüplerde aşırı hava kaçağı ve yetersiz ventilasyon/hipoksemi gelişebilir."
      ],
      "missingCriticalInformation": [
        "Çocuğun tam yaşı ve kilosu",
        "Kaflı (cuffed) veya kafsız (uncuffed) tüp tercih durumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Pediatrik Havayolu Anatomisi ve Yönetimi",
        "Cole ve Motoyama Entübasyon Formülleri",
        "Kaflı Pediatrik Tüplerde Kaf Basıncı Monitörizasyonu"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın yaşını belirleyin (2 yaşından büyük çocuklar için formül geçerlidir).",
        "Kaflı Tüp Çapı: (Yaş / 4) + 3.5 mm.",
        "Kafsız Tüp Çapı: (Yaş / 4) + 4.0 mm.",
        "Entübasyon derinliğini hesaplayın: Tüp Çapı × 3 cm (diş eti/dudak seviyesinde)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Kaflı pediatrik tüplerde kaf basıncı kesinlikle 20 cmH₂O altında tutulmalı ve kaçak testi (leak test) yapılmalıdır"
      ],
      "whenToEscalate": [
        "Pediatrik hastada entübasyon başarısızlığı ve hipoksi durumunda derhal pediatrik zor havayolu algoritmasının başlatılması"
      ],
      "referencesToShow": [
        "AHA Pediatric Advanced Life Support (PALS) Guidelines. 2020. PMID: 33081529.",
        "Coté CJ, et al. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Approximate formulas:\\nCuffed tube internal diameter: age/4 + 3.5\\nUncuffed tube internal diameter: age/4 + 4.0\\nTube depth is roughly internal diameter × 3 or adjusted by age/height.\\n\\nThese are starting estimates only. Confirm leak pressure, capnography, auscultation, chest movement, and tube depth. For neonates and small infants, age/weight-based charts are safer.",
      "immediateRedFlags": [
        "Selecting too large a tube in pediatric patients can cause tracheal mucosal ischemia, edema, and postop subglottic stenosis.",
        "Too small a tube causes excessive air leak, hypoventilation, and threat of hypoxemia."
      ],
      "missingCriticalInformation": [
        "Child's exact age and weight",
        "Preference for cuffed vs uncuffed endotracheal tube"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Pediatric Airway Anatomy and Management",
        "Cole and Motoyama Formulas for Intubation",
        "Cuff Pressure Monitoring in Pediatric Cuffed Tubes"
      ],
      "suggestedNextStepsGeneral": [
        "Identify patient age (formulas apply to children >2 years old).",
        "Cuffed Tube ID: (Age / 4) + 3.5 mm.",
        "Uncuffed Tube ID: (Age / 4) + 4.0 mm.",
        "Calculate insertion depth: Tube ID × 3 cm (at the lip line)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "In cuffed pediatric tubes, keep cuff pressure strictly below 20 cmH₂O and perform a leak test to prevent mucosal injury"
      ],
      "whenToEscalate": [
        "In case of pediatric intubation failure and hypoxemia, immediately activate the pediatric difficult airway protocol"
      ],
      "referencesToShow": [
        "AHA Pediatric Advanced Life Support (PALS) Guidelines. 2020. PMID: 33081529.",
        "Coté CJ, et al. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "abl",
    "category": "clinical_scenarios",
    "keywords": [
      "abl",
      "allowable",
      "blood",
      "izin",
      "kan",
      "loss",
      "verilebilir"
    ],
    "question_tr": "Izin verilebilir kan",
    "question_en": "Abl",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "ABL formülü:\\nABL = EBV × (başlangıç Hct − hedef Hct) / başlangıç Hct\\nEBV hastanın yaşına ve fizyolojisine göre seçilir. Yaklaşık: erişkin erkek 70 mL/kg, erişkin kadın 65 mL/kg, çocuk 70–80 mL/kg, infant 80–90 mL/kg, yenidoğan 85–100 mL/kg.\\n\\nSonuç klinik tablo, hemodinami, aktif kanama, kardiyak hastalık ve oksijen taşıma kapasitesiyle birlikte değerlendirilmelidir.",
      "immediateRedFlags": [
        "ABL sınırına ulaşıldığında aktif kanamanın devam etmesi, hızlı hematokrit takibi ve transfüzyon hazırlığı gerektirir.",
        "Hastada aktif koroner arter hastalığı varsa hedef hematokrit daha yüksek (%30) tutulmalıdır."
      ],
      "missingCriticalInformation": [
        "Hastanın başlangıç Hematokrit (Hct) veya Hemoglobin (Hb) değeri",
        "Hastanın kilosu ve planlanan cerrahinin kanama riski"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İzin Verilebilir Kan Kaybı (Allowable Blood Loss)",
        "Tahmini Kan Hacmi (Estimated Blood Volume - EBV)",
        "Transfüzyon Tetikleyici Eşikleri (Hct/Hb Limitleri)"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın kilosu ve yaş grubuna göre Tahmini Kan Hacmini (EBV) hesaplayın.",
        "Güvenli hedef hematokriti belirleyin (genelde sağlıklı gençlerde %21-24, kardiyak hastalarda %30).",
        "ABL = EBV * (Başlangıç Hct - Hedef Hct) / Başlangıç Hct formülü ile sınırı bulun.",
        "Kan kaybı ABL'ye ulaştığında kristalloid sıvı yerine kan ürünleri veya kolloid replasmanı planlayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "ABL statik bir formüldür; hastanın hemodinamisi, idrar çıkışı ve aktif kanama hızı klinik kararda daha önceliklidir"
      ],
      "whenToEscalate": [
        "Kan kaybının ABL sınırını hızla aşması ve masif kanama durumunda derhal Masif Transfüzyon Protokolünü (MTP) başlatma"
      ],
      "referencesToShow": [
        "Practice Guidelines for Perioperative Blood Management. Anesthesiology 2015. PMID: 25416285.",
        "Shander A, et al. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "ABL formula:\\nABL = EBV × (initial Hct − target Hct) / initial Hct\\nChoose EBV according to age and physiology. Approximate values: adult male 70 mL/kg, adult female 65 mL/kg, child 70–80 mL/kg, infant 80–90 mL/kg, neonate 85–100 mL/kg.\\n\\nInterpret with clinical condition, hemodynamics, active bleeding, cardiac disease, and oxygen delivery.",
      "immediateRedFlags": [
        "Approaching the ABL limit while bleeding continues requires urgent blood availability and hematocrit checks.",
        "If the patient has active coronary artery disease, the target hematocrit must be kept higher (e.g., 30%)."
      ],
      "missingCriticalInformation": [
        "Patient's baseline Hematocrit (Hct) or Hemoglobin (Hb) value",
        "Patient weight and blood loss risk of the scheduled surgery"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Allowable Blood Loss (ABL) Calculation",
        "Estimated Blood Volume (EBV) by Demographics",
        "Transfusion Trigger Thresholds (Hb/Hct Limits)"
      ],
      "suggestedNextStepsGeneral": [
        "Calculate Estimated Blood Volume (EBV) based on weight and age.",
        "Determine target hematocrit (typically 21-24% for healthy adults, 30% for cardiac patients).",
        "Apply the formula: ABL = EBV * (Initial Hct - Target Hct) / Initial Hct.",
        "When blood loss approaches ABL, prepare for blood product transfusion instead of crystalloid volume."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "ABL is a mathematical guide; dynamic clinical signs (hypotension, tachycardia, oliguria, bleeding rate) dictate transfusion decisions"
      ],
      "whenToEscalate": [
        "If blood loss rapidly exceeds ABL with ongoing major hemorrhage, activate the Massive Transfusion Protocol (MTP)"
      ],
      "referencesToShow": [
        "Practice Guidelines for Perioperative Blood Management. Anesthesiology 2015. PMID: 25416285.",
        "Shander A, et al. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "maintenance_fluid",
    "category": "clinical_scenarios",
    "keywords": [
      "fluid",
      "maintenance"
    ],
    "question_tr": "Maintenance fluid",
    "question_en": "Maintenance fluid",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "4-2-1 kuralı:\\nİlk 10 kg: 4 mL/kg/saat\\nİkinci 10 kg: 2 mL/kg/saat\\n20 kg üzeri: 1 mL/kg/saat\\nÖrnek 70 kg hasta: 40 + 20 + 50 = 110 mL/saat.\\n\\nBu sadece idame sıvıdır. Açlık açığı, cerrahi kayıp, kanama, üçüncü boşluk, kalp/böbrek yetmezliği ve hemodinamik hedeflere göre ayarlanmalıdır.",
      "immediateRedFlags": [
        "Ciddi konjestif kalp yetmezliği veya anürik böbrek yetmezliği olan hastalarda 4-2-1 kuralına göre sıvı verilmesi aşırı yüklenmeye ve pulmoner ödeme yol açabilir.",
        "Pediatrik hastalarda hipotonik sıvıların yüksek hızda idame verilmesi ağır hiponatremi ve beyin ödemi riskidir."
      ],
      "missingCriticalInformation": [
        "Hastanın açlık süresi ve bu süredeki tahmini sıvı açığı",
        "Hastanın böbrek ve kardiyak fonksiyon durumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "4-2-1 Sıvı Hesaplama Kuralı (Holiday-Segar Metodu)",
        "İntraoperatif Sıvı Açığı ve Cerrahi Kayıp Hesaplama",
        "Hedefe Yönelik Sıvı Tedavisi (GDFT) İlkeleri"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın kilosuna göre 4-2-1 saatlik idame hızını hesaplayın.",
        "Hastanın aç kaldığı süre (saat) * saatlik idame hızı formülüyle NPO açığını bulun.",
        "NPO açığını operasyonun ilk 3 saatinde kademeli olarak (yarısı 1. saatte, kalan yarısı 2. ve 3. saatte) tamamlayın.",
        "Cerrahi travma derecesine göre ek sıvı (hafif: 2 mL/kg/sa, orta: 4 mL/kg/sa, ağır: 6 mL/kg/sa) ekleyin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Çocuklarda idame sıvı olarak kesinlikle hipotonik solüsyonlar yerine izotonik Dengeli Kristalloidler (örn. İzolete, Plazmalayt) tercih edilmelidir"
      ],
      "whenToEscalate": [
        "Sıvı replasmanına rağmen gelişen oligüri veya hipotansiyonda hedefe yönelik sıvı yönetimi (GDFT) ve invaziv monitörizasyon"
      ],
      "referencesToShow": [
        "Holiday MA, Segar WE. PMID: 13410557.",
        "Practice Guidelines for Perioperative Fluid Therapy. 2018. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "4-2-1 rule:\\nFirst 10 kg: 4 mL/kg/h\\nSecond 10 kg: 2 mL/kg/h\\nEach kg above 20 kg: 1 mL/kg/h\\nExample for 70 kg: 40 + 20 + 50 = 110 mL/h.\\n\\nThis is maintenance only. Adjust for fasting deficit, surgical losses, bleeding, third spacing, cardiac/renal disease, and hemodynamic goals.",
      "immediateRedFlags": [
        "In severe congestive heart failure or anuric renal failure, standard 4-2-1 rate maintenance can trigger volume overload and pulmonary edema.",
        "In pediatric patients, high-rate hypotonic maintenance fluid infusion carries high risk of acute hyponatremia and cerebral edema."
      ],
      "missingCriticalInformation": [
        "Patient's NPO (fasting) duration and estimated fluid deficit",
        "Patient's baseline renal and cardiac status"
      ],
      "likelyClinicalCategoriesToConsider": [
        "4-2-1 Fluid Dosing Rule (Holiday-Segar Method)",
        "Intraoperative Fluid Deficit and Surgical Third-Space Loss",
        "Goal-Directed Fluid Therapy (GDFT) Concepts"
      ],
      "suggestedNextStepsGeneral": [
        "Calculate 4-2-1 hourly maintenance rate based on patient weight.",
        "Determine NPO deficit: Fasting time (hours) * hourly maintenance rate.",
        "Replenish NPO deficit gradually during the first 3 hours of anesthesia (50% in 1st hour, 25% in 2nd and 3rd hours).",
        "Add third-space surgical loss based on incision severity (minor: 2 mL/kg/h, moderate: 4 mL/kg/h, severe: 6 mL/kg/h)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Always prefer isotonic Balanced Crystalloids (e.g. Isolyte, Plasmalyte) over hypotonic solutions for pediatric maintenance to avoid hyponatremia"
      ],
      "whenToEscalate": [
        "For persistent oliguria or hypotension despite calculated volume replacement, transition to invasive monitoring and GDFT"
      ],
      "referencesToShow": [
        "Holiday MA, Segar WE. PMID: 13410557.",
        "Practice Guidelines for Perioperative Fluid Therapy. 2018. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "perioperative_hypertension",
    "category": "clinical_scenarios",
    "keywords": [
      "basıncı",
      "hipertansiyon",
      "hypertension",
      "kan",
      "perioperatif",
      "perioperative",
      "tansiyon",
      "yüksek"
    ],
    "question_tr": "Perioperatif hipertansiyon",
    "question_en": "Kan basıncı yüksek",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Önce ölçümü doğrula ve hipertansiyonun nedenini ara. En sık nedenler: yetersiz anestezi/analjezi, entübasyon veya cerrahi uyarı, hiperkapni, hipoksi, mesane distansiyonu, ağrı, preeklampsi, feokromositoma, ilaç kesilmesi veya intrakraniyal basınç artışı.\\n\\nYaklaşım:\\n1. Kan basıncı ölçümünü doğrula.\\n2. Oksijenasyon, ventilasyon ve ETCO₂’yi kontrol et.\\n3. Anestezi derinliği ve analjeziyi optimize et.\\n4. Cerrahi uyarı veya mesane distansiyonu gibi düzeltilebilir nedenleri gider.\\n5. Devam ederse klinik duruma göre esmolol, labetalol, nitrogliserin, nitroprussid veya hidralazin düşünülebilir.\\n6. Akut uç organ hasarı, nörolojik bulgu, miyokard iskemisi veya aort diseksiyonu şüphesinde acil yaklaşım gerekir.",
      "immediateRedFlags": [
        "Sistolik kan basıncının >=180 mmHg veya diyastolik >=110 mmHg ile birlikte yeni başlayan miyokard iskemisi, aort diseksiyonu veya nörolojik bulguların olması",
        "Açıklanamayan akut akciğer ödemi ve solunum yetmezliği"
      ],
      "missingCriticalInformation": [
        "Hastanın bazal kan basıncı ve kronik kullandığı antihipertansif ilaçlar",
        "İntraoperatif anestezi derinliği (end-tidal volatil anestezik konsantrasyonu - MAC) ve analjezi seviyesi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Perioperatif Akut Hipertansif Kriz",
        "Yetersiz Anestezi ve Cerrahi Ağrı Yönetimi",
        "Feokromositoma ve Tiroid Fırtınası Ayırıcı Tanısı"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle tansiyon ölçümünü tekrarlayın veya invaziv arter hattının kalibrasyonunu yapın.",
        "Anestezi derinliğini artırın ve fentanil/remifentanil ile analjeziyi optimize edin.",
        "İlaç tedavisi için Esmolol (0.5 mg/kg IV yavaş bolus ve ardından 50-200 mcg/kg/dk infüzyon) veya Labetalol (5-20 mg IV) uygulayın.",
        "Gerektiğinde Nitrogliserin (0.5-5 mcg/kg/dk) veya Nitroprussid infüzyonuna geçin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Ortalama Arter Basıncı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Efedrin Monografı"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Hipertansiyonu doğrudan tedavi etmeden önce mutlaka yetersiz anestezi, mesane distansiyonu ve hipoksi/hiperkapniyi dışlayın"
      ],
      "whenToEscalate": [
        "Akut uç organ hasarı şüphesinde invaziv arter izlemi, sürekli vazodilatör infüzyonu ve acil yoğun bakım transferi"
      ],
      "referencesToShow": [
        "2020 ACC/AHA Guidelines for the Management of Patients with Hypertension. Circulation 2020. PMID: 32986423.",
        "Whelton PK, et al. Anesthesiology 2018. PMID: 29016373."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "First confirm the measurement and search for the cause. Common causes include inadequate anesthesia or analgesia, intubation/surgical stimulation, hypercapnia, hypoxia, bladder distension, pain, preeclampsia, pheochromocytoma, drug withdrawal, or increased intracranial pressure.\\n\\nApproach:\\n1. Confirm BP measurement.\\n2. Check oxygenation, ventilation, and ETCO₂.\\n3. Optimize anesthetic depth and analgesia.\\n4. Correct reversible causes such as surgical stimulation or bladder distension.\\n5. Consider esmolol, labetalol, nitroglycerin, nitroprusside, or hydralazine depending on the clinical context.\\n6. Suspected end-organ injury, neurologic deficit, myocardial ischemia, or aortic dissection requires emergency management.",
      "immediateRedFlags": [
        "Systolic BP >=180 mmHg or Diastolic BP >=110 mmHg with acute myocardial ischemia, aortic dissection, or new neurologic deficit.",
        "Unexplained acute pulmonary edema and respiratory failure."
      ],
      "missingCriticalInformation": [
        "Patient's baseline blood pressure and chronic antihypertensive medication history",
        "Intraoperative anesthetic depth (MAC level) and analgesia status"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Perioperative Acute Hypertensive Crisis",
        "Inadequate Anesthetic Depth and Pain Control",
        "Pheochromocytoma and Thyroid Storm Differential Diagnosis"
      ],
      "suggestedNextStepsGeneral": [
        "First, repeat the BP measurement or calibrate the invasive arterial line.",
        "Deepen anesthesia (increase volatile agent) and optimize analgesia with Fentanyl/Remifentanil.",
        "For drug therapy, administer Esmolol (0.5 mg/kg slow IV bolus, then 50-200 mcg/kg/min) or Labetalol (5-20 mg IV).",
        "Use Nitroglycerin (0.5-5 mcg/kg/min) or Nitroprusside if needed."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine Monograph"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Always exclude inadequate anesthesia depth, bladder distension, and hypoxia/hypercapnia before treating hypertension"
      ],
      "whenToEscalate": [
        "In case of suspected acute end-organ damage, start invasive arterial monitoring, continuous vasodilator infusion, and transfer to ICU"
      ],
      "referencesToShow": [
        "2020 ACC/AHA Guidelines for the Management of Patients with Hypertension. Circulation 2020. PMID: 32986423.",
        "Whelton PK, et al. Anesthesiology 2018. PMID: 29016373."
      ],
      "safetyLevel": "urgent"
    }
