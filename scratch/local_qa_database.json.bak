      "var0"
    ],
    "question_tr": "Lipid tedavisinin kontrendikasyonları nelerdir?",
    "question_en": "What are the contraindications of lipid rescue?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "⚠️ Akut kardiyak arrest veya ağır nörotoksisite ile seyreden LAST durumunda lipid tedavisinin hiçbir mutlak kontrendikasyonu yoktur. Yumurta veya soya alerjisi göreceli bir kontrendikasyondur ancak hayati tehlike anında göz ardı edilmelidir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
