  {
    "id": "clinical_followup_anticoagulant_regional_how_0",
    "category": "clinical_followups",
    "keywords": [
      "anticoagulant",
      "antikoagülan",
      "clinical_followup_anticoagulant_regional_how_0",
      "epidural",
      "followup",
      "hematom",
      "hematoma",
      "spinal",
      "var0"
    ],
    "question_tr": "Antikoagülan sonrası spinal blok zamanlaması nasıl olmalıdır?",
    "question_en": "What is the spinal block timing after anticoagulants?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🛡️ ASRA kılavuzlarına göre: 1. Profilaktik Düşük Molekül Ağırlıklı Heparin (LMWH - Enoksaparin) sonrası en az 12 saat, 2. Terapötik LMWH sonrası en az 24 saat beklenmelidir. Kateter çekildikten sonra LMWH dozu en az 4 saat geciktirilmelidir. Klopidogrel için ise 5-7 gün beklenmelidir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🛡️ According to ASRA guidelines: 1. Wait at least 12 hours after prophylactic LMWH (Enoxaparin). 2. Wait at least 24 hours after therapeutic LMWH before block placement or catheter removal. Re-dose LMWH at least 4 hours after catheter removal. Wait 5-7 days for Clopidogrel.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
