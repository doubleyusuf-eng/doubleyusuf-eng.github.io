      "doNotMiss": [
        "Ciddi aort darlığı olan hastalarda spinal anestezinin yapacağı ani SVR düşüşünün koroner perfüzyonu durdurup areste yol açabileceğini"
      ],
      "whenToEscalate": [
        "Hastada koagülopati şüphesi varsa veya ASRA süreleri karşılanmıyorsa, spinal anesteziyi iptal edin ve genel anesteziye geçin"
      ],
      "referencesToShow": [
        "ASRA Antithrombotic Guidelines 2025.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Spinal anesthesia (subarachnoid block) involves injecting local anesthetic into the subarachnoid space. Review these safety criteria strictly before the procedure:\n\n1. Indication and Consent: Confirm procedure type, duration, and explicit patient consent.\n2. Absolute Contraindications: Patient refusal, localized infection at the needle entry site, uncorrected coagulopathy (exceeding ASRA limits), severe uncontrolled hypovolemia/shock, suspected increased intracranial pressure (ICP), and fixed cardiac output states (e.g. severe aortic or mitral stenosis).\n3. Anticoagulation: Review anticoagulant and antiplatelet discontinuation schedules strictly against ASRA 2025 guidelines.\n4. Post-Procedure Monitoring: Sensory/motor block level, blood pressure (spinal hypotension), heart rate (bradycardia), respiratory function, nausea/vomiting, and urinary retention.\n5. Preparation: Ensure patent IV access, resuscitation equipment, and vasopressors (ephedrine, phenylephrine, atropine) are immediately available.",
      "immediateRedFlags": [
        "Active localized skin infection at the planned puncture site (meningitis risk).",
        "Severe uncontrolled hypovolemia or shock (sympathectomy will cause profound cardiovascular collapse).",
        "Signs of elevated ICP (papilledema, projectile vomiting, severe headache)."
      ],
      "missingCriticalInformation": [
        "The exact time of the last dose of any anticoagulant/antiplatelet agent",
        "Presence and severity of stenotic valvular heart disease (e.g., aortic stenosis)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Neuraxial Block Safety Criteria",
        "Spinal Contraindication Screening",
        "Anticoagulant Stopping Times"
      ],
      "suggestedNextStepsGeneral": [
        "Compare the patient's coagulation parameters (platelets, INR, aPTT) and anticoagulant timing directly against ASRA guidelines.",
        "Draw up and label emergency vasopressors (Atropine, Ephedrine, Phenylephrine) before performing the block.",
        "Check blood pressure every 2-3 minutes after spinal placement for the first 15 minutes."
      ],
      "relatedAlgorithms": [
        {
          "id": "spinal_anesthesia",
          "titleTr": "Spinal Anesthesia"
        },
        {
          "id": "neuraxial_safety",
          "titleTr": "Neuraxial Safety"
        }
      ],
      "relatedCalculators": [
        {
          "id": "anticoagulation_table",
          "titleTr": "Anticoagulation Table"
        },
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "bupivacaine",
          "titleTr": "Bupivacaine"
        },
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine"
        },
        {
          "id": "phenylephrine",
          "titleTr": "Phenylephrine"
        },
        {
          "id": "atropine",
          "titleTr": "Atropine"
        }
      ],
      "doNotMiss": [
        "Severe aortic stenosis is a critical contraindication; the sudden fall in SVR will severely impair coronary perfusion and cause arrest"
      ],
      "whenToEscalate": [
        "If the patient has uncorrected coagulopathy or does not meet ASRA stopping times, cancel the spinal block and convert to general anesthesia"
      ],
      "referencesToShow": [
        "ASRA Antithrombotic Guidelines 2025.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
