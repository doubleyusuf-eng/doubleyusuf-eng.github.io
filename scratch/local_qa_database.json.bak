    "question_tr": "Lipid",
    "question_en": "Intralipid",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "%20 lipid emülsiyon için pratik yaklaşım:\\nBolus: 1.5 mL/kg IV.\\nİnfüzyon: 0.25 mL/kg/dk.\\n\\nStabilite sağlanmazsa bolus tekrarlanabilir ve infüzyon artırılabilir.\\nToplam maksimum doz sınırına dikkat edilmelidir. ASRA checklist toplam lipid dozunun 12 mL/kg’ı aşmamasını önerir. Resüsitasyon standart ACLS’den farklıdır; yüksek doz adrenalin ve vazopressinden kaçınılır.",
      "immediateRedFlags": [
        "LAST sırasında gelişen asistoli veya ventriküler fibrilasyon durumunda standart ACLS kılavuzları modifiye edilmelidir.",
        "Lipid emülsiyon tedavisinin geciktirilmesi, kardiyak kollaps riskini artırır."
      ],
      "missingCriticalInformation": [
        "Hastanın tam kilosu (%20 lipid emülsiyon hacminin tam hesabı için)",
        "Toplam enjekte edilen lokal anestezik miktarı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "%20 Lipid Emülsiyonu (Intralipid) Kurtarma Mekanizması",
        "LAST Resüsitasyonunda Modifiye ACLS Protokolü",
        "Lipid Emülsiyonu Maksimum Doz Sınırları"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle %100 O₂ verin ve havayolunu güvenceye alın.",
        "%20 Lipid Emülsiyon: 1.5 mL/kg IV bolus (yaklaşık 100 mL, 1 dakikada) uygulayın.",
        "Hemen ardından 0.25 mL/kg/dk (yaklaşık 15-20 mL/dk) sürekli infüzyon başlatın.",
        "Hemodinamik stabilite sağlanana kadar infüzyonu sürdürün, en az 15 dakika devam edin."
      ],
      "relatedAlgorithms": [
