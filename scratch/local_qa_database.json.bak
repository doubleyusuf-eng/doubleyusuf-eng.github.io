  {
    "id": "sedation_capnography_need",
    "category": "clinical_scenarios",
    "keywords": [
      "capnography",
      "derinleşti",
      "kapnografi",
      "need",
      "sedasyon",
      "sedation"
    ],
    "question_tr": "Sedasyon derinleşti",
    "question_en": "Capnography sedasyon",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Orta-derin sedasyonda solunum depresyonu, hipoventilasyon ve obstrüksiyon SpO₂ düşmeden önce kapnografi ile fark edilebilir. Oksijen verilen hastada pulse oksimetri geç uyarı verebilir. Kapnografi özellikle derin sedasyon, obezite/OSAS, prone veya erişimi zor pozisyon, endoskopi, MRI/NORA ve opioid/benzodiazepin kombinasyonlarında çok değerlidir. Kapnografi yoksa sedasyon riski artar ve klinik solunum izlemi sıkılaştırılmalıdır.",
      "immediateRedFlags": [
        "Sedasyon sırasında kapnografi dalgasının (EtCO2) düzleşmesi veya kaybolması (apne veya obstrüksiyon).",
        "Oksijen alan hastada EtCO2 dalgası bozulmasına rağmen SpO₂'nin hâlâ %98-100 görünmesi (yanıltıcı güvenlik hissi!)."
      ],
      "missingCriticalInformation": [
        "Kullanılan sedasyon cihazında mikroakım (microstream) kapnografi örnekleme hattının varlığı",
        "Hastanın ek risk faktörleri (ciddi KOAH veya uyku apnesi varlığı)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Sedasyonda Kapnografi Kullanım Standartları",
        "Pulse Oksimetrenin Gecikme Süreleri ve Oksijen Maskelemesi",
        "Girişimsel Sedasyon Monitörizasyon Kılavuzu"
      ],
      "suggestedNextStepsGeneral": [
        "Sedasyon uygulanan tüm hastalarda (özellikle orta ve derin sedasyon) EtCO₂ monitörizasyonunu rutin uygulayın.",
        "Hastaya ilave oksijen veriliyorsa solunum izlemini yalnızca SpO₂'ye dayandırmayın.",
        "Mikroakım kapnografik nazal kanülleri kullanarak spontan solunumdaki EtCO₂ dalgasını kesintisiz izleyin.",
        "Dalgada genlik azalması veya düzleşme görür görmez hastayı uyarın ve çene itme manevrası yapın."
      ],
      "relatedAlgorithms": [
        {
          "id": "procedural_sedation",
          "titleTr": "Girişimsel Sedasyon Algoritması"
        },
        {
          "id": "nora_safety",
          "titleTr": "NORA Güvenlik Protokolü"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        },
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monografı"
        },
        {
          "id": "fentanyl",
          "titleTr": "Fentanil Monografı"
        },
        {
          "id": "dexmedetomidine",
          "titleTr": "Dekmedetomidin Monografı"
        }
      ],
      "doNotMiss": [
        "Yüksek akım oksijen alan hastada solunum tamamen dursa dahi pulse oksimetrinin SpO₂ düşüşünü 5-8 dakikaya kadar geciktirebileceğini"
      ],
      "whenToEscalate": [
        "Kapnografide persistan apne veya obstrüksiyon dalgası düzeltici manevralara yanıt vermezse sedasyonu sonlandırın ve maske-ventilasyonuna başlayın"
      ],
      "referencesToShow": [
        "ASA Standards for Basic Anesthetic Monitoring. 2020. www.asahq.org.",
        "Use of Capnography in Sedation. Eur J Anaesthesiol 2015."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "During moderate-to-deep sedation, capnography can detect hypoventilation, respiratory depression, and obstruction before SpO₂ falls. Pulse oximetry may be delayed when supplemental oxygen is used. Capnography is especially valuable in deep sedation, obesity/OSA, prone or difficult access positions, endoscopy, MRI/NORA, and opioid-benzodiazepine combinations. If capnography is unavailable, sedation risk increases and clinical respiratory monitoring must be intensified.",
      "immediateRedFlags": [
        "Flat capnography trace (apnea or complete airway obstruction) under deep sedation.",
        "SpO₂ remaining at 100% despite severe bradypnea due to high flow oxygen masking."
      ],
      "missingCriticalInformation": [
        "Availability of microstream capnography sampling lines suitable for non-intubated patients",
        "History of severe hypercapnic respiratory drive impairment (e.g. severe COPD)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Standards of Capnography During Procedural Sedation",
        "Limitations of Pulse Oximetry Under Supplemental Oxygen",
        "Airway Complication Prophylaxis in Gastrointestinal Endoscopy"
      ],
      "suggestedNextStepsGeneral": [
        "Always apply continuous end-tidal CO₂ (EtCO₂) monitoring for moderate-to-deep sedation procedures.",
        "Use dedicated nasal prongs with a microstream sampling port for non-intubated patients.",
        "Never rely solely on pulse oximetry when supplemental oxygen is actively being delivered.",
        "Promptly apply jaw-thrust or verbal stimulation if EtCO₂ waveforms diminish in amplitude."
      ],
      "relatedAlgorithms": [
        {
          "id": "procedural_sedation",
          "titleTr": "Procedural Sedation Algorithm"
        },
        {
          "id": "nora_safety",
          "titleTr": "NORA Safety Protocol"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        },
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monograph"
        },
        {
          "id": "fentanyl",
          "titleTr": "Fentanyl Monograph"
        },
        {
          "id": "dexmedetomidine",
          "titleTr": "Dexmedetomidine Monograph"
        }
      ],
      "doNotMiss": [
        "Pre-oxygenation and supplemental oxygen provide an oxygen reservoir that prevents SpO₂ drops but masks acute hypoventilation for several minutes"
      ],
      "whenToEscalate": [
        "If progressive hypoventilation or flatline capnogram does not respond to physical stimulation, immediately assist ventilation with a bag-valve-mask"
      ],
      "referencesToShow": [
        "ASA Standards for Basic Anesthetic Monitoring. 2020. www.asahq.org.",
        "Use of Capnography in Sedation. Eur J Anaesthesiol 2015."
      ],
      "safetyLevel": "elective"
    }
