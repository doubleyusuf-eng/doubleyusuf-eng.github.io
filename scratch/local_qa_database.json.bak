  {
    "id": "clinical_followup_malignant_hyperthermia_why_0",
    "category": "clinical_followups",
    "keywords": [
      "clinical_followup_malignant_hyperthermia_why_0",
      "followup",
      "hipertermi",
      "hyperthermia",
      "malign",
      "malignant",
      "mh",
      "var0",
      "why"
    ],
    "question_tr": "Neden volatil ajanları kapatmalıyım?",
    "question_en": "Why should i stop volatile agents?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 Volatil ajanlar ve süksinilkolin, Malign Hipertermi duyarlı hastalarda ryanodine reseptörlerini (RYR1) uyararak sarkoplazmik retikulumdan kontrolsüz kalsiyum salınımına neden olur. Bu da şiddetli kas kontraktürüne, hipermetabolizmaya ve öldürücü ısı yükselmesine yol açar. Tetikleyicilerin derhal kesilmesi kalsiyum birikimini durdurmak için ilk şarttır.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 Volatile agents and succinylcholine stimulate ryanodine receptors (RYR1) in MH-susceptible individuals, causing uncontrolled calcium release from the sarcoplasmic reticulum. This leads to massive muscle rigidity, hypermetabolism, and fatal hyperthermia. Discontinuing triggers immediately stops further calcium release cascade.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    }
  },
