  {
    "id": "clinical_followup_cico_crisis_contraindications_0",
    "category": "clinical_followups",
    "keywords": [
      "airway",
      "cico",
      "clinical_followup_cico_crisis_contraindications_0",
      "contraindications",
      "entübasyon",
      "followup",
      "havayolu",
      "intubasyon",
      "maske",
      "var0"
    ],
    "question_tr": "Krikotiroidotomi kimlere uygulanmaz?",
    "question_en": "What are the contraindications of cricothyroidotomy?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "⚠️ Akut hayati tehdit oluşturan CICO krizinde mutlak kontrendikasyon yoktur. Ancak anatomik bozukluk, trakeal transeksiyon veya laringeal kırık şüphesinde cerrahi girişim trakeostomiye kaydırılmalıdır. Çocuklarda (<8-12 yaş) iğne krikotiroidotomi anatomik nedenlerle cerrahiye tercih edilmelidir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "⚠️ There are no absolute contraindications in an absolute CICO rescue scenario. However, in cases of tracheal transection or severe laryngeal trauma, formal tracheostomy is preferred. In pediatric patients (<8-12 years), needle cricothyroidotomy is preferred over surgical incision due to anatomy.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
