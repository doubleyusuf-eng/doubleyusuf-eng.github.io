  {
    "id": "clinical_followup_anaphylaxis_rescue_how_0",
    "category": "clinical_followups",
    "keywords": [
      "alerji",
      "allergy",
      "anafilaksi",
      "anaphylaxis",
      "clinical_followup_anaphylaxis_rescue_how_0",
      "followup",
      "sok",
      "var0",
      "şok"
    ],
    "question_tr": "Adrenalin anafilakside nasıl dozlanır?",
    "question_en": "How to dose epinephrine in anaphylaxis?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "💉 Kas içi (IM) doz: 0.5 mg (1:1000 formdan 0.5 mL) anterolateral uyluğa uygulanır, her 5-15 dakikada bir tekrarlanabilir. Damar yolu varsa (IV bolus): İntraoperatif anestezide ağır şok için 10-50 mcg titre edilerek IV bolus verilir. Kardiyak arrest durumunda standart 1 mg IV uygulanır.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "💉 Intramuscular (IM) dose: Administer 0.5 mg (0.5 mL of 1:1000 concentration) into the anterolateral thigh, repeat every 5-15 minutes as needed. Intravenous (IV) dose for intraoperative anaphylactic shock: Titrate IV boluses of 10-50 mcg. In case of cardiac arrest, administer standard 1 mg IV.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
