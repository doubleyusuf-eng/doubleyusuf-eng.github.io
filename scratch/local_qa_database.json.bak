  {
    "id": "clinical_followup_ponv_rescue_why_0",
    "category": "clinical_followups",
    "keywords": [
      "bulantı",
      "clinical_followup_ponv_rescue_why_0",
      "followup",
      "kusma",
      "nausea",
      "ponv",
      "rescue",
      "var0",
      "vomiting",
      "why"
    ],
    "question_tr": "Neden kombine profilaksi tekli profilaksiden üstündür?",
    "question_en": "Why is combination prophylaxis superior to monotherapy?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 Bulantı ve kusma fizyolojisi; serotonin (5-HT3), dopamin (D2), histamin (H1) ve nörokinin (NK1) dahil olmak üzere birden fazla reseptör yolağını içerir. Farklı sınıflardan iki veya daha fazla ilacın kombine edilmesi (örn. Ondansetron + Deksametazon), tek bir ilaca göre belirgin olarak daha yüksek etkinlik sağlar.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 The physiology of nausea and vomiting involves multiple receptor pathways, including serotonin (5-HT3), dopamine (D2), histamine (H1), and neurokinin (NK1). Combining two or more agents from different classes (e.g. Ondansetron + Dexamethasone) achieves synergistic blockade and far superior clinical outcomes.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
