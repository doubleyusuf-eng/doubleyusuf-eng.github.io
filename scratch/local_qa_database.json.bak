      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "Travmalı hastada kaza anından sonra aç geçen sürenin anlamsız olduğunu, çünkü ağrı ve sempatik deşarj nedeniyle mide boşalmasının durduğunu"
      ],
      "whenToEscalate": [
        "Hastada regürjitasyon gelişirse derhal havayolunu aspire edin, entübe edip kafı şişirin, %100 O2 ile ventile edin ve bronkospazmı tedavi edin"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Preoperative Fasting. 2023.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Adherence to standard preoperative fasting (NPO) guidelines (6-8 hours for solids, 2 hours for clear liquids) does not guarantee an empty stomach. The risk of a full stomach and subsequent pulmonary aspiration is elevated in emergency surgeries, acute trauma (pain and anxiety halt gastric motility), pregnancy (especially after 20 weeks), morbid obesity, diabetic gastroparesis, bowel obstruction, active nausea/vomiting, chronic opioid or sedative use, GLP-1 agonists, severe GERD, and acute severe pain. Management: If aspiration risk is high, perform a rapid sequence induction (RSI) for general anesthesia, utilize a head-up position, ensure robust suction is immediately functional, have an experienced intubator manage the airway, and perform a bedside gastric ultrasound if possible. For cases planned under sedation, avoid unintentional deep sedation.",
      "immediateRedFlags": [
        "Active projectile vomiting or silent regurgitation during induction of anesthesia.",
        "Visible food or fluid residues in the oropharynx prior to securing the airway.",
        "Rapidly progressive hypoxemia and severe bronchospasm following suspected aspiration."
      ],
      "missingCriticalInformation": [
        "The exact composition and volume of the last meal (high-fat meals significantly delay gastric emptying)",
        "For trauma patients, the exact time of the injury relative to their last meal (digestion ceases at the moment of trauma)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Delayed Gastric Emptying",
        "Full Stomach Management",
        "Airway Aspiration Prevention"
      ],
      "suggestedNextStepsGeneral": [
        "Screen the patient preoperatively for delayed gastric emptying risk factors.",
        "Treat all trauma, late-pregnancy, and emergency surgical patients as having a full stomach.",
        "Perform an RSI utilizing propofol followed by succinylcholine or high-dose rocuronium.",
        "For monitored anesthesia care (MAC), keep sedation light to preserve protective airway reflexes."
      ],
      "relatedAlgorithms": [
        {
          "id": "aspiration_risk",
          "titleTr": "Aspiration Risk"
        },
        {
          "id": "rsi",
          "titleTr": "RSI Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "In trauma patients, the NPO duration post-injury is irrelevant because severe pain and sympathetic tone freeze gastric emptying"
      ],
      "whenToEscalate": [
        "If active regurgitation occurs, immediately place the patient head-down, apply oral/pharyngeal suction, intubate, inflate the cuff, and administer 100% oxygen"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Preoperative Fasting. 2023.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    }
