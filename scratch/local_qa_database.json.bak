    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Duke Aktivite Durum İndeksi (DASI), hastaların günlük yaşam aktiviteleri üzerinden fonksiyonel kapasitelerini tahmin etmede kullanılan pratik ve geçerliliği kanıtlanmış bir ankettir. Ankette kişisel bakım, yürüme, merdiven çıkma, bahçe işleri, ev işleri, cinsel aktivite ve eğlence/spor aktiviteleri gibi 12 başlık sorgulanır. Her aktivitenin MET değerine göre bir puanı vardır. Düşük DASI skoru (< 34 puan, yaklaşık 4 MET'e eşdeğerdir), düşük fonksiyonel kapasiteyi ve dolayısıyla perioperatif kardiyak olay ve mortalite riskinde artışı gösterir. DASI skoru tek başına cerrahiyi iptal ettirmez; ancak EKG, ekokardiyografi, biyobelirteç ihtiyacı ve invaziv izlem planını şekillendirmek için cerrahi risk ve RCRI/NSQIP risk skorlarıyla birlikte yorumlanmalıdır.",
      "immediateRedFlags": [
        "DASI skoru çok düşük (< 15 puan) olan ve en ufak kişisel bakımda bile dispne/anjina yaşayan hastalar.",
        "Düşük efor kapasitesine eşlik eden dekompanse kalp yetmezliği bulguları.",
        "Hafif yürüyüşle tetiklenen senkop veya presenkop öyküsü."
      ],
      "missingCriticalInformation": [
        "Hastanın 12 DASI sorusuna verdiği net bireysel yanıtlar",
        "Hastanın koroner arter hastalığı veya sol ventrikül fonksiyon durumu (EF değeri)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "DASI Skoru ve METS Tahmini",
        "Preoperatif Efor Kapasitesi",
        "Kardiyak Risk Stratifikasyonu"
      ],
      "suggestedNextStepsGeneral": [
        "Hastaya DASI anketini uygulayarak toplam skoru hesaplayın.",
        "DASI skoru < 34 olan hastaları artmış perioperatif kardiyak risk grubu olarak sınıflandırın.",
        "Düşük efor kapasitesi olan hastalarda preoperatif EKG çekilmesini sağlayın.",
        "Büyük ortopedik veya vasküler cerrahi öncesi efor kapasitesini optimize etmek için prehabilitasyon düşünün."
      ],
      "relatedAlgorithms": [
        {
          "id": "geriatric_anesthesia",
          "titleTr": "Geriyatrik Anestezi"
        },
        {
          "id": "myocardial_ischemia",
          "titleTr": "Miyokard İskemisi Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "DASI'nin subjektif METS tahminine göre perioperatif kardiyak olayları öngörmede çok daha tutarlı ve objektif olduğunu"
      ],
      "whenToEscalate": [
        "DASI skoru aşırı düşük olan ve aktif kardiyak semptomu olan hastaları stabilizasyon için acil kardiyoloji kliniğine sevk edin"
      ],
      "referencesToShow": [
        "Duke Activity Status Index Validation Studies. 1989.",
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "The Duke Activity Status Index (DASI) is a validated, 12-item self-administered questionnaire used to estimate functional capacity based on daily physical activities (such as personal care, walking, climbing stairs, housework, sexual activity, and recreational sports). Each item has a specific weight based on metabolic cost. A low DASI score (< 34 points, roughly corresponding to < 4 METs) correlates with poor functional capacity and is a strong predictor of perioperative myocardial injury, complications, and mortality. DASI should not be used in isolation to cancel surgery; rather, it should be integrated with surgical risk, active symptoms, RCRI/NSQIP risk scores, ECG/Echo requirements, and biomarkers.",
      "immediateRedFlags": [
        "Extremely low DASI score (< 15 points) with dyspnea or chest pain during basic personal care.",
        "Poor exercise capacity accompanied by signs of decompensated heart failure.",
        "Syncope or near-syncope triggered by minor physical exertion."
      ],
      "missingCriticalInformation": [
        "The patient's precise answers to the 12 DASI questions",
        "The patient's history of coronary artery disease or left ventricular ejection fraction (EF)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "DASI Score and METS Estimation",
        "Preoperative Exercise Capacity",
        "Cardiac Risk Stratification"
      ],
      "suggestedNextStepsGeneral": [
        "Administer the DASI questionnaire to calculate the patient's functional capacity score.",
        "Classify patients with a DASI score < 34 as having elevated perioperative risk.",
        "Ensure a preoperative ECG is completed for patients with low DASI scores.",
        "Consider prehabilitation for patients with poor exercise capacity prior to major orthopedic/vascular cases."
      ],
      "relatedAlgorithms": [
        {
          "id": "geriatric_anesthesia",
          "titleTr": "Geriatric Anesthesia"
        },
        {
          "id": "myocardial_ischemia",
          "titleTr": "Myocardial Ischemia"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "DASI provides a much more consistent and objective estimation of functional capacity than unstructured clinical METS estimation"
      ],
      "whenToEscalate": [
        "Postpone surgery and refer patients with extremely low DASI scores and active cardiorespiratory symptoms to cardiology for urgent evaluation"
      ],
      "referencesToShow": [
        "Duke Activity Status Index Validation Studies. 1989.",
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024."
      ],
      "safetyLevel": "elective"
    }
  },
