  {
    "id": "ebus_rigid_bronchoscopy",
    "category": "clinical_scenarios",
    "keywords": [
      "anestezi",
      "bronchoscopy",
      "bronkoskopi",
      "ebus",
      "rigid",
      "rijit"
    ],
    "question_tr": "Ebus",
    "question_en": "Ebus anestezi",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "EBUS ve rijit bronkoskopide havayolu paylaşılır; hipoksemi, hiperkapni, kanama, bronkospazm ve hava yolu obstrüksiyonu riski vardır. Rijit bronkoskopi genellikle derin anestezi ve kas gevşemesi gerektirir; ventilasyon cerrah/pulmonologla koordine edilir. Büyük hava yolu lezyonu varsa indüksiyon sonrası obstrüksiyon kötüleşebilir. Kanama veya obstrüksiyon durumunda acil plan, tüp/jet ventilasyon ekipmanı ve cerrahi destek önceden hazırlanmalıdır.",
      "immediateRedFlags": [
        "Cerrahi manipülasyon sırasında trakeobronşiyal duvarda masif yırtılma veya arter ponksiyonuna bağlı fışkıran kanama.",
        "İndüksiyon sonrasında mediastinal basıya bağlı olarak ventilasyonun tamamen imkansız hale gelmesi.",
        "Rijit skop yerleşimi sonrasında gelişen ani derin hipoksemi (SpO2 < %80)."
      ],
      "missingCriticalInformation": [
        "Trakeobronşiyal lezyonun tam boyutu, yeri ve havayolu lümenini ne oranda daralttığı",
        "İşlem sırasında jet ventilasyon kullanılıp kullanılmayacağı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "EBUS ve Rijit Bronkoskopi Anestezisi",
        "Paylaşılan Havayolunda Ventilasyon Teknikleri",
        "Akut Endobronşiyal Kanama Kontrolü"
      ],
      "suggestedNextStepsGeneral": [
        "İşlem öncesi pulmonolog ile solunumsal hedefleri ve acil durum planını netleştirin.",
        "Rijit bronkoskopi için derin anestezi (TIVA tercih edilir) ve tam nöromüsküler blok uygulayın.",
        "Masif kanama riskine karşı yedek çift lümenli tüp, bronşiyal bloker veya acil cerrahi ekibi hazır bulundurun.",
        "Sıkışan lümen varlığında indüksiyonu spontan solunumu koruyarak (örn. inhalasyon indüksiyonu veya ketamin/dekmedetomidin) yapmayı değerlendirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        },
        {
          "id": "bronchospasm",
          "titleTr": "Bronkospazm Tedavi Kılavuzu"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        },
        {
          "id": "remifentanil",
          "titleTr": "Remifentanil Monografı"
        },
        {
          "id": "rocuronium",
          "titleTr": "Roküronyum Monografı"
        },
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol Monografı"
        }
      ],
      "doNotMiss": [
        "Rijit bronkoskopide ventilasyonun skopun yan portu üzerinden yapıldığını ve sızıntıların ventilasyonu bozabileceğini"
      ],
      "whenToEscalate": [
        "Masif endobronşiyal kanama durumunda hastayı derhal kanayan akciğer tarafı altta kalacak şekilde lateral pozisyona getirin, tek akciğer ventilasyonuna geçin veya rijit skop ile tamponad yapın"
      ],
      "referencesToShow": [
        "Anesthesia for Rigid Bronchoscopy. Annals of the American Thoracic Society 2018.",
        "Shared Airway Management. Anaesthesia 2018."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "EBUS and rigid bronchoscopy involve a shared airway with risk of hypoxemia, hypercapnia, bleeding, bronchospasm, and airway obstruction. Rigid bronchoscopy usually requires deep anesthesia and muscle relaxation, with ventilation coordinated with the proceduralist. Large airway lesions may worsen after induction. Prepare an emergency plan for bleeding or obstruction, including tube/jet ventilation options and surgical support.",
      "immediateRedFlags": [
        "Massive tracheobronchial tear or arterial rupture causing immediate flooding of the airway with blood.",
        "Complete loss of ventilatory ability due to airway collapse post-induction in a major mediastinal mass.",
        "Severe desaturation during rigid scope placement."
      ],
      "missingCriticalInformation": [
        "Location and extent of the airway narrowing (tracheal vs. main bronchial) and luminal patency percentage",
        "Planned mode of ventilation (e.g., standard positive pressure via scope side-port vs. jet ventilation)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "EBUS and Rigid Bronchoscopy Anesthesia Protocols",
        "Shared Airway Ventilation and Leaks",
        "Acute Endobronchial Hemorrhage Management"
      ],
      "suggestedNextStepsGeneral": [
        "Establish a clear interdisciplinary communication protocol and ventilation targets before starting.",
        "For rigid bronchoscopy, provide deep TIVA and complete muscle relaxation (monitor with TOF).",
        "Have emergency double-lumen tubes, bronchial blockers, and adrenaline-soaked saline immediately available.",
        "Maintain spontaneous ventilation during induction if high-grade central airway obstruction is present."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Algorithm"
        },
        {
          "id": "bronchospasm",
          "titleTr": "Bronchospasm Rescue Algorithm"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        },
        {
          "id": "remifentanil",
          "titleTr": "Remifentanil Monograph"
        },
        {
          "id": "rocuronium",
          "titleTr": "Rocuronium Monograph"
        },
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol Monograph"
        }
      ],
      "doNotMiss": [
        "Rigid bronchoscopy ventilation relies on circuit connection to the scope; major gas leaks around the scope can prevent effective ventilation"
      ],
      "whenToEscalate": [
        "In the event of catastrophic airway hemorrhage, immediately tilt the patient toward the bleeding side, isolate the non-bleeding lung, and notify thoracic surgery"
      ],
      "referencesToShow": [
        "Anesthesia for Rigid Bronchoscopy. Annals of the American Thoracic Society 2018.",
        "Shared Airway Management. Anaesthesia 2018."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "tracheal_stent_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "anesthesia",
      "hava",
      "migrasyon",
      "stent",
      "stenti",
      "tracheal",
      "trakeal",
      "yolu"
    ],
    "question_tr": "Trakeal stent",
    "question_en": "Stent migrasyon",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Trakeal stentte migrasyon, tıkanıklık, granülasyon, kanama ve hava yolu obstrüksiyonu riski vardır. Stentin tipi, yeri, çapı ve son bronkoskopi bulguları öğrenilmelidir. Entübasyon stenti yerinden oynatabilir; tüp ucu stentle ilişkili dikkatle planlanmalıdır. Fiberoptik değerlendirme gerekebilir. Acil obstrüksiyon için rijit bronkoskopi, KBB/göğüs cerrahisi veya girişimsel pulmonoloji desteği hazır olmalıdır.",
      "immediateRedFlags": [
        "Cerrahi manipülasyon veya entübasyon sırasında stentin yerinden oynaması (migrasyon) ve solunumu tamamen kapatması.",
        "Stent lümeninin sekresyon veya kan pıhtısı ile aniden tıkanması (akut obstrüksiyon)."
      ],
      "missingCriticalInformation": [
        "Stentin tam tipi (metalik vs silikon), yerleşim yeri (karinaya olan mesafe) ve boyutu",
        "Son bronkoskopi değerlendirmesi (granülasyon dokusu varlığı)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Trakeal Stent Güvenlik Standartları",
        "Zor Havayolu ve Fiberoptik Entübasyon",
        "Akut Stent Tıkanıklığı Müdahalesi"
      ],
      "suggestedNextStepsGeneral": [
        "İndüksiyon öncesi hastanın stent tipini ve son göğüs CT/bronkoskopi görüntülerini inceleyin.",
        "Entübasyon gerekiyorsa, kafın stente zarar vermemesi veya stenti kaydırmaması için entübasyonu mutlaka fiberoptik rehberliğinde gerçekleştirin.",
        "Endotrakeal tüp ucunu stentin proksimalinde (mümkünse) sabitleyin.",
        "Sekresyon birikimini ve tıkanıklığı önlemek için havayolu nemlendirmesini iyi sağlayın ve sık aspire edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "dexamethasone",
          "titleTr": "Deksametazon Monografı"
        },
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol Monografı"
        }
      ],
      "doNotMiss": [
        "Körlemesine entübasyonun silikon stentleri kolayca yerinden oynatabileceğini ve katastrofik obstrüksiyona yol açabileceğini"
      ],
      "whenToEscalate": [
        "Akut intraoperatif stent migrasyonu veya obstrüksiyonu saptandığında, derhal işlemi durdurun, fiberoptik skop ile stenti değerlendirin ve girişimsel pulmonoloji ekibini çağırın"
      ],
      "referencesToShow": [
        "Anesthetic Management of Patients with Airway Stents. Journal of Cardiothoracic and Vascular Anesthesia 2019.",
        "Shared Airway Management Guidelines. 2018."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Tracheal stents carry risk of migration, obstruction, granulation, bleeding, and airway compromise. Determine stent type, location, diameter, and recent bronchoscopy findings. Intubation may dislodge the stent; plan tube position carefully relative to the stent. Fiberoptic assessment may be needed. Prepare rigid bronchoscopy and ENT/thoracic surgery/interventional pulmonology support for emergency obstruction.",
      "immediateRedFlags": [
        "Stent migration or displacement during intubation causing acute complete airway obstruction.",
        "Sudden complete obstruction of the stent lumen by thick secretions or blood clots."
      ],
      "missingCriticalInformation": [
        "Exact type of stent (silicone vs. self-expanding metal), dimensions, and distance from the vocal cords/carina",
        "Presence of significant granulation tissue around the stent edges"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Tracheal Stent Anesthetic Precautions",
        "Difficult Airway and Fiberoptic Intubation",
        "Emergency Stent Obstruction Protocols"
      ],
      "suggestedNextStepsGeneral": [
        "Review the patient's chest CT scans and recent bronchoscopy records before induction.",
        "Use fiberoptic-guided intubation to visualize the stent and avoid accidental mechanical displacement.",
        "Position the endotracheal tube cuff proximal to the stent, ensuring it does not exert pressure on the stent.",
        "Ensure meticulous airway humidification and suctioning to prevent mucous plugging."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Algorithm"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "dexamethasone",
          "titleTr": "Dexamethasone Monograph"
        },
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol Monograph"
        }
      ],
      "doNotMiss": [
        "Blind intubation of a patient with a tracheal stent is highly contraindicated as it can dislodge silicone stents"
      ],
      "whenToEscalate": [
        "If acute stent displacement occurs, immediately perform rigid bronchoscopy or fiberoptic examination, and summon interventional pulmonology"
      ],
      "referencesToShow": [
        "Anesthetic Management of Patients with Airway Stents. Journal of Cardiothoracic and Vascular Anesthesia 2019.",
        "Shared Airway Management Guidelines. 2018."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "mediastinal_mass_collapse_risk",
    "category": "clinical_scenarios",
    "keywords": [
      "collapse",
      "kitle",
      "mass",
      "mediastinal",
      "ortopne",
      "risk",
      "sendromu",
      "svc"
    ],
    "question_tr": "Mediastinal kitle",
    "question_en": "Ortopne kitle",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Mediastinal kitle anestezi indüksiyonu sonrası hava yolu veya kardiyovasküler kollapsa yol açabilir. Supin pozisyon, kas gevşemesi ve pozitif basınçlı ventilasyon obstrüksiyonu artırabilir. Risk bulguları: ortopne, stridor, SVC sendromu, ciddi trakeobronşiyal bası, büyük damar/kalp basısı. Mümkünse spontan solunum korunarak, hastanın rahat pozisyonunda, cerrahi/ECMO veya kardiyopulmoner bypass planı hazır şekilde ilerlenir. Yüksek riskli hastada genel anestezi öncesi multidisipliner plan şarttır.",
      "immediateRedFlags": [
        "İndüksiyon veya kas gevşetici verilmesi sonrasında gelişen mutlak CICO (havayolu kollapsı).",
        "Supin pozisyona geçişte gelişen derin hipotansiyon, nabız alınamaması ve kardiyak kollaps (büyük damar basısı)."
      ],
      "missingCriticalInformation": [
        "Kitlenin trakea çapını daraltma yüzdesi (%50 üzeri kritik)",
        "Hastanın oturur veya supin pozisyondaki klinik ve semptomatik toleransı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Mediastinal Kitle ve Havayolu Kollapsı",
        "Kardiyovasküler Kompresyon Sendromu",
        "ECMO / Bypass Yedekli Anestezi"
      ],
      "suggestedNextStepsGeneral": [
        "Preoperatif dönemde hastada ortopne, stridor veya SVC sendromu (yüz/boyun ödemi) varlığını titizlikle değerlendirin.",
        "Hastanın solunumunu korumak için indüksiyonda kas gevşetici (nöromüsküler bloker) kullanmaktan kesinlikle kaçının.",
        "İndüksiyonu hastanın semptomsuz olduğu en rahat pozisyonda (yarı oturur veya lateral) gerçekleştirin.",
        "Kritik vakalarda genel anestezi indüksiyonu öncesinde ECMO veya femoral kanülasyon ile kardiyopulmoner bypass yedeğini aktif edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        },
        {
          "id": "cico",
          "titleTr": "CICO Kurtarma Protokolü"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "ketamine",
          "titleTr": "Ketamin Monografı"
        },
        {
          "id": "dexmedetomidine",
          "titleTr": "Dekmedetomidin Monografı"
        }
      ],
      "doNotMiss": [
        "Supin pozisyona geçişte yer çekiminin kitlenin trakea ve vena kava üzerindeki basısını dramatik şekilde artıracağını"
      ],
      "whenToEscalate": [
        "İndüksiyon sonrasında havayolu kollapsı gelişirse hastayı derhal prone (yüzüstü) veya lateral pozisyona çevirin, rijit bronkoskopi uygulayın veya ECMO'ya geçin"
      ],
      "referencesToShow": [
        "Anesthetic Management of Anterior Mediastinal Masses. Journal of Cardiothoracic and Vascular Anesthesia 2018.",
        "ASA Standards on Difficult Airway. 2022."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "A mediastinal mass can cause airway or cardiovascular collapse after induction. Supine position, muscle relaxation, and positive-pressure ventilation may worsen obstruction. High-risk features include orthopnea, stridor, SVC syndrome, severe tracheobronchial compression, or great vessel/cardiac compression. When possible, maintain spontaneous ventilation in the patient’s position of comfort, with surgical/ECMO or cardiopulmonary bypass backup planned. High-risk patients require a multidisciplinary plan before general anesthesia.",
      "immediateRedFlags": [
        "Immediate complete inability to ventilate (airway collapse) following muscle relaxant administration.",
        "Profound cardiovascular collapse (obliterated blood pressure) upon transitioning to the supine position."
      ],
      "missingCriticalInformation": [
        "Percentage of tracheal lumen compression on chest CT (>50% is high risk)",
        "Patient's subjective symptomatic response to flat supine positioning"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Mediastinal Mass and Airway Collapse Risks",
        "Cardiovascular Compression Syndrome",
        "ECMO/CPB Anesthesia Backup Plans"
      ],
      "suggestedNextStepsGeneral": [
        "Screen for orthopnea, stridor, or superior vena cava (SVC) syndrome during preoperative assessment.",
        "Avoid neuromuscular blockers during induction; preserve spontaneous ventilation at all costs.",
        "Induce anesthesia in the patient's position of comfort (e.g. semi-fowler's or lateral).",
        "In critical cases, establish awake femoral cannulation for ECMO or cardiopulmonary bypass before induction."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Algorithm"
        },
        {
          "id": "cico",
          "titleTr": "CICO Management Protocol"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [
        {
          "id": "ketamine",
          "titleTr": "Ketamine Monograph"
        },
        {
          "id": "dexmedetomidine",
          "titleTr": "Dexmedetomidine Monograph"
        }
      ],
      "doNotMiss": [
        "Gravity worsens compression of the trachea and superior vena cava by the mass when the patient is placed supine"
      ],
      "whenToEscalate": [
        "If severe airway collapse occurs post-induction, immediately place the patient in the prone or lateral position, or initiate emergency bypass"
      ],
      "referencesToShow": [
        "Anesthetic Management of Anterior Mediastinal Masses. Journal of Cardiothoracic and Vascular Anesthesia 2018.",
        "ASA Standards on Difficult Airway. 2022."
      ],
      "safetyLevel": "elective"
    }
