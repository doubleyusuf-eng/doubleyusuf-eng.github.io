  {
    "id": "last",
    "category": "clinical_scenarios",
    "keywords": [
      "anestezik",
      "last",
      "lokal",
      "toksisite",
      "toxicity"
    ],
    "question_tr": "Last",
    "question_en": "Lokal anestezik",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "LAST nörolojik belirtiler, nöbet, aritmi veya kardiyak kollaps ile ortaya çıkabilir.\\n\\n1. Lokal anestezik enjeksiyonunu durdur.\\n2. Yardım çağır, havayolu ve oksijenasyonu sağla.\\n3. Nöbet varsa benzodiazepin kullan.\\n4. %20 lipid emülsiyon tedavisini başlat.\\n5. Kardiyak arrest varsa LAST’e uyarlanmış resüsitasyon uygula; yüksek doz adrenalin ve vazopressinden kaçın.\\n6. Lipid emülsiyonu stabilizasyondan sonra en az 15 dakika sürdür; maksimum toplam doz sınırına dikkat et.\\n7. Nöbet sonrası en az 2 saat, kardiyovasküler instabilite sonrası en az 4–6 saat izlem gerekir.",
      "immediateRedFlags": [
        "Lokal anestezik enjeksiyonu sırasında metalik tat, perioral uyuşukluk veya kulak çınlaması sistemik emilim uyarısıdır.",
        "LAST sırasında gelişen dirençli ventriküler aritmiler ve kardiyak arrest son derece zordur (yüksek lipid desteği şarttır!)."
      ],
      "missingCriticalInformation": [
        "Uygulanan lokal anesteziğin türü, konsantrasyonu ve tam dozu",
        "Hastanın kilosu (%20 lipid emülsiyon hesaplaması için)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Lokal Anestezik Sistemik Toksisitesi (LAST)",
        "%20 Lipid Emülsiyonu Kurtarma Protokolü",
        "LAST-Modifiye ACLS Resüsitasyonu"
      ],
      "suggestedNextStepsGeneral": [
        "Lokal anestezik enjeksiyonunu derhal sonlandırın.",
        "Hastayı oksijenize edin; gerekirse entübe edin (asidoz ve hipoksi LAST toksisitesini şiddetlendirir).",
        "%20 Lipid Emülsiyonu: 1.5 mL/kg IV bolus (1 dakikada) uygulayın, ardından 0.25 mL/kg/dk infüzyon başlatın."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "pediatric_dosing",
          "titleTr": "Pediatrik Doz Hesaplayıcı"
        },
        {
          "id": "dantrolene_rescue",
          "titleTr": "Dantrolen Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Efedrin Monografı"
        }
      ],
      "doNotMiss": [
        "LAST resüsitasyonunda standart ACLS'den farklı olarak yüksek doz Adrenalin (>1 mcg/kg) verilmemelidir, ritim dönüşünü engeller"
      ],
      "whenToEscalate": [
        "Lipid kurtarma tedavisine dirençli kardiyak arrest durumunda derhal acil CPB / ECMO hazırlığı yapılması"
      ],
      "referencesToShow": [
        "ASRA (American Society of Regional Anesthesia) Checklist for Local Anesthetic Systemic Toxicity. 2020.",
        "Neal JM, et al. PMID: 29016373."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "LAST may present with neurologic symptoms, seizure, arrhythmia, or cardiovascular collapse. Stop local anesthetic injection, call for help, secure airway and oxygenation, treat seizures with benzodiazepines, start 20% lipid emulsion therapy, and use LAST-modified resuscitation if cardiac arrest occurs; avoid high-dose epinephrine and vasopressin. Continue lipid infusion for at least 15 minutes after stability and observe at least 2 hours after seizure or 4–6 hours after cardiovascular instability.",
      "immediateRedFlags": [
        "Metallic taste, perioral numbness, or tinnitus during local anesthetic injection are early signs of systemic absorption.",
        "Intractable ventricular arrhythmias and cardiac arrest during LAST are extremely resistant to standard resuscitation."
      ],
      "missingCriticalInformation": [
        "Specific local anesthetic used, concentration, and exact dose",
        "Patient weight for 20% lipid emulsion dosage calculations"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Local Anesthetic Systemic Toxicity (LAST)",
        "20% Lipid Emulsion Rescue Protocol",
        "LAST-Modified ACLS Resuscitation"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately discontinue the local anesthetic injection.",
        "Ensure excellent oxygenation and ventilation (acidosis and hypoxia dramatically increase local anesthetic toxicity).",
        "20% Lipid Emulsion: Administer 1.5 mL/kg IV bolus (over 1 min), then start an infusion at 0.25 mL/kg/min."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "pediatric_dosing",
          "titleTr": "Pediatric Dosing Calculator"
        },
        {
          "id": "dantrolene_rescue",
          "titleTr": "Dantrolene Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine Monograph"
        }
      ],
      "doNotMiss": [
        "In LAST resuscitation, avoid high-dose Epinephrine (>1 mcg/kg) as it impairs myocardial recovery and limits lipid rescue"
      ],
      "whenToEscalate": [
        "In lipid-refractory cardiac arrest, prepare immediately for cardiopulmonary bypass (CPB) or ECMO"
      ],
      "referencesToShow": [
        "ASRA Checklist for Local Anesthetic Systemic Toxicity. 2020.",
        "Neal JM, et al. PMID: 29016373."
      ],
      "safetyLevel": "emergency"
    }
  },
