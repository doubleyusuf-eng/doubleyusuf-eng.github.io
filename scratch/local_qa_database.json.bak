  {
    "id": "clinical_followup_anticoagulant_regional_contraindications_0",
    "category": "clinical_followups",
    "keywords": [
      "anticoagulant",
      "antikoagülan",
      "clinical_followup_anticoagulant_regional_contraindications_0",
      "contraindications",
      "epidural",
      "followup",
      "hematom",
      "hematoma",
      "spinal",
      "var0"
    ],
    "question_tr": "Antikoagülasyon durumunda nöraksiyal blok ne zaman kontrendikedir?",
    "question_en": "When is neuraxial block contraindicated in anticoagulation?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "⚠️ Güvenli bekleme sürelerine uyulmadığında veya hastanın INR değeri > 1.4 ise nöraksiyal blok (Spinal/Epidural) yapılması kesinlikle kontrendikedir. Terapötik Heparinizasyon veya aktif yeni nesil oral antikoagülan (NOAC) kullanımı durumunda da kesinlikle kaçınılmalıdır.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "⚠️ Neuraxial blockade is strictly contraindicated if safe waiting times are not met or if the patient's INR is > 1.4. It is also absolutely contraindicated in therapeutic heparinization or active target-specific oral anticoagulant (NOAC) therapy.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    }
