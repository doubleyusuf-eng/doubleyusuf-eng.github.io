      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "👶 Positive Pressure Ventilation (PPV): Deliver at 40-60 breaths/min, initially using room air (21% O2). If HR remains < 60 bpm after 30 seconds of effective PPV, start chest compressions at a 3:1 compression-to-ventilation ratio and increase O2 to 100%. Use two-thumb technique compressing 1/3 of chest depth.",
