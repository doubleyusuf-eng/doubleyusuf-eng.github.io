      "relatedDrugCards": [],
      "doNotMiss": [
        "Tek başına klasik Aspirin (100 mg/gün) kullanımı spinal/epidural anestezi için engel teşkil etmez, ilacın kesilmesi gerekmez"
      ],
      "whenToEscalate": [
        "Epidural hematom bulguları varlığında (ilerleyici nörolojik kayıp) derhal beyin cerrahisi konsültasyonu ve MRG"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Regional Anesthesia. 2018. PMID: 29362691.",
        "Horlocker TT, et al. PMID: 29362691."
      ],
      "safetyLevel": "routine"
