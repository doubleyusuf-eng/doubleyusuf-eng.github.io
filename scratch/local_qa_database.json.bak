      ],
      "whenToEscalate": [
        "İntraoperatif kritik anemi ve durdurulamayan kanama durumunda fibrinojen, PCC veya hastanın kabul ettiği diğer fraksiyonları point-of-care takibine göre uygulayın"
      ],
      "referencesToShow": [
        "Association of Anaesthetists Guidelines on Management of Refusal of Blood. Anaesthesia 2018.",
        "SABM Standards for Patient Blood Management. 2021."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "A detailed preoperative discussion is required, and accepted/refused products and procedures must be documented. Red cells, plasma, and platelets may be refused; acceptance of albumin, factor concentrates, cell salvage, or acute normovolemic hemodilution varies by patient. Plan anemia treatment, iron/erythropoietin, blood-sparing surgery, TXA, normothermia, avoidance of hypotension, minimal phlebotomy, and point-of-care coagulation management. In emergencies, the patient’s documented wishes remain central.",
      "immediateRedFlags": [
        "Entering major high-blood-loss surgery without a legally documented blood refusal form on file.",
        "Development of profound intraoperative anemia (Hb <5-6 g/dL) with EKG signs of myocardial ischemia."
      ],
      "missingCriticalInformation": [
        "Signed and witnessed advance directive detailing specific allowed blood fractions (e.g. albumin, clotting factors)",
        "Patient's consent regarding autologous blood conservation techniques (e.g. cell salvage, ANH)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Jehovah's Witness and Blood Product Refusal",
        "Patient Blood Management (PBM) Strategies",
        "Preoperative Anemia Optimization"
      ],
      "suggestedNextStepsGeneral": [
        "Review and document the patient's specific choices in a calm, private preoperative environment.",
        "Treat preoperative anemia aggressively with IV iron and high-dose Erythropoietin.",
        "Use intraoperative blood conservation methods: cell salvage, acute normovolemic hemodilution (ANH) if permitted.",
        "Administer Tranexamic Acid (TXA) early and maintain absolute normothermia and physiological MAP."
      ],
      "relatedAlgorithms": [
        {
          "id": "blood_refusal",
          "titleTr": "Blood Refusal Protocol"
        },
        {
          "id": "anemia_management",
