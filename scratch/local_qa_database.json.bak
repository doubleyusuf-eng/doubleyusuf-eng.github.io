    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Serebral palsi (SP) olan hastalarda anestezi yönetiminde spastisite kontrolü, gastroözofageal reflü (aspirasyon riski), nöbet kontrolü, zor pozisyonlama ve ilaç etkileşimleri ön plandadır. Hastalarda kronik kas spazmı olmasına rağmen süksinilkolin kullanımı genellikle güvenlidir (ekstrajanksiyonel reseptör regülasyonu yanık/omurilik hasarı gibi yaygın değildir), ancak kas erimesi çok ağırsa kaçınılabilir. Nondepolarizan kas gevşeticilerin etkisi daha uzun sürebilir. Baklofen kullanan hastalarda ilacın perioperatif dönemde kesilmemesi gerekir; aniden kesilmesi şiddetli yoksunluk krizine ve spastisite artışına yol açar. Hipotermi riski yüksektir.",
      "immediateRedFlags": [
        "Kronik intratekal baklofen kullanan hastada pompanın kapatılması veya ilacın aniden kesilmesi sonucu gelişen baklofen yoksunluk krizi (hipertermi, rijidite, nöbet).",
        "Gastroözofageal reflüye bağlı indüksiyonda pulmoner aspirasyon."
      ],
      "missingCriticalInformation": [
        "Hastanın spastisite tedavisi için aldığı ilaçlar (özellikle Baklofen)",
        "Gastroözofageal reflü derecesi ve yutma disfonksiyonu varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Serebral Palsili Hastada Anestezi",
        "Baklofen Yoksunluğu Perioperatif Yönetimi",
        "Pediatrik Spastisite ve Kas Gevşetici Duyarlılığı"
      ],
      "suggestedNextStepsGeneral": [
        "Baklofen tedavisini (oral veya intratekal) ameliyat sabahı dahil kesintisiz sürdürün.",
        "Yutma disfonksiyonu ve reflü nedeniyle hastayı tok kabul edip hızlı ardışık indüksiyon (RSI) yapmayı planlayın.",
        "Eklem kontraktürleri nedeniyle ameliyat masasında pozisyonlamayı son derece hassas yapın ve basınç noktalarını koruyun.",
        "Termoregülasyon bozukluğu sıklığı nedeniyle hastayı aktif ısıtın ve ısı probu kullanın."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        },
        {
          "id": "aspiration",
          "titleTr": "Aspirasyon Önleme Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "maintenance_fluid",
          "titleTr": "Sıvı Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "rocuronium",
          "titleTr": "Roküronyum Monografı"
        }
      ],
      "doNotMiss": [
        "Baklofenin ani kesilmesinin malign hipertermiyi taklit edebilen şiddetli bir yoksunluk tablosuna (hipertermi, rijidite, rabdomiyoliz) yol açabileceğini"
      ],
      "whenToEscalate": [
        "Postoperatif dönemde baklofen yoksunluk krizi veya şiddetli spastisite atağı gelişirse, derhal IV veya intratekal baklofen replasmanını planlayın ve yoğun bakıma alın"
      ],
      "referencesToShow": [
        "Anesthesia for Children with Cerebral Palsy. Pediatric Anesthesia 2019.",
        "Management of Intrathecal Baclofen Withdrawal. Pediatric Critical Care Medicine 2016."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "In patients with cerebral palsy (CP), anesthesia management focuses on controlling spasticity, preventing gastroesophageal reflux (aspiration risk), managing seizures, delicate positioning, and drug interactions. Despite chronic spasticity, succinylcholine is generally safe (extrajunctional receptor upregulation is not as extensive as in burns/spinal injury), but may be avoided in severe muscle wasting. Non-depolarizing muscle relaxants may have a prolonged effect. Do not discontinue baclofen perioperatively; abrupt withdrawal can cause a life-threatening crisis (rigidity, hyperthermia, seizures). Hypothermia risk is high.",
      "immediateRedFlags": [
        "Abrupt discontinuation of chronic baclofen therapy, leading to severe withdrawal crisis (hyperthermia, rigidity, rhabdomyolysis, seizures).",
        "Pulmonary aspiration of gastric contents due to chronic severe reflux and dysphagia."
      ],
      "missingCriticalInformation": [
        "Complete anti-spasticity drug list (specifically Baclofen dose and route)",
        "Severity of gastroesophageal reflux and baseline seizure frequency"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Anesthesia for Patients with Cerebral Palsy",
        "Perioperative Baclofen Withdrawal Prevention",
        "Pediatric Neuromuscular Blockade Sensitivity"
      ],
      "suggestedNextStepsGeneral": [
        "Continue all baclofen therapy (oral or intrathecal pump) uninterrupted through the morning of surgery.",
        "Treat the patient as 'full stomach' due to dysphagia and reflux; plan rapid sequence induction (RSI).",
        "Ensure meticulous padding and gentle positioning of extremities due to joint contractures.",
        "Implement aggressive warming and continuous core temperature monitoring to prevent shivering-induced spasticity."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Algorithm"
        },
        {
          "id": "aspiration",
          "titleTr": "Aspiration Protocol"
        }
      ],
      "relatedCalculators": [
        {
          "id": "maintenance_fluid",
          "titleTr": "Pediatric Fluid Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "rocuronium",
          "titleTr": "Rocuronium Monograph"
        }
      ],
      "doNotMiss": [
        "Abrupt baclofen withdrawal can mimic malignant hyperthermia or neuroleptic malignant syndrome with rigidity and hyperpyrexia"
      ],
      "whenToEscalate": [
        "If acute baclofen withdrawal is suspected postoperatively, immediately consult pediatric neurology and arrange intensive care stabilization"
      ],
      "referencesToShow": [
        "Anesthesia for Children with Cerebral Palsy. Pediatric Anesthesia 2019.",
        "Management of Intrathecal Baclofen Withdrawal. Pediatric Critical Care Medicine 2016."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "autism_spectrum_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "anesthesia",
      "autism",
      "osb",
      "otizm",
      "overload",
      "premedikasyon",
      "sensory",
      "spectrum"
    ],
    "question_tr": "Otizm",
    "question_en": "Premedikasyon",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Otizm spektrum bozukluğu (OSB) olan çocuklarda en önemli hedef anksiyete, ajitasyon ve duyusal aşırı yüklenmeyi (sensory overload) en aza indirmektir. Preoperatif hazırlık bireyselleştirilmelidir. Aileyle görüşülerek hastanın tetikleyicileri (ışık, ses, dokunma) öğrenilmelidir. Sedatif premedikasyon (midazolam, ketamin veya oral/intranazal dekmedetomidin) sıklıkla gereklidir. İndüksiyon odasında sessiz, loş ışıklı bir ortam sağlanmalı, monitorizasyon (EKG, tansiyon manşonu) hasta sakinleşene kadar ertelenebilir. Mümkünse maske indüksiyonu sırasında ailenin varlığı sürdürülmelidir.",
      "immediateRedFlags": [
        "Preoperatif dönemde premedikasyon yapılmadan hastanın zorla sedasyon odasına/ameliyathaneye götürülmesi (şiddetli ajitasyon ve psikolojik travma riski).",
        "Uyanma döneminde (deliryum esnasında) hastanın kendine zarar verecek ölçüde kontrolsüz ajitasyonu."
      ],
      "missingCriticalInformation": [
        "Çocuğun iletişim becerileri düzeyi (sözel vs sözel olmayan) ve spesifik duyusal hassasiyetleri",
        "Geçmişteki anestezi veya sedasyon deneyimleri"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Otizm Spektrum Bozukluğunda Anestezi",
        "Pediatrik Premedikasyon Seçenekleri",
        "Duyusal Hassasiyet ve Ameliyathane Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Ameliyat gününden önce aile ile iletişim kurarak çocuğun sevdiği nesneleri, sakinleştirici yöntemleri ve hassasiyetlerini öğrenin.",
        "Güçlü bir premedikasyon planlayın; oral Midazolam (0.5 mg/kg) veya intranazal Dekmedetomidin (2 mcg/kg) uygulayın.",
        "Ameliyathaneye girişte gürültüyü, bip seslerini ve parlak ışıkları tamamen kapatın.",
        "Damar yolu açılması veya monitör yerleştirilmesini indüksiyon (maske ile uyutma) sonrasına erteleyin."
      ],
      "relatedAlgorithms": [
        {
          "id": "postoperative_delirium",
          "titleTr": "Postoperatif Deliryum Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "maintenance_fluid",
          "titleTr": "Sıvı Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monografı"
        },
        {
          "id": "ketamine",
          "titleTr": "Ketamin Monografı"
        },
        {
          "id": "dexmedetomidine",
          "titleTr": "Dekmedetomidin Monografı"
        }
      ],
      "doNotMiss": [
        "OSB'li çocuklarda sessiz ve uyaranlardan arındırılmış bir ortamın en iyi sedatiften bile daha etkili olabileceğini"
      ],
      "whenToEscalate": [
        "Postoperatif dönemde şiddetli, durdurulamayan ajitasyon gelişirse düşük doz IV propofol, ketamin veya dekmedetomidin ile hastayı sakinleştirin"
      ],
      "referencesToShow": [
        "Anesthesia for Children with Autism Spectrum Disorder. Pediatric Anesthesia 2017.",
        "ASA Practice Guidelines on Preoperative Sedation in Special Needs Patients. 2020."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "In children with autism spectrum disorder (ASD), the primary goal is to minimize anxiety, agitation, and sensory overload. Preoperative preparation must be highly individualized. Consult the family to identify specific triggers (light, sound, touch) and coping mechanisms. Sedative premedication (oral/intranasal midazolam, ketamine, or dexmedetomidine) is highly recommended. Maintain a quiet, dimly lit environment in the induction room; defer monitoring (EKG, blood pressure cuff) until the child is asleep or calm. Encourage parental presence during mask induction if appropriate.",
      "immediateRedFlags": [
        "Forcing an unprepared, severely agitated ASD child into the OR without prior sedation or behavioral planning.",
        "Severe postoperative emergence delirium leading to self-injury or dislodgement of lines."
      ],
      "missingCriticalInformation": [
        "Patient's baseline communication level (verbal vs. non-verbal) and specific sensory triggers",
        "History of previous anesthetic or medical encounters and successful calming methods"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Autism Spectrum Disorder Anesthetic Care",
        "Pediatric Premedication and Sedation",
        "Sensory Overload Prevention in the OR"
      ],
      "suggestedNextStepsGeneral": [
        "Conduct a detailed pre-op interview with parents regarding the child's communication preferences and favorite toys.",
        "Administer effective premedication (e.g. intranasal dexmedetomidine 2 mcg/kg or oral midazolam 0.5 mg/kg) in a quiet room.",
        "Silence all unnecessary monitors, alarms, and bright lights in the operating room prior to patient arrival.",
        "Decline awake IV cannulation or EKG placement; perform a smooth inhalational mask induction first."
      ],
      "relatedAlgorithms": [
        {
          "id": "postoperative_delirium",
          "titleTr": "Postoperative Delirium Guidelines"
        }
      ],
      "relatedCalculators": [
        {
          "id": "maintenance_fluid",
          "titleTr": "Pediatric Fluid Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monograph"
        },
        {
          "id": "ketamine",
          "titleTr": "Ketamine Monograph"
        },
        {
          "id": "dexmedetomidine",
          "titleTr": "Dexmedetomidine Monograph"
        }
      ],
      "doNotMiss": [
        "A quiet, low-sensory environment in the OR is often more effective than pharmacological sedation alone for children with ASD"
      ],
      "whenToEscalate": [
        "In cases of uncontrollable emergence agitation, administer rescue low-dose IV propofol, ketamine, or dexmedetomidine in a monitored setting"
      ],
      "referencesToShow": [
        "Anesthesia for Children with Autism Spectrum Disorder. Pediatric Anesthesia 2017.",
        "ASA Practice Guidelines on Preoperative Sedation in Special Needs Patients. 2020."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "malignant_hyperthermia_differential",
    "category": "clinical_scenarios",
    "keywords": [
      "ayırıcı",
      "benzeri",
      "differential",
      "hipertermi",
      "hyperthermia",
      "malign",
