    "question_tr": "Bnp nt probnp use",
    "question_en": "Bnp nt probnp use",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Preoperatif BNP (Beyin Natriüretik Peptid) veya NT-proBNP ölçümü, özellikle bilinen veya şüpheli kalp yetmezliği olan, kardiyak riski yüksek (RCRI >= 1-2) veya efor kapasitesi tam değerlendirilemeyen hastalarda perioperatif advers kardiyak olay (MACE) ve postoperatif mortalite riskini öngörmeye yardımcı olan güçlü bir biyobelirteçtir. Normal veya düşük preoperatif değerler, düşük kısa dönem kardiyak risk lehine güçlü bir kanıt sağlar. Yüksek değerler (örn. BNP > 92 pg/mL veya NT-proBNP > 300 pg/mL) ise daha dikkatli klinik değerlendirme, yakın intraoperatif hemodinamik izlem ve postoperatif troponin takibi (MINS izlemi) gerektirir. Biyobelirteç yüksekliği cerrahiyi otomatik olarak iptal ettirmez; kalp yetmezliği dışında böbrek yetmezliği, ileri yaş, atriyal fibrilasyon ve pulmoner hipertansiyon durumlarında da yükselebileceği bilinmelidir. 2024 AHA/ACC kılavuzu seçilmiş yüksek riskli hastalarda biyobelirteçlerin risk sınıflandırmasına ek katkı sağlayabileceğini belirtir. ([ahajournals.org])",
      "immediateRedFlags": [
        "BNP veya NT-proBNP değerlerinde açıklanamayan, belirgin ani yükselişler.",
        "Biyobelirteç yüksekliğine eşlik eden juguler venöz dolgunluk, S3 üfürümü ve akciğerde raller (Dekompanse Kalp Yetmezliği).",
        "Yüksek BNP ile birlikte EKG'de yeni başlayan atriyal fibrilasyon veya iskemik ST değişiklikleri."
      ],
      "missingCriticalInformation": [
        "Hastanın bazal böbrek fonksiyonları (eGFR/kreatinin düzeyi NT-proBNP eliminasyonunu doğrudan etkiler)",
        "Hastanın kalp yetmezliği tedavisi alıp almadığı ve son ekokardiyografi (EF) bulguları"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Natriüretik Peptidler (BNP/NT-proBNP)",
        "Preoperatif Biyobelirteç Takibi",
        "Kalp Yetmezliği Risk Sınıflaması"
      ],
      "suggestedNextStepsGeneral": [
        "Kardiyak risk profili yüksek veya efor kapasitesi belirsiz hastalarda preoperatif BNP/NT-proBNP ölçün.",
        "Değerler yüksek saptanırsa, hastayı dekompanse kalp yetmezliği bulguları açısından muayene edin.",
        "Yüksek riskli bu hastalarda intraoperatif MAP stabilitesini koruyun ve postoperatif troponin takibi planlayın.",
        "Diyaliz veya ileri böbrek yetmezliği olan hastalarda NT-proBNP'nin yalancı yüksek çıkabileceğini unutmayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "myocardial_ischemia",
          "titleTr": "Miyokard İskemisi Algoritması"
        },
        {
          "id": "sepsis",
          "titleTr": "Sepsis & Şok Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "Preoperatif natriüretik peptidlerin, postoperatif dönemde gelişebilecek sessiz miyokardiyal hasarı (MINS) öngörmede en güçlü prediktörlerden biri olduğunu"
      ],
      "whenToEscalate": [
        "Aşırı yüksek preoperatif NT-proBNP (> 1000 pg/mL) ile birlikte solunum sıkıntısı, ortopne veya hipotansiyon saptanırsa elektif ameliyatı iptal edin ve hastayı yoğun bakım/kardiyoloji gözetiminde stabilize edin"
      ],
      "referencesToShow": [
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024.",
        "Canadian Cardiovascular Society Guidelines on Perioperative Cardiac Risk. 2020."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Preoperative BNP (Brain Natriuretic Peptide) or NT-proBNP measurement is a powerful biomarker that helps predict perioperative Major Adverse Cardiac Events (MACE) and all-cause mortality, especially in patients with known or suspected heart failure, high clinical risk (RCRI >= 1-2), or unassessable functional capacity. Normal or low preoperative values provide strong reassurance of low short-term cardiac risk. Elevated values (e.g., BNP > 92 pg/mL or NT-proBNP > 300 pg/mL) indicate a high risk of postoperative events, prompting closer clinical assessment, optimized intraoperative hemodynamics, and postoperative troponin (MINS) surveillance. Biomarker elevation does not automatically cancel surgery; it can occur in renal impairment, advanced age, atrial fibrillation, and pulmonary hypertension. The 2024 AHA/ACC guidelines support natriuretic peptide testing in selected high-risk patients for refined risk stratification. ([ahajournals.org])",
      "immediateRedFlags": [
        "Unexplained, extremely high or acute elevations in BNP or NT-proBNP.",
        "Elevated biomarkers accompanied by jugular venous distention, S3 gallop, or pulmonary rales (Decompensated Heart Failure).",
        "Elevated BNP with new-onset atrial fibrillation or ischemic ST changes on the ECG."
      ],
      "missingCriticalInformation": [
        "The patient's baseline renal function (NT-proBNP clearance is highly dependent on eGFR)",
        "Active heart failure medications and the most recent echocardiography (EF) results"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Natriuretic Peptides (BNP/NT-proBNP)",
        "Preoperative Biomarker Testing",
        "Heart Failure Risk Stratification"
      ],
      "suggestedNextStepsGeneral": [
        "Measure preoperative BNP/NT-proBNP in patients with high cardiac risk or unassessable exercise capacity.",
        "If elevated, carefully examine the patient for clinical signs of volume overload or heart failure.",
        "Maintain intraoperative MAP stability and establish a postoperative troponin monitoring protocol.",
        "Interpret NT-proBNP values cautiously in patients with advanced renal failure due to decreased clearance."
      ],
      "relatedAlgorithms": [
        {
          "id": "myocardial_ischemia",
          "titleTr": "Myocardial Ischemia"
        },
        {
          "id": "sepsis",
          "titleTr": "Sepsis & Shock Management"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Preoperative natriuretic peptides are among the strongest predictors of postoperative myocardial injury (MINS) and 30-day mortality"
      ],
      "whenToEscalate": [
        "For extremely high NT-proBNP (> 1000 pg/mL) accompanied by clinical dyspnea, orthopnea, or hypotension, postpone elective surgery immediately and arrange urgent cardiology/ICU management"
      ],
      "referencesToShow": [
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024.",
        "Canadian Cardiovascular Society Guidelines on Perioperative Cardiac Risk. 2020."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "postoperative_troponin_mins",
    "category": "clinical_scenarios",
    "keywords": [
      "mins",
      "perioperatif",
      "postop",
      "postoperative",
      "troponin"
    ],
    "question_tr": "Postop troponin",
    "question_en": "Troponin",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Postoperatif troponin yüksekliği, perioperatif miyokardiyal hasarı gösterebilir ve hastada göğüs ağrısı, nefes darlığı gibi iskemik semptomlar olmasa bile postoperatif mortalite artışı ile güçlü şekilde ilişkilidir. Nonkardiyak cerrahi sonrası miyokard hasarı (MINS - Myocardial Injury after Noncardiac Surgery), cerrahi sonrası ilk 30 günde iskemik mekanizmayla gelişen troponin yüksekliği olarak tanımlanır (başka nedenler ekarte edildikten sonra). Yaklaşım: 1. Hastanın EKG'sini çekin ve semptomları, hemodinamisini, oksijenasyonunu, hemoglobin düzeyini, sepsis veya PE olasılığını ve böbrek fonksiyonlarını birlikte değerlendirin. 2. Troponin trendini seri ölçümlerle izleyin (yükselme ve düşme paterni). 3. İskemik semptomlar, EKG değişiklikleri (ST elevasyonu/depresyonu, yeni T dalgası inversiyonu), hemodinamik instabilite veya yüksek şüphe varlığında derhal kardiyoloji konsültasyonu isteyin. 4. 2024 AHA/ACC kılavuzu yüksek riskli hastalarda (RCRI >= 2, preoperatif BNP yüksekliği vb.) perioperatif troponin takibinin (MINS izlemi) yapılmasını destekler. ([ahajournals.org])",
      "immediateRedFlags": [
        "Yeni başlayan göğüs ağrısı, nefes darlığı veya hemodinamik şok tablosu.",
        "EKG'de yeni gelişen ST elevasyonu, derin ST depresyonu veya yeni sol dal bloğu (akut MI).",
        "Troponin değerlerinde hızlı, katlanarak artan yükselme trendi."
      ],
      "missingCriticalInformation": [
        "Hastanın preoperatif bazal troponin düzeyi (kronik böbrek yetmezliğinde troponin kronik olarak yüksek olabilir)",
        "Hastanın güncel hemoglobin düzeyi, oksijen satürasyonu ve kalp hızı (Tip 2 MI ekarte etmek için)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Nonkardiyak Cerrahi Sonrası Miyokard Hasarı (MINS)",
        "Postoperatif Biyobelirteç İzlemi",
        "Perioperatif Miyokard Enfarktüsü"
      ],
      "suggestedNextStepsGeneral": [
        "Yüksek riskli hastalarda ameliyat sonrası 1, 2 ve 3. günlerde troponin düzeylerini izleyin.",
        "Troponin yüksekliği saptanırsa derhal 12 derivasyonlu EKG çekin ve önceki EKG'lerle kıyaslayın.",
        "Hemodinamik stabiliteyi koruyun; taşikardi, hipoksi ve hipotansiyondan kaçının.",
        "Kardiyoloji konsültasyonu ile birlikte aspirin, statin ve uygun durumlarda beta-bloker başlanmasını değerlendirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "myocardial_ischemia",
          "titleTr": "Miyokard İskemisi Algoritması"
        },
        {
          "id": "sepsis",
          "titleTr": "Sepsis & Şok Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "MINS olgularının %90'ından fazlasının hiçbir göğüs ağrısı belirtisi göstermediğini (sessiz iskemi) ve bunun sadece troponin takibiyle saptanabileceğini"
      ],
      "whenToEscalate": [
        "EKG'de ST segment elevasyonu veya hemodinamik instabiliteye yol açan akut iskemi saptanırsa derhal kardiyoloji ekibini arayarak acil koroner anjiyografi/girişim planlayın ve yoğun bakıma alın"
      ],
      "referencesToShow": [
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024.",
        "MANAGE Trial Investigators: Dabigatran for MINS. Lancet 2018."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Postoperative troponin elevation indicates myocardial injury and is strongly associated with 30-day and long-term mortality, even in asymptomatic patients. Myocardial Injury after Noncardiac Surgery (MINS) is defined as troponin elevation of ischemic origin within 30 days after noncardiac surgery. Management: 1. Obtain a 12-lead ECG and evaluate symptoms, hemodynamics, oxygenation, hemoglobin levels, potential sepsis or PE, and renal function. 2. Monitor the troponin trend with serial measurements to establish a rise or fall pattern. 3. Request an urgent cardiology consultation in the presence of ischemic symptoms, new ECG changes (ST elevation/depression, new T-wave inversion), hemodynamic instability, or high suspicion. The 2024 AHA/ACC guidelines support postoperative troponin surveillance in high-risk patients (e.g., RCRI >= 2, poor exercise capacity, elevated preoperative BNP). ([ahajournals.org])",
      "immediateRedFlags": [
        "New-onset chest pain, severe dyspnea, or unexplained hemodynamic shock.",
        "ECG showing new ST-segment elevation, deep ST depression, or new-onset left bundle branch block.",
        "A rapidly ascending, exponential trend in serial troponin levels."
      ],
      "missingCriticalInformation": [
        "The patient's baseline preoperative troponin level (critical in chronic kidney disease where troponin is chronically elevated)",
        "Current hemoglobin level, oxygen saturation, and heart rate (to rule out Type 2 mismatch MI)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Myocardial Injury after Noncardiac Surgery (MINS)",
        "Postoperative Biomarker Surveillance",
        "Perioperative Myocardial Infarction"
      ],
      "suggestedNextStepsGeneral": [
        "Screen high-risk patients with troponin checks on postoperative days 1, 2, and 3.",
        "Obtain an immediate 12-lead ECG upon detecting any troponin elevation; compare with baseline.",
        "Optimize myocardial oxygen supply/demand by avoiding tachycardia, hypoxemia, and hypotension.",
        "Consult cardiology regarding initiation of aspirin, statin, and potentially beta-blockers."
      ],
      "relatedAlgorithms": [
        {
          "id": "myocardial_ischemia",
          "titleTr": "Myocardial Ischemia"
        },
        {
          "id": "sepsis",
          "titleTr": "Sepsis & Shock Management"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Over 90% of MINS events are entirely asymptomatic (silent ischemia) and will be completely missed without active biomarker screening"
      ],
      "whenToEscalate": [
        "For ST-elevation MI (STEMI) or myocardial injury with cardiogenic shock/refractory hypotension, contact cardiology immediately for emergent coronary angiography/intervention and transfer to the ICU"
      ],
      "referencesToShow": [
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024.",
        "MANAGE Trial Investigators: Dabigatran for MINS. Lancet 2018."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "active_cardiac_conditions",
    "category": "clinical_scenarios",
    "keywords": [
      "active",
      "aktif",
      "cardiac",
      "condition",
      "conditions",
      "durum",
      "kardiyak"
    ],
    "question_tr": "Aktif kardiyak durum",
    "question_en": "Active cardiac condition",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Elektif nonkardiyak cerrahi öncesinde 'aktif kardiyak durumlar' mutlaka dışlanmalı ve saptanırsa ameliyat ertelenmelidir. Erteleme ve ileri tetkik gerektiren durumlar: 1. Akut veya instabil koroner sendromlar (instabil anjina, yeni geçirilmiş MI), 2. Dekompanse kalp yetmezliği bulguları (NYHA Sınıf IV, yeni başlayan kalp yetmezliği bulguları), 3. Ciddi semptomatik kapak hastalıkları (özellikle ciddi semptomatik aort darlığı veya mitral darlığı), 4. Kontrolsüz ciddi aritmiler veya yüksek dereceli AV bloklar (örn. 3. derece AV blok, yeni başlayan semptomatik supraventriküler aritmiler), 5. Ciddi pulmoner hipertansiyonla seyreden instabil durumlar, 6. Açıklanamayan senkop veya eforla tetiklenen ciddi göğüs ağrısı. Bu durumlarda temel hedef, cerrahiye aceleyle 'onay almak' değil; hastayı stabilize etmek, altta yatan nedeni saptamak ve perioperatif MACE riskini en aza indirmektir. Acil cerrahi kaçınılmazsa, invaziv hemodinamik izlem (arteriyol, CVP), postoperatif yoğun bakım ve multidisipliner risk azaltma planı yapılmalıdır.",
      "immediateRedFlags": [
        "İstirahatte gelişen ve nitrata yanıt vermeyen şiddetli göğüs ağrısı (Akut Koroner Sendrom).",
        "Sırtüstü yatamama (ortopne) ve akciğerde yaygın raller (Akut Akciğer Ödemi).",
        "Ciddi bradikardiyle birlikte seyreden senkop atağı."
      ],
      "missingCriticalInformation": [
        "Planlanan cerrahi girişimin aciliyet derecesi (acil, öncelikli, elektif)",
        "Hastanın güncel kardiyovasküler ilaç listesi ve tedaviye uyumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Aktif Kardiyak Durumlar",
        "Cerrahi Erteleme Kriterleri",
        "Preoperatif Kardiyak Stabilizasyon"
      ],
      "suggestedNextStepsGeneral": [
        "Elektif cerrahi öncesi hastayı 6 aktif kardiyak durum açısından sorgulayın ve muayene edin.",
        "Aktif kardiyak durum saptanırsa elektif ameliyatı erteleyin ve hastayı kardiyolojiye yönlendirin.",
        "Acil cerrahi gerekiyorsa, hastayı kardiyoloji ve yoğun bakımla ortak yöneterek invaziv monitörizasyon planlayın.",
        "Aort darlığı şüphesi olan hastada üfürüm muayenesi yapıp acil EKO planlayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "myocardial_ischemia",
          "titleTr": "Miyokard İskemisi Algoritması"
        },
        {
          "id": "hypertension",
          "titleTr": "Hipotansiyon Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "Semptomatik ciddi aort darlığının genel anestezi altında çok yüksek ani ölüm riski taşıdığını ve elektif cerrahi öncesi mutlaka kapak replasmanı/valvüloplasti ile optimize edilmesi gerektiğini"
      ],
      "whenToEscalate": [
        "Akut hemodinamik instabiliteye yol açan aktif kardiyak durum saptanırsa, acil resüsitasyon önlemlerini alın ve hastayı acil anjiyografi/kardiyak yoğun bakıma transfer edin"
      ],
      "referencesToShow": [
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024.",
        "ESC Guidelines on Non-Cardiac Surgery: Cardiovascular Assessment. 2022."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Active cardiac conditions must be excluded before elective noncardiac surgery. If identified, elective procedures must be postponed for optimization. Delay-inducing active conditions include: 1. Acute or unstable coronary syndromes (unstable angina, recent MI within 30 days), 2. Decompensated heart failure (NYHA Class IV, worsening or new-onset HF), 3. Severe symptomatic valvular heart disease (especially severe symptomatic aortic stenosis or mitral stenosis), 4. Uncontrolled serious arrhythmias or high-grade conduction blocks (e.g., third-degree AV block, new-onset symptomatic SVT), 5. Severe unstable pulmonary hypertension, 6. Unexplained syncope or exertion-induced chest pain. The goal is not simply to get 'cardiac clearance' but to stabilize the patient, diagnose the underlying pathology, and minimize perioperative MACE. If emergency surgery is mandatory, develop a multidisciplinary risk-mitigation plan with invasive monitoring (arterial line) and post-op ICU care.",
      "immediateRedFlags": [
        "Severe chest pain occurring at rest, unresponsive to nitrates (Acute Coronary Syndrome).",
        "Orthopnea and diffuse bilateral pulmonary crackles (Acute Pulmonary Edema).",
        "Syncope associated with severe bradycardia or high-grade conduction block."
      ],
      "missingCriticalInformation": [
        "The urgency level of the planned surgery (emergency vs. elective)",
        "The patient's current cardiovascular medication list and compliance"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Active Cardiac Conditions",
        "Surgery Postponement Criteria",
        "Preoperative Cardiac Stabilization"
      ],
      "suggestedNextStepsGeneral": [
        "Screen the patient preoperatively for the six active cardiac conditions.",
        "Postpone elective procedures immediately if any active cardiac condition is present.",
        "If emergency surgery is required, establish invasive monitoring and involve cardiology/ICU early.",
        "Perform a thorough cardiac auscultation; order a rapid Echo if a systolic murmur is detected."
      ],
      "relatedAlgorithms": [
        {
          "id": "myocardial_ischemia",
          "titleTr": "Myocardial Ischemia"
        },
        {
          "id": "hypotension",
          "titleTr": "Hypotension Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Symptomatic severe aortic stenosis carries an extremely high risk of sudden intraoperative arrest due to fixed stroke volume; elective cases must be postponed"
      ],
      "whenToEscalate": [
        "In the event of an active cardiac condition causing hemodynamic instability, shock, or acute pulmonary edema, initiate emergency resuscitation and arrange transfer to a cardiac ICU"
      ],
      "referencesToShow": [
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024.",
        "ESC Guidelines on Non-Cardiac Surgery: Cardiovascular Assessment. 2022."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "smoking_cessation",
    "category": "clinical_scenarios",
    "keywords": [
      "bırakma",
      "cessation",
      "pack",
      "paket",
      "preoperatif",
      "preoperative",
      "sigara",
      "smoking",
      "year",
      "yıl"
    ],
    "question_tr": "Sigara bırakma",
    "question_en": "Preoperative smoking",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Sigara içen hastalarda preoperatif dönemde sigaranın bırakılması, perioperatif akciğer komplikasyonlarını (atelektazi, pnömoni, bronkospazm), yara yeri enfeksiyonlarını ve kardiyovasküler olay riskini azaltmada en etkili optimizasyon adımlarından biridir. Genel kural olarak, sigaranın cerrahiden mümkün olan en erken dönemde (ideal olarak >= 4-8 hafta önce) bırakılması önerilir. Kısa süre önce bırakmanın 'balgam salgısını artırarak atelektazi riski yaratacağı' yönündeki eski inanış günümüzde geçerliliğini yitirmiştir; cerrahiden 1-2 gün önce bile sigaranın bırakılması karbonmonoksit düzeyini düşürerek doku oksijenasyonunu hızla iyileştirir. Preoperatif değerlendirmede sigara içme miktarı (paket-yıl), eşlik eden KOAH/astım, aktif sekresyon varlığı ve egzersiz kapasitesi sorgulanmalıdır. Nikotin replasman tedavileri (sakız, yama) veya farmakolojik tedaviler planlanabilir.",
      "immediateRedFlags": [
        "Son dönemde sigara içiminde ani artışa eşlik eden pürülan balgam ve ateş (akut akciğer enfeksiyonu).",
        "Ağır bronkospazm ile seyreden kontrolsüz hırıltılı solunum (wheezing).",
        "Dinlenirken bile olan nefes darlığı ve oda havasında SpO2 < %92 olması."
      ],
      "missingCriticalInformation": [
        "Hastanın günlük sigara içme miktarı ve toplam sigara içme yılı (paket-yıl)",
        "KOAH veya astım tanısının varlığı, kullandığı inhaler tedaviler"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Sigara Bırakma Optimizasyonu",
        "Preoperatif Pulmoner Risk Yönetimi",
        "Havayolu Aşırı Duyarlılığı Kontrolü"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın sigara içme öyküsünü ve solunumsal semptomlarını preoperatif olarak sorgulayın.",
        "Hastaya sigarayı hemen bırakmasını tavsiye edin; nikotin replasmanı seçeneklerini tartışın.",
        "Aktif KOAH/astım varlığında inhaler tedavileri (bronkodilatörler, steroidler) optimize edin.",
        "Hastaya ameliyat öncesi solunum egzersizleri (triflo kullanımı) ve öksürme tekniklerini öğretin."
      ],
      "relatedAlgorithms": [
        {
          "id": "bronchospasm",
          "titleTr": "Bronkospazm Algoritması"
        },
        {
          "id": "desaturation",
          "titleTr": "Hipoksemi Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "Sigaranın bırakılmasından sonraki ilk 12-24 saat içinde kan hemoglobinine bağlı karboksihemoglobin (COHb) düzeyinin normale döndüğünü ve oksijen sunumunun düzeldiğini"
      ],
      "whenToEscalate": [
        "Akut solunum yolu enfeksiyonu bulguları (pürülan balgam, ateş) veya ağır dirençli bronkospazm varsa elektif cerrahiyi en az 2-4 hafta erteleyin, bronkodilatör ve antibiyotik tedavisi başlayın"
      ],
      "referencesToShow": [
        "WHO Tobacco Free Initiative: Tobacco and Surgery. 2020.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Preoperative smoking cessation is one of the most effective interventions to reduce postoperative pulmonary complications (atelectasis, pneumonia, bronchospasm), wound-healing delays, and cardiovascular events. Ideally, smoking should be stopped as early as possible before surgery (optimally >= 4-8 weeks). The historical concern that short-term cessation (e.g., < 4 weeks) is harmful due to increased sputum production and reactive airways has been debunked; even 1-2 days of abstinence rapidly decreases carboxyhemoglobin (COHb) levels, improving tissue oxygenation. Preoperative assessment must document smoking burden (pack-years), co-existing COPD/asthma, active sputum, and exercise tolerance. Nicotine replacement therapy (gum, patches) or pharmacologic support should be offered.",
      "immediateRedFlags": [
        "Purulent sputum, fever, and acute productive cough (active respiratory infection).",
        "Severe, uncontrolled wheezing or bronchospasm on physical examination.",
        "Resting dyspnea or baseline oxygen saturation < 92% on room air."
      ],
      "missingCriticalInformation": [
        "The patient's daily smoking amount and total duration (pack-years)",
        "Co-existing diagnosis of COPD or asthma, and active inhaler therapy compliance"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Smoking Cessation Optimization",
        "Preoperative Pulmonary Risk Management",
        "Airway Hyperreactivity Control"
      ],
      "suggestedNextStepsGeneral": [
        "Assess the patient's smoking history and presence of productive cough or wheezing.",
        "Strongly advise the patient to quit smoking immediately; offer nicotine replacements.",
        "Optimize inhaler therapies (bronchodilators, inhaled steroids) in patients with COPD/asthma.",
        "Prescribe incentive spirometry (triflo) and instruct on deep breathing exercises preoperatively."
      ],
      "relatedAlgorithms": [
        {
          "id": "bronchospasm",
          "titleTr": "Bronchospasm Algorithm"
        },
        {
          "id": "desaturation",
          "titleTr": "Hypoxemia Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Within 12-24 hours of quitting smoking, carboxyhemoglobin levels return to normal, significantly increasing arterial oxygen content"
      ],
      "whenToEscalate": [
        "In the presence of active respiratory infection (fever, purulent sputum) or refractory bronchospasm, postpone elective surgery for 2-4 weeks and initiate pulmonary medical treatment"
      ],
      "referencesToShow": [
        "WHO Tobacco Free Initiative: Tobacco and Surgery. 2020.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "preoperative_anemia_optimization",
    "category": "clinical_scenarios",
    "keywords": [
      "anemi",
      "anemia",
      "deficiency",
      "demir",
      "eksikliği",
      "eritropoietin",
      "iron",
      "iv",
      "optimizasyon",
      "optimization",
      "preoperatif",
      "preoperative"
    ],
    "question_tr": "Preoperatif anemi",
    "question_en": "Iv iron",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Preoperatif anemi, nonkardiyak cerrahi sonrasında artmış morbidite, mortalite ve transfüzyon ihtiyacı ile doğrudan ilişkili bağımsız bir risk faktörüdür. Kan kaybı beklenen (kanama ihtimali > 500 mL olan) tüm elektif cerrahiler öncesinde anemi taraması yapılmalıdır. Amaç sadece transfüzyon tetik eşiğini beklemek değil, aneminin nedenini önceden belirleyip tedavi etmektir. 1. Hb seviyesini ve aneminin türünü saptamak için tam kan, serum ferritin, transferrin satürasyonu, B12/folat düzeyleri ve renal fonksiyon paneli değerlendirilir. 2. Demir eksikliği anemisi saptanırsa, oral veya IV demir tedavisi planlanır; cerrahiye kalan süre azsa (< 3-4 hafta) veya emilim bozukluğu varsa IV demir tedavisi (hızlı etki için) tercih edilir. 3. Kronik böbrek yetmezliği veya kronik hastalık anemisinde eritropoietin (EPO) desteği düşünülebilir. 4. Gastrointestinal veya jinekolojik aktif kanama kaynakları araştırılmalıdır. 5. Ameliyat sırasında traneksamik asit (TXA) kullanımı, cell salvage (hücre kurtarma) ve minimal kan örneği alımı gibi hasta kan yönetimi (PBM) stratejileri planlanır. Acil cerrahide optimizasyon süresi sınırlıdır; doku oksijenasyonu ve kanama yönetimi önceliklidir.",
      "immediateRedFlags": [
        "Ciddi anemiye (Hb < 7-8 g/dL) eşlik eden aktif göğüs ağrısı, taşikardi ve EKG'de iskemi bulguları.",
        "Hızlı ve kontrolsüz kanamaya bağlı hemodinamik instabilite ve şok tablosu.",
        "Akut iskemik inmeyi taklit eden kognitif bozukluklar."
      ],
      "missingCriticalInformation": [
        "Hastanın güncel hemoglobin düzeyi, MCV ve demir profili (ferritin, TSAT)",
        "Cerrahi girişimin tahmini kan kaybı miktarı ve hastanın kan grubu/crossmatch durumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Preoperatif Anemi Optimizasyonu",
        "Hasta Kan Yönetimi (PBM)",
        "Demir Eksikliği Anemisi Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Kan kaybı beklenen ameliyatlardan en az 3-4 hafta önce tam kan ve demir paneli isteyin.",
        "Mutlak veya fonksiyonel demir eksikliği saptanan hastalara IV demir tedavisi planlayın.",
        "Cerrahi ekiple ameliyat esnasında hemostaz önlemlerini ve TXA endikasyonunu görüşün.",
        "Düşük hemoglobinli hastalarda intraoperatif dönemde anemik hipoksiyi önlemek için MAP stabilitesini koruyun."
      ],
      "relatedAlgorithms": [
        {
          "id": "postop_pain_ladder",
          "titleTr": "Postoperatif Ağrı Yönetimi"
        },
        {
          "id": "desaturation",
          "titleTr": "Hipoksemi Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "Preoperatif anemi düzeltilmeden yapılan cerrahilerde, postoperatif dönemde gelişen transfüzyonların enfeksiyon, akciğer hasarı (TRALI) ve mortalite riskini artırdığını"
      ],
      "whenToEscalate": [
        "Elektif major cerrahi öncesi Hb < 8 g/dL olan ve düzeltilemeyen aktif demir eksikliği anemisi saptanırsa ameliyatı erteleyin, hematoloji önerisiyle IV demir ve gerekirse EPO tedavisi planlayın"
      ],
      "referencesToShow": [
        "SABM Administrative and Clinical Standards for Patient Blood Management. 2021.",
        "ESAIC Guidelines on the Management of Preoperative Anemia. 2022."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Preoperative anemia is a strong, independent predictor of adverse postoperative outcomes, including increased morbidity, 30-day mortality, and blood transfusion requirements. Anemia screening should be performed prior to any elective surgery with an expected blood loss > 500 mL. The goal of preoperative patient blood management (PBM) is not merely to wait for a transfusion threshold, but to diagnose and actively treat the underlying cause. Check Hb, MCV, ferritin, transferrin saturation (TSAT), B12/folate, and renal function. Treat iron deficiency with oral or IV iron; IV iron is preferred if surgery is scheduled in < 3-4 weeks or if GI absorption is impaired. Erythropoietin (EPO) may be considered in chronic kidney disease or anemia of chronic disease. Inquire about active bleeding sources. Plan intraoperative blood conservation strategies (e.g., tranexamic acid, cell salvage, restrictive transfusion thresholds). In emergency cases, optimization is limited; focus on oxygen delivery and bleeding control.",
      "immediateRedFlags": [
        "Severe anemia (Hb < 7-8 g/dL) accompanied by active chest pain, tachycardia, or ECG ischemia.",
        "Hemodynamic instability or shock secondary to active, uncontrolled bleeding.",
        "Altered mental status mimicking acute ischemic stroke in severe anemia."
      ],
      "missingCriticalInformation": [
        "The patient's current Hb, MCV, and complete iron panel (ferritin, TSAT)",
        "Estimated surgical blood loss and the patient's blood type/crossmatch status"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Preoperative Anemia Optimization",
        "Patient Blood Management (PBM)",
        "Iron Deficiency Anemia Management"
      ],
      "suggestedNextStepsGeneral": [
        "Screen patients for anemia at least 3-4 weeks prior to major elective surgeries.",
        "Prescribe IV iron replacement for patients with documented absolute or functional iron deficiency.",
        "Discuss intraoperative tranexamic acid (TXA) and cell salvage with the surgical team.",
        "Avoid intraoperative hypotension in anemic patients to preserve tissue oxygen delivery."
      ],
      "relatedAlgorithms": [
        {
          "id": "postop_pain_ladder",
          "titleTr": "Postoperative Pain Management"
        },
        {
          "id": "desaturation",
          "titleTr": "Hypoxemia Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Preoperative anemia is a modifiable risk factor; failing to correct it leads to unnecessary postoperative transfusions, which carry risks of infection, TRALI, and death"
      ],
      "whenToEscalate": [
        "If a patient scheduled for major elective surgery presents with Hb < 8 g/dL and uncorrected iron deficiency, postpone the procedure for IV iron/EPO optimization"
      ],
      "referencesToShow": [
        "SABM Administrative and Clinical Standards for Patient Blood Management. 2021.",
        "ESAIC Guidelines on the Management of Preoperative Anemia. 2022."
      ],
      "safetyLevel": "elective"
    }
  },
