    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "GLP-1 receptor agonists (semaglutide, liraglutide, tirzepatide, dulaglutide) significantly delay gastric emptying, increasing the risk of nausea, vomiting, regurgitation, and pulmonary aspiration during general anesthesia or deep sedation. Current recommendations (2024 multisociety guidance and 2025 ANZCA recommendations) favor an individualized risk assessment over automatic elective cancellation or automatic drug discontinuation. High-risk features include dose-escalation phase, high maintenance doses, active gastrointestinal symptoms (nausea, vomiting, abdominal pain), diabetic gastroparesis, obesity/bariatric surgery, urgent surgery, or high aspiration-risk procedures. Management options include: 1. Transitioning to a liquid diet preoperatively, 2. Bedside gastric ultrasound to assess gastric volume, 3. Rapid sequence induction (RSI) with full-stomach precautions, 4. Modifying the anesthetic plan to regional anesthesia, or 5. Postponing high-risk elective procedures. ([ScienceDirect])",
      "immediateRedFlags": [
        "Sudden regurgitation, vomiting, and pulmonary aspiration during induction (wheezing, rapid desaturation).",
        "Severe abdominal pain and persistent vomiting in a GLP-1 user (suspect acute pancreatitis).",
        "The patient reporting feeling full or having food stagnation on the morning of elective surgery."
      ],
      "missingCriticalInformation": [
        "The specific GLP-1 agonist name, dosage, and whether it is a daily or weekly formulation",
        "The date of the last dose and the presence of active reflux or dyspeptic symptoms"
      ],
      "likelyClinicalCategoriesToConsider": [
        "GLP-1 Agonists Perioperative Management",
        "Delayed Gastric Emptying",
        "Pulmoner Aspiration Risk Control"
      ],
      "suggestedNextStepsGeneral": [
        "Document the exact GLP-1 agent, dose, dosing interval, and the date of the last dose.",
        "Assume a high risk of full stomach if the patient has active GI symptoms or diabetic gastroparesis.",
        "Perform a bedside point-of-care gastric ultrasound pre-induction if trained and available.",
        "If gastric status is unclear or risky, perform an RSI with a fast-acting muscle relaxant."
      ],
      "relatedAlgorithms": [
        {
          "id": "aspiration_risk",
          "titleTr": "Aspiration Risk"
        },
        {
          "id": "rsi",
          "titleTr": "RSI Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Even with perfect adherence to standard NPO guidelines, patients taking GLP-1 agonists can have substantial solid gastric residue on induction"
      ],
      "whenToEscalate": [
        "If pulmonary aspiration occurs on induction, immediately place the patient head-down and turned to the left, suction the airway, intubate, and provide emergent respiratory support"
      ],
      "referencesToShow": [
        "Multisociety Clinical Practice Guidance for Safe Use of GLP-1 Receptor Agonists. 2024.",
        "ANZCA Safety Statement on GLP-1 Agonists. 2025."
      ],
      "safetyLevel": "elective"
    }
