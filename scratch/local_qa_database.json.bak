        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "RCRI'nın stabil olmayan anjina, dekompanse kalp yetmezliği veya ciddi kapak patolojileri gibi aktif ve acil durumları doğrudan hesaba katmadığını, bu durumların öncelikle elenmesi gerektiğini"
      ],
      "whenToEscalate": [
        "Yüksek RCRI skorlu hastada akut koroner sendrom şüphesi, yeni başlayan dispne veya ritim bozukluğu saptanırsa elektif işlemi derhal erteleyin ve kardiyolojiye sevk edin"
      ],
      "referencesToShow": [
        "Lee's Revised Cardiac Risk Index Study. Circulation 1999.",
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This replace does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "The Revised Cardiac Risk Index (RCRI or Lee's Score) is the most widely used clinical tool to estimate the risk of Major Adverse Cardiac Events (MACE) in patients undergoing noncardiac surgery. It consists of six clinical variables: 1. High-risk surgery (intrathoracic, intra-abdominal, or suprainguinal vascular), 2. History of ischemic heart disease, 3. History of congestive heart failure, 4. History of cerebrovascular disease, 5. Preoperative treatment with insulin for diabetes, 6. Preoperative serum creatinine > 2.0 mg/dL (177 mcmol/L). Each variable is assigned 1 point. An RCRI score >= 2 indicates significantly elevated perioperative cardiac risk. While highly practical, RCRI is not sufficient alone; it must be interpreted alongside the patient's active cardiac symptoms, exercise tolerance (DASI/METs), frailty, pulmonary hypertension, and valvular heart disease. The 2024 AHA/ACC guidelines emphasize that risk calculators should complement, not replace, comprehensive clinical judgment. ([ahajournals.org])",
      "immediateRedFlags": [
        "RCRI score >= 3 scheduled for major vascular or high-risk surgery.",
        "High RCRI score accompanied by poor exercise tolerance (METS < 4) or decompensated heart failure.",
        "Acute worsening of renal function in a patient with a high cardiovascular risk profile."
      ],
      "missingCriticalInformation": [
        "The patient's current preoperative serum creatinine level",
        "The exact type and surgical invasiveness of the planned procedure"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Revised Cardiac Risk Index (RCRI)",
        "Cardiac Risk Prediction and Stratification",
        "Preoperative Clinical Risk Assessment"
      ],
      "suggestedNextStepsGeneral": [
        "Screen the patient for the six RCRI variables to calculate the total score.",
        "Classify patients with an RCRI score >= 2 as high-risk and secure a preoperative ECG.",
        "Plan postoperative troponin (MINS) surveillance and ECG checks for high-risk patients.",
        "Integrate the RCRI score with objective functional capacity metrics (like DASI)."
      ],
      "relatedAlgorithms": [
        {
          "id": "myocardial_ischemia",
          "titleTr": "Myocardial Ischemia"
        },
        {
          "id": "renal_failure_anesthesia",
          "titleTr": "Renal Failure"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "RCRI does not account for active cardiac conditions like unstable angina, decompensated heart failure, or critical aortic stenosis, which must be ruled out first"
      ],
      "whenToEscalate": [
        "For high-RCRI patients presenting with acute coronary syndrome symptoms, new-onset dyspnea, or serious arrhythmia, immediately postpone elective surgery and seek cardiology consultation"
      ],
      "referencesToShow": [
        "Lee's Revised Cardiac Risk Index Study. Circulation 1999.",
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "bnp_nt_probnp_use",
    "category": "clinical_scenarios",
    "keywords": [
