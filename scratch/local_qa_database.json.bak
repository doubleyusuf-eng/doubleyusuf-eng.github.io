  {
    "id": "anticoagulated_peripheral_block",
    "category": "clinical_scenarios",
    "keywords": [
      "anticoagulated",
      "antikoagülan",
      "block",
      "blok",
      "derin",
      "edilemeyen",
      "komprese",
      "periferik",
      "peripheral",
      "pleksus"
    ],
    "question_tr": "Antikoagülan periferik",
    "question_en": "Anticoagulated peripheral",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Risk blok yerine göre değişir. Yüzeyel, komprese edilebilir alanlardaki bloklar daha düşük risklidir; derin pleksus ve derin periferik bloklar nöroaksiyel bloklara benzer ciddiyette kanama riski taşıyabilir. İlaç tipi, son doz zamanı, renal fonksiyon, koagülasyon, eş zamanlı antiplatelet kullanımı ve blok bölgesinin komprese edilebilirliği değerlendirilmelidir. ASRA/ESRA veya kurum antikoagülasyon protokolü izlenmelidir. (rapm.bmj.com)",
      "immediateRedFlags": [
        "Derin, komprese edilemeyen sinir bloğu (örn. Psoas kompartman veya lomber pleksus bloğu) sonrasında gelişen masif retroperitoneal kanama bulguları.",
        "Blok bölgesinde hızla büyüyen, kompresyona yanıt vermeyen hematom ve nörolojik kayıp."
      ],
      "missingCriticalInformation": [
        "Hastanın kullandığı antikoagülanın son alım saati ve yarı ömrü",
        "Blok bölgesinin anatomik komprese edilebilirlik durumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Antikoagüle Hastada Periferik Blok Güvenliği",
        "Derin Pleksus Blokları Kanama Riski",
        "ASRA Rejyonal Anestezi Sınırları"
      ],
      "suggestedNextStepsGeneral": [
        "Uygulanacak periferik bloğun derinliğini ve komprese edilebilirliğini değerlendirin (örn. Aksiller/femoral bloklar yüzeyel ve komprese edilebilirdir; psoas/paravertebral bloklar derin ve tehlikelidir).",
        "Derin ve komprese edilemeyen bloklar için ASRA nöroaksiyel bekleme sürelerini (LMWH için 12-24 saat, DOAC için 72 saat) aynen uygulayın.",
        "Yüzeyel ve komprese edilebilir bloklar için antikoagülasyon altında işlem kararını hastanın kanama riskine göre bireyselleştirin.",
        "Blok sonrasında lokal bası uygulayın ve hematom yönünden yakın izleme yapın."
      ],
      "relatedAlgorithms": [
        {
          "id": "neuraxial_safety",
          "titleTr": "Nöroaksiyel Güvenlik Kılavuzu"
        }
      ],
      "relatedCalculators": [
        {
          "id": "crcl",
          "titleTr": "Kreatinin Klerensi Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monografı"
        }
      ],
      "doNotMiss": [
        "Lomber pleksus, paravertebral ve psoas kompartman bloklarının kanama riski açısından nöroaksiyel bloklar ile eşdeğer kabul edildiğini"
      ],
      "whenToEscalate": [
        "Blok sonrasında internal kanama bulguları (taşikardi, açıklanamayan Hb düşüşü) veya ilerleyici motor kayıp gelişirse derhal görüntüleme (USG/CT) ve cerrahi hemostaz planlayın"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Regional Anesthesia in the Patient Receiving Antithrombotic Drugs. 2025.",
        "ESRA Practice Advisory. Regional Anesthesia & Pain Medicine 2021."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Risk depends on block site. Superficial blocks in compressible areas are lower risk, while deep plexus and deep peripheral blocks may carry bleeding risks similar to neuraxial procedures. Assess drug type, last dose, renal function, coagulation, concurrent antiplatelet therapy, and whether the block site is compressible. Follow ASRA/ESRA or institutional anticoagulation guidance.",
      "immediateRedFlags": [
        "Development of retroperitoneal hematoma or hemorrhagic shock after a deep, non-compressible lumbar plexus block.",
        "Rapidly expanding hematoma at the block site with progressive neurological deficit."
      ],
      "missingCriticalInformation": [
        "Exact timing of the last dose of the antithrombotic agent",
        "Anatomical compressibility status of the planned block location"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Peripheral Blocks in Anticoagulated Patients",
        "Deep Plexus Blocks and Bleeding Risk",
        "ASRA Anticoagulation Regional Standards"
      ],
      "suggestedNextStepsGeneral": [
        "Classify the block as compressible (e.g. axillary, femoral) or non-compressible/deep (e.g. psoas compartment, paravertebral).",
        "For deep, non-compressible blocks, adhere strictly to the ASRA neuraxial delay guidelines (e.g. hold DOACs 72 hours).",
        "For superficial, compressible blocks, individualize the decision based on coagulation status and vascular access.",
        "Apply prolonged direct manual pressure after needle withdrawal to minimize hematoma risk."
      ],
      "relatedAlgorithms": [
        {
          "id": "neuraxial_safety",
          "titleTr": "Neuraxial Safety Guidelines"
        }
      ],
      "relatedCalculators": [
        {
          "id": "crcl",
          "titleTr": "Cockcroft-Gault CrCl"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "heparin",
          "titleTr": "Heparin Monograph"
        }
      ],
      "doNotMiss": [
        "Deep regional blocks (psoas compartment, paravertebral) are treated as neuraxial procedures due to the risk of concealed bleeding"
      ],
      "whenToEscalate": [
        "In the event of suspected internal bleeding (hypotension, unexplained hematocrit drop) post-block, obtain urgent ultrasound/CT and consult surgery"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Regional Anesthesia in the Patient Receiving Antithrombotic Drugs. 2025.",
        "ESRA Practice Advisory. Regional Anesthesia & Pain Medicine 2021."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "pyloric_stenosis_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "anesthesia",
      "hipertrofik",
      "pilor",
      "pyloric",
      "stenosis",
      "stenozu"
    ],
    "question_tr": "Pilor stenozu",
    "question_en": "Hipertrofik pilor",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "İnfantil hipertrofik pilor stenozu tıbbi bir acildir, cerrahi bir acil değildir! Cerrahi öncesinde hastanın metabolik alkalozu, dehidratasyonu, hipokalemisi ve hipoklorisi tam olarak düzeltilmelidir (Klor > 100 mmol/L, HCO3 < 28 mmol/L, idrar çıkışı > 1 mL/kg/saat). Anestezi indüksiyonunda 'tok hasta' (full stomach) kabul edilir; indüksiyon öncesi nazogastrik (NG) tüp ile 3 pozisyonda (supin, sol lateral, sağ lateral) mide aspire edilmelidir. Hızlı ardışık indüksiyon (RSI) veya uyanık fiberoptik havayolu güvenliği planlanmalı, postoperatif dönemde solunum depresyonu ve apne riski yakın izlenmelidir.",
      "immediateRedFlags": [
        "Ciddi dehidratasyon bulguları, hipokloremik metabolik alkaloz (pH > 7.45, HCO3 > 30 mmol/L) düzeltilmeden anestezi indüksiyonu yapılması.",
        "İndüksiyon esnasında mide içeriğinin pulmoner aspirasyonu."
      ],
      "missingCriticalInformation": [
        "Bebeğin serum elektrolit paneli (özellikle Klor, Potasyum ve Sodyum)",
        "Bazal hidrasyon durumu, son idrar çıkışı ve NG tüpten gelen miktar"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Pediatrik Pilor Stenozu Yönetimi",
        "Hipokloremik Metabolik Alkaloz Düzeltimi",
        "Pediatrik Tok Hasta İndüksiyon Protokolü"
      ],
      "suggestedNextStepsGeneral": [
        "Serum klorür seviyesini >100 mmol/L ve bikarbonatı <26-28 mmol/L seviyelerine getirene kadar cerrahiyi erteleyin (normalde 24-48 saat IV hidrasyon gerekir).",
        "İndüksiyondan hemen önce NG tüp yerleştirip mideyi supin, sol lateral ve sağ lateral pozisyonlarda tamamen aspire edin.",
        "Hızlı ardışık indüksiyon (RSI) uygulayın; atropin ile premedikasyon yaparak vagal bradikardi riskini azaltın.",
        "Postoperatif dönemde (ilk 24 saat) merkezi solunum depresyonu ve apne riskine karşı hastayı yakın monitorize edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        },
        {
          "id": "pediatric_bradycardia",
          "titleTr": "Pediatrik Bradikardi Kılavuzu"
        }
      ],
      "relatedCalculators": [
        {
          "id": "maintenance_fluid",
          "titleTr": "Pediatrik Sıvı İdame Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "atropine",
          "titleTr": "Atropin Monografı"
        },
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Pilor stenozunun kesinlikle cerrahi bir acil olmadığını, metabolik bozukluklar düzeltilmeden ameliyata alınmasının mortaliteyi artıracağını"
      ],
      "whenToEscalate": [
        "İntraoperatif aspirasyon veya postoperatif uzamış apne gelişmesi durumunda bebeği entübe tutarak yoğun bakıma transfer edin"
      ],
      "referencesToShow": [
        "Smith's Anesthesia for Infants and Children, 10th Edition. 2021.",
        "AAGBI Safety Guideline for Pediatric Anesthesia. 2020."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Infantile hypertrophic pyloric stenosis is a medical emergency, not a surgical emergency! Metabolic alkalosis, dehydration, hypokalemia, and hypochloremia must be fully corrected before surgery (Chlor > 100 mmol/L, HCO3 < 28 mmol/L, urine output > 1 mL/kg/h). The baby is considered to have a 'full stomach'; aspirate the stomach via a nasogastric (NG) tube in three positions (supine, left lateral, right lateral) prior to induction. Plan rapid sequence induction (RSI) or awake intubation, and closely monitor for postoperative apnea and central respiratory depression.",
      "immediateRedFlags": [
        "Proceeding to anesthesia induction with uncorrected hypochloremic metabolic alkalosis (pH >7.45, HCO3 >30 mmol/L).",
        "Pulmonary aspiration of gastric contents during induction."
      ],
      "missingCriticalInformation": [
        "Current serum electrolyte panel (particularly Chloride, Potassium, and Sodium)",
        "Clinical signs of dehydration and documented urine output in the last 6-12 hours"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Pediatric Pyloric Stenosis Anesthesia",
        "Hypochloremic Metabolic Alkalosis Correction",
        "Pediatric Full Stomach Airway Management"
      ],
      "suggestedNextStepsGeneral": [
        "Postpone surgery for 24-48 hours until chloride is >100 mmol/L, bicarbonate is <26-28 mmol/L, and dehydration is resolved.",
        "Perform wide-bore gastric aspiration in supine, left, and right lateral positions immediately before induction.",
        "Use rapid sequence induction (RSI) with atropine premedication to prevent vagal bradycardia.",
        "Monitor the infant closely postoperatively for at least 24 hours for central apnea due to CSF alkalosis."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Algorithm"
        },
        {
          "id": "pediatric_bradycardia",
          "titleTr": "Pediatric Bradycardia Guidelines"
        }
      ],
      "relatedCalculators": [
        {
          "id": "maintenance_fluid",
          "titleTr": "Pediatric Maintenance Fluid Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "atropine",
          "titleTr": "Atropine Monograph"
        },
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Pyloric stenosis is a medical, not surgical emergency; metabolic optimization takes absolute priority over incision timing"
      ],
      "whenToEscalate": [
        "If active aspiration occurs or persistent postoperative apnea develops, secure the airway and transfer to the NICU"
      ],
      "referencesToShow": [
        "Smith's Anesthesia for Infants and Children, 10th Edition. 2021.",
        "AAGBI Safety Guideline for Pediatric Anesthesia. 2020."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "neonatal_resuscitation_2025",
    "category": "clinical_scenarios",
    "keywords": [
      "2025",
      "canlandırma",
      "neonatal",
      "nrp",
      "resuscitation",
      "resüsitasyon"
    ],
    "question_tr": "Neonatal resüsitasyon",
    "question_en": "Canlandırma",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "2025 AHA/AAP Neonatal Resüsitasyon algoritması adımları: 1) Isıtma, kurulama, pozisyon verme, havayolu temizliği ve stimülasyon. 2) Apne veya iç çekme tarzı solunum varsa, ya da kalp hızı (HR) < 100/dk ise ilk 60 saniyede Pozitif Basınçlı Ventilasyon (PPV) başlatın. 3) SpO2 ve kardiyak monitör takın. 4) Ventilasyona rağmen HR yükselmezse düzeltici ventilasyon adımlarını uygulayın (MR. SOPA: Maske ayarlama, Re-pozisyon, Emme/sekresyon temizleme, Ağız açıklığı, Basınç artırma, Alternatif havayolu). 5) HR < 60/dk ise entübasyon yapın, %100 O₂ ile 3:1 oranında (90 kompresyon, 30 ventilasyon) göğüs kompresyonu başlatın. 6) Yanıt yoksa IV/IO Adrenalin (0.01-0.03 mg/kg) ve hacim genişletici planlayın.",
      "immediateRedFlags": [
        "İlk 60 saniyede (Golden Minute) apneik veya bradikardik bebekte PPV başlatılmasının geciktirilmesi.",
        "Yetersiz göğüs ekspansiyonu varken doğrudan göğüs kompresyonlarına veya adrenalin tedavisine geçilmesi."
      ],
      "missingCriticalInformation": [
        "Bebeğin doğum haftası, mekonyum varlığı ve doğum sonrasındaki tam geçen süre (saniye olarak)",
        "Kord klemplenme zamanı ve plasental patolojiler"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Neonatal Resüsitasyon Algoritması (NRP 2025)",
        "MR. SOPA Ventilasyon Düzeltme Adımları",
        "Neonatal Asfiksi ve Kordon Kan Gazı"
      ],
      "suggestedNextStepsGeneral": [
        "Doğum odasını önceden 26°C'ye ısıtın, radyan ısıtıcıyı açın ve ılık havlular hazırlayın.",
        "Solunum yetersizse veya kalp hızı <100/dk ise ilk 60 saniye içinde T-parçalı canlandırıcı ile PPV'ye başlayın.",
        "Kalp hızı yükselmezse göğüs hareketlerini kontrol edin; yoksa MR. SOPA adımlarını eksiksiz sırasıyla uygulayın.",
        "Kalp hızı hala <60/dk ise bebeği entübe edin, kompresyona başlayın ve UVC (umblikal venöz kateter) yolu açın."
      ],
      "relatedAlgorithms": [
        {
          "id": "pediatric_bradycardia",
          "titleTr": "Pediatrik Bradikardi Algoritması"
        },
        {
          "id": "cardiac_arrest",
          "titleTr": "Kardiyak Arrest Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "pediatric_tube",
          "titleTr": "Pediatrik Tüp Çapı Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "epinephrine",
          "titleTr": "Adrenalin Monografı"
        },
        {
          "id": "atropine",
          "titleTr": "Atropin Monografı"
        }
      ],
      "doNotMiss": [
        "NRP'deki en kritik basamağın etkili ventilasyon olduğunu; ventilasyon düzeltilmeden kompresyona geçilmemesi gerektiğini"
      ],
      "whenToEscalate": [
        "10 dakikalık etkin NRP resüsitasyonuna rağmen Apgar 0 ise ve kalp atımı alınamıyorsa, etik kurullar çerçevesinde sonlandırmayı değerlendirin"
      ],
      "referencesToShow": [
        "2025 AHA/AAP Guidelines for Neonatal Resuscitation. Pediatrics 2025.",
        "International Consensus on CPR Science (CoSTR). 2025."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "2025 AHA/AAP Neonatal Resuscitation steps: 1) Warm, dry, position, clear airway if indicated, and stimulate. 2) If apnea, gasping, or HR < 100 bpm, initiate Positive Pressure Ventilation (PPV) within the first 60 seconds (Golden Minute). 3) Apply SpO2 and cardiac monitoring. 4) If HR does not rise despite PPV, execute corrective ventilation steps (MR. SOPA: Mask adjustment, Reposition airway, Suction mouth/nose, Open mouth, Pressure increase, Alternative airway). 5) If HR remains < 60 bpm, secure airway (ETT/LMA), start 3:1 chest compressions (90 compressions, 30 breaths/min) with 100% O2. 6) If HR remains < 60, administer IV/IO Epinephrine (0.01-0.03 mg/kg) via UVC.",
      "immediateRedFlags": [
        "Delaying PPV beyond 60 seconds in an apneic or bradycardic newborn.",
        "Initiating chest compressions or epinephrine before verifying effective chest rise and bilateral ventilation."
      ],
      "missingCriticalInformation": [
        "Gestational age, presence of thick meconium, and exact seconds elapsed since birth",
        "Umbilical cord clamping delay status"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Neonatal Resuscitation Protocol (NRP 2025)",
        "MR. SOPA Corrective Ventilation Protocol",
        "Neonatal Asphyxia and Cord Blood Analysis"
      ],
      "suggestedNextStepsGeneral": [
        "Preheat the delivery room to 26°C, activate the radiant warmer, and prepare warm dry blankets.",
        "If HR < 100 bpm or apneic, start PPV immediately using a T-piece resuscitator or self-inflating bag.",
        "Perform the MR. SOPA checklist systematically if the chest is not rising and HR is not increasing.",
        "For persistent HR < 60 bpm after 30s of effective PPV, intubate, start chest compressions, and place a UVC."
      ],
      "relatedAlgorithms": [
        {
          "id": "pediatric_bradycardia",
          "titleTr": "Pediatric Bradycardia Guidelines"
        },
        {
          "id": "cardiac_arrest",
          "titleTr": "Cardiac Arrest Guidelines"
        }
      ],
      "relatedCalculators": [
        {
          "id": "pediatric_tube",
          "titleTr": "Pediatric Tube Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "epinephrine",
          "titleTr": "Epinephrine Monograph"
        },
        {
          "id": "atropine",
          "titleTr": "Atropine Monograph"
        }
      ],
      "doNotMiss": [
        "Ventilation is the single most important step in neonatal resuscitation; do not proceed to cardiac interventions without achieving chest rise"
      ],
      "whenToEscalate": [
        "If there is no heart rate detected at 10 minutes of continuous high-quality resuscitation, discuss cessation of efforts with the team"
      ],
      "referencesToShow": [
        "2025 AHA/AAP Guidelines for Neonatal Resuscitation. Pediatrics 2025.",
        "International Consensus on CPR Science (CoSTR). 2025."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "neonatal_hypoglycemia_management",
    "category": "clinical_scenarios",
    "keywords": [
      "bebek",
      "gir",
      "glukoz",
      "hipoglisemi",
      "hypoglycemia",
      "infüzyon",
      "management",
      "neonatal",
      "şeker"
    ],
    "question_tr": "Neonatal hipoglisemi",
    "question_en": "Gir",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Neonatal hipoglisemi (glukoz < 40-45 mg/dL) nörogelişimsel hasara yol açabilen kritik bir durumdur. Semptomatik bebeklerde (ajitasyon, letarji, apne, nöbet bulguları) derhal IV tedavi başlanmalıdır. Semptomatik ise veya glukoz < 25 mg/dL ise acil olarak 2 mL/kg %10 Dekstroz (D10W) bolusu (200 mg/kg glukoz) 1-2 dakikada yavaşça verilir ve ardından 4-8 mg/kg/dk hızında IV Dekstroz infüzyonu (GIR) sürdürülür. Semptomsuz hafif olgularda enteral besleme veya oral %40 glukoz jel (0.5 g/kg) ilk basamak olarak düşünülebilir. Kan şekeri takibi 30-60 dakikada bir tekrarlanmalıdır.",
      "immediateRedFlags": [
        "Semptomatik neonatal hipoglisemide IV bolus tedavisinin geciktirilmesi.",
        "%10'dan daha yüksek konsantrasyondaki dekstroz solüsyonlarının periferik damardan hızlı bolus olarak verilmesi (tromboz/doku nekrozu riski)."
      ],
      "missingCriticalInformation": [
        "Yenidoğanın doğum kilosu, gestasyonel yaşı ve semptomların varlığı",
        "Annenin diyabetik öyküsü ve doğum odasındaki glukoz takip sıklığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Neonatal Hipoglisemi Tanı ve Tedavisi",
        "Glukoz İnfüzyon Hızı (GIR) Hesaplama",
        "Yenidoğan Metabolik Takip Protokolleri"
      ],
      "suggestedNextStepsGeneral": [
        "Semptomatik bebekte derhal damar yolu açın ve 2 mL/kg %10 Dekstroz bolusu uygulayın.",
        "Bolus sonrasında 6-8 mg/kg/dk hızında glukoz infüzyonu (GIR) başlatın ve periferik veya santral (UVC) hattan infüzyonu sürdürün.",
        "Glukoz seviyesini 30-60 dakikada bir kontrol ederek hedef değeri >45-50 mg/dL düzeyinde tutun.",
        "İnfüzyonu sonlandırırken rebound hipoglisemiyi önlemek için dozu kademeli olarak azaltın."
      ],
      "relatedAlgorithms": [
        {
          "id": "sepsis",
          "titleTr": "Neonatal Sepsis Protokolü"
        }
      ],
      "relatedCalculators": [
        {
          "id": "maintenance_fluid",
          "titleTr": "Pediatrik Sıvı Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Semptomatik bebeklerde hedef glukoz seviyesinin >45-50 mg/dL, ilk 24 saatten sonra ise >60 mg/dL olması gerektiğini"
      ],
      "whenToEscalate": [
        "İnfüzyon hızı (GIR) > 12-15 mg/kg/dk olmasına rağmen düzeltilemeyen inatçı hipoglisemide acil endokrinoloji konsültasyonu isteyin ve hidrokortizon tedavisini değerlendirin"
      ],
      "referencesToShow": [
        "AAP Clinical Report on Postnatal Glucose Homeostasis. Pediatrics 2011. Reconfirmed 2021.",
        "ESPE/PES Consensus Guidelines on Neonatal Hypoglycemia. Hormone Research in Paediatrics 2020."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Neonatal hypoglycemia (glucose <40-45 mg/dL) can lead to permanent neurodevelopmental damage. In symptomatic neonates (jitteriness, lethargy, apnea, seizures), immediately initiate IV treatment. For symptomatic infants or glucose <25 mg/dL, administer an emergent 2 mL/kg bolus of 10% Dextrose (D10W) slow IV over 1-2 minutes (200 mg/kg glucose), followed by a continuous IV infusion providing a Glucose Infusion Rate (GIR) of 4-8 mg/kg/min. For asymptomatic mild cases, first-line enteral feeding or oral 40% glucose gel (0.5 g/kg) can be initiated. Recheck blood glucose every 30-60 minutes.",
      "immediateRedFlags": [
        "Delaying IV glucose resuscitation in a symptomatic or severely hypoglycemic infant.",
        "Bolusing dextrose concentrations >10% through a peripheral vein due to high risk of thrombophlebitis and tissue necrosis."
      ],
      "missingCriticalInformation": [
        "Exact blood glucose value, presence of neurological symptoms, and gestational age",
        "Maternal diabetic status and birth weight (SGA vs. LGA)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Neonatal Hypoglycemia Management",
        "Glucose Infusion Rate (GIR) Optimization",
        "Neonatal Metabolic Stabilization Protocols"
      ],
      "suggestedNextStepsGeneral": [
        "Establish immediate IV access and administer 2 mL/kg of D10W slow IV for symptomatic hypoglycemia.",
        "Start continuous IV infusion of D10W at a GIR of 6-8 mg/kg/min immediately following the bolus.",
        "Recheck capillary or venous glucose levels every 30-60 minutes until stable above target (>45-50 mg/dL).",
        "Wean IV fluids gradually once enteral feeds are tolerated to prevent rebound hypoglycemia."
      ],
      "relatedAlgorithms": [
        {
          "id": "sepsis",
          "titleTr": "Neonatal Sepsis Protocol"
        }
      ],
      "relatedCalculators": [
        {
          "id": "maintenance_fluid",
          "titleTr": "Pediatric Fluid Calculator"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Symptomatic neonates require target blood glucose levels >45-50 mg/dL; after 24 hours of life, target levels should be >60 mg/dL"
      ],
      "whenToEscalate": [
        "If GIR requirements exceed 12-15 mg/kg/min to maintain euglycemia, obtain urgent pediatric endocrinology consult for suspected hyperinsulinism"
      ],
      "referencesToShow": [
        "AAP Clinical Report on Postnatal Glucose Homeostasis. Pediatrics 2011. Reconfirmed 2021.",
        "ESPE/PES Consensus Guidelines on Neonatal Hypoglycemia. Hormone Research in Paediatrics 2020."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "neonatal_hypothermia_prevention",
    "category": "clinical_scenarios",
    "keywords": [
      "bebek",
      "hipotermi",
      "hypothermia",
      "neonatal",
      "prematüre",
      "prevention",
      "sargı",
      "soğuk",
      "stresi",
      "üşü"
    ],
    "question_tr": "Neonatal hipotermi",
    "question_en": "Prematüre sargı",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Yenidoğanlarda (özellikle prematürelerde) hipotermi (vücut ısısı < 36.5°C) mortalite, morbidite, metabolik asidoz ve solunum sıkıntısı riskini dramatik şekilde artırır. Profilaksi doğum odasında başlar. Prematüre bebekler (<32 hafta) kurulanmadan doğrudan polietilen plastik torbaya/sargıya konulmalıdır. Doğum odası sıcaklığı en az 23-25°C olmalı (prematürelerde 25-26°C), bebek radyan ısıtıcı altında tutulmalı, başlık takılmalı ve tüm IV sıvılar ile solunum gazları ısıtılıp nemlendirilmelidir. Hipotermi saptanırsa radyan ısıtıcı veya kuvöz ile saatte 0.5°C artış hedefleyen kademeli ısıtma yapılmalıdır.",
      "immediateRedFlags": [
        "Prematüre bebeğin (<32 hafta) doğum odasında kurulanmaya çalışılarak ısı kaybedilmesi (doğrudan plastik sargıya konulmalıdır).",
        "Vücut ısısı < 35°C olan ağır hipotermik bebekte ani, kontrolsüz hızlı ısıtma yapılması (vazodilatasyon ve şok riski)."
      ],
      "missingCriticalInformation": [
        "Yenidoğanın güncel rektal/aksiller sıcaklığı ve gestasyonel yaşı",
        "Doğum odası ve ameliyathane ortam sıcaklık derecesi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Neonatal Hipotermi Önleme ve Isı Zinciri",
        "Prematüre Bebek Isı Koruma Yöntemleri",
        "Neonatal Metabolik Asidoz ve Soğuk Stresi"
      ],
      "suggestedNextStepsGeneral": [
        "<32 hafta doğan bebekleri kurulamadan derhal başı açıkta kalacak şekilde polietilen torbaya yerleştirin.",
        "Doğum odası ve transport ortam sıcaklığını en az 25°C'ye ayarlayın.",
        "Isı takibini aksiller veya sürekli cilt probu ile yapın ve vücut ısısını 36.5-37.5°C aralığında tutun.",
        "Hipotermik bebeği ısıtırken hızı saatte 0.5-1.0°C aralığında tutarak kademeli ısıtma uygulayın; kan şekeri ve kan gazı takibi yapın."
      ],
      "relatedAlgorithms": [
        {
          "id": "pediatric_bradycardia",
          "titleTr": "Pediatrik Bradikardi Algoritması"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Soğuk stresinin sürfaktan sentezini inhibe ettiğini, pulmoner hipertansiyonu tetiklediğini ve hipoglisemiye yol açtığını"
      ],
      "whenToEscalate": [
        "Kademeli ısıtmaya rağmen vücut ısısı yükselmeyen ve inatçı metabolik asidoz (pH < 7.20) ile hipotansiyonu süren bebekte neonatal yoğun bakım desteğini aktif edin"
      ],
      "referencesToShow": [
        "WHO Guidelines on Newborn Thermal Care. 2018.",
        "AHA/AAP Neonatal Resuscitation Program (NRP) Textbook, 8th Edition. 2021."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "In neonates (especially preterms), hypothermia (body temperature <36.5°C) dramatically increases mortality, morbidity, metabolic acidosis, and respiratory distress. Prevention begins in the delivery room. Extremely preterm infants (<32 weeks) should not be dried; place them immediately into a polyethylene plastic wrap/bag under a radiant warmer. Maintain delivery/OR temperature at 23-25°C (25-26°C for preterms), apply a warm cap, and use warmed, humidified IV fluids and respiratory gases. If hypothermia occurs, rewarm gradually at a rate of 0.5°C/hour using a radiant warmer or incubator.",
      "immediateRedFlags": [
        "Wasting time drying a very low birth weight preterm (<32 weeks) instead of placing them immediately into a plastic wrap.",
        "Rapid, uncontrolled active rewarming of a severely hypothermic infant (<35°C) causing peripheral vasodilation and hypovolemic shock."
      ],
      "missingCriticalInformation": [
        "Newborn's current axial or rectal temperature, birth weight, and gestational age",
        "Ambient temperature of the delivery room or operating theater"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Neonatal Hypothermia Prevention and Warm Chain",
        "Preterm Thermal Regulation Standards",
        "Neonatal Cold Stress and Metabolic Acidosis"
      ],
      "suggestedNextStepsGeneral": [
        "For infants born <32 weeks gestation, place them immediately into a polyethylene bag up to the neck without drying.",
        "Pre-warm the delivery room or OR to 25-26°C and prepare warm linen and a neonatal cap.",
        "Use warmed humidified respiratory gases for ventilation and pre-warm all IV fluids.",
        "Rewarm hypothermic infants gradually (0.5°C/h) to minimize the risk of apnea, hypoglycemia, and hypotension."
      ],
      "relatedAlgorithms": [
        {
          "id": "pediatric_bradycardia",
          "titleTr": "Pediatric Bradycardia Guidelines"
        }
      ],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Cold stress inhibits surfactant synthesis, triggers persistent pulmonary hypertension (PPHN), and causes profound hypoglycemia"
      ],
      "whenToEscalate": [
        "In cases of refractory hypothermia associated with persistent metabolic acidosis (pH <7.20) or shock, secure the airway and initiate advanced NICU stabilization"
      ],
      "referencesToShow": [
        "WHO Guidelines on Newborn Thermal Care. 2018.",
        "AHA/AAP Neonatal Resuscitation Program (NRP) Textbook, 8th Edition. 2021."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "congenital_heart_disease_noncardiac",
    "category": "clinical_scenarios",
    "keywords": [
      "congenital",
      "disease",
      "dkh",
      "doğumsal",
      "heart",
      "kalp",
      "noncardiac",
      "spell",
      "tet",
      "şant"
    ],
    "question_tr": "Doğumsal kalp",
    "question_en": "Şant",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Doğumsal kalp hastalığı (DKH) olan çocuklarda nonkardiyak cerrahi öncesinde şant yönü (soldan sağa vs sağdan sola), obstrüksiyon varlığı (aort stenozu, TOF), pulmoner vasküler direnç (PVR) ve sistemik vasküler direnç (SVR) dengesi tam analiz edilmelidir. Soldan sağa şantlarda (ASD, VSD, PDA) yüksek SVR ve düşük PVR şant miktarını ve kalp yetmezliğini artırır. Sağdan sola şantlarda (TOF) SVR düşüşü veya PVR artışı (hipoksi, hiperkapni, asidoz, ağrı) şantı artırarak derin siyanoz krizine (tet spell) yol açar. Damar yollarında hava kabarcığı olmamasına (paradoksikal emboli riski) azami dikkat edilmelidir.",
      "immediateRedFlags": [
        "Sağdan sola şantlı (örn. Fallot Tetralojisi) çocukta indüksiyonda ani gelişen derin siyanoz krizi (SpO2 < %50) ve arrest.",
        "IV hatlarda hava kabarcığı varlığı (sağdan sola şant nedeniyle direkt serebral/koroner emboli riski)."
      ],
      "missingCriticalInformation": [
        "DKH'nin tam anatomik tanısı, şantların derecesi ve güncel ekokardiyografi (EKO) raporu",
        "Hastanın günlük egzersiz/beslenme toleransı ve pulmoner hipertansiyon varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Doğumsal Kalp Hastalıklarında Anestezi",
        "Siyanoz Krizleri (Tet Spell) Müdahalesi",
        "Pulmoner ve Sistemik Vasküler Direnç Dengesi"
      ],
      "suggestedNextStepsGeneral": [
        "Elektif vakalarda güncel pediatrik kardiyoloji raporunu ve şant dinamiklerini teyit edin.",
        "IV hatlardaki tüm havayı titizlikle temizleyin; mutlaka hava filtreli setler kullanın.",
        "Fallot hastasında indüksiyonda SVR'yi korumak için yavaş titrasyon yapın ve acil durum için Fenilefrin (SVR artırıcı) hazır bulundurun.",
        "Siyanoz krizi gelişirse: %100 O₂ verin, diz-göğüs pozisyonu uygulayın, hiperventilasyon yapın, IV sıvı bolusu verin, morfin ve IV fenilefrin uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "pediatric_bradycardia",
          "titleTr": "Pediatrik Bradikardi Algoritması"
        },
        {
          "id": "cardiac_arrest",
          "titleTr": "Kardiyak Arrest Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Ortalama Arter Basıncı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "phenylephrine",
          "titleTr": "Fenilefrin Monografı"
        },
        {
          "id": "morphine",
          "titleTr": "Morfin Monografı"
        },
        {
          "id": "esmolol",
          "titleTr": "Esmolol Monografı"
        }
      ],
      "doNotMiss": [
        "Tüm konjenital şantlı çocuklarda IV hatlardaki en küçük hava kabarcığının bile direkt inmeye yol açabileceğini (paradoksikal emboli)"
      ],
      "whenToEscalate": [
        "Medikal tedaviye (diz-göğüs, sıvı, fenilefrin, morfin) yanıt vermeyen inatçı tet krizinde acil pediatrik kardiyak cerrahi veya kardiyoloji girişimini aktif edin"
      ],
      "referencesToShow": [
        "Anesthesia for Congenital Heart Disease, 4th Edition. 2020.",
        "ASA Practice Advisory on Patients with CHD Undergoing Noncardiac Surgery. 2021."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "In children with congenital heart disease (CHD) undergoing noncardiac surgery, carefully analyze shunt direction (L-to-R vs. R-to-L), presence of obstruction (AS, TOF), and the balance between pulmonary (PVR) and systemic vascular resistance (SVR). In left-to-right shunts (ASD, VSD, PDA), high SVR and low PVR increase shunt volume and heart failure. In right-to-left shunts (TOF), a drop in SVR or rise in PVR (hypoxia, hypercapnia, acidosis, pain) increases the shunt, triggering a hypercyanotic spell (tet spell). Meticulously avoid air bubbles in IV lines due to risk of paradoxical systemic embolization.",
      "immediateRedFlags": [
        "Sudden severe hypercyanotic spell (SpO2 <50%) and hemodynamic collapse during induction in a right-to-left shunt patient.",
        "Presence of visible air bubbles in any IV tubing (high risk of paradoxical cerebral or coronary air embolism)."
      ],
      "missingCriticalInformation": [
        "Exact anatomical diagnosis, shunt fraction (Qp/Qs), and the most recent echocardiography (ECHO) report",
        "Patient's functional status, exercise tolerance, and presence of pulmonary hypertension"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Anesthesia for Congenital Heart Disease",
        "Hypercyanotic Tet Spell Emergency Management",
        "PVR and SVR Pathophysiological Balance"
      ],
      "suggestedNextStepsGeneral": [
        "Review the latest pediatric cardiology evaluation and baseline oxygen saturations before surgery.",
        "Remove all air from IV lines meticulously and use air-eliminating filters.",
        "For TOF patients, maintain SVR during induction; have intravenous Phenylephrine (SVR-increasing agent) drawn and ready.",
        "For hypercyanotic spells: administer 100% O2, place in knee-chest position, hyperventilate, give fluid bolus, and administer IV morphine or phenylephrine."
      ],
      "relatedAlgorithms": [
        {
          "id": "pediatric_bradycardia",
          "titleTr": "Pediatric Bradycardia Guidelines"
        },
        {
          "id": "cardiac_arrest",
          "titleTr": "Cardiac Arrest Guidelines"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "Mean Arterial Pressure"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "phenylephrine",
          "titleTr": "Phenylephrine Monograph"
        },
        {
          "id": "morphine",
          "titleTr": "Morphine Monograph"
        },
        {
          "id": "esmolol",
          "titleTr": "Esmolol Monograph"
        }
      ],
      "doNotMiss": [
        "Any congenital shunt makes the patient vulnerable to paradoxical air embolism; even a tiny bubble can cause a stroke or myocardial infarction"
      ],
      "whenToEscalate": [
        "If a hypercyanotic spell is refractory to medical management (fluids, knee-chest, morphine, phenylephrine), immediately call pediatric cardiology or cardiothoracic surgery"
      ],
      "referencesToShow": [
        "Anesthesia for Congenital Heart Disease, 4th Edition. 2020.",
        "ASA Practice Advisory on Patients with CHD Undergoing Noncardiac Surgery. 2021."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "down_syndrome_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "21",
      "anesthesia",
      "atlantoaksiyel",
      "down",
      "makroglossi",
      "sendromu",
      "syndrome",
      "trizomi"
    ],
    "question_tr": "Down sendromu",
    "question_en": "Makroglossi",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Down sendromlu (Trizomi 21) hastalarda anestezi yönetimi birden fazla organ sistemini ilgilendirir. En kritik havayolu riski Atlantoaksiyel İnstabilitedir (AAI); başın aşırı fleksiyon veya ekstansiyonundan kaçınılmalı, nötr pozisyonda entübe edilmelidir. Havayolu anatomik olarak dardır; makroglossi, subglottik stenoz ve tonsiller hipertrofi nedeniyle zor havayolu riski yüksektir. Hastaların %40-50'sinde doğumsal kalp hastalığı (özellikle AV kanal defektleri, VSD) eşlik eder; kardiyak değerlendirme şarttır. Ayrıca postoperatif apne ve bradikardi riski yüksektir.",
      "immediateRedFlags": [
        "Entübasyon veya pozisyon verme sırasında boyuna aşırı fleksiyon/ekstansiyon manevraları uygulanması (kuadripleji/spinal kord yaralanması riski).",
        "Ciddi doğumsal kalp anomalisi olan hastada kontrolsüz indüksiyon ve hemodinamik kollaps."
      ],
      "missingCriticalInformation": [
        "Preoperatif atlantoaksiyel instabilite taraması (boyun grafileri)",
        "Doğumsal kalp hastalığı öyküsü ve güncel kardiyoloji/EKO değerlendirmesi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Down Sendromunda Anestezi Yaklaşımı",
        "Atlantoaksiyel İnstabilite (AAI) ve Pozisyon",
        "Pediatrik Subglottik Stenoz ve Havayolu"
      ],
      "suggestedNextStepsGeneral": [
        "Preoperatif dönemde AAI bulgularını (hiperrefleksi, yürüyüş bozukluğu) sorgulayın ve boyun hareketlerini minimumda tutun.",
        "Subglottik stenoz riski nedeniyle her zaman hesaplanandan 0.5 veya 1 boy daha küçük endotrakeal tüp hazır bulundurun.",
        "Entübasyonu ve cerrahi pozisyonlamayı boynu kesinlikle aşırı fleksiyon veya ekstansiyona getirmeden nötr pozisyonda yapın.",
        "Eşlik eden şantlı kalp hastalıkları yönünden IV hatlarda hava filtresi kullanımını zorunlu kılın."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        },
        {
          "id": "congenital_heart_disease_noncardiac",
          "titleTr": "Konjenital Kalp Hastalığı Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "pediatric_tube",
          "titleTr": "Pediatrik Tüp Çapı Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "atropine",
          "titleTr": "Atropin Monografı"
        }
      ],
      "doNotMiss": [
        "Down sendromlu hastalarda subglottik stenoz sıklığı nedeniyle her zaman beklenenden daha küçük tüp seçilmesi gerektiğini"
      ],
      "whenToEscalate": [
        "Postoperatif dönemde şüpheli spinal kord basısı bulguları (yeni gelişen motor güçsüzlük, duyu kaybı) saptanırsa acil MRG isteyin ve beyin cerrahisi çağırın"
      ],
      "referencesToShow": [
        "Anesthesia for Down Syndrome. Pediatric Anesthesia 2018.",
        "Screening for Atlantoaxial Instability in Down Syndrome. Pediatrics 2011. Reconfirmed 2020."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "In Down syndrome (Trisomy 21), anesthesia involves multiple organ systems. The most critical airway risk is Atlantoaxial Instability (AAI); avoid hyperextension or hyperflexion of the neck, maintaining a neutral position during intubation and positioning. The airway is anatomically narrow due to macroglossia, subglottic stenosis, and tonsillar hypertrophy, making mask ventilation and intubation difficult. Congenital heart disease (particularly AV canal defects, VSD) is present in 40-50% of patients; cardiac clearance is mandatory. There is also a high risk of postoperative apnea and bradycardia.",
      "immediateRedFlags": [
        "Excessive neck extension or flexion during laryngoscopy or positioning in a patient with Down syndrome (high risk of spinal cord transection).",
        "Inducing anesthesia in a patient with uninvestigated or severe congenital heart disease."
      ],
      "missingCriticalInformation": [
        "Preoperative cervical spine clearance for atlantoaxial instability (neck X-rays)",
        "Documented history of congenital heart disease and recent ECHO report"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Down Syndrome Anesthetic Management",
        "Atlantoaxial Instability (AAI) Airway Safety",
        "Pediatric Subglottic Stenosis and Tube Selection"
      ],
      "suggestedNextStepsGeneral": [
        "Inquire about signs of AAI (hyperreflexia, gait changes, neck pain) during preoperative visit.",
        "Always prepare endotracheal tubes 0.5 to 1.0 size smaller than calculated due to high incidence of subglottic stenosis.",
        "Intubate and position the patient keeping the head and neck in a strict neutral alignment.",
        "Ensure a thorough pediatric cardiology evaluation is obtained and use air-inline filters for IV access."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Algorithm"
        },
        {
          "id": "congenital_heart_disease_noncardiac",
          "titleTr": "Congenital Heart Disease Guidelines"
        }
      ],
      "relatedCalculators": [
        {
          "id": "pediatric_tube",
          "titleTr": "Pediatric Tube Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "atropine",
          "titleTr": "Atropine Monograph"
        }
      ],
      "doNotMiss": [
        "Subglottic stenosis is common in Down syndrome; standard age-based tube size calculations often overestimate the required size"
      ],
      "whenToEscalate": [
        "If post-operative neurological changes (new weakness, localized numbness) are suspected, order emergency cervical MRI and consult neurosurgery"
      ],
      "referencesToShow": [
        "Anesthesia for Down Syndrome. Pediatric Anesthesia 2018.",
        "Screening for Atlantoaxial Instability in Down Syndrome. Pediatrics 2011. Reconfirmed 2020."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "cerebral_palsy_anesthesia",
