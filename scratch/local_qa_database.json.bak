      "doNotMiss": [
        "Entübasyon sonrasında tüpten pozitif basınç verilmesinin aspire edilmiş materyali akciğerlerin daha derinlerine (distale) iteceğini, bu nedenle ventilasyondan önce trakeal aspirasyon yapılması gerektiğini"
      ],
      "whenToEscalate": [
        "Ağır hipoksemi, ARDS tablosu veya dirençli bronkospazm gelişirse, hastayı mekanik ventilatörde akciğer koruyucu ayarlarla (düşük tidal hacim) yoğun bakıma transfer edin"
      ],
      "referencesToShow": [
        "2023 American Society of Anesthesiologists Practice Guidelines for Preoperative Fasting.",
        "Mendelson's Syndrome Clinical Review."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "What should be done if regurgitation occurs during induction? Call for help. Position the patient to reduce pulmonary contamination if possible, such as head-down/lateral positioning. Use strong suction to clear the oropharynx. Give 100% oxygen. Secure the airway rapidly; intubation should be performed by an experienced clinician if needed. Bronchoscopy may be required if tracheal aspiration is suspected. Monitor oxygenation, bronchospasm, lung compliance, and hemodynamics. Postoperative chest imaging/ABG, ICU care, and antibiotics depend on clinical findings; prophylactic antibiotics are not automatic for every aspiration.",
      "immediateRedFlags": [
        "Active flow of acidic or particulate gastric contents into the glottis.",
        "Severe, sudden oxygen desaturation (SpO2 < 80%) and intense bronchospasm post-aspiration.",
        "Abrupt loss of lung compliance with skyrocketing peak airway pressures."
      ],
      "missingCriticalInformation": [
        "The nature of the aspirated material (acidic liquid vs. solid food particles)",
        "Whether tracheal intubation has been successfully accomplished"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Regurgitation During Induction",
        "Acute Pulmonary Aspiration",
        "Airway Emergency Management"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately place the patient in Trendelenburg (head-down) or turn the head to the side.",
        "Clear the oropharynx rapidly using large-bore suction (Yankauer).",
        "Secure the trachea swiftly with a cuffed endotracheal tube under 100% O2.",
        "Suction the inside of the ETT thoroughly BEFORE applying the first positive pressure breath."
      ],
      "relatedAlgorithms": [
        {
          "id": "aspiration_risk",
          "titleTr": "Aspiration Management"
        },
        {
          "id": "rsi",
          "titleTr": "RSI Algorithm"
        },
        {
          "id": "hypoxemia",
          "titleTr": "Hypoxemia Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "oxygenation_calculator",
          "titleTr": "Oxygenation"
        },
        {
          "id": "abg_interpretation",
          "titleTr": "ABG Interpretation"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine"
        }
      ],
      "doNotMiss": [
        "Applying positive pressure ventilation immediately after intubation pushes the aspirated material deep into the distal alveoli; clear the tube first"
      ],
      "whenToEscalate": [
        "In the event of refractory hypoxemia, severe bronchospasm, or ARDS, initiate lung-protective mechanical ventilation (low tidal volume, PEEP) and transfer to the ICU"
      ],
      "referencesToShow": [
