  {
    "id": "clinical_followup_neonatal_resus_contraindications_0",
    "category": "clinical_followups",
    "keywords": [
      "clinical_followup_neonatal_resus_contraindications_0",
      "cocuk",
      "contraindications",
      "followup",
      "neonatal",
      "pediatri",
      "pediatric",
      "resus",
      "var0",
      "yenidoğan",
      "çocuk"
    ],
    "question_tr": "Yenidoğanda balon-maskenin kontrendike olduğu durum nedir?",
    "question_en": "When is bag-mask ventilation contraindicated in newborns?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "⚠️ **Konjenital Diyafragma Hernisi (KDH)** varlığında balon-maske ventilasyonu kesinlikle kontrendikedir! PBV yapılması mide ve bağırsakları hava ile şişirerek akciğerleri daha da sıkıştırır ve fatal hipoksiye yol açar. Bebek doğar doğmaz derhal entübe edilmelidir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "⚠️ **Congenital Diaphragmatic Hernia (CDH)** is an absolute contraindication to bag-mask ventilation! Positive pressure via mask inflates the herniated bowel in the thorax, causing fatal lung compression. The infant must be endotracheally intubated immediately at birth.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
