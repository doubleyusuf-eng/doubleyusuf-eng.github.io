          "id": "myocardial_ischemia",
          "titleTr": "Miyokard İskemisi Algoritması"
        },
        {
          "id": "hypertension",
          "titleTr": "Hipotansiyon Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinefrin Monografı"
        }
      ],
      "doNotMiss": [
        "Düşük efor kapasitesinin postoperatif akciğer ve kalp komplikasyonları için bağımsız bir risk faktörü olduğunu"
      ],
      "whenToEscalate": [
        "İstirahatte anjina, dekompanse kalp yetmezliği veya yeni gelişen 3. derece AV blok saptanırsa elektif vakayı iptal edin, hastayı acil kardiyoloji takibine alın"
      ],
      "referencesToShow": [
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Preoperative functional capacity assessment is critical for predicting perioperative cardiac risk. Rather than just asking if the patient 'can climb stairs,' assess exercise capacity using a spectrum of daily activities (e.g., brisk walking, light housework, heavy gardening). Patients with poor functional capacity (METS < 4) carry an increased risk of cardiovascular complications, especially during major or high-risk surgeries. Elective surgery should be postponed for cardiology assessment and stabilization if the patient exhibits chest pain, unexplained dyspnea, syncope, severe symptomatic valvular disease, or decompensated heart failure. The 2024 AHA/ACC guidelines emphasize combining functional capacity with validated risk calculators for optimization. ([ahajournals.org])",
      "immediateRedFlags": [
        "New-onset or unstable angina pectoris symptoms.",
        "Dyspnea on minimal exertion, orthopnea, or resting dyspnea.",
        "Unexplained syncope or suspected severe cardiac arrhythmias."
      ],
      "missingCriticalInformation": [
        "The patient's precise baseline exercise capacity (METS score)",
        "Active or suspected ischemic heart disease history and cardiovascular medication regimen"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Functional Capacity Assessment",
        "Cardiac Risk Optimization",
        "Preoperative Cardiovascular Evaluation"
      ],
      "suggestedNextStepsGeneral": [
        "Inquire specifically about chest pain, pressure, or shortness of breath during daily tasks.",
        "Estimate the patient's METS score objectively using the DASI questionnaire.",
        "In patients with METS < 4 undergoing major surgery, obtain a preoperative ECG and consider an Echo.",
        "If active cardiac symptoms are present, postpone elective procedures for cardiology consult."
      ],
      "relatedAlgorithms": [
        {
          "id": "myocardial_ischemia",
          "titleTr": "Myocardial Ischemia"
        },
        {
          "id": "hypotension",
          "titleTr": "Hypotension Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Poor functional capacity is a strong, independent predictor of adverse postoperative cardiovascular and pulmonary outcomes"
      ],
      "whenToEscalate": [
        "If the patient presents with resting angina, decompensated heart failure, or new high-grade AV block, immediately cancel elective surgery and transfer to emergency cardiology care"
      ],
      "referencesToShow": [
        "2024 AHA/ACC Guideline on Perioperative Cardiovascular Evaluation. 2024.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    }
