        }
      ],
      "relatedDrugCards": [
        {
          "id": "lidocaine",
          "titleTr": "Lidokain"
        },
        {
          "id": "bupivacaine",
          "titleTr": "Bupivakain"
        },
        {
          "id": "ropivacaine",
          "titleTr": "Ropivakain"
        },
        {
          "id": "lipid_emulsion",
          "titleTr": "Lipid Emülsiyonu"
        }
      ],
      "doNotMiss": [
        "Taraf cerrahisi doğrulanmadan ve cerrahi taraf işareti bizzat görülmeden asla iğnenin batırılmaması gerektiği"
      ],
      "whenToEscalate": [
        "Blok tarafında veya hasta kimliğinde uyuşmazlık saptanırsa işlemi durdurun, anestezi ve cerrahi liderleriyle durumu hemen doğrulatın"
      ],
      "referencesToShow": [
        "ASRA Regional Anesthesia Safety Checklist.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "A safety check is mandatory before performing any peripheral nerve block:\n\n1. Confirm correct patient, correct side, and correct block type.\n2. Verify that the surgical site is marked.\n3. Screen for allergies, anticoagulants/antiplatelets, pre-existing neurologic disease, and local infection.\n4. Calculate the maximum safe local anesthetic total dose.\n5. Ensure standard monitoring, patent IV access, oxygen, and resuscitation equipment are ready.\n6. Confirm that lipid emulsion (20% Intralipid) is immediately accessible.\n7. Prepare the ultrasound machine, block needle, catheter, and sterile prep materials.\n8. Plan post-block sensory/motor monitoring and fall-risk precautions.",
      "immediateRedFlags": [
        "Lack of surgical site marking or discrepancy in side verification.",
        "No immediate accessibility to a lipid rescue kit (Intralipid).",
        "Uncorrected coagulopathy in deep or non-compressible block sites."
      ],
      "missingCriticalInformation": [
        "The exact time of the last dose of any anticoagulant medication",
        "Depth of the planned block and compressibility of the anatomical region"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Regional Anesthesia Safety Protocol",
        "LAST Prevention Measures",
        "Patient Safety and Site Verification"
      ],
      "suggestedNextStepsGeneral": [
        "Conduct a formal pre-block 'Time-out' with the team.",
        "Calculate the total milligrams of local anesthetic and ensure it is within safe maximum guidelines.",
        "Visually confirm the presence of lipid emulsion and emergency airway equipment."
      ],
      "relatedAlgorithms": [
        {
          "id": "regional_anesthesia_safety",
          "titleTr": "Regional Safety Control"
        },
        {
          "id": "last_management",
          "titleTr": "LAST Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "local_anesthetic_max_dose",
          "titleTr": "LA Max Dose"
        },
        {
          "id": "anticoagulation_table",
          "titleTr": "Anticoagulation Table"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "lidocaine",
          "titleTr": "Lidocaine"
        },
        {
          "id": "bupivacaine",
          "titleTr": "Bupivacaine"
        },
        {
          "id": "ropivacaine",
          "titleTr": "Ropivakain"
        },
        {
          "id": "lipid_emulsion",
          "titleTr": "Lipid Emulsion"
        }
      ],
      "doNotMiss": [
        "Never insert the needle before verifying the surgical site marking and confirming the side with the patient and chart"
      ],
      "whenToEscalate": [
        "In case of any side or patient discrepancy, immediately halt the procedure and verify with the attending team and surgical leader"
      ],
      "referencesToShow": [
        "ASRA Regional Anesthesia Safety Checklist.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    }
