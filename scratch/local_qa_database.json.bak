    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 Subarachnoid local anesthetic blocks sympathetic preganglionic fibers. This sympathetic blockade triggers profound arterial vasodilation (decreased systemic vascular resistance) and venous pooling (decreased venous return and cardiac output), resulting in rapid hypotension.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
