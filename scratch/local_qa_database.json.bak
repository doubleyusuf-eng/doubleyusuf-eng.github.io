    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "After neuraxial block or epidural catheterization, urgent red flags include new or severe back pain, motor block lasting longer than expected, progressive weakness, sensory loss, radicular pain, or bladder/bowel dysfunction. Review anticoagulant/antiplatelet status, obtain urgent neurologic assessment and MRI. Delay may cause permanent neurologic injury, so the need for surgical decompression must be assessed rapidly.",
      "immediateRedFlags": [
        "Progressive complete motor paralysis of the lower extremities after spinal anesthesia or epidural is a critical emergency.",
        "Urinary retention or fecal incontinence indicates cauda equina compression."
      ],
      "missingCriticalInformation": [
        "Timing of the last anticoagulant/antiplatelet dose",
        "History of a traumatic or bloody needle pass during the procedure"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Post-Neuraxial Spinal Epidural Hematoma Diagnosis",
        "Emergency Spinal Cord Decompression Window",
        "ASRA Hemorrhagic Complications Protocol"
      ],
      "suggestedNextStepsGeneral": [
        "Perform a detailed neurological exam and record motor/sensory deficits.",
        "Order an emergent contrast-enhanced Lumbar MRI immediately.",
        "Alert the Neurosurgery team regarding potential emergent decompression surgery."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "epidural_hematoma_suspicion",
          "titleTr": "Epidural Hematoma Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "asra_coagulation",
          "titleTr": "ASRA Coagulation Table"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "A bloody or difficult needle pass during neuraxial blockade increases hematoma risk; observe closely postoperatively"
      ],
      "whenToEscalate": [
        "In progressive motor deficit, emergency decompressive laminectomy must be performed within 8 HOURS to prevent permanent paraplegia"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Regional Anesthesia and Anticoagulation. 2018. PMID: 29362691.",
        "Horlocker TT, et al. PMID: 29362691."
      ],
      "safetyLevel": "emergency"
    }
