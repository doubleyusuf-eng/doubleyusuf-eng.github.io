  {
    "id": "methemoglobinemia_treatment",
    "category": "clinical_scenarios",
    "keywords": [
      "blue",
      "cyanosis",
      "mavisi",
      "methemoglobinemi",
      "methemoglobinemia",
      "methylene",
      "metilen",
      "prilocaine",
      "prilokain",
      "siyanoz",
      "treatment"
    ],
    "question_tr": "Methemoglobinemi",
    "question_en": "Prilocaine cyanosis",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Methemoglobinemi pulse oksimetrede açıklanamayan yaklaşık %85 civarında satürasyon, çikolata rengi kan, siyanoz ve PaO₂ ile SpO₂ uyumsuzluğu ile düşünülebilir. Prilokain, benzokain, nitratlar ve bazı ilaçlar tetikleyebilir. Tanı ko-oksimetri ile doğrulanır. Semptomatik veya yüksek methemoglobin düzeyinde metilen mavisi düşünülür. G6PD eksikliğinde metilen mavisi etkisiz veya zararlı olabilir; uzman desteği gerekir.",
      "immediateRedFlags": [
        "%100 oksijen tedavisine rağmen SpO₂'nin inatçı şekilde %85 dolaylarında kalması ve hastada derin siyanoz görülmesi.",
        "Çikolata kahverengi koyu renkli arter kanı ve buna eşlik eden doku hipoksisi/laktik asidoz bulguları."
      ],
      "missingCriticalInformation": [
        "Hastanın bilinen G6PD (Glukoz-6-Fosfat Dehidrogenaz) eksikliği öyküsü",
        "Methemoglobin düzeyinin tam oranı (kan gazında ko-oksimetri ile ölçülür)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Methemoglobinemi Tanı ve Tetikleyicileri",
        "Metilen Mavisi Dozlama ve Sınırlamaları",
        "G6PD Eksikliğinde Alternatif Kurtarma Tedavileri (C Vitamini)"
      ],
      "suggestedNextStepsGeneral": [
        "Tetikleyici lokal anestezikleri (Prilokain/Citanest, Benzokain) ve nitratları derhal sonlandırın.",
        "Tanıyı doğrulamak için kan gazından 'Ko-oksimetri' (Co-oximetry) ile methemoglobin (MetHb) yüzdesini ölçün.",
        "Eğer MetHb oranı > %20-30 ise veya hastada doku hipoksisi semptomları varsa, Metilen Mavisi (1-2 mg/kg IV %1'lik solüsyon, 5-10 dakikada) uygulayın.",
        "Eğer hastada G6PD eksikliği varsa Metilen Mavisi kullanmayın (hemolize yol açar); alternatif olarak yüksek doz C Vitamini (Askorbik Asit) düşünün.",
        "Hastayı %100 oksijen ile ventile etmeye devam edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "desaturation",
          "titleTr": "Hipoksemi Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "epinephrine",
          "titleTr": "Adrenalin Monografı"
        },
        {
          "id": "atropine",
          "titleTr": "Atropin Monografı"
        }
      ],
      "doNotMiss": [
        "Pulse oksimetrenin (SpO₂) methemoglobin varlığında %85'e kilitlendiğini, gerçek parsiyel oksijen basıncının (PaO₂) ise normal olabileceğini (SpO₂-PaO₂ uyumsuzluğu)"
      ],
      "whenToEscalate": [
        "Metilen mavisi tedavisine yanıt vermeyen ağır methemoglobinemi ve doku hipoksisi vakalarında yoğun bakıma alıp exchange transfüzyon veya hiperbarik oksijen planlayın"
      ],
      "referencesToShow": [
        "Methemoglobinemia: Etiology, Diagnosis, and Management. Annals of Pharmacotherapy 2018. PMID: 29016373.",
        "ASA Practice Advisory. Anesthesiology 2021. PMID: 32986423."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Suspect methemoglobinemia when pulse oximetry remains around 85% despite oxygen, with chocolate-colored blood, cyanosis, and a PaO₂-SpO₂ mismatch. Prilocaine, benzocaine, nitrates, and other drugs may trigger it. Confirm with co-oximetry. Methylene blue may be used for symptomatic or high methemoglobin levels. In G6PD deficiency, methylene blue may be ineffective or harmful; specialist support is needed.",
      "immediateRedFlags": [
        "Refractory oxygen saturation reading of ~85% despite 100% FiO₂ combined with persistent cyanosis.",
        "Dark chocolate-colored arterial blood and signs of systemic tissue hypoxemia (rising lactate)."
      ],
      "missingCriticalInformation": [
        "Patient's baseline Glucose-6-phosphate dehydrogenase (G6PD) deficiency status",
        "Exact methemoglobin percentage determined via co-oximetry"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Etiology and Diagnosis of Drug-Induced Methemoglobinemia",
        "Methylene Blue Administration Guidelines and Dosing Limits",
        "Alternative Antidotes in G6PD Deficiency (Ascorbic Acid)"
      ],
      "suggestedNextStepsGeneral": [
        "Discontinue the suspected triggering drug immediately (e.g. Prilocaine, Benzocaine topical sprays, Nitrates).",
        "Confirm the diagnosis by measuring the methemoglobin level via an arterial blood gas with a co-oximeter.",
        "Administer Methylene Blue (1-2 mg/kg IV of 1% solution over 5-10 minutes) for MetHb >20-30% or symptomatic tissue hypoxia.",
        "Avoid Methylene Blue in patients with known G6PD deficiency (risk of severe acute hemolysis); utilize high-dose Vitamin C.",
        "Administer 100% high-flow oxygen."
      ],
      "relatedAlgorithms": [
        {
          "id": "desaturation",
          "titleTr": "Hypoxemia Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "epinephrine",
          "titleTr": "Epinephrine Monograph"
        },
        {
          "id": "atropine",
          "titleTr": "Atropine Monograph"
        }
      ],
      "doNotMiss": [
        "Oximeters fail to accurately read oxygen saturation in MetHb, locking onto ~85% due to light absorption overlap, causing an apparent SpO₂-PaO₂ gap"
      ],
      "whenToEscalate": [
        "For refractory cases or severe tissue hypoxia unresponsive to methylene blue, plan immediate ICU transfer for exchange transfusion or hyperbaric oxygen therapy"
      ],
      "referencesToShow": [
        "Methemoglobinemia: Etiology, Diagnosis, and Management. Annals of Pharmacotherapy 2018. PMID: 29016373.",
        "ASA Practice Advisory. Anesthesiology 2021. PMID: 32986423."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "beta_blocker_toxicity",
    "category": "clinical_scenarios",
    "keywords": [
      "beta",
      "blocker",
      "bloker",
      "toksisitesi",
      "toxicity",
      "zehirlenmesi"
    ],
    "question_tr": "Beta bloker toksisitesi",
    "question_en": "Beta bloker zehirlenmesi",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Beta bloker toksisitesi bradikardi, hipotansiyon, AV blok, kardiyojenik şok, bronkospazm, hipoglisemi ve nöbet ile gelebilir. İlk yaklaşım ABC, oksijen, IV erişim ve EKG monitörizasyonudur. Atropin denenebilir ancak yetersiz kalabilir. Glukagon, yüksek doz insülin-öglisemi tedavisi, vazopressör/inotrop, kalsiyum, lipid emülsiyon ve pacing ileri seçeneklerdir. Ciddi olgularda toksikoloji/yoğun bakım ve ECMO değerlendirilir.",
      "immediateRedFlags": [
        "Tedaviye dirençli ağır bradikardi (HR <40 bpm), geniş QRS aritmileri veya tam AV blok.",
        "Kardiyojenik şoka bağlı derin doku perfüzyon bozukluğu, soğuk ekstremiteler ve anüri."
      ],
      "missingCriticalInformation": [
        "Alınan beta bloker ilacın cinsi (özellikle propranolol sodyum kanal blokajı da yapabilir) ve dozu",
        "Eş zamanlı kalsiyum kanal blokeri veya diğer kardiyak ilaçların alınıp alınmadığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Beta Bloker Zehirlenmesi ve Kardiyotoksisite",
        "Yüksek Doz İnsülin-Öglisemi Tedavisi (HDI) Protokolleri",
        "Glukagon ve Vazopressör Tedavi Limitleri"
      ],
      "suggestedNextStepsGeneral": [
        "Havayolunu emniyete alın, yüksek akışlı O₂ başlayın ve geniş IV damar yolları açın.",
        "Bradikardiye karşı Atropin (0.5-1 mg IV) deneyin; ancak dirençli olgularda zaman kaybetmeden ileri tedavilere geçin.",
        "Miyokardiyal kontraktiliteyi artırmak için Glukagon (3-10 mg IV yavaş bolus, ardından 2-5 mg/saat infüzyon) uygulayın.",
        "HDI tedavisi başlatın: 1 U/kg IV Regüler İnsülin bolusu, ardından 1 U/kg/saat infüzyon uygulayın ve öglisemiyi sürdürmek için %20 Dekstroz infüzyonu ile destekleyin.",
        "Hemodinamiyi desteklemek için Noradrenalin veya Epinefrin infüzyonunu filtre edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "pediatric_bradycardia",
          "titleTr": "Pediatrik Bradikardi Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        },
        {
          "id": "maintenance_fluid",
          "titleTr": "İdame Sıvı Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "epinephrine",
          "titleTr": "Adrenalin Monografı"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        },
        {
          "id": "atropine",
          "titleTr": "Atropin Monografı"
        }
      ],
      "doNotMiss": [
        "Glukagonun miyokardiyumu beta-reseptörlerden bağımsız olarak intrasellüler cAMP üzerinden uyararak kasılmayı artırdığını"
      ],
      "whenToEscalate": [
        "Medikal tedaviye dirençli refrakter kardiyojenik şokta acil yoğun bakım ve toksikoloji desteği isteyin, intraaortik balon pompası veya acil VA-ECMO planlayın"
      ],
      "referencesToShow": [
        "Management of Beta-Blocker Poisoning. Clinical Toxicology 2018. PMID: 29016373.",
        "AHA/ACC Guidelines on Toxicology and Poisoning. Circulation 2020."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Beta blocker toxicity may cause bradycardia, hypotension, AV block, cardiogenic shock, bronchospasm, hypoglycemia, and seizures. Initial management includes ABCs, oxygen, IV access, and ECG monitoring. Atropine may be tried but may be insufficient. Options include glucagon, high-dose insulin euglycemia therapy, vasopressors/inotropes, calcium, lipid emulsion, and pacing. Severe cases require toxicology/ICU support and possible ECMO evaluation.",
      "immediateRedFlags": [
        "Refractory bradycardia (HR <40 bpm), widening QRS complexes, or high-degree AV blocks.",
        "Profound cardiogenic shock with systemic hypoperfusion, severe metabolic acidosis, and anuria."
      ],
      "missingCriticalInformation": [
        "Specific beta-blocker ingested (propranolol is unique due to sodium-channel blocking activity) and dose",
        "Co-ingestion of calcium channel blockers or other cardiotoxic agents"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Cardiotoxicity of Beta-Blocker Overdose",
        "High-Dose Insulin-Euglycemia Therapy (HDI) Protocols",
        "Glucagon and Adjuvant Vasopressor Dosing Guidelines"
      ],
      "suggestedNextStepsGeneral": [
        "Secure the airway, provide high-flow oxygen, and establish reliable wide-bore IV access.",
        "Administer Atropine (0.5-1 mg IV) as initial bradycardia rescue; proceed rapidly if ineffective.",
        "Administer Glucagon (3-10 mg IV slow bolus, followed by an infusion of 2-5 mg/h).",
        "Initiate High-Dose Insulin (HDI) therapy: 1 U/kg IV regular insulin bolus followed by 1 U/kg/h infusion, paired with 20% Dextrose to maintain euglycemia.",
        "Support perfusion with titrated Norepinephrine or Epinephrine infusion."
      ],
      "relatedAlgorithms": [
        {
          "id": "pediatric_bradycardia",
          "titleTr": "Pediatric Bradycardia Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        },
        {
          "id": "maintenance_fluid",
          "titleTr": "Maintenance Fluid Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "epinephrine",
          "titleTr": "Epinephrine Monograph"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        },
        {
          "id": "atropine",
          "titleTr": "Atropine Monograph"
        }
      ],
      "doNotMiss": [
        "Glucagon bypasses beta-receptors, directly stimulating intracellular adenylate cyclase and cAMP to increase myocardial contractility"
      ],
      "whenToEscalate": [
        "In the event of refractory shock unresponsive to pharmacotherapy, immediately contact toxicology, plan for transvenous pacing or initiate emergency VA-ECMO"
      ],
      "referencesToShow": [
        "Management of Beta-Blocker Poisoning. Clinical Toxicology 2018. PMID: 29016373.",
        "AHA/ACC Guidelines on Toxicology and Poisoning. Circulation 2020."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "calcium_channel_blocker_toxicity",
    "category": "clinical_scenarios",
    "keywords": [
