  {
    "id": "clinical_followup_anticoagulant_regional_why_0",
    "category": "clinical_followups",
    "keywords": [
      "anticoagulant",
      "antikoagülan",
      "clinical_followup_anticoagulant_regional_why_0",
      "epidural",
      "followup",
      "hematom",
      "hematoma",
      "spinal",
      "var0",
      "why"
    ],
    "question_tr": "Neden antikoagülan kullananlarda spinal blok tehlikelidir?",
    "question_en": "Why is spinal block dangerous in anticoagulated patients?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 Subaraknoid veya epidural boşlukta yer alan epidural venöz pleksus son derece kırılgandır. Antikoagüle hastada iğne teması veya kateter yerleşimi/çekilmesi bu venlerde kanamaya yol açar. Biriken kan, kapalı spinal kanal içinde omuriliği sıkıştırarak kalıcı paraplejiye (bacak felci) neden olur.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 The epidural venous plexus in the neuraxial canal is highly fragile. Needle puncture or catheter manipulation in an anticoagulated patient can cause venous rupture. The accumulating blood compresses the spinal cord within the rigid bony canal, causing permanent paraplegia.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    }
  },
