  {
    "id": "clinical_followup_spinal_hypotension_why_0",
    "category": "clinical_followups",
    "keywords": [
      "blok",
      "clinical_followup_spinal_hypotension_why_0",
      "followup",
      "hipotansiyon",
      "hypotension",
      "post",
      "spinal",
      "var0",
      "why"
    ],
    "question_tr": "Spinal anestezi neden hipotansiyon yapar?",
    "question_en": "Why does spinal anesthesia cause hypotension?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 Lokal anestezik subaraknoid mesafeye verildiğinde, sempatik sinir liflerini bloke eder. Bu sempatik blokaj arteriyel vazodilasyona (sistemik vasküler direnç düşüşü) ve venöz göllenmeye (venöz dönüş ve kardiyak debi düşüşü) yol açar. Sonuçta ani ve derin hipotansiyon gelişir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 Subarachnoid local anesthetic blocks sympathetic preganglionic fibers. This sympathetic blockade triggers profound arterial vasodilation (decreased systemic vascular resistance) and venous pooling (decreased venous return and cardiac output), resulting in rapid hypotension.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    }
  },
