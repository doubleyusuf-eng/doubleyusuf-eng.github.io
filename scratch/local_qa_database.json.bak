        },
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine"
        },
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine"
        },
        {
          "id": "atropine",
          "titleTr": "Atropine"
        },
        {
          "id": "epinephrine",
          "titleTr": "Epinephrine"
        }
      ],
      "doNotMiss": [
        "Apnea in total spinal is caused by motor paralysis of the diaphragm and intercostals, not primary lung injury; prompt mechanical ventilation is curative"
      ],
      "whenToEscalate": [
        "If pulselessness or cardiac arrest occurs, initiate immediate CPR and follow advanced cardiac life support (ACLS) guidelines"
      ],
      "referencesToShow": [
        "ASRA Neuraxial Guidelines.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "emergency"
    }
