      "relatedDrugCards": [],
      "doNotMiss": [
        "Nöroaksiyel kateter yerleştirilmesi sırasında kan gelmesi epidural hematom riskini artırır; postoperatif izlem sıklaştırılmalıdır"
      ],
      "whenToEscalate": [
        "İlerleyici motor kayıpta kalıcı felci önlemek amacıyla ilk 8 SAAT İÇİNDE acil cerrahi dekompresif laminektomi uygulanmalıdır"
      ],
      "referencesToShow": [
