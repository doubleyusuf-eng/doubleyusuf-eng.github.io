      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Even if symptoms have not yet started, accidental wrong-drug administration requires rapid and proactive evaluation. Confirm the drug name, concentration, route, and exact amount. Anticipate expected toxic and pharmacological effects: severe hypotension, hypertension, arrhythmia, respiratory depression, seizure, muscle paralysis, hypoglycemia, or severe allergic reactions. Intensify monitoring (ECG, BP, respiration). Start supportive treatment and specific antidotes immediately if indicated. Inform the surgical team. Document the event transparently, communicate openly, and participate in institutional root-cause analysis.",
      "immediateRedFlags": [
        "Sudden anaphylactic shock or airway edema following wrong-drug administration.",
        "Accidental neuromuscular blocker injection causing acute paralysis and panic in an awake patient.",
        "Refractory arrhythmias caused by accidental cardiotoxic drug injection."
      ],
      "missingCriticalInformation": [
        "The mechanism of action and half-life of the accidentally administered drug",
        "The patient's known drug allergies and active concurrent drug therapies"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Wrong-Drug Administration",
        "Medication Safety & Error Prevention",
        "Crisis Resource Management"
      ],
      "suggestedNextStepsGeneral": [
        "Inspect the vial/syringe label to verify the exact drug and amount administered.",
        "Prepare pharmacologic antagonists or supportive measures ahead of symptom onset.",
        "Ensure advanced airway equipment and resuscitation drugs are immediately at hand.",
        "Record the event honestly and completely in the patient's medical records."
      ],
      "relatedAlgorithms": [
        {
          "id": "last",
          "titleTr": "LAST Toxicity Algorithm"
        },
        {
          "id": "anaphylaxis",
          "titleTr": "Anaphylaxis Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map_calculator",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "epinephrine",
          "titleTr": "Epinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Most wrong-drug errors occur due to look-alike vials or syringe swaps; strict double-checking and labeling are crucial"
      ],
      "whenToEscalate": [
        "If apnea, loss of airway reflexes, or circulatory collapse occurs, secure the airway immediately, call for help, and initiate advanced life support"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Wylie and Churchill-Davidson's A Practice of Anesthesia, 7th Edition."
      ],
      "safetyLevel": "urgent"
    }
