      ],
      "whenToEscalate": [
        "Blok sonrası hastada diz cerrahisine rağmen uylukta motor kayıp varsa, diz splinti uygulayın, hastayı yalnız yürütmeyin ve dozu azaltmayı düşünün"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Adductor Canal Block.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Adductor canal block (ACB) targets the saphenous nerve and the articular branches of the vastus medialis nerve within the adductor canal deep to the sartorius muscle at the mid-thigh. It is widely used for knee surgery analgesia (e.g. total knee arthroplasty).\n\nClinical Characteristics:\n1. Motor-Sparing Property: Preserves quadriceps motor strength (especially rectus femoris and vastus intermedius) much better than a femoral nerve block, femergencyitating early mobilization and active physical therapy.\n2. Limitations: Not purely motor-sparing. High volumes (e.g. > 20 mL) can cause proximal spread into the femoral triangle, resulting in quadriceps weakness.\n3. Analgesic Gaps: Excellent for anterior knee pain but does not cover posterior knee pain (sciatic nerve territory); should be combined with local infiltration analgesia (LIA) or systemic adjuvants.\n4. Risks: Inadvertent femoral vessel puncture (the saphenous nerve lies close to the artery in the canal), LAST, and hematoma.",
      "immediateRedFlags": [
        "Accidental injection into the adjacent femoral vessels within the canal (immediate LAST).",
        "Unexpected dense quadriceps paralysis due to proximal volume runoff.",
        "Deep mid-thigh hematoma following vascular injury."
      ],
      "missingCriticalInformation": [
        "The planned block volume (routinely capped at 15 mL to maintain motor sparing)",
        "Use of intraoperative local infiltration analgesia (LIA) by the surgeon"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Knee Analgesia and Rapid Mobilization",
        "Motor-Sparing Block Limits",
        "Adductor Canal Anatomy"
      ],
      "suggestedNextStepsGeneral": [
        "At the mid-thigh, identify the sartorius muscle, femoral artery, and the saphenous nerve situated anterolateral to the vessel.",
        "Cap the local anesthetic volume at 15 mL to prevent retrograde spread.",
        "Ensure the patient's first post-op ambulation is supervised despite the motor-sparing target."
      ],
      "relatedAlgorithms": [
        {
          "id": "adductor_canal_block",
          "titleTr": "Adductor Canal Block"
        },
        {
          "id": "fall_prevention",
          "titleTr": "Fall Prevention Protocol"
        }
      ],
      "relatedCalculators": [
        {
          "id": "local_anesthetic_max_dose",
          "titleTr": "LA Max Dose"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ropivacaine",
          "titleTr": "Ropivacaine"
        },
        {
          "id": "bupivacaine",
          "titleTr": "Bupivacaine"
        }
      ],
      "doNotMiss": [
        "High volumes in the adductor canal can spill over into the femoral triangle, converting a motor-sparing block into a full femoral motor block"
      ],
      "whenToEscalate": [
        "If the patient demonstrates significant quadriceps weakness after ACB, apply a knee immobilizer, ensure assisted ambulation, and review the volume utilized"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Adductor Canal Block.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    }
  },
