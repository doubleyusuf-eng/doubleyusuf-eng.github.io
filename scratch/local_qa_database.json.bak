      "relatedDrugCards": [],
      "doNotMiss": [
        "PCV modunda kompliyans veya direnç değiştiğinde (örn. cerrahın karına basması) hastaya verilen tidal volümün aniden yarıya düşebileceğini, bu nedenle yakın hacim takibi gerektiğini"
      ],
      "whenToEscalate": [
        "PCV modunda hedeflenen basınca rağmen yetersiz tidal volüm ve dirençli hiperkapni (pH < 7.20) gelişirse, basınç limitini dikkatle artırın veya VCV moduna dönerek frekansı optimize edin"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Anesthesia Ventilator Modes and Clinical Practice Guidelines."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Volume-controlled ventilation delivers a set tidal volume, while pressures vary with compliance and resistance. Pressure-controlled ventilation limits airway pressure, while tidal volume changes with compliance and resistance. Volume control provides more predictable minute ventilation. Pressure control may provide lower peak pressure and decelerating flow in obesity, laparoscopy, or high-pressure situations, but tidal volume may fall. More important than the mode is monitoring tidal volume, plateau pressure, driving pressure, ETCO₂, SpO₂, hemodynamics, and waveforms.",
      "immediateRedFlags": [
        "Dangerous drop in tidal volume during PCV when compliance decreases or surgical pressure rises.",
        "Sudden spike in peak airway pressure (> 35-40 cmH2O) during VCV due to compliance drop.",
        "Acute oxygen desaturation during switching of ventilator modes."
      ],
      "missingCriticalInformation": [
        "The type of surgery (e.g., laparoscopic procedures often benefit from PCV)",
        "The patient's predicted body weight (PBW)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Comparison of Ventilation Modes",
        "VCV and PCV Selection Criteria",
        "Intraoperative Ventilator Management"
      ],
      "suggestedNextStepsGeneral": [
        "Select VCV as the default mode in routine cases where minute ventilation must be guaranteed.",
        "Switch to PCV in obese, pregnant, or laparoscopic patients if peak pressures exceed limits.",
        "In PCV mode, continuously monitor and verify that tidal volume remains within the safe 6-8 mL/kg PBW range.",
        "Track plateau pressure and driving pressure limits regardless of the selected mode."
      ],
      "relatedAlgorithms": [
        {
          "id": "mechanical_ventilation_modes",
          "titleTr": "Mechanical Ventilation Modes"
        },
        {
          "id": "lung_protective_ventilation",
          "titleTr": "Lung Protective Ventilation"
        }
      ],
      "relatedCalculators": [
        {
          "id": "minute_ventilation_calculator",
          "titleTr": "Minute Ventilation Calculator"
        },
        {
          "id": "pbw_calculator",
          "titleTr": "PBW Calculator"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "In PCV mode, any decrease in compliance (e.g., abdominal insufflation) will immediately reduce the delivered tidal volume, requiring strict monitoring"
      ],
      "whenToEscalate": [
        "If target tidal volumes are not met in PCV with persistent hypercapnia (pH < 7.20), carefully increase the pressure limit or switch to VCV and optimize rate"
      ],
      "referencesToShow": [
        "Miller's Anesthesia, 9th Edition.",
        "Anesthesia Ventilator Modes and Clinical Practice Guidelines."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "prone_position_ventilation",
    "category": "clinical_scenarios",
    "keywords": [
      "position",
      "pozisyon",
      "prone",
      "ventilasyon",
