    ],
    "question_tr": "Ponv",
    "question_en": "Vomiting",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Basitleştirilmiş Apfel skoru 4 risk faktöründen oluşur: kadın cinsiyet, sigara içmeme, PONV/taşıt tutması öyküsü, postoperatif opioid kullanımı.\\n0 faktör: düşük risk\\n1 faktör: hafif risk\\n2 faktör: orta risk\\n3–4 faktör: yüksek risk\\n\\nRisk arttıkça multimodal profilaksi düşünülür: TIVA/propofol, opioid azaltma, yeterli hidrasyon, deksametazon, ondansetron veya farklı sınıftan antiemetik kombinasyonu. Kurtarma tedavisinde profilakside kullanılmayan farklı sınıftan ilaç tercih edilir.",
      "immediateRedFlags": [
        "Dirençli PONV durumunda intraabdominal basınç artarak dikiş açılması veya aspirasyon riskini doğurur.",
        "Ciddi kusma sonrası gelişen hipokalemi ve dehidratasyon EKG aritmilerini tetikler."
      ],
      "missingCriticalInformation": [
        "Hastanın Apfel risk puanı (0-4)",
        "Cerrahi türü (laparoskopik, şaşılık, KBB cerrahileri riski bağımsız artırır)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postoperatif Bulantı Kusma (PONV) Kılavuz Standartları",
        "Apfel Risk Skorlama Modeli",
        "Multimodal Antiemetik Profilaksisi ve TİVA"
      ],
      "suggestedNextStepsGeneral": [
        "Apfel skorunu hesaplayın: Kadın (1), Sigara içmeyen (1), PONV öyküsü (1), Postop opioid (1).",
        "Skor >=2 ise multimodal profilaksi: İndüksiyonda Deksametazon 4-8 mg IV ve cerrahi bitiminde Ondansetron 4 mg IV uygulayın.",
        "Yüksek riskli hastalarda indüksiyonda propofol TİVA tekniği planlayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Kurtarma tedavisinde, profilaksi için verilmiş olan ilaç sınıfından (örn. 5-HT3 blokörü Ondansetron) tekrar doz yapılmamalıdır"
      ],
      "whenToEscalate": [
        "Dirençli ve dehidratasyona yol açan PONV varlığında sürekli sıvı replasmanı ve farklı sınıftan antiemetiklerin (örn. Metoklopramid, Droperidol) kombinasyonu"
      ],
      "referencesToShow": [
        "Fourth Consensus Guidelines for the Management of Postoperative Nausea and Vomiting. Anesth Analg 2020; 131(2):411-448. PMID: 32467512.",
        "Apfel CC, et al. PMID: 10485907."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "The simplified Apfel score includes 4 risk factors: female sex, nonsmoking status, history of PONV/motion sickness, and postoperative opioid use.\\n0: low risk\\n1: mild risk\\n2: moderate risk\\n3–4: high risk\\n\\nAs risk increases, consider multimodal prophylaxis: TIVA/propofol, opioid-sparing analgesia, adequate hydration, dexamethasone, ondansetron, or antiemetics from different classes. Rescue therapy should use a different drug class than prophylaxis when possible.",
      "immediateRedFlags": [
        "Intractable vomiting increases intra-abdominal pressure, threatening wound dehiscence or aspiration.",
        "Severe emesis-induced hypokalemia and dehydration can precipitate cardiac arrhythmias."
      ],
      "missingCriticalInformation": [
        "Patient's calculated Apfel risk score (0-4)",
        "Surgical type (laparoscopic, middle ear, strabismus, and ENT surgeries independently increase risk)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postoperative Nausea and Vomiting (PONV) Guidelines",
        "Apfel Simplified Scoring System",
        "Multimodal Antiemetic Prophylaxis and TIVA"
      ],
      "suggestedNextStepsGeneral": [
        "Calculate Apfel score: Female (1), Nonsmoker (1), History of PONV/motion sickness (1), Postop opioids (1).",
        "If score >=2, plan multimodal prophylaxis: Dexamethasone 4-8 mg IV at induction, and Ondansetron 4 mg IV at wound closure.",
        "For high-risk patients, use propofol-based TIVA instead of volatile anesthetics."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Do not administer a repeat dose of the same drug class used for prophylaxis (e.g., repeating Ondansetron) for rescue therapy within 6 hours"
      ],
      "whenToEscalate": [
        "For refractory emesis causing dehydration, initiate active IV fluid replacement and add alternative drug classes (e.g., Metoclopramide, Droperidol)"
      ],
      "referencesToShow": [
        "Fourth Consensus Guidelines for the Management of Postoperative Nausea and Vomiting. Anesth Analg 2020; 131(2):411-448. PMID: 32467512.",
        "Apfel CC, et al. PMID: 10485907."
      ],
      "safetyLevel": "routine"
    }
