  {
    "id": "clinical_followup_cico_crisis_why_0",
    "category": "clinical_followups",
    "keywords": [
      "airway",
      "cico",
      "clinical_followup_cico_crisis_why_0",
      "entübasyon",
      "followup",
      "havayolu",
      "intubasyon",
      "maske",
      "var0",
      "why"
    ],
    "question_tr": "Neden cerrahi havayoluna geçmek zorundayım?",
    "question_en": "Why must i switch to surgical airway?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 CICO (Cannot Intubate, Cannot Oxygenate - Entübe Edilemeyen, Oksijenlenemeyen) durumu en ölümcül anestezi acilidir. Kalıcı hipoksik beyin hasarı ve kardiyak arrest 4 ila 6 dakika içinde gelişir. Havayolu kontrolü üstten sağlanamadığında, hastayı yaşatmak için tek çare membran altından cerrahi havayolu (krikotiroidotomi) açmaktır.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 CICO (Cannot Intubate, Cannot Oxygenate) is the most lethal airway emergency. Irreversible hypoxic brain damage and cardiac arrest occur within 4 to 6 minutes. When the upper airway is completely inaccessible, emergency surgical airway (cricothyroidotomy) is the only option to save the patient's life.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
