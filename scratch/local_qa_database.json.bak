  {
    "id": "clinical_followup_ponv_rescue_contraindications_0",
    "category": "clinical_followups",
    "keywords": [
      "bulantı",
      "clinical_followup_ponv_rescue_contraindications_0",
      "contraindications",
      "followup",
      "kusma",
      "nausea",
      "ponv",
      "rescue",
      "var0",
      "vomiting"
    ],
    "question_tr": "Ondansetronun kontrendikasyonları nelerdir?",
    "question_en": "What are the contraindications of ondansetron?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "⚠️ Ondansetron, konjenital **Uzun QT Sendromu** olan hastalarda kesinlikle kontrendikedir, çünkü QT intervalini daha da uzatarak Torsades de Pointes aritmisine yol açabilir. Droperidol de benzer şekilde QT uzaması olanlarda kontrendikedir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "⚠️ Ondansetron is strictly contraindicated in patients with congenital **Long QT Syndrome**, as it prolongs the QT interval and can precipitate fatal Torsades de Pointes. Similarly, Droperidol is contraindicated in patients with known prolonged QT intervals.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
