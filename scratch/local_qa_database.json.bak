          "id": "local_anesthetic_max_dose",
          "titleTr": "LA Maksimum Doz"
        },
        {
          "id": "pain_score",
          "titleTr": "Ağrı Skoru"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ropivacaine",
          "titleTr": "Ropivakain"
        },
        {
          "id": "bupivacaine",
          "titleTr": "Bupivakain"
        },
        {
          "id": "paracetamol",
          "titleTr": "Parasetamol"
        }
      ],
      "doNotMiss": [
        "Fasya iliaka bloğunun kuadriseps kasında geçici felç yaptığını ve hastanın ilk mobilizasyonunda mutlaka yardım alması gerektiğini"
      ],
      "whenToEscalate": [
        "Blok sonrası hastada dirençli ve şiddetli ağrı devam ederse, blok başarısızlığını, cerrahi komplikasyonu veya kompartman sendromunu ekarte etmek için detaylı muayene yapın"
      ],
      "referencesToShow": [
        "ASRA Hip Fracture Analgesia Guidelines.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Fascia iliaca block (FIB) is a high-volume fascial plane block designed to deposit local anesthetic beneath the fascia iliaca, anesthetizing the femoral nerve, lateral femoral cutaneous nerve, and variably the obturator nerve.\n\nClinical Characteristics:\n1. Indications: Excellent option for relieving preoperative and postoperative pain in geriatric hip fracture patients, femergencyitating positioning, and reducing systemic opioid requirements.\n2. Motor Weakness and Fall Risk: Because the femoral nerve is blocked, quadriceps muscle weakness is expected. This significantly increases the risk of falls; the patient must not ambulate without assistance.\n3. Safety: Direct femoral vessel or nerve puncture risk is lower than with a dedicated femoral nerve block, as the injection site is situated lateral to the femoral neurovascular bundle.\n4. Monitoring: Monitor anticoagulation status, hematoma risk, and LAST (due to the large volumes required, e.g. 30-40 mL). Plan backup analgesia if the block fails.",
      "immediateRedFlags": [
        "Unassisted ambulation leading to a patient fall due to quadriceps weakness.",
        "Systemic local anesthetic toxicity (LAST) from rapid absorption of the high-volume block.",
        "Expanding hematoma in the iliac fossa or groin swelling."
      ],
      "missingCriticalInformation": [
        "The patient's mobility goals and surgical scheduling status",
        "Concurrent anticoagulant use (frequent in elderly hip fracture patients)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Hip Fracture Analgesia Strategies",
        "Fall Prevention and Mobilization Guidelines",
        "High-Volume Fascial Block Management"
      ],
      "suggestedNextStepsGeneral": [
        "Identify the iliacus muscle, fascia iliaca, femoral artery, and femoral nerve clearly under ultrasound.",
        "Advance the needle lateral to the femoral artery, pierce the fascia, and observe the anesthetic peel the fascia iliaca off the muscle.",
        "Ensure a 'Fall Risk' protocol is implemented immediately and the nursing staff is informed."
      ],
      "relatedAlgorithms": [
        {
          "id": "fascia_iliaca_block",
          "titleTr": "Fascia Iliaca Block"
        },
        {
          "id": "fall_prevention",
          "titleTr": "Fall Prevention Protocol"
        },
        {
          "id": "last_management",
          "titleTr": "LAST Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "local_anesthetic_max_dose",
          "titleTr": "LA Max Dose"
        },
        {
          "id": "pain_score",
          "titleTr": "Pain Score"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ropivacaine",
          "titleTr": "Ropivacaine"
        },
        {
          "id": "bupivacaine",
          "titleTr": "Bupivacaine"
        },
        {
          "id": "paracetamol",
          "titleTr": "Paracetamol"
        }
      ],
      "doNotMiss": [
        "A fascia iliaca block consistently causes temporary quadriceps paralysis, making unassisted ambulation extremely dangerous"
      ],
      "whenToEscalate": [
        "Persistent severe pain despite the block requires a complete physical exam to rule out block failure, displaced fracture complications, or compartment syndrome"
      ],
      "referencesToShow": [
        "ASRA Hip Fracture Analgesia Guidelines.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "femoral_block",
    "category": "clinical_scenarios",
    "keywords": [
