      "koroner",
      "stent",
      "var0"
    ],
    "question_tr": "Stent yönetim hatalarının komplikasyonları nelerdir?",
    "question_en": "What are the complications of stent mismanagement?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 En korkulan komplikasyon akut intraoperatif stent trombozudur. Diğer taraftan, DAPT kesilmediğinde cerrahi sahada kontrol edilemeyen masif kanama gelişebilir. Bu nedenle her vaka kardiyolog, cerrah ve anestezist ortak kararıyla multidisipliner yönetilmelidir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 The most feared complication is acute intraoperative stent thrombosis. Conversely, maintaining full DAPT during major surgery can lead to uncontrollable, massive surgical hemorrhage. Manage patients using a joint multidisciplinary decision model.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    }
  },
