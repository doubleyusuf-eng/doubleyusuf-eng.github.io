  {
    "id": "hypertension_postponement",
    "category": "clinical_scenarios",
    "keywords": [
      "ameliyat",
      "ertele",
      "erteleme",
      "ertelenmeli",
      "hypertension",
      "postponed",
      "postponement",
      "tansiyon",
      "yüksek"
    ],
    "question_tr": "Ameliyat ertelenmeli mi",
    "question_en": "Tansiyon yüksek ertele",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Tek bir yüksek tansiyon ölçümüyle karar verilmemelidir; ölçüm tekrarlanmalı, doğru manşon kullanılmalı ve hastanın semptomları değerlendirilmelidir.\\nElektif cerrahide ağır hipertansiyon, özellikle sistolik ≥180 mmHg veya diyastolik ≥110 mmHg düzeylerinde ise, akut uç organ hasarı veya semptom varsa erteleme/optimizasyon düşünülür.\\nGöğüs ağrısı, nörolojik defisit, akut kalp yetmezliği, akut böbrek hasarı, görme bozukluğu veya aort diseksiyonu şüphesi varsa acil değerlendirme gerekir.\\nAsemptomatik, hafif-orta hipertansiyonda çoğu vaka uygun monitörizasyonla devam edebilir.",
      "immediateRedFlags": [
        "Ameliyat öncesi sistolik tansiyonun >=180 mmHg veya diyastolik tansiyonun >=110 mmHg olması ile birlikte semptomların (göğüs ağrısı, nefes darlığı, baş ağrısı, görme kaybı) eşlik etmesi"
      ],
      "missingCriticalInformation": [
        "Hastanın evde ölçülen normal kan basıncı seyri ve ilaç uyumu",
        "Daha önceden bilinen sol ventrikül hipertrofisi veya böbrek yetmezliği durumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Elektif Cerrahide İptal / Erteleme Kriterleri",
        "Asemptomatik Ciddi Hipertansiyon Yönetimi",
        "Kronik Antihipertansif İlaçların Perioperatif Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Ölçümü sakin bir ortamda 5-10 dakika sonra uygun boyutta manşonla tekrarlayın.",
        "Hastanın sabah antihipertansif ilaçlarını (özellikle beta bloker veya kalsiyum kanal blokerini) alıp almadığını kontrol edin.",
        "ACE inhibitörleri ve ARB'lerin genellikle cerrahi sabahı kesildiğini doğrulayın (intraoperatif dirençli hipotansiyon riski).",
        "Asemptomatik hafif-orta hipertansiyon (sistolik <180, diyastolik <110 mmHg) varlığında cerrahiye devam edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Ortalama Arter Basıncı"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "ACE inhibitörü ve ARB grubu ilaçların cerrahi sabahı alınmasının intraoperatif dirençli vazoplejiye (hipotansiyon) neden olabileceği"
      ],
      "whenToEscalate": [
        "Semptomatik organ hasarı bulguları varlığında ameliyatı erteleyin, kardiyoloji konsültasyonu isteyin ve acil servise/yoğun bakıma yönlendirin"
      ],
      "referencesToShow": [
        "ASA/Association of Anaesthetists Guidelines on Perioperative Hypertension. Anaesthesia 2021. PMID: 34599691.",
        "Whelton PK, et al. Anesthesiology 2018. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Do not decide based on a single elevated reading. Repeat the measurement, use an appropriate cuff, and assess symptoms.\\nFor elective surgery, severe hypertension, especially around SBP ≥180 mmHg or DBP ≥110 mmHg, may justify postponement or optimization if symptoms or acute end-organ injury are present. Chest pain, neurologic deficit, acute heart failure, acute kidney injury, visual symptoms, or suspected aortic dissection requires urgent evaluation. Mild to moderate asymptomatic hypertension can often proceed with appropriate monitoring.",
      "immediateRedFlags": [
        "Preoperative SBP >=180 mmHg or DBP >=110 mmHg accompanied by symptoms (chest pain, dyspnea, severe headache, visual loss)."
      ],
      "missingCriticalInformation": [
        "Patient's baseline blood pressure trend at home and medication compliance",
        "History of left ventricular hypertrophy, coronary disease, or renal impairment"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Elective Surgery Cancellation / Postponement Criteria",
        "Asymptomatic Severe Hypertension Management",
        "Perioperative Management of Chronic Antihypertensive Medications"
      ],
      "suggestedNextStepsGeneral": [
        "Repeat measurement after 5-10 minutes of quiet rest using a correct-sized cuff.",
        "Verify if the patient took their morning antihypertensives (especially beta-blockers or calcium channel blockers).",
        "Confirm if ACE inhibitors/ARBs were held on the morning of surgery to prevent refractory intraoperative hypotension.",
        "Proceed with surgery in asymptomatic mild-to-moderate hypertension (SBP <180, DBP <110 mmHg)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Taking ACEIs or ARBs on the morning of surgery can precipitate refractory intraoperative vasoplegic shock"
      ],
      "whenToEscalate": [
        "If symptomatic target organ injury is suspected, postpone elective surgery, obtain Cardiology consult, and transfer to ER/ICU"
      ],
      "referencesToShow": [
        "ASA/Association of Anaesthetists Guidelines on Perioperative Hypertension. Anaesthesia 2021. PMID: 34599691.",
        "Whelton PK, et al. Anesthesiology 2018. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "diabetes_glucose",
    "category": "clinical_scenarios",
    "keywords": [
      "diabetes",
      "diyabet",
      "diyabetik",
      "glucose",
      "glukoz",
      "insülin",
      "yönetimi"
    ],
    "question_tr": "Diyabetik",
    "question_en": "Diyabet",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Amaç hipoglisemiden kaçınırken ciddi hiperglisemiyi önlemektir.\\n\\n1. Son insülin/oral antidiyabetik zamanı öğren.\\n2. Preop glukozu ölç.\\n3. Hipoglisemi varsa önce tedavi et.\\n4. Ciddi hiperglisemi, keton, asidoz veya DKA/HHS şüphesi varsa elektif cerrahi ertelenir.\\n5. İntraoperatif glukozu düzenli izle.\\n6. Uzun cerrahi, insülin kullanan hasta veya glukoz instabilitesi varsa insülin infüzyonu ve dekstroz/potasyum planı gerekebilir.\\n7. SGLT2 inhibitörü kullanan hastada öglisemik ketoasidoz riski unutulmamalıdır.",
      "immediateRedFlags": [
        "Cerrahi öncesi glukoz düzeyinin >300 mg/dL olması ve buna eşlik eden asidoz, keton pozitifliği (Diyabetik Ketoasidoz şüphesi).",
        "Kan glukoz düzeyinin <70 mg/dL olması (akut hipoglisemi krizi)."
      ],
      "missingCriticalInformation": [
        "Hastanın son HbA1c değeri ve en son insülin dozu tipi/saati",
        "Elektif cerrahi sabahı oral antidiyabetiklerin (özellikle Metformin, SGLT2) kesilip kesilmediği"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Perioperatif Diyabet ve Glukoz Yönetimi Kılavuzları",
        "Diyabetik Ketoasidoz (DKA) ve Hiperozmolar Hiperglisemik Durum (HHS)",
        "SGLT2 İnhibitörü İlişkili Öglisemik Ketoasidoz"
      ],
      "suggestedNextStepsGeneral": [
        "Kan şekerini preoperatif dönemde ölçün; hedef aralığı 140-180 mg/dL tutun.",
        "Eğer glukoz <70 mg/dL ise: 100 mL %10 Dekstroz IV verin ve 15 dk sonra tekrar ölçün.",
        "Uzun cerrahilerde kan şekerini her 2 saatte bir izleyin.",
        "Gerektiğinde Regüler İnsülin infüzyonu (infüzyon hızı = glukoz/100 U/saat) ve eş zamanlı %5 Dekstroz + 20 mEq K içeren sıvı infüzyonu başlatın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "SGLT2 inhibitörü alan diyabetiklerde kan şekeri tamamen normal olsa bile perioperatif DKA (öglisemik DKA) gelişebileceği"
      ],
      "whenToEscalate": [
        "Ağır ketoasidoz, anyon gap yüksekliği ve kontrolsüz hiperglisemide ameliyatı erteleyin ve DKA protokolüne geçerek yoğun bakıma yatırın"
      ],
      "referencesToShow": [
        "ADA Standards of Care in Diabetes. Diabetes Care 2023. PMID: 36522802.",
        "Joint British Diabetes Societies (JBDS) Guidelines. 2021."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "The goal is to avoid hypoglycemia while preventing severe hyperglycemia.\\n\\n1. Check the timing of the last insulin/oral antidiabetic dose.\\n2. Measure preoperative glucose.\\n3. Treat hypoglycemia first.\\n4. Postpone elective surgery if severe hyperglycemia, ketones, acidosis, DKA, or HHS is suspected.\\n5. Monitor glucose intraoperatively.\\n6. Long procedures, insulin-treated patients, or unstable glucose may require insulin infusion with dextrose/potassium planning.\\n7. Do not miss euglycemic ketoacidosis risk in patients taking SGLT2 inhibitors.",
      "immediateRedFlags": [
        "Preoperative glucose >300 mg/dL accompanied by acidosis or positive ketones (suspected DKA).",
        "Blood glucose <70 mg/dL (acute hypoglycemia emergency)."
      ],
      "missingCriticalInformation": [
        "Patient's recent HbA1c and type/timing of last insulin dose",
        "Whether oral antidiabetics (especially Metformin, SGLT2 inhibitors) were held on the morning of surgery"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Perioperative Diabetes and Glucose Management Guidelines",
        "Diabetic Ketoacidosis (DKA) and Hyperosmolar Hyperglycemic State (HHS)",
        "SGLT2 Inhibitor-Induced Euglycemic Ketoacidosis"
      ],
      "suggestedNextStepsGeneral": [
        "Check blood glucose preoperatively; target a range of 140-180 mg/dL.",
        "If glucose <70 mg/dL: Administer 100 mL of 10% Dextrose IV and recheck in 15 minutes.",
        "Monitor glucose every 2 hours during long procedures.",
        "If needed, start a regular insulin infusion (rate = glucose/100 U/h) paired with 5% Dextrose + 20 mEq K infusion."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "SGLT2 inhibitor patients can develop severe perioperative DKA even with completely normal blood glucose levels (euglycemic DKA)"
      ],
      "whenToEscalate": [
        "In cases of severe ketoacidosis, high anion gap, and uncontrolled hyperglycemia, postpone surgery and transfer to ICU for insulin protocol"
      ],
      "referencesToShow": [
        "ADA Standards of Care in Diabetes. Diabetes Care 2023. PMID: 36522802.",
        "Joint British Diabetes Societies (JBDS) Guidelines. 2021."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "hypoglycemia",
    "category": "clinical_scenarios",
    "keywords": [
      "düştü",
      "düşük",
      "hipoglisemi",
      "hypoglycemia",
      "kan",
      "şeker",
      "şekeri"
    ],
    "question_tr": "Hipoglisemi",
    "question_en": "Şeker düştü",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Hipoglisemi anestezi altında maskelenebilir; terleme, taşikardi, hemodinamik değişiklik veya açıklanamayan bilinç gecikmesi ile fark edilebilir.\\n\\n1. Kan glukozunu doğrula.\\n2. IV dekstroz ver.\\n3. Glukozu 10–15 dakika sonra tekrar ölç.\\n4. Uzun etkili insülin veya oral antidiyabetik varsa tekrarlayan hipoglisemi açısından izle.\\n5. Bilinci kapalı veya IV erişimi olmayan hastada glukagon düşünülebilir.\\n6. Altta yatan nedenleri değerlendir: açlık, fazla insülin, böbrek yetmezliği, sepsis, karaciğer yetmezliği.",
      "immediateRedFlags": [
        "Kan şekerinin <50 mg/dL olması, dirençli konvülsiyonlar (havale) veya uyanma gecikmesi durumunda kalıcı nörolojik hasar riski mevcuttur."
      ],
      "missingCriticalInformation": [
        "Kullanılan insülin veya oral hipoglisemik ajanın türü (özellikle uzun etkili sülfonilüreler tekrarlayan kriz yapar)",
        "Hastanın eşlik eden renal veya hepatik yetmezlik varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İntraoperatif Maskelenmiş Hipoglisemi Krizleri",
        "Nöroglikopenik Beyin Hasarı ve Koruma",
        "İntravenöz Dekstroz Rezerv Resüsitasyonu"
      ],
      "suggestedNextStepsGeneral": [
        "Kan şekerini derhal parmak ucu veya kan gazından ölçerek doğrulayın.",
        "Erişkinde: 50-100 mL %20 Dekstroz IV veya 200 mL %10 Dekstroz IV yavaş bolus olarak uygulayın.",
        "Çocukta: 2 mL/kg %10 Dekstroz IV bolus uygulayın.",
        "Kan şekerini 10-15 dakikada bir tekrarlayarak >100 mg/dL düzeyinde kaldığını teyit edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Anestezi altındaki hastaların hipoglisemik nörojenik belirtileri (örn. titreme, konfüzyon, ajitasyon) gösteremeyeceği ve sadece terleme/taşikardi ile gelebileceği"
      ],
      "whenToEscalate": [
        "IV yola rağmen kontrol altına alınamayan ağır hipoglisemide Glukagon (1 mg IM/SC) kullanımı ve acil endokrinoloji konsültasyonu ile yoğun bakım"
      ],
      "referencesToShow": [
        "AHA ACLS Guidelines: Management of Metabolic Emergencies. 2020. PMID: 33081529.",
        "ADA Diabetes Standards. 2023. PMID: 36522802."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Hypoglycemia may be masked under anesthesia and may present with sweating, tachycardia, hemodynamic changes, or delayed emergence. Confirm blood glucose, administer IV dextrose, recheck glucose in 10–15 minutes, and monitor for recurrence if long-acting insulin or oral antidiabetics are involved. Glucagon may be considered if IV access is unavailable. Evaluate causes such as fasting, excess insulin, renal failure, sepsis, or liver failure.",
      "immediateRedFlags": [
        "Glucose level <50 mg/dL, refractory seizures, or prolonged unconsciousness carry high risk of irreversible neurological injury."
      ],
      "missingCriticalInformation": [
        "Type of insulin or oral hypoglycemic agent used (long-acting sulfonylureas cause recurrent hypoglycemia)",
        "Co-existing renal or hepatic impairment which impairs glycogenolysis"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Intraoperative Masked Hypoglycemia Crisis",
        "Neuroglycopenic Brain Injury Prevention",
        "Intravenous Dextrose Resuscitation Guidelines"
      ],
      "suggestedNextStepsGeneral": [
        "Confirm blood glucose immediately using a point-of-care test or blood gas.",
        "In adults: Administer 50-100 mL of 20% Dextrose IV or 200 mL of 10% Dextrose IV slow bolus.",
        "In children: Administer 2 mL/kg of 10% Dextrose IV bolus.",
        "Recheck glucose every 10-15 minutes until it stabilizes above 100 mg/dL."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Anesthetized patients cannot show neurogenic symptoms of hypoglycemia; look for unexplained diaphoresis and tachycardia"
      ],
      "whenToEscalate": [
        "If IV access is lost or hypoglycemia is refractory, administer Glucagon 1 mg IM/SC and transfer to ICU with endocrinology consult"
      ],
      "referencesToShow": [
        "AHA ACLS Guidelines: Management of Metabolic Emergencies. 2020. PMID: 33081529.",
        "ADA Diabetes Standards. 2023. PMID: 36522802."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "sglt2_inhibitors",
    "category": "clinical_scenarios",
    "keywords": [
      "inhibitor",
      "inhibitors",
      "ketoacidosis",
      "ketoasidoz",
      "sglt2"
    ],
    "question_tr": "Sglt2",
    "question_en": "Ketoacidosis",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "SGLT2 inhibitörleri perioperatif dönemde öglisemik ketoasidoz riski oluşturabilir. Elektif cerrahide ilacın önceden kesilmiş olması tercih edilir.\\nBulantı, kusma, karın ağrısı, taşipne, açıklanamayan asidoz, keton pozitifliği veya yüksek anyon gap varsa glukoz normal olsa bile ketoasidoz düşünülmelidir.\\nAcil cerrahide keton, kan gazı, elektrolit ve anyon gap takibi yapılmalı; şüphede insülin, dekstroz, sıvı ve yoğun izlem planlanmalıdır.",
      "immediateRedFlags": [
        "Elektif veya acil vakada kan gazında derin metabolik asidoz (pH <7.20, HCO₃ <15 mEq/L) ve kan glukozunun normal (<200 mg/dL) olmasına rağmen belirgin ketonemi/ketonüri mevcudiyeti (Öglisemik DKA)."
      ],
      "missingCriticalInformation": [
        "İlacın (örn. Dapagliflozin, Empagliflozin, Kanagliflozin) en son ne zaman alındığı",
        "Hastanın o anki idrar ve kan keton düzeyleri"
      ],
      "likelyClinicalCategoriesToConsider": [
        "SGLT2 İnhibitörü İlişkili Öglisemik Diyabetik Ketoasidoz (euDKA)",
        "Perioperatif Metabolik Asidoz Ayırıcı Tanısı",
        "İnsülin-Dekstroz Ko-infüzyon Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "SGLT2 inhibitörünü elektif majör cerrahilerden 3-4 gün önce kesildiğini doğrulayın (FDA önerisi).",
        "Açıklanamayan asidoz varlığında glukoz normal olsa bile derhal idrar ve kan ketonu ölçün.",
        "Anyon açığını (Anyon Gap) hesaplayın.",
        "Diyabetik ketoasidoz gelişirse: Hızlı sıvı replasmanı yapın, Regüler İnsülin infüzyonu (0.05-0.1 U/kg/saat) ve asidozu önlemek için %5-10 Dekstroz infüzyonu başlatın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "SGLT2 kullanan hastalarda DKA tablosunda kan şekerinin tamamen normal olabileceği, bu durumun yanıltıcı olmaması gerektiği"
      ],
      "whenToEscalate": [
        "Öglisemik DKA tanısı netleştiğinde elektif cerrahiyi iptal edin ve hastayı insülin-dekstroz infüzyonu ile yoğun bakıma alın"
      ],
      "referencesToShow": [
        "FDA Drug Safety Communication: SGLT2 Inhibitor Hold Times. 2020. PMID: 32986423.",
        "Whelton PK, et al. Anesthesiology 2018. PMID: 29016373."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "SGLT2 inhibitors increase the risk of perioperative euglycemic ketoacidosis. For elective surgery, the medication should ideally be held in advance. Nausea, vomiting, abdominal pain, tachypnea, unexplained acidosis, positive ketones, or high anion gap should raise suspicion even if glucose is normal. In urgent surgery, monitor ketones, blood gas, electrolytes, and anion gap; if suspected, treat with insulin, dextrose, fluids, and close monitoring.",
      "immediateRedFlags": [
        "Severe metabolic acidosis (pH <7.20, HCO₃ <15 mEq/L) on arterial blood gas with normal blood glucose (<200 mg/dL) but positive ketones (Euglycemic DKA)."
      ],
      "missingCriticalInformation": [
        "Exact timing of the last SGLT2 inhibitor dose (e.g., Dapagliflozin, Empagliflozin, Canagliflozin)",
        "Patient's current blood or urine ketone levels"
      ],
      "likelyClinicalCategoriesToConsider": [
        "SGLT2 Inhibitor-Associated Euglycemic Diabetic Ketoacidosis (euDKA)",
        "Perioperative Metabolic Acidosis Differential Diagnosis",
        "Insulin-Dextrose Co-infusion Management Protocol"
      ],
      "suggestedNextStepsGeneral": [
        "Confirm that SGLT2 inhibitors were held 3-4 days before elective major surgeries (FDA guidance).",
        "In the presence of unexplained metabolic acidosis, check ketones immediately even if glucose is normal.",
        "Calculate the Anion Gap.",
        "If DKA occurs: Initiate aggressive fluid resuscitation, start Regular Insulin infusion (0.05-0.1 U/kg/h) combined with 5-10% Dextrose infusion."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Blood glucose can be entirely normal in SGLT2-induced DKA; do not let normal glycemia delay diagnosis"
      ],
      "whenToEscalate": [
        "Once euglycemic DKA is confirmed, postpone elective surgery and immediately transfer the patient to the ICU on an insulin protocol"
      ],
      "referencesToShow": [
        "FDA Drug Safety Communication: SGLT2 Inhibitor Hold Times. 2020. PMID: 32986423.",
        "Whelton PK, et al. Anesthesiology 2018. PMID: 29016373."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "pacemaker_prep",
    "category": "clinical_scenarios",
    "keywords": [
      "cihaz",
      "icd",
      "kalp",
      "kontrolü",
      "pacemaker",
      "pili",
      "prep"
    ],
    "question_tr": "Pacemaker",
    "question_en": "Cihaz kontrolü",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Cihaz tipi, endikasyon, pacemaker bağımlılığı, son kontrol tarihi ve cerrahi alan elektrokoter ilişkisi değerlendirilmelidir.\\n\\n1. Cihaz kartını veya son raporu kontrol et.\\n2. Pacemaker bağımlılığı var mı değerlendir.\\n3. Elektrokoter kullanılacaksa monopolar/bipolar farkını ve cerrahi alanı belirle.\\n4. ICD varsa intraoperatif şok tedavilerinin geçici devre dışı bırakılması gerekebilir.\\n5. Harici defibrilatör/pacing pedleri hazır olmalı.\\n6. Mıknatıs yanıtı cihazdan cihaza değişir; varsayım yapma.\\n7. Postoperatif cihaz kontrolü gerekebilir.",
      "immediateRedFlags": [
        "Hastanın pacemaker bağımlı olması ve monopolar kotere maruz kalacak göğüs üstü majör cerrahiye girmesi.",
        "ICD'si (İmplantabl Kardiyoverter Defibrilatör) olan hastada koter etkileşimi nedeniyle cihazın yanlışlıkla şok verme riski."
      ],
      "missingCriticalInformation": [
        "Son 6-12 ay içinde yapılmış resmi kardiyoloji cihaz kontrolü raporu",
        "Hastanın pacemaker bağımlılık durumu (vagal bradikardi veya total AV blok öyküsü)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Perioperatif Kalp Pili (Pacemaker) ve ICD Yönetimi",
        "Elektromanyetik Girişim (EMI) Risk Skoru",
        "Mıknatıs (Magnet) Uygulama Standartları"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın cihaz kartını inceleyerek model, tip ve endikasyonu teyit edin.",
        "Eğer ICD varsa: Elektrokoterin yanlış şok tetiklemesini önlemek için cihazı ameliyat öncesi inaktive ettirin.",
        "Ameliyathanede harici defibrilatör pedlerini hastanın göğsüne yapışık ve hazır bulundurun.",
        "Cerrahın bipolar koter veya harmonik neşter kullanmasını zorunlu tutun."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Mıknatıs konulmasının her cihazda aynı etkiyi yapmadığı; bazı cihazlarda magnet koymanın ICD şokunu engellediği ama pacing modunu değiştirmediği"
      ],
      "whenToEscalate": [
        "Coter sonrasında pacing kaybı veya disritmi geliştiğinde derhal cerrahiyi durdurun ve harici pacing'e geçin"
      ],
      "referencesToShow": [
        "ASA Practice Advisory on the Perioperative Management of Patients with CIEDs. Anesthesiology 2020. PMID: 32014671.",
        "Kardiyoloji Derneği Kılavuzları. 2021."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Assess device type, indication, pacemaker dependence, last interrogation, and the relationship between surgical field and electrocautery. Check the device card or report, determine pacemaker dependence, identify monopolar/bipolar cautery use and surgical site, and consider temporary suspension of ICD shock therapies when indicated. External defibrillation/pacing pads should be available. Magnet response varies by device; do not assume. Postoperative device interrogation may be required.",
      "immediateRedFlags": [
        "A pacemaker-dependent patient scheduled for major thoracic/abdominal surgery involving monopolar cautery.",
        "An active ICD patient exposed to monopolar cautery above the umbilicus, risking inappropriate shocks."
      ],
      "missingCriticalInformation": [
        "A formal device interrogation report within the last 6 months (ICD) or 12 months (pacemaker)",
        "Patient's pacemaker dependency status (e.g., complete AV block)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Perioperative Cardiac Implantable Electronic Device (CIED) Management",
        "Electromagnetic Interference (EMI) Risk Assessment",
        "Intraoperative Magnet Application Principles"
      ],
      "suggestedNextStepsGeneral": [
        "Review the device card to identify model, type, and programming.",
        "If patient has an ICD: Temporarily suspend anti-tachycardia/shock therapies prior to incision.",
        "Ensure external defibrillation pads are applied to the patient before induction.",
        "Ensure the surgeon uses bipolar cautery or ultrasonic scalpel in short bursts."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Placing a magnet over an ICD disables shock therapy but does NOT guarantee asynchronous pacing mode; verify device configuration"
      ],
      "whenToEscalate": [
        "If electromagnetic interference triggers severe bradycardia or asystole, halt cautery immediately and activate external pacing"
      ],
      "referencesToShow": [
        "ASA Practice Advisory on the Perioperative Management of Patients with CIEDs. Anesthesiology 2020. PMID: 32014671.",
        "Kardiyoloji Derneği Kılavuzları. 2021."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "electrocautery_interference",
    "category": "clinical_scenarios",
    "keywords": [
      "electrocautery",
      "elektrokoter",
      "girişim",
      "interference",
      "koter"
    ],
    "question_tr": "Koter",
    "question_en": "Girişim",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Evet, özellikle monopolar elektrokoter elektromanyetik girişim yapabilir. Bu durum pacemaker inhibisyonu, uygunsuz pacing, ICD’de uygunsuz şok veya tedavinin engellenmesine yol açabilir.\\n\\nRisk azaltma: bipolar koter tercih et, kısa aralıklı düşük enerji kullan, dispersif elektrodu cihazdan uzak ve akım yolu cihazdan geçmeyecek şekilde yerleştir, hemodinamiyi ve EKG’yi izle, harici defibrilasyon/pacing hazır bulundur. ICD tedavileri askıya alındıysa işlem sonrası yeniden aktive edildiğinden emin ol.",
      "immediateRedFlags": [
        "Monopolar koter kullanımı sırasında EKG dalga boyunun tamamen parazitlenmesi ve nabız oksimetresinin dalga kaybı (hemodinaminin izlenememesi).",
        "Cihazın koter dalgasını R dalgası sanarak pacing'i tamamen durdurması (asistoli)."
      ],
      "missingCriticalInformation": [
        "Elektrokoterin uygulanacağı cerrahi bölgenin cihaza uzaklığı (göbek altı cerrahilerde EMI riski düşüktür)",
        "Hastanın anlık nabız ve arter dalga trasesi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Elektromanyetik Girişim (EMI) ve Pacing İnhibisyonu",
        "Koter Şase (Dispersif) Elektrot Yerleşim Kuralları",
        "Harici Defibrilatör ve Transkütan Pacing Hazırlığı"
      ],
      "suggestedNextStepsGeneral": [
        "Monopolar elektrokoter yerine öncelikle Bipolar veya Harmonik koter kullanımını zorunlu tutun.",
        "Coter plağını akım yolu kalpten ve pacemaker cihazından geçmeyecek şekilde bacağa yerleştirin.",
        "Koter kullanımını 2-3 saniyelik kısa boluslarla sınırlayın.",
        "Koter sırasında nabzı ve arter trasesini (varsa) sürekli takip edin.",
        "Koter sonrası EKG'de pacing ritminin devam ettiğini doğrulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Koter kullanımı sırasında EKG parazitlendiği için hemodinami takibinin nabız arter trasesi veya pletismografi ile yapılması gerektiği"
      ],
      "whenToEscalate": [
        "Pacemaker inhibisyonu sonucu asistoli veya ventriküler taşikardi gelişirse derhal koteri durdurtun ve magnet yerleştirerek asenkron moda (VOO/DOO) geçin"
      ],
      "referencesToShow": [
        "ASA Practice Advisory on the Perioperative Management of Patients with CIEDs. Anesthesiology 2020. PMID: 32014671.",
        "HRS/ASA Expert Consensus Statement. 2011."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Yes. Monopolar electrocautery can cause electromagnetic interference, leading to pacemaker inhibition, inappropriate pacing, inappropriate ICD shocks, or failure of therapy. Reduce risk by using bipolar cautery when possible, short low-energy bursts, placing the dispersive pad away from the device so current does not cross it, monitoring ECG and hemodynamics, and having external defibrillation/pacing ready. If ICD therapies are suspended, ensure they are reactivated after the procedure.",
      "immediateRedFlags": [
        "Complete loss of ECG tracing and plethysmographic waveform during active monopolar cautery use.",
        "Oversensing of cautery signals by the pacemaker, resulting in complete inhibition of pacing and asystole."
      ],
      "missingCriticalInformation": [
        "Distance between the surgical incision site and the CIED generator (below umbilicus is low risk)",
        "Patient's real-time arterial pressure trace or plethysmographic pulse"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Electromagnetic Interference (EMI) and Pacing Inhibition",
        "Dispersive Electrode (Grounding Pad) Placement Guidelines",
        "External Defibrillating and Transcutaneous Pacing Readiness"
      ],
      "suggestedNextStepsGeneral": [
        "Mandate bipolar or harmonic electrocautery instead of monopolar when possible.",
        "Place the grounding pad on a lower extremity to ensure current path avoids the heart and generator.",
        "Limit monopolar cautery bursts to less than 2-3 seconds at a time.",
        "Monitor perfusion continuously via arterial line or pulse oximetry plethysmography during cautery bursts.",
        "Verify the return of baseline pacing rhythm immediately after cautery stop."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "ECG monitors are highly susceptible to cautery noise; utilize pulse oximetry sound or arterial trace to monitor hemodynamics during cautery use"
      ],
      "whenToEscalate": [
        "In the event of severe pacing inhibition or ventricular arrhythmia, immediately stop cautery and apply a magnet to force asynchronous (VOO/DOO) mode"
      ],
      "referencesToShow": [
        "ASA Practice Advisory on the Perioperative Management of Patients with CIEDs. Anesthesiology 2020. PMID: 32014671.",
        "HRS/ASA Expert Consensus Statement. 2011."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "preeclampsia_anesthesia",
    "category": "clinical_scenarios",
    "keywords": [
      "anestezi",
      "anesthesia",
      "gebelik",
      "obstetrik",
      "preeclampsia",
      "preeklampsi",
      "tansiyonu"
    ],
    "question_tr": "Preeklampsi",
    "question_en": "Pregnancy tansiyonu",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Preeklampside temel riskler hipertansiyon, zor havayolu, pulmoner ödem, koagülopati, trombositopeni, eklampsi ve uteroplasental perfüzyon bozulmasıdır.\\n\\n1. Kan basıncı, semptomlar, trombosit, karaciğer/böbrek fonksiyonları değerlendirilir.\\n2. Trombosit ve koagülasyon uygunsa nöroaksiyel anestezi genellikle avantajlıdır.\\n3. Genel anestezi gerekirse zor havayolu, aspirasyon ve abartılı hipertansif entübasyon yanıtı için hazırlık yapılır.\\n4. Magnezyum sülfat kullanılıyorsa nöromüsküler bloker duyarlılığı ve solunum depresyonu açısından dikkat edilir.\\n5. Ciddi hipertansiyon acil tedavi edilmelidir.",
      "immediateRedFlags": [
        "Trombosit sayısının <70.000/mcL olması veya hızla düşmesi (HELLP sendromu şüphesi - spinal epidural hematom riski!).",
        "Preeklamptik gebede EKG'de veya dinlemede pulmoner ödem bulguları (krepitaller, SpO₂ düşüşü)."
      ],
      "missingCriticalInformation": [
        "Güncel trombosit sayısı ve koagülasyon parametreleri (son 2 saat içinde alınmış olmalıdır)",
        "Hastanın nörolojik durumu (şiddetli baş ağrısı, klonus, görme bulanıklığı var mı?)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Preeklampsi ve HELLP Sendromu Anestezi Kriterleri",
        "Obstetrik Zor Havayolu ve Larenjeal Ödem",
        "Magnezyum Sülfat Tedavisi ve İlaç Etkileşimleri"
      ],
      "suggestedNextStepsGeneral": [
        "Trombosit sayısı >75.000-80.000/mcL ve stabil ise spinal anesteziyi tercih edin (genel anesteziye göre çok daha güvenlidir).",
        "Genel anestezi uygulanacaksa, laringoskopiye bağlı şiddetli hipertansif atağı (inme riski) önlemek için Esmolol (0.5 mg/kg IV) veya Remifentanil (1 mcg/kg IV) kullanın.",
        "Magnezyum alan hastada kas gevşeticilerin (özellikle roküronyum) etkisinin uzayacağını öngörün ve TOF takibi yapın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Süksinilkolin Monografı"
        },
        {
          "id": "rocuronium",
          "titleTr": "Roküronyum Monografı"
        }
      ],
      "doNotMiss": [
        "Preeklamptik gebelerde larenjeal ödem nedeniyle normal gebelere kıyasla entübasyonun çok daha zor olabileceği gerçeği"
      ],
      "whenToEscalate": [
        "Eklampsi nöbeti veya akciğer ödemi gelişirse derhal Magnezyum Sülfat infüzyonunu başlatın, havayolunu güvenceye alın ve yoğun bakıma alın"
      ],
      "referencesToShow": [
        "ACOG Practice Bulletin No. 222: Gestational Hypertension and Preeclampsia. Obstet Gynecol 2020. PMID: 32444461.",
        "Obstetric Anesthesia Digest. 2021."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Main risks include hypertension, difficult airway, pulmonary edema, coagulopathy, thrombocytopenia, eclampsia, and impaired uteroplacental perfusion. Assess blood pressure, symptoms, platelets, liver and renal function. If platelet count and coagulation are acceptable, neuraxial anesthesia is often advantageous. If general anesthesia is required, prepare for difficult airway, aspiration risk, and exaggerated hypertensive response to intubation. Magnesium sulfate increases sensitivity to neuromuscular blockers and may contribute to respiratory depression. Severe hypertension requires urgent treatment.",
      "immediateRedFlags": [
        "Platelet count <70,000/mcL or dropping rapidly (HELLP syndrome suspicion - extreme risk of spinal hematoma).",
        "ECG or clinical signs of pulmonary edema (rales, wheezing, SpO₂ drop) in a preeclamptic parturient."
      ],
      "missingCriticalInformation": [
        "Most recent platelet count and coagulation profile (must be within the last 2 hours)",
        "Neurological symptoms (severe headache, hyperreflexia, visual disturbances)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Preeclampsia and HELLP Syndrome Anesthetic Guidelines",
        "Obstetric Difficult Airway and Laryngeal Edema",
        "Magnesium Sulfate Therapy and Neuromuscular Blockade Interactions"
      ],
      "suggestedNextStepsGeneral": [
        "If platelets are >75,000-80,000/mcL and stable, prefer spinal anesthesia over general anesthesia.",
        "If general anesthesia is unavoidable, blunt the hypertensive response to intubation with Esmolol (0.5 mg/kg IV) or Remifentanil (1 mcg/kg IV).",
        "Anticipate significantly prolonged duration of non-depolarizing neuromuscular blockers in patients receiving Magnesium Sulfate; utilize quantitative TOF."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Succinylcholine Monograph"
        },
        {
          "id": "rocuronium",
          "titleTr": "Rocuronium Monograph"
        }
      ],
      "doNotMiss": [
        "Airway edema is highly prevalent in severe preeclampsia; anticipate a significantly more difficult intubation than a standard obstetric patient"
      ],
      "whenToEscalate": [
        "In the event of an eclamptic seizure or acute pulmonary edema, initiate Magnesium protocol, secure the airway, and transfer to ICU"
      ],
      "referencesToShow": [
        "ACOG Practice Bulletin No. 222: Gestational Hypertension and Preeclampsia. Obstet Gynecol 2020. PMID: 32444461.",
        "Obstetric Anesthesia Digest. 2021."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "eclampsia_seizure",
    "category": "clinical_scenarios",
    "keywords": [
      "eclampsia",
      "eklampsi",
      "magnezyum",
      "nöbet",
      "nöbeti",
      "seizure",
      "sülfat"
    ],
    "question_tr": "Eklampsi nöbeti",
    "question_en": "Nöbet",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "1. Yardım çağır.\\n2. Hastayı travmadan koru, sol lateral pozisyon ver.\\n3. Havayolu ve oksijenasyonu sağla.\\n4. Magnezyum sülfat ilk basamak antikonvülzandır.\\n5. Kan basıncını kontrol et; ciddi hipertansiyon tedavi edilmelidir.\\n6. Fetal durum ve doğum planı obstetri ekibiyle değerlendirilir.\\n7. Magnezyum toksisitesi açısından solunum sayısı, refleksler ve idrar çıkışı izlenir; toksisite varsa kalsiyum glukonat hazır olmalıdır.",
      "immediateRedFlags": [
        "Dirençli nöbetler (status epileptikus) ve buna bağlı gelişen derin maternal hipoksi.",
        "Nöbet sırasında gelişen gastrik içerik aspirasyonu.",
        "Magnezyum toksisitesine bağlı solunum depresyonu veya derin bradikardi."
      ],
      "missingCriticalInformation": [
        "Hastanın o ana kadar aldığı toplam Magnezyum Sülfat miktarı",
        "Nöbet sonrasında gelişen maternal SpO₂ ve hemodinami durumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Eklamptik Nöbet Kriz Yönetimi",
        "Magnezyum Sülfat Yükleme ve İdame Dozlama Protokolleri",
        "Magnezyum Toksisitesi ve Reversal (Kalsiyum) İlkeleri"
      ],
      "suggestedNextStepsGeneral": [
        "Acil yardım çağırın ve hastayı korumak için sol lateral pozisyona alın, orofarenksi aspire edin.",
        "Magnezyum Sülfat: 4-6 g IV bolus (15-20 dakikada) uygulayın, ardından 1-2 g/saat sürekli infüzyon başlatın.",
        "Nöbet devam ederse: Ek 2 g Magnezyum Sülfat IV bolus veya yavaş yavaş Midazolam (2-5 mg IV) uygulayın.",
        "Ciddi hipertansiyon (Tansiyon >160/110 mmHg) varsa: Labetalol (20 mg IV yavaş bolus) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Süksinilkolin Monografı"
        },
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monografı"
        }
      ],
      "doNotMiss": [
        "Magnezyum toksisitesi durumunda (derin tendon refleksleri kaybı, solunum depresyonu) panzehir olarak derhal 1 g Kalsiyum Glukonat veya Kalsiyum Klorür IV verilmelidir"
      ],
      "whenToEscalate": [
        "Nöbete bağlı havayolu korunamıyorsa, hipoksi düzelmiyorsa derhal hızlı ardışık entübasyon (RSI) ve acil sezaryen planı ile yoğun bakım"
      ],
      "referencesToShow": [
        "ACOG Guidelines. Obstet Gynecol 2020. PMID: 32444461.",
        "AHA Resuscitation Guidelines. 2020. PMID: 33081529."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "1. Call for help.\\n2. Protect the patient from injury, place in left lateral position.\\n3. Secure airway and oxygenation.\\n4. Magnesium sulfate is the first-line anticonvulsant therapy.\\n5. Control severe hypertension.\\n6. Assess fetal status and delivery plan with the obstetric team.\\n7. Monitor for magnesium toxicity using respiratory rate, reflexes, and urine output; calcium gluconate should be available for toxicity.",
      "immediateRedFlags": [
        "Refractory seizures (status eclampticus) causing profound maternal hypoxia and fetal distress.",
        "Gastric aspiration during active seizure.",
        "Magnesium toxicity-induced severe respiratory depression or cardiac bradycardia."
      ],
      "missingCriticalInformation": [
        "Cumulative dose of Magnesium Sulfate administered prior to the seizure",
        "Post-ictal maternal SpO₂ and hemodynamic parameters"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Eclamptic Seizure Crisis Management",
        "Magnesium Sulfate Loading and Maintenance Protocols",
        "Magnesium Toxicity Recognition and Reversal"
      ],
      "suggestedNextStepsGeneral": [
        "Call for experienced obstetric and anesthesia help immediately; place patient in left lateral position.",
        "Magnesium Sulfate: Administer 4-6 g IV loading dose (over 15-20 min), followed by 1-2 g/h continuous infusion.",
        "If seizures recur: Administer an additional 2 g IV Magnesium Sulfate or slow IV Midazolam (2-5 mg).",
        "Treat severe hypertension (BP >160/110 mmHg) with slow IV Labetalol (20 mg boluses)."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Succinylcholine Monograph"
        },
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monograph"
        }
      ],
      "doNotMiss": [
        "In case of Magnesium toxicity (loss of patellar reflexes, apnea), immediately administer 1 g Calcium Gluconate IV as the antidote"
      ],
      "whenToEscalate": [
        "If the airway is compromised or hypoxia persists post-seizure, perform rapid sequence intubation (RSI) and plan emergent delivery"
      ],
      "referencesToShow": [
        "ACOG Guidelines. Obstet Gynecol 2020. PMID: 32444461.",
        "AHA Resuscitation Guidelines. 2020. PMID: 33081529."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "postpartum_hemorrhage",
    "category": "clinical_scenarios",
    "keywords": [
      "doğum",
      "hemoraji",
      "hemorrhage",
      "kanama",
      "postpartum",
      "sonu",
      "uterotonik"
    ],
    "question_tr": "Postpartum hemoraji",
    "question_en": "Uterotonik",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Postpartum hemoraji obstetrik acildir.\\n\\n1. Yardım çağır; obstetri, anestezi, kan bankası ve yoğun bakım koordinasyonu sağla.\\n2. Büyük damar yolu aç, arter hattı düşün.\\n3. MTP’yi erken aktive et.\\n4. Uterotonikler ve cerrahi kanama kontrolü obstetri ekibiyle eş zamanlı yürütülür.\\n5. Traneksamik asit uygun zamanda düşünülür.\\n6. Fibrinojen obstetrik kanamada erken düşebilir; fibrinojen/ROTEM-FIBTEM hedefli replasman önemlidir.\\n7. Hipotermi, asidoz ve hipokalsemi düzeltilmelidir.",
      "immediateRedFlags": [
        "Hızlı vajinal/abdominal kanama ile birlikte gelişen refrakter hipotansiyon (OAB <50 mmHg) ve taşikardi (şok tablosu).",
        "Sezaryen sırasında gelişen anutrik atoni (uterusun kasılamaması).",
        "Erken dönemde ortaya çıkan pıhtılaşma bozukluğu (yaygın damar içi pıhtılaşma - DIC)."
      ],
      "missingCriticalInformation": [
        "Postpartum kanamanın temel nedeni (4T kuralı: Tonus/Atoni, Doku/Plasenta artığı, Travma/Yırtık, Trombin/Koagülopati)",
        "Kan bankasındaki taze donmuş plazma ve eritrosit hazırlık durumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postpartum Hemoraji (PPH) Kriz Kılavuzları",
        "Uterotonik İlaç Protokolleri ve Dosing",
        "Obstetrik Kanamalarda Hedefe Yönelik Fibrinojen Replasmanı"
      ],
      "suggestedNextStepsGeneral": [
        "Obstetrik Mavi Kod ilan edin ve Masif Transfüzyon Protokolünü (MTP) derhal aktive edin.",
        "Geniş çaplı (14-16G) iki adet damar yolu açın, arter hattı yerleştirin ve Level 1 hızlı infüzyon sistemini hazırlayın.",
        "Oksitosin (20-40 Ünite/L SF içinde infüzyon), gerekirse Metilergometrin (0.2 mg IM) veya Karboprost (0.25 mg IM) uygulayın.",
        "Traneksamik Asit: Doğum sonrası ilk 3 saat içinde 1 g IV (yavaş bolus) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Obstetrik kanamalarda fibrinojen düzeyinin 200 mg/dL'nin altına düşmesi kritik eşiktir; erken dönemde fibrinojen konsantresi verilmelidir"
      ],
      "whenToEscalate": [
        "Medikal tedaviye dirençli atoni kanamalarında cerrahi ligasyon, B-Lynch sütürü, balon tamponad veya acil histerektomi kararı"
      ],
      "referencesToShow": [
        "ACOG Practice Bulletin No. 183: Postpartum Hemorrhage. Obstet Gynecol 2017. PMID: 28937966.",
        "WOMAN Trial Collaborators. Lancet 2017. PMID: 28457704."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Postpartum hemorrhage is an obstetric emergency. Call for help and coordinate obstetrics, anesthesia, blood bank, and ICU teams. Establish large-bore IV access and consider arterial monitoring. Activate MTP early. Uterotonics and surgical bleeding control should proceed with the obstetric team. Consider timely tranexamic acid. Fibrinogen may fall early in obstetric bleeding; fibrinogen/ROTEM-FIBTEM guided replacement is important. Correct hypothermia, acidosis, and hypocalcemia.",
      "immediateRedFlags": [
        "Rapid vaginal or intra-abdominal bleeding presenting with refractory hypotension (MAP <50 mmHg) and tachycardia (hemorrhagic shock).",
        "Severe uterine atony unresponsive to primary massage.",
        "Early onset of coagulopathy and diffuse oozing (DIC)."
      ],
      "missingCriticalInformation": [
        "Primary cause of PPH (4Ts rule: Tone/Atony, Tissue/Retained placenta, Trauma/Laceration, Thrombin/Coagulopathy)",
        "Availability of blood components in the hospital blood bank"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postpartum Hemorrhage (PPH) Management Guidelines",
        "Uterotonic Pharmacotherapy and Dosing",
        "Goal-Directed Fibrinogen Replacement in Obstetrics"
      ],
      "suggestedNextStepsGeneral": [
        "Declare an Obstetric Hemorrhage Emergency and activate the Massive Transfusion Protocol (MTP).",
        "Insert two large-bore (14G or 16G) IV lines and establish arterial line monitoring.",
        "Administer Oxytocin (20-40 U/L infusion), Methergine (0.2 mg IM), or Carboprost (0.25 mg IM) as indicated.",
        "Give Tranexamic Acid (1 g IV slow bolus) within 3 hours of birth."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Fibrinogen levels fall rapidly in major obstetric bleeding; a level <200 mg/dL is a trigger for immediate fibrinogen concentrate or cryoprecipitate"
      ],
      "whenToEscalate": [
        "For uterine atony refractory to medical management, immediately proceed to intrauterine balloon tamponade, uterine compression sutures, pelvic embolization, or emergency hysterectomy"
      ],
      "referencesToShow": [
        "ACOG Practice Bulletin No. 183: Postpartum Hemorrhage. Obstet Gynecol 2017. PMID: 28937966.",
        "WOMAN Trial Collaborators. Lancet 2017. PMID: 28457704."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "maternal_arrest",
    "category": "clinical_scenarios",
    "keywords": [
      "arrest",
      "deplasman",
      "gebede",
      "maternal",
      "perimortem",
      "sezaryen",
      "sol",
      "uterin"
    ],
    "question_tr": "Gebede arrest",
    "question_en": "Perimortem sezaryen",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "🚨 GEBEDE KARDİYAK ARREST! SOL UTERİN DEPLASMAN VE YÜKSEK KALİTELİ RESÜSİTASYONU DERHAL BAŞLATIN!",
      "conversationalText": "Gebede resüsitasyon temel ACLS prensiplerine dayanır, ancak uterin aortokaval bası giderilmelidir.\\n\\n1. Yüksek kaliteli CPR başlat.\\n2. Sol uterin deplasman uygula.\\n3. Defibrilasyon endikasyonu değişmez.\\n4. Havayolu ve aspirasyon riski için deneyimli kişi çağır.\\n5. Geri döndürülebilir nedenleri ara: kanama, emboli, anestezi komplikasyonu, eklampsi, sepsis, kardiyak hastalık.\\n6. Gebelik haftası uygunsa ve ROSC sağlanamıyorsa perimortem sezaryen kararı erken verilmelidir.",
      "immediateRedFlags": [
        "Maternal nabızsızlık ve apne.",
        "Aortokaval kompresyona bağlı olarak sırtüstü pozisyonda yapılan göğüs kompresyonlarının kalbe dönen kanı tamamen engellemesi (etkisiz CPR)."
      ],
      "missingCriticalInformation": [
        "Gebeliğin tam haftası (20. gebelik haftası veya uterusun göbek seviyesine ulaştığı durum perimortem sezaryen eşiğidir)",
        "Arrestin tetikleyici nedeni (örn. yüksek spinal anestezi, magnezyum toksisitesi, anafilaksi, amniyotik sıvı embolisi)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Maternal Kardiyak Arrest Kılavuzları (AHA 2020/2025)",
        "Aortokaval Kompresyon ve Sol Uterin Deplasman",
        "Perimortem Sezaryen (Resüsitatif Histerektomi) Zamanlaması"
      ],
      "suggestedNextStepsGeneral": [
        "Kardiyak arrest ilan edin, CPR başlatın ve defibrilatörü getirtin.",
        "Göğüs kompresyonları sırasında uterusu manuel olarak SOLA iterek (Sol Uterin Deplasman) aortokaval basıyı kesinlikle giderin.",
        "Havayolunu hızlıca kaflı endotrakeal tüp ile güvenceye alın (gebede zor havayolu ve aspirasyon riski çok yüksektir).",
        "Arrestin 4. dakikasında ROSC sağlanamadıysa, 5. dakikada doğumu tamamlamak üzere derhal 'Perimortem Sezaryen' (PMCD) başlatın."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Efedrin Monografı"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Perimortem sezaryenin temel amacının bebeği kurtarmak değil, aortokaval basıyı kaldırarak annenin kalbine kan dönüşünü ve sağ kalım şansını artırmak olduğu"
      ],
      "whenToEscalate": [
        "Maternal arrestin 4. dakikasında yatak başı cerrahi histerektomiye başlanması ve eş zamanlı neonatal canlandırma ekibinin aktive edilmesi"
      ],
      "referencesToShow": [
        "AHA Guidelines for CPR and ECC: Maternal Resuscitation. Circulation 2020. PMID: 33081529.",
        "Jeejeebhoy FM, et al. PMID: 26269410."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "🚨 MATERNAL CARDIAC ARREST! INITIATE LEFT UTERINE DISPLACEMENT AND HIGH-QUALITY CPR IMMEDIATELY!",
      "conversationalText": "Resuscitation follows standard ACLS principles, but aortocaval compression must be relieved.\\n\\n1. Start high-quality CPR.\\n2. Perform left uterine displacement.\\n3. Defibrillate when indicated.\\n4. Call experienced airway help because aspiration and difficult airway risks are increased.\\n5. Search reversible causes such as hemorrhage, embolism, anesthesia complications, eclampsia, sepsis, and cardiac disease.\\n6. If gestational age is appropriate and ROSC is not achieved, perimortem cesarean delivery should be considered early.",
      "immediateRedFlags": [
        "Maternal pulselessness and apnea.",
        "Aortocaval compression in supine position completely blocking venous return and rendering chest compressions ineffective."
      ],
      "missingCriticalInformation": [
        "Gestational age (fundus at or above umbilicus / >=20 weeks is the threshold for emergent delivery)",
        "Primary trigger of maternal arrest (e.g., high spinal, anaphylaxis, amniotic fluid embolism, magnesium overdose)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Maternal Cardiac Arrest Guidelines (AHA 2020/2025)",
        "Aortocaval Compression and Left Uterine Displacement (LUD)",
        "Perimortem Cesarean Delivery (Resuscitative Hysterotomy) Timing"
      ],
      "suggestedNextStepsGeneral": [
        "Declare maternal arrest, start CPR, and bring the defibrillator immediately.",
        "Perform continuous manual Left Uterine Displacement (LUD) to push the uterus to the left during compressions.",
        "Secure the airway early with a cuffed endotracheal tube (anticipate difficult airway and high aspiration risk).",
        "If ROSC is not achieved by 4 minutes of resuscitation, perform immediate Perimortem Cesarean Delivery (PMCD) at the bedside, aiming for delivery by minute 5."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine Monograph"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "The primary physiological goal of perimortem cesarean is maternal decompression to restore venous return and double maternal survival chance, not just fetal rescue"
      ],
      "whenToEscalate": [
        "Initiate resuscitative hysterotomy at the bedside at 4 minutes if ROSC is not returned, activating a second pediatric code team for the neonate"
      ],
      "referencesToShow": [
        "AHA Guidelines for CPR and ECC: Maternal Resuscitation. Circulation 2020. PMID: 33081529.",
        "Jeejeebhoy FM, et al. PMID: 26269410."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "pediatric_bradycardia",
    "category": "clinical_scenarios",
    "keywords": [
      "bradikardi",
      "bradycardia",
      "pediatric",
      "pediatrik",
      "vagal",
      "çocuk"
    ],
    "question_tr": "Pediatrik bradikardi",
    "question_en": "Vagal bradikardi",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Pediatrik bradikardide en önemli nedenlerden biri hipoksidir. Önce oksijenasyon ve ventilasyonu düzelt.\\n\\n1. %100 oksijen ver.\\n2. Havayolu, tüp pozisyonu, ventilasyon ve ETCO₂’yi kontrol et.\\n3. Cerrahi/vagal uyarıyı durdur.\\n4. Derin anestezi, ilaçlar ve hiperkalemi gibi nedenleri değerlendir.\\n5. Perfüzyon bozuksa ve bradikardi devam ediyorsa pediatrik resüsitasyon algoritmasına geç.\\n6. Atropin özellikle vagal bradikardi veya kolinerjik nedenlerde kullanılabilir; hipoksik bradikardide temel tedavi ventilasyon/oksijenasyondur.",
      "immediateRedFlags": [
        "Çocukta kalp hızının <60/dk olması ile birlikte zayıf nabız, perfüzyon bozukluğu ve solunum arresti (derhal CPR başlatılmalıdır!).",
        "SpO₂'nin hızla düşmesi ve siyanoz."
      ],
      "missingCriticalInformation": [
        "Çocuğun kilosu ve tam yaşı (acil ilaç ve defibrilasyon doz hesabı için)",
        "Kantitatif ETCO₂ değeri (ventilasyon kalitesini izlemek için)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Pediatrik Bradikardi Kriz Yönetimi",
        "Pediatrik Resüsitasyon (PALS) Standartları",
        "Vagal Refleksler ve Hipoksik Kalp Yavaşlaması"
      ],
      "suggestedNextStepsGeneral": [
        "FiO₂'yi derhal 1.0 (%100 O₂) yapın.",
        "Tüpün yerini (endobronşiyal kaçış veya yerinden çıkma) kapnografi ve göğüs hareketiyle kontrol edin.",
        "Kalp hızı <60/dk ise ve perfüzyon bozuksa: Derhal göğüs kompresyonlarına (CPR) başlayın.",
        "Vagal uyarılarda: Atropin 0.02 mg/kg IV bolus (minimum 0.1 mg) uygulayın.",
        "Dirençli veya resüsitasyon gerektiren durumlarda: Adrenalin 0.01 mg/kg (0.1 mL/kg 1:10.000 solüsyondan) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "atropine",
          "titleTr": "Atropin Monografı"
        },
        {
          "id": "adrenaline",
          "titleTr": "Adrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Çocuklarda bradikardinin en sık nedeninin hipoksi olduğu; hipoksi çözülmeden verilen ilaçların bradikardiyi düzeltemeyeceği"
      ],
      "whenToEscalate": [
        "Atropin ve ventilasyona dirençli asistan bradikardide acil PALS arrest algoritmasına geçiş ve Adrenalin uygulaması"
      ],
      "referencesToShow": [
        "AHA Guidelines for CPR and ECC: Pediatric Basic and Advanced Life Support. Circulation 2020. PMID: 33081529.",
        "PALS Training Manual. 2021."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Hypoxia is a major cause of pediatric bradycardia. Correct oxygenation and ventilation first. Give 100% oxygen, check airway, tube position, ventilation and ETCO₂, stop surgical/vagal stimulation, and assess anesthetic depth, drugs, and hyperkalemia. If perfusion is poor and bradycardia persists, follow pediatric resuscitation algorithms. Atropine may be used for vagal or cholinergic bradycardia; in hypoxic bradycardia, ventilation and oxygenation are the primary treatment.",
      "immediateRedFlags": [
        "Heart rate <60/min in an infant or child with poor systemic perfusion despite oxygenation (requires immediate CPR!).",
        "Rapidly falling SpO₂ with clinical cyanosis."
      ],
      "missingCriticalInformation": [
        "Child's exact weight (essential for PALS dosing)",
        "Quantitative ETCO₂ monitoring values to verify ventilation"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Pediatric Bradycardia Emergency Management",
        "Pediatric Advanced Life Support (PALS) Standards",
        "Hypoxia-Induced vs Vagal-Induced Pediatric Bradycardia"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately increase FiO₂ to 1.0 (100% O₂).",
        "Check airway patency, tube positioning (rule out mainstem intubation/dislodgement), and verify chest rise.",
        "If heart rate is <60/min with signs of poor perfusion despite 100% O₂ and ventilation: Start chest compressions (CPR) immediately.",
        "For vagal bradycardia: Administer Atropine 0.02 mg/kg IV (minimum dose 0.1 mg).",
        "For resuscitation: Administer Epinephrine 0.01 mg/kg IV/IO (0.1 mL/kg of 1:10,000 solution)."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "atropine",
          "titleTr": "Atropine Monograph"
        },
        {
          "id": "adrenaline",
          "titleTr": "Epinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Hypoxia is the primary trigger of pediatric bradycardia until proven otherwise; ventilate and oxygenate before assuming a cardiac etiology"
      ],
      "whenToEscalate": [
        "If bradycardia is refractory to ventilation and atropine, immediately escalate to PALS cardiac arrest protocol and initiate epinephrine every 3-5 minutes"
      ],
      "referencesToShow": [
        "AHA Guidelines for CPR and ECC: Pediatric Basic and Advanced Life Support. Circulation 2020. PMID: 33081529.",
        "PALS Training Manual. 2021."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "pediatric_uri",
    "category": "clinical_scenarios",
    "keywords": [
      "child",
      "enfeksiyonu",
      "nose",
      "pediatric",
      "runny",
      "solunum",
      "uri",
      "yolu",
      "üst",
      "üsye"
    ],
    "question_tr": "Üsye",
    "question_en": "Runny nose child",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Karar semptom şiddeti, yaş, cerrahi aciliyet ve havayolu planına göre verilir.\\nHafif burun akıntısı olan, ateşi olmayan ve genel durumu iyi çocuklarda cerrahi devam edebilir.\\nAteş, produktif öksürük, wheezing, letarji, alt solunum yolu bulgusu, prematürite, ciddi komorbidite veya havayolu cerrahisi varsa erteleme daha güçlü düşünülür.\\nEntübasyon, havayolu reaktivitesini artırır; mümkünse daha az irritan havayolu yaklaşımı değerlendirilir.",
      "immediateRedFlags": [
        "ÜSYE semptomlarına eşlik eden ateş (>38°C), pürülan (yeşil-sarı) burun akıntısı, ıslak produktif öksürük veya dinlemekle raller/wheezing duyulması.",
        "Çocukta takipne (hızlı soluma) veya subkostal çekilmelerin olması (alt solunum yolu enfeksiyonu riski)."
      ],
      "missingCriticalInformation": [
        "Çocuğun yaşı (özellikle <1 yaş veya prematüre doğmuş bebekler yüksek risk altındadır)",
        "Planlanan cerrahinin türü (havayolu veya torasik cerrahilerde reaktivite katlanır)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Pediatrik Üst Solunum Yolu Enfeksiyonunda Anestezi Kararı",
        "Bronkospazm ve Laringospazm Risk Faktörleri",
        "Laryngeal Mask (LMA) vs. Endotrakeal Entübasyon Seçimi"
      ],
      "suggestedNextStepsGeneral": [
        "Detaylı bir anamnez alın ve göğüs oskültasyonunu tekrarlayın.",
        "Hafif ÜSYE (pürüzsüz burun akıntısı, ateşsiz, genel durum iyi) varlığında: Cerrahiye devam edebilirsiniz.",
        "Eğer entübasyon gerekiyorsa: Reaktiviteyi azaltmak için Sevofluran indüksiyonu sonrası derin anestezide laringoskopi yapın.",
        "Mümkünse entübasyon yerine LMA (Laringeal Maske) kullanmayı tercih edin (havayolu irritasyonunu azaltır)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "ÜSYE geçiren çocuklarda havayolu aşırı duyarlılığının enfeksiyon düzeldikten sonra bile 6-8 hafta boyunca devam edebileceği"
      ],
      "whenToEscalate": [
        "Aktif alt solunum yolu enfeksiyonu (pnömoni, bronşiolit) veya ağır bronkospazm varlığında elektif ameliyatları en az 4-6 hafta erteleyin"
      ],
      "referencesToShow": [
        "Anesthesia in Children with Upper Respiratory Tract Infections. Pediatric Anesthesia 2020. PMID: 32014671.",
        "ASA Standards. 2021."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Decision depends on symptom severity, age, surgical urgency, and airway plan. Mild rhinorrhea without fever and with good general condition may proceed.\\n\\nFever, productive cough, wheezing, lethargy, lower respiratory signs, prematurity, major comorbidity, or airway surgery favors postponement. Tracheal intubation increases airway reactivity; less irritating airway approaches may be considered when appropriate.",
      "immediateRedFlags": [
        "Active URI accompanied by fever (>38°C), purulent nasal discharge, wet productive cough, or wheezing/rales on auscultation.",
        "Tachypnea or subcostal retractions (indicating lower respiratory tract involvement)."
      ],
      "missingCriticalInformation": [
        "Child's age (infants <1 year and former preterms have significantly higher hyperreactivity risk)",
        "Type of surgery (airway and thoracic surgeries carry exponentially higher bronchospasm risk)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Pediatric Upper Respiratory Infection Anesthetic Risk Assessment",
        "Bronchospasm and Laryngospasm Risk Scoring",
        "Laryngeal Mask Airway (LMA) vs. Endotracheal Tube Selection"
      ],
      "suggestedNextStepsGeneral": [
        "Perform a thorough history and chest auscultation.",
        "For mild URI (clear rhinorrhea, afebrile, active and playing): Proceed with appropriate monitoring.",
        "If proceeding, prefer a supraglottic airway (LMA) over endotracheal intubation to minimize mechanical airway stimulation.",
        "Ensure deep anesthesia prior to any airway manipulation if intubating."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Airway hyperreactivity persists for up to 6-8 weeks after clinical resolution of an upper respiratory infection"
      ],
      "whenToEscalate": [
        "In case of active lower respiratory tract infection (bronchitis, pneumonia) or acute reactive bronchospasm, postpone elective surgery for 4-6 weeks"
      ],
      "referencesToShow": [
        "Anesthesia in Children with Upper Respiratory Tract Infections. Pediatric Anesthesia 2020. PMID: 32014671.",
        "ASA Standards. 2021."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "pediatric_laryngospasm",
    "category": "clinical_scenarios",
    "keywords": [
      "laringospazm",
      "laryngospasm",
      "pediatric",
      "pediatrik",
      "çocuk"
    ],
    "question_tr": "Pediatrik laringospazm",
    "question_en": "Pediatric laryngospasm",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "1. Cerrahi uyarıyı durdur, yardım çağır.\\n2. %100 oksijen, jaw thrust ve CPAP uygula.\\n3. Sekresyon/kan varsa nazik aspirasyon yap.\\n4. Anestezi derinliğini artır; propofol düşünülebilir.\\n5. Ventilasyon yoksa veya desatürasyon ilerliyorsa süksinilkolin ve atropin hazırlığı yap, entübasyona geç.\\n6. Olay sonrası negatif basınçlı pulmoner ödem açısından izle.",
      "immediateRedFlags": [
        "Pediatrik hastada laringospazm sırasında gelişen hızlı desatürasyon ve ağır bradikardi (kalp hızının <60/dk olması - durma öncesi kritik evre!).",
        "Paradoksal solunum hareketi (göğsün içeri çökmesi, karnın dışarı şişmesi) ile birlikte solunum seslerinin tamamen kaybolması."
      ],
      "missingCriticalInformation": [
        "Çocuğun tam ağırlığı (Süksinilkolin ve Atropin acil doz hesabı için)",
        "İntravenöz (IV) damar yolunun açık ve çalışır durumda olup olmadığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Pediatrik Ekstübasyon Laringospazmı Yönetimi",
        "Larson Manevrası (Laringospazm Çentiği Basısı)",
        "Pediatrik Acil Havayolu İlaç Dozlaması"
      ],
      "suggestedNextStepsGeneral": [
        "Ekibe pediatrik acil durum bildirin ve %100 O₂ ile maske CPAP (15-20 cmH₂O) uygulayın.",
        "Larson manevrasını (mandibula köşesinin arkasındaki çentiğe güçlü iki taraflı parmak basısı) uygulayın.",
        "Eğer IV yol varsa: Propofol (0.5-1 mg/kg IV) uygulayın; spazm kırılmazsa Süksinilkolin (0.5-1 mg/kg IV) + Atropin (0.02 mg/kg IV) uygulayın.",
        "Eğer IV yol YOKSA: Acil intramüsküler (IM) Süksinilkolin (3-4 mg/kg IM) + Atropin (0.02 mg/kg IM) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        },
        {
          "id": "succinylcholine",
          "titleTr": "Süksinilkolin Monografı"
        }
      ],
      "doNotMiss": [
        "Çocuklarda laringospazmın en sık ekstübasyon veya indüksiyon sırasında yetersiz anestezi derinliğindeyken havayolunun uyarılmasıyla (sekresyon, LMA oynatılması) tetiklendiği"
      ],
      "whenToEscalate": [
        "Süksinilkolin sonrası düzelmeyen total spazmda derhal endotrakeal entübasyon veya acil cerrahi havayolu"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "AHA Guidelines for CPR and ECC. 2020. PMID: 33081529."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "1. Stop stimulation and call for help.\\n2. Provide 100% oxygen, jaw thrust, and CPAP.\\n3. Gently suction secretions or blood.\\n4. Deepen anesthesia; propofol may be considered.\\n5. If ventilation is impossible or desaturation progresses, prepare succinylcholine and atropine and proceed to intubation.\\n6. Monitor afterward for negative-pressure pulmonary edema.",
      "immediateRedFlags": [
        "Pediatric laryngospasm triggering rapid desaturation and severe bradycardia (HR <60/min - pre-arrest warning).",
        "Paradoxical chest wall movement (seesaw breathing) with complete loss of breath sounds and airflow."
      ],
      "missingCriticalInformation": [
        "Child's exact weight for emergency drug calculations",
        "IV access patency (if lost, prepare for immediate IM administration)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Pediatric Extubation Laryngospasm Emergency Protocol",
        "Larson's Maneuver (Laryngospasm Notch Pressure Technique)",
        "Pediatric Emergency Airway Pharmacotherapy"
      ],
      "suggestedNextStepsGeneral": [
        "Declare pediatric airway emergency and apply tight face-mask CPAP (15-20 cmH₂O) with 100% O₂.",
        "Apply bilateral Larson's maneuver behind the earlobes at the jaw notch.",
        "If IV access is patent: Administer Propofol (0.5-1 mg/kg IV); if unresolved, give Succinylcholine (0.5-1 mg/kg IV) + Atropine (0.02 mg/kg IV).",
        "If NO IV access: Administer emergency IM Succinylcholine (3-4 mg/kg IM) + IM Atropine (0.02 mg/kg IM) into the deltoid/thigh."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        },
        {
          "id": "succinylcholine",
          "titleTr": "Succinylcholine Monograph"
        }
      ],
      "doNotMiss": [
        "Avoid mechanical suctioning of the posterior pharynx in a light patient, as it can worsen the reflex spasm"
      ],
      "whenToEscalate": [
        "If complete spasm persists despite succinylcholine, perform immediate tracheal intubation or surgical access"
      ],
      "referencesToShow": [
        "Practice Guidelines for Management of the Difficult Airway. Anesthesiology 2022. PMID: 34762285.",
        "AHA Guidelines for CPR and ECC. 2020. PMID: 33081529."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "preterm_apnea",
    "category": "clinical_scenarios",
    "keywords": [
      "apne",
      "apnea",
      "postkonseptüel",
      "postop",
      "prematüre",
      "preterm"
    ],
    "question_tr": "Prematüre",
    "question_en": "Postkonseptüel",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Prematüre ve eski prematüre infantlarda postoperatif apne riski gestasyonel yaş, postkonseptüel yaş, anemi, önceki apne öyküsü, enfeksiyon ve opioid/sedatif kullanımıyla artar.\\nRiskli infantlarda günübirlik cerrahi uygun olmayabilir. Postoperatif monitörizasyon, apne-bradikardi takibi ve opioid azaltıcı analjezi planı yapılmalıdır. Bölgesel anestezi riski azaltabilir ama tamamen ortadan kaldırmaz; sedasyon eklenirse risk yeniden artabilir.",
      "immediateRedFlags": [
        "Postkonseptüel yaşı <60 hafta olan eski prematüre bebekte taburculuk öncesi uykuda solunum durması (apne) veya bradikardi ataklarının izlenmesi.",
        "Hemoglobin düzeyinin <10 g/dL olması (anemi apneyi tetikler)."
      ],
      "missingCriticalInformation": [
        "Bebeğin gestasyonel (doğum) yaşı ve şu anki kronolojik yaşı (Postkonseptüel yaş = Gestasyonel hafta + Doğum sonrası hafta)",
        "Bebekte eşlik eden bronkopulmoner displazi (BPD) varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Eski Prematüre Bebeklerde Postoperatif Apne Riski",
        "Postkonseptüel Yaş ve Günübirlik Cerrahi Sınırları",
        "Opioidsiz Analjezi (Kaudal/Rejyonel Bloklar) Yaklaşımı"
      ],
      "suggestedNextStepsGeneral": [
        "Postkonseptüel yaşı (PCA) hesaplayın. Eğer PCA <60 hafta ise günübirlik cerrahi planını iptal edin ve hastayı yatırın.",
        "Operasyon sonrası bu bebekleri en az 12-24 saat boyunca kesintisiz kardiyorespiratuar monitörle (apne izlemi) takip edin.",
        "İntraoperatif ve postoperatif dönemde opioidlerden kaçının; analjezi için parasetamol ve lokal infiltrasyon tercih edin.",
        "Apne profilaksisi için gerekirse Kafein Sitrat (20 mg/kg IV yükleme) düşünün."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Genel anesteziye eklenen en ufak sedatif ilacın (örn. Midazolam) eski prematürelerde postop apne riskini dramatik olarak artırdığı"
      ],
      "whenToEscalate": [
        "Postoperatif dirençli apne ve bradikardi atakları gösteren bebeklerin entübe edilerek mekanik ventilatör desteğiyle yoğun bakıma nakli"
      ],
      "referencesToShow": [
        "Postoperative Apnea in Former Preterm Infants. Anesthesiology 2015. PMID: 25416285.",
        "ASA guidelines on Pediatric Outpatient Surgery. 2018."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Postoperative apnea risk in preterm or former preterm infants increases with lower gestational age, lower postconceptual age, anemia, previous apnea, infection, and opioid/sedative use. High-risk infants may not be suitable for ambulatory surgery. Plan postoperative monitoring for apnea/bradycardia and use opioid-sparing analgesia. Regional anesthesia may reduce but does not eliminate risk; added sedation can increase risk again.",
      "immediateRedFlags": [
        "Any sleep apnea (pause >20 seconds) or bradycardia episode observed in a former preterm infant prior to discharge.",
        "Preoperative hemoglobin <10 g/dL (anemia independently multiplies apnea risk)."
      ],
      "missingCriticalInformation": [
        "Gestational age at birth and current chronological age (Postconceptual Age PCA = Gestational age + chronological age in weeks)",
        "History of bronchopulmonary dysplasia (BPD) or active home oxygen therapy"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postoperative Apnea Risk in Former Preterm Infants",
        "Postconceptual Age (PCA) Limits for Ambulatory Surgery",
        "Opioid-Sparing Analgesia (Caudal/Regional Blocks) utility"
      ],
      "suggestedNextStepsGeneral": [
        "Calculate Postconceptual Age (PCA). If PCA <60 weeks, cancel outpatient discharge plans and admit the infant for overnight monitoring.",
        "Monitor the infant continuously for at least 12-24 hours postoperatively with a cardiorespiratory monitor.",
        "Use strictly opioid-sparing protocols; prefer paracetamol, ibuprofen, and regional blocks (e.g., caudal block).",
        "Consider Caffeine Citrate (20 mg/kg IV loading dose) to stimulate respiratory drive in high-risk infants."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Even minimal sedation added to regional anesthesia reinstates the high postoperative apnea risk in former preterms"
      ],
      "whenToEscalate": [
        "For persistent, recurrent postoperative apnea or bradycardia episodes, secure the airway, ventilate, and admit to neonatal ICU"
      ],
      "referencesToShow": [
        "Postoperative Apnea in Former Preterm Infants. Anesthesiology 2015. PMID: 25416285.",
        "ASA guidelines on Pediatric Outpatient Surgery. 2018."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "olv_hypoxemia",
    "category": "clinical_scenarios",
    "keywords": [
      "akciğer",
      "hypoxemia",
      "lung",
      "olv",
      "one",
      "tek",
      "torasik"
    ],
    "question_tr": "Tek akciğer",
    "question_en": "Torasik",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "1. FiO₂’yi 1.0 yap.\\n2. Tüp/bronşiyal bloker pozisyonunu fiberoptik ile kontrol et.\\n3. Ventilasyon yapılan akciğerde sekresyon, bronkospazm, atelektazi veya düşük tidal volüm var mı değerlendir.\\n4. Ventile edilen akciğere uygun PEEP uygula.\\n5. Non-dependent akciğere CPAP düşün.\\n6. Hemodinami ve kardiyak outputu optimize et.\\n7. Düzelmezse cerrahiden geçici iki akciğer ventilasyonu için izin iste.",
      "immediateRedFlags": [
        "Tek akciğer ventilasyonu (OLV) sırasında SpO₂'nin hızla %85'in altına düşmesi ve ventilasyon uygulanan akciğerin havayolu basınçlarının aniden yükselmesi.",
        "Hemodinamik instabilite ve kardiyak debi düşüşü."
      ],
      "missingCriticalInformation": [
        "Kullanılan çift lümenli tüpün (DLT) tipi (sağ vs sol) ve boyutu",
        "Hastanın ameliyat öncesi solunum fonksiyon testleri ve akciğer rezervi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Tek Akçiger Ventilasyonunda (OLV) Hipoksemi Algoritması",
        "Çift Lümenli Tüp (DLT) Yer Değiştirme ve Fiberoptik Kontrolü",
        "Non-dependent Akciğerde CPAP ve Şant Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Derhal FiO₂'yi 1.0 (%100 O₂) yapın.",
        "Fiberoptik bronkoskopu tüpün içine sürerek DLT'nin veya bronşiyal blokerin kaymadığını (pozisyonunu) kesinlikle doğrulayın.",
        "Ventile edilen akciğerde sekresyonları aspire edin, gerekirse bronkodilatör verin.",
        "Ventile edilen (aşağıdaki) akciğere 5 cmH₂O PEEP uygulayın.",
        "Ventile edilmeyen (yukarıdaki, cerrahi uygulanan) akciğere 2-5 cmH₂O CPAP (oksijen üfleme) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Çift lümenli tüplerin cerrahın hastayı çevirmesi veya mediasteni çekiştirmesi sırasında çok kolay yer değiştirebileceği"
      ],
      "whenToEscalate": [
        "Tüm önlemlere rağmen SpO₂ <%85 kalmaya devam ederse derhal cerraha haber verin ve geçici olarak İki Akciğer Ventilasyonuna (TLV) geçilmesini talep edin"
      ],
      "referencesToShow": [
        "Principles of One-Lung Ventilation. Anesthesiology Clinics 2019. PMID: 32014671.",
        "Thoracic Anesthesia Guidelines. 2020."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Set FiO₂ to 1.0. Confirm double-lumen tube or bronchial blocker position with bronchoscopy. Assess the ventilated lung for secretions, bronchospasm, atelectasis, or inadequate tidal volume. Apply appropriate PEEP to the dependent lung, consider CPAP to the non-dependent lung, optimize hemodynamics and cardiac output, and if unresolved request temporary two-lung ventilation.",
      "immediateRedFlags": [
        "Rapid arterial desaturation (SpO₂ <85%) during one-lung ventilation (OLV) accompanied by sudden rise in peak airway pressure.",
        "Hemodynamic instability or dropping cardiac output indicating severe shunt."
      ],
      "missingCriticalInformation": [
        "Type (left vs right) and size of the double-lumen tube (DLT) or bronchial blocker",
        "Preoperative pulmonary function test parameters and cardiac shunt history"
      ],
      "likelyClinicalCategoriesToConsider": [
        "One-Lung Ventilation (OLV) Hypoxemia Algorithm",
        "Double-Lumen Tube (DLT) Dislodgement and Bronchoscopic Verification",
        "CPAP Application to the Non-dependent Lung"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately increase FiO₂ to 1.0 (100% O₂).",
        "Pass a fiberoptic bronchoscope down the DLT to verify that the tube has not migrated or become obstructed.",
        "Suction secretions from the ventilated (dependent) lung and rule out bronchospasm.",
        "Apply 5 cmH₂O PEEP to the dependent lung.",
        "Apply 2-5 cmH₂O CPAP to the non-dependent (non-ventilated) lung to reduce intrapulmonary shunt."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "DLT position is highly dynamic; lateral positioning of the patient or surgical retraction of the lung frequently triggers displacement"
      ],
      "whenToEscalate": [
        "If SpO₂ remains below 85% despite all maneuvers, immediately inform the surgeon and request temporary resumption of two-lung ventilation (TLV)"
      ],
      "referencesToShow": [
        "Principles of One-Lung Ventilation. Anesthesiology Clinics 2019. PMID: 32014671.",
        "Thoracic Anesthesia Guidelines. 2020."
      ],
      "safetyLevel": "urgent"
    }
