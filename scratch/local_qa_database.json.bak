  {
    "id": "clinical_followup_coronary_stent_contraindications_0",
    "category": "clinical_followups",
    "keywords": [
      "antiplatelet",
      "clinical_followup_coronary_stent_contraindications_0",
      "contraindications",
      "coronary",
      "dapt",
      "dual",
      "followup",
      "koroner",
      "stent",
      "var0"
    ],
    "question_tr": "Stentli hastada hangi anestezik yaklaşımlar kontrendikedir?",
    "question_en": "What anesthetic approaches are contraindicated in stented patients?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "⚠️ Aktif DAPT (Aspirin + Klopidogrel) kullanan hastalarda rejyonal anestezi (Spinal/Epidural blok) yapılması, epidural hematom riski nedeniyle kesinlikle kontrendikedir. Ayrıca intraoperatif dönemde ağır hipotansiyon ve taşikardi, stent perfüzyonunu bozacağı için kesinlikle önlenmelidir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "⚠️ Performing neuraxial blockade (spinal/epidural block) in patients on active DAPT (Aspirin + Clopidogrel) is strictly contraindicated due to spinal hematoma risk. Perioperative severe hypotension and tachycardia are also highly dangerous as they directly impair coronary stent perfusion.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    }
  },
