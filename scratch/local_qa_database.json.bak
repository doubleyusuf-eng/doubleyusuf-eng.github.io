      ],
      "whenToEscalate": [
        "Hastada indüksiyonda aspirasyon gelişirse derhal hastayı baş aşağı ve sola meyilli pozisyona getirin, havayolunu aspire edin, entübe edin ve acil bronşiyal lavaj ve solunum desteği sağlayın"
      ],
      "referencesToShow": [
        "Multisociety Clinical Practice Guidance for Safe Use of GLP-1 Receptor Agonists. 2024.",
        "ANZCA Safety Statement on GLP-1 Agonists. 2025."
      ],
      "safetyLevel": "elective"
