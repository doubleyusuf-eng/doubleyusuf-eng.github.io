    ],
    "question_tr": "Ekstübasyon sonrası takip",
    "question_en": "Post extubation monitoring",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Ekstübasyon sonrası ilk dakikalar kritiktir. İzlenecekler: SpO₂, solunum sayısı, solunum işi, stridor, konuşma/öksürük kalitesi, bilinç, kan basıncı, kalp hızı, ağrı, ajitasyon ve kanama. Riskli hastada kapnografi, HFNC/CPAP ve daha uzun PACU/yoğun bakım izlemi gerekebilir. Stridor, desatürasyon, artan solunum işi, yorgunluk, bilinç bozulması veya sekresyon temizleyememe erken müdahale gerektirir. Reentübasyon zor olacaksa gecikmeden kıdemli yardım çağrılmalıdır.",
      "immediateRedFlags": [
        "Ekstübasyondan hemen sonra duyulan inspiratuvar stridor ve interkostal retraksiyonlar.",
        "Oksijen desteğine rağmen SpO2'nin <%90'ın altına düşmesi ve solunum sıkıntısı.",
        "Havayolu tıkanıklığına bağlı paradoksal göğüs-karın solunumu bulguları."
      ],
      "missingCriticalInformation": [
        "Hastanın bazal solunum paterni ve KOAH öyküsü",
        "Ameliyat esnasında verilen opioidlerin ve sedatiflerin toplam dozu (solunum depresyonu riskini değerlendirmek için)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Ekstübasyon Sonrası Takip",
        "PACU Güvenlik Standartları",
        "Stridor ve Laringospazm Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Hasta derlenme ünitesindeyken SpO2, solunum hızı ve solunum işini sürekli gözlemleyin.",
        "Herhangi bir hırıltı veya stridor duyulduğunda derhal dik pozisyona getirin ve oksijen verin.",
        "Hafif stridorda nebulize adrenalin ve IV deksametazon tedavisini geciktirmeyin.",
        "Solunum depresyonundan şüphelenildiğinde sedatiflerin/opioidlerin etkisini geri döndürmeyi değerlendirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_extubation",
          "titleTr": "Zor Ekstübasyon Algoritması"
        },
        {
          "id": "stridor",
          "titleTr": "Post-ekstübasyon Stridoru"
        },
        {
          "id": "hypoxemia",
          "titleTr": "Hipoksemi Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "respiratory_score_calculator",
          "titleTr": "Solunum Skoru"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "nebulized_epinephrine",
          "titleTr": "Nebulize Adrenalin"
        },
        {
          "id": "dexamethasone",
          "titleTr": "Deksametazon Monografı"
        },
        {
          "id": "naloxone_if_opioid",
          "titleTr": "Nalokson"
        }
      ],
      "doNotMiss": [
        "Paradoksal solunumun (göğüs içeri çökerken karnın şişmesi) tam havayolu obstrüksiyonunun en net bulgusu olduğunu ve acil müdahale gerektirdiğini"
      ],
      "whenToEscalate": [
        "Hastada stridor, paradoksal solunum ve bilinç bulanıklığı eşlik eden tam obstrüksiyon varsa derhal kıdemli yardım çağırın, çene itme (jaw thrust) uygulayın ve reentübasyona hazırlanın"
      ],
      "referencesToShow": [
        "Difficult Airway Society Guidelines on Extubation. Anaesthesia 2012.",
        "ASA Standards for Post-Anesthesia Care. 2020."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "The first minutes after extubation are critical. Monitor SpO₂, respiratory rate, work of breathing, stridor, speech/cough quality, consciousness, blood pressure, heart rate, pain, agitation, and bleeding. High-risk patients may require capnography, HFNC/CPAP, and longer PACU/ICU monitoring. Stridor, desaturation, increasing work of breathing, fatigue, altered consciousness, or inability to clear secretions requires early intervention. If reintubation would be difficult, call senior help without delay.",
      "immediateRedFlags": [
        "Inspiratory stridor and severe accessory muscle use immediately post-extubation.",
        "Deteriorating oxygen saturation (SpO2 < 90%) unresponsive to supplemental oxygen.",
        "Paradoxical chest and abdominal movement indicating complete airway obstruction."
      ],
      "missingCriticalInformation": [
        "The patient's baseline pulmonary function and COPD status",
        "Cumulative doses of intraoperative opioids and sedatives (predisposing to hypoventilation)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Post-Extubation Monitoring",
        "PACU Safety Standards",
        "Stridor and Laryngospasm Management"
      ],
      "suggestedNextStepsGeneral": [
        "Monitor SpO2, respiratory rate, and accessory muscle use continuously in the PACU.",
        "At the first sign of stridor, sit the patient upright and administer high-flow oxygen.",
        "For mild/moderate stridor, promptly administer nebulized epinephrine and IV dexamethasone.",
        "Evaluate and reverse residual opioid or sedative effects if hypoventilation is suspected."
      ],
      "relatedAlgorithms": [
        {
          "id": "difficult_extubation",
          "titleTr": "Difficult Extubation"
        },
        {
          "id": "stridor",
          "titleTr": "Post-extubation Stridor"
        },
        {
          "id": "hypoxemia",
          "titleTr": "Hypoxemia Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "respiratory_score_calculator",
          "titleTr": "Respiratory Score"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "nebulized_epinephrine",
          "titleTr": "Nebulized Epinephrine"
        },
        {
          "id": "dexamethasone",
          "titleTr": "Dexamethasone Monograph"
        },
        {
          "id": "naloxone_if_opioid",
          "titleTr": "Naloxone"
        }
      ],
      "doNotMiss": [
        "Paradoxical breathing ('seesaw' breathing) is a key sign of complete airway obstruction and demands immediate intervention"
      ],
      "whenToEscalate": [
        "If the patient develops worsening stridor, paradoxical respirations, and progressive obtundation, call for emergency senior help and prepare for urgent reintubation"
      ],
      "referencesToShow": [
        "Difficult Airway Society Guidelines on Extubation. Anaesthesia 2012.",
        "ASA Standards for Post-Anesthesia Care. 2020."
