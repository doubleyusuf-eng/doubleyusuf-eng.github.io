  {
    "id": "clinical_followup_cico_crisis_how_0",
    "category": "clinical_followups",
    "keywords": [
      "airway",
      "cico",
      "clinical_followup_cico_crisis_how_0",
      "entübasyon",
      "followup",
      "havayolu",
      "intubasyon",
      "maske",
      "var0"
    ],
    "question_tr": "Skalpel-buji krikotiroidotomi nasıl uygulanır?",
    "question_en": "How to perform scalpel-bougie cricothyroidotomy?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🔪 Krikotiroid membran palpe edilir. 10 numara skalpel ile yatay kesi yapılır. Skalpel membrane yerleştirilmişken buji (bougie) trakeaya doğru yönlendirilir. Skalpel çekilir, buji üzerinden 6.0 cuffed endotrakeal tüp trakeaya kaydırılır. Kaf şişirilir ve ventilasyon doğrulanır.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🔪 Palpate cricothyroid membrane. Make a transverse incision with a size 10 scalpel. Maintain scalpel position and slide the bougie alongside the blade into the trachea. Remove scalpel, advance a cuffed 6.0 mm ETT over the bougie into the trachea, inflate cuff, and confirm ventilation.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
