      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Efedrin Monografı"
        }
      ],
      "doNotMiss": [
        "Laparoskopik pnömoperitonda insuflasyon sırasında vagal bradikardi gelişirse karın hemen desufle edilmelidir"
      ],
      "whenToEscalate": [
        "Atropine dirençli instabil bradikardide acil Adrenalin infüzyonu (2-10 mcg/dk) veya transkutanöz pacing"
      ],
      "referencesToShow": [
        "AHA Guidelines for CPR and ECC. 2020. PMID: 33081529.",
        "ERC Guidelines. 2021. PMID: 33773824."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Assess perfusion first. Hypotension, altered mental status, ischemia, shock, or heart failure indicates instability. Causes include hypoxia, vagal stimulation, deep anesthesia, high spinal, beta blockers, oculocardiac reflex, laparoscopy, and hyperkalemia. Correct oxygenation and ventilation, stop surgical stimulus, review drugs. Symptomatic bradycardia may be treated with atropine; if ineffective, consider epinephrine/dopamine infusion or pacing.",
      "immediateRedFlags": [
        "Progressive bradycardia accompanied by hypotension is a key warning for impending cardiac arrest."
      ],
      "missingCriticalInformation": [
        "Patient perfusion status and hemodynamic stability",
        "Oxygenation status (SpO₂)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Intraoperative Symptomatic Bradycardia Management",
        "Vagal Reflexes and Oculocardiac Reflex",
        "High Spinal Block Hemodynamic Side Effects"
      ],
      "suggestedNextStepsGeneral": [
        "Optimize oxygenation and ventilation first.",
        "Ask the surgeon to pause traction (especially ocular or peritoneal manipulation).",
        "Administer Atropine 0.5-1 mg IV for symptomatic bradycardia, repeat if necessary."
      ],
      "relatedAlgorithms": [
        {
          "id": "bradycardia_rescue",
          "titleTr": "Bradycardia Rescue Algorithm"
        },
        {
          "id": "sepsis_shock",
          "titleTr": "Sepsis & Shock Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine Monograph"
        }
      ],
      "doNotMiss": [
        "If severe bradycardia occurs during laparoscopic insufflation, release pneumoperitoneum immediately"
      ],
      "whenToEscalate": [
        "In atropine-refractory unstable bradycardia, initiate Epinephrine infusion (2-10 mcg/min) or transcutaneous pacing"
      ],
      "referencesToShow": [
        "AHA Guidelines for CPR and ECC. 2020. PMID: 33081529.",
        "ERC Guidelines. 2021. PMID: 33773824."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "tachycardia",
    "category": "clinical_scenarios",
    "keywords": [
      "nabız",
      "tachycardia",
      "taşikardi",
      "yüksek"
    ],
    "question_tr": "Taşikardi",
    "question_en": "Nabız yüksek",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Önce stabil/instabil ayrımı yap. Hipotansiyon, göğüs ağrısı/iskemi, bilinç değişikliği, şok veya kalp yetmezliği varsa instabildir ve senkronize kardiyoversiyon gerekebilir.\\nStabil hastada QRS dar/geniş ve ritim düzenli/düzensiz olarak değerlendirilir.\\nNedenler: ağrı, yetersiz anestezi, hipovolemi, anemi, hipoksi, hiperkapni, ateş/MH, anafilaksi, ilaçlar, aritmi.\\nTedavi altta yatan nedene göre yapılır; SVT’de vagal manevra/adenozin, AF’de hız kontrolü, geniş kompleks taşikardide amiodaron veya kardiyoversiyon düşünülür.",
      "immediateRedFlags": [
        "Hipotansiyon ve göğüs ağrısı eşliğinde seyreden hızlı taşikardi (>150/dk) acil elektriksel müdahale gerektirir.",
        "Taşikardi ile birlikte ani karbondioksit (ETCO₂) yükselişi Malign Hipertermi krizinin habercisi olabilir."
      ],
      "missingCriticalInformation": [
        "QRS kompleksinin genişliği (dar vs geniş QRS)",
        "Ritim düzeni (düzenli vs düzensiz)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İntraoperatif Akut Taşikardi Ayırıcı Tanısı",
        "Dar ve Geniş QRS Taşikardi Tedavi Şemaları",
        "Senkronize Kardiyoversiyon İlkeleri"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle anestezi derinliğini ve ağrı durumunu kontrol edin (fentanil/propofol ekleyin).",
        "Stabil dar QRS SVT'de vagal manevra veya Adenozin (6 mg IV hızlı bolus) uygulayın.",
        "Stabil dar QRS düzensiz AF'de hız kontrolü için Esmolol (0.5 mg/kg IV bolus ve infüzyon) düşünün."
      ],
      "relatedAlgorithms": [
        {
          "id": "tachycardia_rescue",
          "titleTr": "Taşikardi Algoritması"
        },
        {
          "id": "bradycardia_rescue",
          "titleTr": "Bradikardi Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Efedrin Monografı"
        }
      ],
      "doNotMiss": [
        "İntraoperatif taşikardi ve hiperkapninin birlikte bulunmasının Malign Hipertermiyi düşündürmesi gerektiği"
      ],
      "whenToEscalate": [
        "Hemodinamik instabilite gelişen taşikardide derhal senkronize kardiyoversiyon (50-100 J) uygulayın"
      ],
      "referencesToShow": [
        "AHA Guidelines for CPR and ECC. Circulation 2020. PMID: 33081529.",
        "ERC Guidelines. 2021. PMID: 33773824."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "First determine stability. Hypotension, ischemia, altered mental status, shock, or heart failure indicates instability and may require synchronized cardioversion. In stable patients, classify QRS as narrow/wide and rhythm as regular/irregular. Causes include pain, inadequate anesthesia, hypovolemia, anemia, hypoxia, hypercapnia, fever/MH, anaphylaxis, drugs, and arrhythmia. Treat the cause; consider vagal maneuvers/adenosine for SVT, rate control for AF, and amiodarone or cardioversion for wide-complex tachycardia.",
      "immediateRedFlags": [
        "Tachycardia (>150/min) with hypotension or active myocardial ischemia requires immediate electrical intervention.",
        "Tachycardia coupled with a rapid rise in ETCO₂ is a critical warning for malignant hyperthermia."
      ],
      "missingCriticalInformation": [
        "Width of the QRS complex (narrow vs wide QRS)",
        "Rhythm regularity (regular vs irregular)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Intraoperative Acute Tachycardia Differential Diagnosis",
        "Narrow and Wide QRS Tachycardia Treatment Pathways",
        "Synchronized Cardioversion Principles"
      ],
      "suggestedNextStepsGeneral": [
        "Assess and optimize anesthetic depth and analgesia first (add fentanyl or propofol).",
        "For stable narrow QRS SVT, try vagal maneuvers or Adenosine 6 mg rapid IV bolus.",
        "For stable irregular AF, consider Esmolol (0.5 mg/kg IV bolus and infusion) for rate control."
      ],
      "relatedAlgorithms": [
        {
          "id": "tachycardia_rescue",
          "titleTr": "Tachycardia Rescue Algorithm"
        },
        {
          "id": "bradycardia_rescue",
          "titleTr": "Bradycardia Rescue Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine Monograph"
        }
      ],
      "doNotMiss": [
        "Concomitant tachycardia and hypercapnia under volatile anesthesia must raise immediate suspicion for MH"
      ],
      "whenToEscalate": [
        "In hemodynamically unstable tachycardia, perform immediate synchronized cardioversion (50-100 J)"
      ],
      "referencesToShow": [
        "AHA Guidelines for CPR and ECC. Circulation 2020. PMID: 33081529.",
        "ERC Guidelines. 2021. PMID: 33773824."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "aspiration",
    "category": "clinical_scenarios",
    "keywords": [
      "akciğere",
      "aspirasyon",
      "aspiration",
      "kaç"
    ],
    "question_tr": "Aspirasyon",
    "question_en": "Akciğere kaç",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "1. Hastayı baş aşağı/lateral uygun pozisyona almayı düşün ve orofarenksi aspire et.\\n2. %100 oksijen ver.\\n3. Hava yolunu güvenceye al; entübe değilse entübasyon gerekebilir.\\n4. Trakeal aspirasyon yap; büyük partikül varsa bronkoskopi düşün.\\n5. Bronkospazm varsa tedavi et.\\n6. Oksijenasyon, akciğer kompliyansı ve hemodinamiye göre cerrahiye devam/erteleme kararı ver.\\n7. Rutin profilaktik antibiyotik ve steroid her aspirasyon için otomatik değildir; klinik gidiş, enfeksiyon bulgusu ve aspirat tipine göre değerlendirilir.\\n8. Postoperatif akciğer grafisi, kan gazı ve izlem gerekebilir.",
      "immediateRedFlags": [
        "Orofaringeal sekresyon veya mide içeriği aspirasyonu sonrası aniden gelişen şiddetli bronkospazm ve hipoksi (Mendelson Sendromu).",
        "Trakeal tüpten besin partiküllerinin veya safra içerikli sıvının gelmesi."
      ],
      "missingCriticalInformation": [
        "Aspirasyonun gerçekleştiği tam an (indüksiyon, idame veya uyanma sırasında mı?)",
        "Aspire edilen içeriğin niteliği (asidik sıvı vs katı partiküller)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Akut Pulmoner Mide İçeriği Aspirasyonu",
        "Kimyasal Pnömoni (Mendelson Sendromu) Patofizyolojisi",
        "Aspirasyon Sonrası Solunumsal Destek Kriterleri"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın başını hemen yana çevirin ve orofarenksi güçlü bir şekilde aspire edin.",
        "%100 O₂ verin ve eğer entübe değilse hızlıca entübe edin.",
        "Entübasyon sonrası tüpün içinden trakeal aspirasyon uygulayın (tüpün içine salin enjekte etmeyin!)."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Aspirasyon sonrası rutin profilaktik antibiyotik ve steroid kullanımı kanıta dayalı değildir ve önerilmez"
      ],
      "whenToEscalate": [
        "Ağır ARDS, dirençli hipoksemi ve solunum yetmezliği gelişen hastaların acil yoğun bakıma nakli"
      ],
      "referencesToShow": [
        "Practice Guidelines for Preoperative Fasting. Anesthesiology 2023. PMID: 36622802.",
        "Nason KS. PMID: 26210243."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "1. Consider head-down/lateral positioning when appropriate and suction the oropharynx.\\n2. Give 100% oxygen.\\n3. Secure the airway; intubation may be required if not already intubated.\\n4. Suction the trachea and consider bronchoscopy for particulate matter.\\n5. Treat bronchospasm.\\n6. Decide whether to continue or postpone surgery based on oxygenation, lung compliance, and hemodynamics.\\n7. Routine prophylactic antibiotics or steroids are not automatic for every aspiration event; decide based on clinical course, infection signs, and aspirate type.\\n8. Postoperative chest imaging, blood gas, and observation may be needed.",
      "immediateRedFlags": [
        "Severe bronchospasm and hypoxia immediately following aspiration of gastric contents (Mendelson syndrome).",
        "Visible food particles or bile-stained fluid suctioned from the endotracheal tube."
      ],
      "missingCriticalInformation": [
        "Exact timing of aspiration (induction, maintenance, or emergence?)",
        "Nature of the aspirate (acidic fluid vs solid particulate matter)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Acute Pulmonary Aspiration of Gastric Contents",
        "Chemical Pneumonitis (Mendelson Syndrome) Pathophysiology",
        "Post-Aspiration Respiratory Support Criteria"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately turn the patient's head to the side and suction the oropharynx aggressively.",
        "Deliver 100% O₂ and intubate rapidly if the airway is not already secured.",
        "Perform tracheal suctioning through the ETT before applying positive pressure (do not inject saline!)."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Routine prophylactic antibiotics and corticosteroid administration are not recommended immediately post-aspiration"
      ],
      "whenToEscalate": [
        "In case of severe ARDS, refractory hypoxemia, or respiratory failure, transfer the patient to the ICU immediately"
      ],
      "referencesToShow": [
        "Practice Guidelines for Preoperative Fasting. Anesthesiology 2023. PMID: 36622802.",
        "Nason KS. PMID: 26210243."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "massive_bleeding",
    "category": "clinical_scenarios",
    "keywords": [
      "bleeding",
      "kanama",
      "masif",
      "massive",
      "mtp"
    ],
    "question_tr": "Masif kanama",
    "question_en": "Kanama",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Masif kanamada erken MTP aktivasyonu önemlidir.\\n1. Yardım çağır, kan bankasını haberdar et.\\n2. Cerrahi kanama kontrolü sağlanırken ısı, kalsiyum, pH ve koagülasyonu koru.\\n3. Eritrosit, plazma ve trombosit dengesini sağla; kurum protokolünü uygula.\\n4. Fibrinojen düzeyi veya ROTEM/TEG varsa hedefe yönelik replasman yap.\\n5. Hipokalsemi, hipotermi ve asidozu agresif düzelt.\\n6. Uygun endikasyonda traneksamik asit düşün.\\n7. Arter hattı, büyük damar yolu ve hızlı infüzyon sistemi kullan.",
      "immediateRedFlags": [
        "Kanama hızıyla birlikte seyreden kontrolsüz hipotansiyon (OAB <50 mmHg) ve aniden düşen ETCO₂ (ağır hipovolemi belirtisi).",
        "Hipotermi, asidoz ve koagülopati birlikteliği olan 'ölüm üçgeni' (lethal triad) tablosu."
      ],
      "missingCriticalInformation": [
        "Hastanın tahmini kan hacmi (EBV) ve o anki tahmini kan kaybı (ABL)",
        "Kan bankasındaki mevcut eritrosit ve plazma stok durumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Masif Transfüzyon Protokolü (MTP) Kriterleri",
        "Koagülopatinin Ölümcül Üçgeni (Triad of Death)",
        "Hedefe Yönelik Koagülasyon Tedavisi (ROTEG/TEG)"
      ],
      "suggestedNextStepsGeneral": [
        "Derhal Masif Transfüzyon Protokolünü (MTP) aktive edin.",
        "Isıtıcı cihazları ve hızlı infüzyon sistemlerini (Level 1 vb.) hazırlatın.",
        "Geniş çaplı (14-16G) iki adet damar yolu veya santral hat açın.",
        "Her 4 ünite eritrosit süspansiyonu sonrası 1 flakon Kalsiyum Klorür IV uygulayarak hipokalsemiyi önleyin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Masif transfüzyonda kristalloid sıvılarla aşırı yüklemeden kaçınılmalı, erken dönemde bire bir oranında ES:TDP:Trombosit verilmelidir"
      ],
      "whenToEscalate": [
        "Cerrahi olarak durdurulamayan masif kanamalarda acil anjiyografik embolizasyon veya cerrahi tamponad (packing) kararı"
      ],
      "referencesToShow": [
        "AAGBI guidelines on the management of massive haemorrhage. Anaesthesia 2015. PMID: 26477884.",
        "Spahn DR, et al. PMID: 30880340."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Activate the massive transfusion protocol early. Call for help and notify the blood bank. While surgical bleeding control is pursued, maintain temperature, calcium, pH, and coagulation. Balance red cells, plasma, and platelets according to local protocol. Use fibrinogen levels or ROTEM/TEG for goal-directed replacement when available. Aggressively correct hypocalcemia, hypothermia, and acidosis. Consider tranexamic acid when indicated. Use arterial monitoring, large-bore access, and rapid infusion capability.",
      "immediateRedFlags": [
        "Uncontrolled hypotension (MAP <50 mmHg) matching rapid blood loss and a sharp drop in ETCO₂ (severe hypovolemia).",
        "The presence of the 'lethal triad': hypothermia, acidosis, and coagulopathy."
      ],
      "missingCriticalInformation": [
        "Estimated blood volume (EBV) and estimated allowable blood loss (ABL)",
        "Availability of typed/crossmatched blood products in the blood bank"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Massive Transfusion Protocol (MTP) Criteria",
        "The Lethal Triad of Coagulopathy",
        "Goal-Directed Coagulation Therapy (ROTEM/TEG)"
      ],
      "suggestedNextStepsGeneral": [
        "Activate the Massive Transfusion Protocol (MTP) immediately.",
        "Ensure blood warmers and rapid infusion devices are set up.",
        "Establish large-bore peripheral access (14-16G) or insert a central/rapid-infusion catheter.",
        "Administer 1 vial of Calcium Chloride IV after every 4 units of PRBCs to prevent hypocalcemia."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Avoid crystalloid volume overload; prioritize early balanced PRBC:FFP:Platelet transfusion in a 1:1:1 ratio"
      ],
      "whenToEscalate": [
        "In surgically uncontrollable bleeding, coordinate immediately for angio-embolization or emergency packing"
      ],
      "referencesToShow": [
        "AAGBI guidelines on the management of massive haemorrhage. Anaesthesia 2015. PMID: 26477884.",
        "Spahn DR, et al. PMID: 30880340."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "rotem",
    "category": "clinical_scenarios",
    "keywords": [
      "rotem",
      "teg",
      "tromboelastografi",
      "tromboelastometri"
    ],
    "question_tr": "Rotem",
    "question_en": "Tromboelastometri",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Genel mantık:\\nUzamış pıhtılaşma başlangıcı: koagülasyon faktör eksikliği veya antikoagülan etkisi; plazma veya PCC düşünülür.\\nDüşük pıhtı amplitüdü / düşük MCF: fibrinojen veya trombosit eksikliği olabilir.\\nFIBTEM düşükse fibrinojen replasmanı düşünülür.\\nEXTEM düşük, FIBTEM yeterli ise trombosit desteği düşünülür.\\nHiperfibrinoliz varsa traneksamik asit düşünülür.\\nHer zaman klinik kanama, laboratuvar, sıcaklık, pH, kalsiyum ve kurum protokolü ile birlikte yorumlanmalıdır.",
      "immediateRedFlags": [
        "ROTEM/TEG'de görülen aşırı lizis (hiperfibrinoliz) masif kontrolsüz kanamanın en agresif habercisidir (acil TXA ihtiyacı!).",
        "Son derece uzamış CT (Clotting Time), pıhtılaşmanın başlamadığını gösterir ve ciddi koagülasyon faktör eksikliği belirtisidir."
      ],
      "missingCriticalInformation": [
        "Hastanın mevcut vücut sıcaklığı ve kalsiyum düzeyleri (hipotermi ve hipokalsemi pıhtılaşmayı in vitro testten bağımsız olarak bozar)",
        "ROTEM/TEG tetkikinin spesifik parametreleri (CT, CFT, Alpha açısı, A10, MCF, LI30)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Viskoelastik Hemostaz Testleri (ROTEM/TEG)",
        "Fibrinojen Konsantresi ve Trombosit Transfüzyon Eşikleri",
        "Hiperfibrinoliz ve Traneksamik Asit Kullanımı"
      ],
      "suggestedNextStepsGeneral": [
        "EXTEM CT >80 sn veya TEG R zamanı uzamışsa: TDP (Taze Donmuş Plazma) veya PCC uygulayın.",
        "FIBTEM A10 <10 mm ise: Fibrinojen Konsantresi (1-2 g IV) veya Kriyopresipitat uygulayın.",
        "EXTEM A10 <35 mm iken FIBTEM normalse: Trombosit transfüzyonu planlayın.",
        "Lizis parametreleri (ML >%15) yüksekse: Traneksamik Asit (1 g IV yavaş bolus) verin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Koagülasyon testleri pıhtılaşmayı mekanik ölçer; hastanın sıcaklığı <35°C veya pH <7.2 ise koagülasyon vücutta çalışmaz"
      ],
      "whenToEscalate": [
        "MTP aktivasyonu gerektiren ağır travmatik veya obstetrik kanamalarda hedefe yönelik ROTEM kılavuzlu transfüzyon"
      ],
      "referencesToShow": [
        "European Guidelines on Management of Major Bleeding. Eur J Anaesthesiol 2019. PMID: 30880340.",
        "Kozek-Langenecker SA, et al. PMID: 28059918."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "General principles: prolonged clot initiation suggests factor deficiency or anticoagulant effect; consider plasma or PCC. Low clot amplitude/MCF suggests fibrinogen or platelet deficiency. Low FIBTEM supports fibrinogen replacement. Low EXTEM with adequate FIBTEM suggests platelet support. Hyperfibrinolysis supports tranexamic acid. Always interpret with clinical bleeding, labs, temperature, pH, calcium, and institutional protocol.",
      "immediateRedFlags": [
        "Extreme lysis (hyperfibrinolysis) on ROTEM/TEG is a harbinger of massive uncontrolled bleeding (immediate TXA indicated!).",
        "Extremely prolonged CT (Clotting Time) indicates failure of clotting initiation, suggesting severe coagulation factor depletion."
      ],
      "missingCriticalInformation": [
        "Patient's current body temperature and calcium levels (hypothermia and hypocalcemia impair coagulation in vivo despite in vitro test values)",
        "Specific ROTEM/TEG parameters (CT, CFT, Alpha angle, A10, MCF, LI30)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Viscoelastic Hemostasis Assays (ROTEM/TEG)",
        "Fibrinogen Concentrate and Platelet Transfusion Thresholds",
        "Hyperfibrinolysis and Tranexamic Acid Utility"
      ],
      "suggestedNextStepsGeneral": [
        "If EXTEM CT >80s or TEG R-time is prolonged: Administer FFP or PCC.",
        "If FIBTEM A10 <10 mm: Administer Fibrinogen Concentrate (1-2 g IV) or Cryoprecipitate.",
        "If EXTEM A10 <35 mm with normal FIBTEM: Plan platelet transfusion.",
        "If lysis index (ML >15%) is elevated: Administer Tranexamic Acid (1 g IV slow bolus)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
