  {
    "id": "clinical_followup_malignant_hyperthermia_contraindications_0",
    "category": "clinical_followups",
    "keywords": [
      "clinical_followup_malignant_hyperthermia_contraindications_0",
      "contraindications",
      "followup",
      "hipertermi",
      "hyperthermia",
      "malign",
      "malignant",
      "mh",
      "var0"
    ],
    "question_tr": "Dantrolenin kontrendikasyonları nelerdir?",
    "question_en": "What are the contraindications of dantrolene?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "⚠️ Akut hayati tehdit oluşturan Malign Hipertermi krizinde Dantrolen uygulamasının hiçbir mutlak kontrendikasyonu yoktur. Ancak kronik kullanımda ciddi karaciğer yetmezliği kontrendikedir. Kalsiyum kanal blokörleri (Verapamil vb.) ile eş zamanlı kullanımı hiperkalemi ve kardiyak kollaps riskini artırdığı için kaçınılmalıdır.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "⚠️ There are no absolute contraindications to Dantrolene in an acute life-threatening Malignant Hyperthermia crisis. However, in chronic spasticity management, severe active hepatic disease is contraindicated. Co-administration with calcium channel blockers (e.g. Verapamil) should be avoided due to severe hyperkalemia and cardiovascular collapse risks.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
