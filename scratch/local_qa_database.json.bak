          "id": "ephedrine",
          "titleTr": "Ephedrine Monograph"
        }
      ],
      "doNotMiss": [
        "In LAST-induced arrest, do NOT administer Vasopressin, and limit Epinephrine to <1 mcg/kg (e.g., 10-100 mcg boluses)"
      ],
      "whenToEscalate": [
        "If cardiovascular stability is not restored despite reaching cumulative 12 mL/kg lipid dose, transition immediately to ECMO/CPB support"
      ],
      "referencesToShow": [
        "ASRA Checklist for Local Anesthetic Systemic Toxicity. 2020.",
        "Neal JM, et al. PMID: 29016373."
