  {
    "id": "laparoscopy_hypercapnia",
    "category": "clinical_scenarios",
    "keywords": [
      "etco2",
      "hypercapnia",
      "laparoscopy",
      "laparoskopide",
      "pnömoperitoneum",
      "rising",
      "yükseldi"
    ],
    "question_tr": "Laparoskopide etco2",
    "question_en": "Etco2 yükseldi",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "ETCO₂ yükselmesi CO₂ absorbsiyonu, hipoventilasyon, rebreathing, artmış metabolizma, malign hipertermi veya cihaz problemi nedeniyle olabilir.\\n\\n1. Ventilasyonu artırmadan önce devre ve soda lime/rebreathing ihtimalini kontrol et.\\n2. Dakika ventilasyonunu artır.\\n3. Pnömoperitoneum basıncını ve cerrahi CO₂ absorbsiyonunu değerlendir.\\n4. Ani ve belirgin yükselme, taşikardi, rijidite ve hipertermi varsa malign hipertermi düşün.\\n5. Hemodinamik bozulma eşlik ederse CO₂ embolisi veya tansiyon pnömotoraksı akılda tut.",
      "immediateRedFlags": [
        "ETCO₂'nin >60 mmHg düzeyine çıkması ve buna şiddetli solunumsal asidoz (pH <7.15), taşiaritmi ve hipotansiyonun eşlik etmesi.",
        "ETCO₂ yükselmesi sırasında hastada kas rijiditesi ve vücut sıcaklığı artışının başlaması (MH alarmı!)."
      ],
      "missingCriticalInformation": [
        "Pnömoperitoneum insuflasyon basıncı değeri (mmHg cinsinden, ideal olarak <12-15 mmHg olmalıdır)",
        "Cerrahi süresi ve karına verilen toplam CO₂ miktarı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Laparoskopik Cerrahide Karbondioksit Absorbsiyonu ve Eliminasyonu",
        "Auto-PEEP ve Ventilatör Devre Rebreathing Sorunları",
        "Akut Solunumsal Asidoz Hemodinamik Komplikasyonları"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle ventilatör devresini, CO₂ absorberini (soda lime) ve tek yönlü valfleri kontrol edin (rebreathing olmadığını doğrulayın).",
        "Dakika ventilasyonunu (frekansı ve tidal hacmi) artırarak karbondioksit eliminasyonunu yükseltin.",
        "Cerrahla görüşerek pnömoperitoneum basıncının <12 mmHg düzeyine düşürülmesini isteyin.",
        "Kan gazı alarak pH ve PaCO₂ değerlerini takip edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Laparoskopi sırasında intraperitoneal CO₂ absorbsiyonunun cerrahinin ilk 30-40 dakikasında tavan yaptığı ve dakika ventilasyonunun buna göre ayarlanması gerektiği"
      ],
      "whenToEscalate": [
        "Dirençli hiperkapniye bağlı kardiyovasküler kollaps veya tansiyon pnömotoraks şüphesinde derhal pnömoperitoneumu boşalttırın ve cerrahiyi durdurun"
      ],
      "referencesToShow": [
        "Physiological Changes during Laparoscopic Surgery. Surgical Endoscopy 2018. PMID: 32014671.",
        "ASA Standards. 2020."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Rising ETCO₂ may result from CO₂ absorption, hypoventilation, rebreathing, increased metabolism, malignant hyperthermia, or equipment problems. Check the circuit and soda lime/rebreathing before simply increasing ventilation. Increase minute ventilation, assess pneumoperitoneum pressure and CO₂ absorption, and consider malignant hyperthermia if sudden marked rise is associated with tachycardia, rigidity, or hyperthermia. If hemodynamic collapse occurs, consider CO₂ embolism or tension pneumothorax.",
      "immediateRedFlags": [
        "ETCO₂ >60 mmHg accompanied by severe respiratory acidosis (pH <7.15), tachyarrhythmia, and hypotension.",
        "ETCO₂ rise paired with muscle rigidity or hyperthermia (impending MH crisis)."
      ],
      "missingCriticalInformation": [
        "Intra-abdominal pneumoperitoneum pressure (should be maintained <12-15 mmHg)",
        "Ventilator circuit configuration (to rule out mechanical rebreathing)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Laparoscopic CO₂ Insufflation and Absorption Kinetics",
        "Expiratory Rebreathing and Soda Lime Exhaustion",
        "Hemodynamic Effects of Acute Respiratory Acidosis"
      ],
      "suggestedNextStepsGeneral": [
        "Check the ventilator circuit, check expiratory valve function, and inspect soda lime for exhaustion (exclude rebreathing).",
        "Increase minute ventilation by escalating respiratory rate and tidal volume.",
        "Ask the surgeon to reduce intra-abdominal pressure (ideally <12 mmHg).",
        "Obtain arterial blood gas to monitor pH and PaCO₂."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "CO₂ absorption peaks within 30-40 minutes of pneumoperitoneum; adjust minute ventilation proactively rather than reactively"
      ],
      "whenToEscalate": [
        "If severe hypercapnia causes cardiovascular collapse, or tension pneumothorax/embolism is suspected, deflate the abdomen immediately and halt surgery"
      ],
      "referencesToShow": [
        "Physiological Changes during Laparoscopic Surgery. Surgical Endoscopy 2018. PMID: 32014671.",
        "ASA Standards. 2020."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "co2_embolism",
    "category": "clinical_scenarios",
    "keywords": [
      "co2",
      "emboli",
      "embolisi",
      "embolism",
      "karbondioksit"
    ],
    "question_tr": "Co2 embolisi",
    "question_en": "Karbondioksit emboli",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "CO₂ embolisi ani ETCO₂ düşüşü, hipotansiyon, hipoksemi, aritmi veya kardiyovasküler kollaps ile gelebilir.\\n\\n1. Cerraha haber ver; insufflasyonu durdur ve pnömoperitoneumu boşalt.\\n2. %100 oksijen ver.\\n3. Hemodinamik destek başlat.\\n4. Sol lateral/Trendelenburg pozisyonu düşünülebilir.\\n5. Santral venöz kateter varsa aspirasyon denenebilir.\\n6. Kardiyak arrest gelişirse ACLS uygula.\\n7. Ayırıcı tanıda pulmoner emboli, kanama, anafilaksi ve tansiyon pnömotoraksı düşün.",
      "immediateRedFlags": [
        "Laparoskopide CO₂ insuflasyonu başladıktan hemen sonra ETCO₂'nin aniden sıfıra yaklaşması, derin hipotansiyon ve EKG'de asistoli/areste gidiş.",
        "Oskültasyonda kalpte tipik değirmen çarkı (mill-wheel) üfürümünün duyulması."
      ],
      "missingCriticalInformation": [
        "İnsuflasyonun gaz akım hızı (özellikle hızlı başlangıç akımları riski artırır)",
        "Santral venöz kateterin (CVC) varlığı ve açıklığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Laparoskopik Venöz Gaz Embolisi (CO₂ Embolisi)",
        "Aortokaval Bası ve Gaz Kilidi (Gas Lock) Mekanizması",
        "Sağ Ventrikül Yetmezliği ve Acil Aspirasyon Tedavisi"
      ],
      "suggestedNextStepsGeneral": [
        "Derhal cerraha haber verin; CO₂ insuflasyonunu hemen durdurtun ve pnömoperitoneumu boşalttırın.",
        "FiO₂'yi 1.0 (%100 O₂) yapın.",
        "Hastayı Durant pozisyonuna (sol lateral dekubit ve hafif Trendelenburg) getirin (gaz kabarcıklarının sağ ventrikül çıkış yolunu tıkamasını engellemek için).",
        "Eğer santral venöz kateter varsa, kateterden CO₂ gazını enjektörle aspire etmeyi deneyin.",
        "Kardiyovasküler kollaps varsa hızlıca Adrenalin (50-100 mcg IV) uygulayın ve gerekirse CPR başlatın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        },
        {
          "id": "adrenaline",
          "titleTr": "Adrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "CO₂ embolisinde gaz kabarcıklarının sağ ventrikülde sıkışarak kan akımını tamamen kesebileceği (gaz kilidi) gerçeği"
      ],
      "whenToEscalate": [
        "Sağ ventrikül çıkış yolu tıkanıklığına bağlı arrest geliştiğinde kesintisiz kardiyopulmoner resüsitasyon (ACLS) başlatılması"
      ],
      "referencesToShow": [
        "Carbon Dioxide Embolism in Laparoscopy. JSLS 2017. PMID: 26210243.",
        "AHA Guidelines. 2020. PMID: 33081529."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "CO₂ embolism may present with sudden ETCO₂ drop, hypotension, hypoxemia, arrhythmia, or cardiovascular collapse. Inform the surgeon, stop insufflation, release pneumoperitoneum, give 100% oxygen, start hemodynamic support, consider left lateral/Trendelenburg positioning, attempt aspiration if a central venous catheter is present, and follow ACLS if cardiac arrest occurs. Consider pulmonary embolism, bleeding, anaphylaxis, and tension pneumothorax in the differential.",
      "immediateRedFlags": [
        "Sudden catastrophic drop in ETCO₂ near zero, profound hypotension, and impending cardiac arrest right after starting laparoscopy insufflation.",
        "A classic 'mill-wheel' murmur heard on cardiac auscultation."
      ],
      "missingCriticalInformation": [
        "Insufflation flow rate (high-flow insufflation directly increases risk if a vessel is breached)",
        "Availability of central venous access (CVC)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Laparoscopic Venous Gas Embolism (CO₂ Embolism)",
        "Right Ventricular Outflow Obstruction (Gas Lock) Physiology",
        "ACLS Adaptation for Gas Embolism Resuscitation"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately notify the surgeon; halt CO₂ insufflation and completely deflate the pneumoperitoneum.",
        "Increase FiO₂ to 1.0 (100% O₂).",
        "Place the patient in Durant's position (left lateral decubitus and Trendelenburg) to trap gas in the right atrium.",
        "If a central venous catheter is present, attempt to aspirate gas from the right heart.",
        "Initiate aggressive vasoactive support with Epinephrine (50-100 mcg IV boluses) if cardiovascular collapse occurs."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        },
        {
          "id": "adrenaline",
          "titleTr": "Epinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "CO₂ gas can create a physical 'gas lock' in the right ventricular outflow tract, completely halting pulmonary blood flow"
      ],
      "whenToEscalate": [
        "In the event of refractory gas-induced cardiac arrest, initiate immediate high-quality CPR and follow standard ACLS protocols"
      ],
      "referencesToShow": [
        "Carbon Dioxide Embolism in Laparoscopy. JSLS 2017. PMID: 26210243.",
        "AHA Guidelines. 2020. PMID: 33081529."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "tension_pneumothorax",
    "category": "clinical_scenarios",
    "keywords": [
      "dekompresyon",
      "iğne",
      "pneumothorax",
      "pnömotoraks",
      "tansiyon",
      "tension"
    ],
    "question_tr": "Tansiyon pnömotoraks",
    "question_en": "Iğne dekompresyon",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Tansiyon pnömotoraks hipoksemi, hipotansiyon, yüksek havayolu basıncı, tek taraflı solunum sesi azalması, trakeal deviasyon ve kardiyovasküler kollaps ile gelebilir.\\nŞüphe güçlüyse görüntüleme beklenmez.\\n\\n1. %100 oksijen ver.\\n2. Cerraha haber ver, yardım çağır.\\n3. Acil iğne dekompresyon veya tüp torakostomi uygula/uygulat.\\n4. Hemodinamik destek ver.\\n5. Ayırıcı tanıda bronkospazm, tüp tıkanıklığı, endobronşiyal entübasyon, PE ve anafilaksi düşün.",
      "immediateRedFlags": [
        "Havayolu basınçlarının aniden fırlamasıyla birlikte arter basıncının ölçülemeyecek kadar düşmesi (şok tablosu).",
        "Tek taraflı solunum seslerinin tamamen kaybolması ve trakeanın karşı tarafa kayması.",
        "EKG'de NEA (Nabızsız Elektriksel Aktivite) ritmine ilerleme."
      ],
      "missingCriticalInformation": [
        "Mevcut SpO₂ ve ETCO₂ dalga yapısı",
        "Hastanın santral venöz basınç trasesi (varsa - aşırı yüksek CVP tıkanıklığı doğrular)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İntraoperatif Tansiyon Pnömotoraks Kriz Yönetimi",
        "İğne Dekompresyonu (İğne Torakostomi) Teknik Adımları",
        "Göğüs Tüpü (Tüp Torakostomi) Uygulama Standartları"
      ],
      "suggestedNextStepsGeneral": [
        "Cerraha derhal haber verin ve göğüs manipülasyonunu veya pnömoperitoneumu durdurtun.",
        "FiO₂'yi 1.0 (%100 O₂) yapın.",
        "Hemodinamik şok veya NEA varsa radyolojik görüntüleme beklemeden derhal ACİL İĞNE DEKOMPRESYONU uygulayın.",
        "İğne Giriş Noktası: 2. interkostal aralık (midklavikular hat) veya 4./5. interkostal aralık (ön aksiller hat) üzerinden kalın bir branül (14-16G) ile girin.",
        "Hemen ardından kalıcı göğüs tüpü takılması için cerrahi ekibi yönlendirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Zor Entübasyon Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        },
        {
          "id": "adrenaline",
          "titleTr": "Adrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Tansiyon pnömotoraksının mekanik ventilasyon altında pozitif basıncın etkisiyle saniyeler içinde ölümcül şok yaratabileceği"
      ],
      "whenToEscalate": [
        "Pnömotoraksa bağlı kalp durmasında (kardiyak arrest) derhal iğne dekompresyonu yapın ve eş zamanlı yüksek kaliteli CPR başlatın"
      ],
      "referencesToShow": [
        "Tension Pneumothorax under General Anesthesia. British Journal of Anaesthesia 2018. PMID: 26210243.",
        "ACLS Guidelines. 2020."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Tension pneumothorax may present with hypoxemia, hypotension, high airway pressure, reduced unilateral breath sounds, tracheal deviation, and cardiovascular collapse. If suspicion is high, do not wait for imaging. Give 100% oxygen, inform the surgeon, call for help, perform or request emergency needle decompression or tube thoracostomy, and provide hemodynamic support. Consider bronchospasm, tube obstruction, endobronchial intubation, pulmonary embolism, and anaphylaxis in the differential.",
      "immediateRedFlags": [
        "Catastrophic drop in blood pressure (shock) accompanied by a sudden spike in peak airway pressure.",
        "Unilateral absence of breath sounds with contralateral tracheal deviation.",
        "Rapid progression to Pulseless Electrical Activity (PEA)."
      ],
      "missingCriticalInformation": [
        "Current SpO₂ and ETCO₂ trends",
        "Whether central venous pressure (CVP) is elevated (reflecting impaired venous return)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Intraoperative Tension Pneumothorax Crisis Management",
        "Needle Decompression (Needle Thoracostomy) Landmarks",
        "Chest Tube (Tube Thoracostomy) Emergency Placement"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately inform the surgeon and pause chest manipulation or abdominal insufflation.",
        "Increase FiO₂ to 1.0 (100% O₂).",
        "If patient is in shock or PEA occurs, perform immediate NEEDLE DECOMPRESSION without waiting for a chest X-ray.",
        "Landmarks: Insert a large-bore (14G or 16G) IV cannula into the 2nd intercostal space at the midclavicular line, or 4th/5th intercostal space at the anterior axillary line.",
        "Follow immediately with a formal chest tube (tube thoracostomy) insertion."
      ],
      "relatedAlgorithms": [
        {
          "id": "unexpected_difficult_intubation",
          "titleTr": "Difficult Intubation Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        },
        {
          "id": "adrenaline",
          "titleTr": "Epinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Under positive-pressure mechanical ventilation, a simple pneumothorax converts to a life-threatening tension pneumothorax extremely rapidly"
      ],
      "whenToEscalate": [
        "If cardiac arrest occurs due to tension pneumothorax, perform decompression immediately as it is the only way to restore cardiac output, while performing CPR"
      ],
      "referencesToShow": [
        "Tension Pneumothorax under General Anesthesia. British Journal of Anaesthesia 2018. PMID: 26210243.",
        "ACLS Guidelines. 2020."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "postoperative_delirium",
    "category": "clinical_scenarios",
    "keywords": [
      "agitation",
      "ajitasyon",
      "delirium",
      "deliryum",
      "pacu",
      "postoperatif",
      "postoperative"
    ],
    "question_tr": "Postoperatif deliryum",
    "question_en": "Pacu delirium",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Önce hayatı tehdit eden ve düzeltilebilir nedenleri dışla: hipoksemi, hiperkapni, hipoglisemi, hipotansiyon, ağrı, idrar retansiyonu, kanama, sepsis, inme, ilaç etkisi veya yoksunluk.\\n\\n1. ABC ve vital bulguları değerlendir.\\n2. SpO₂/ETCO₂, glukoz, ağrı ve mesane distansiyonunu kontrol et.\\n3. Gereksiz sedasyondan kaçın.\\n4. Sessiz ortam, reoryantasyon, gözlük/işitme cihazı, aile desteği gibi non-farmakolojik yöntemleri uygula.\\n5. Hasta kendine veya ekibe zarar verecek düzeyde ajite ise düşük doz antipsikotik veya sedatif dikkatle düşünülebilir.",
      "immediateRedFlags": [
        "PACU'da uyanan yaşlı hastada ani başlayan agresif ajitasyon, kendine zarar verme eğilimi (damar yollarını, tüpleri çekme).",
        "Uyanma odasında SpO₂'nin düşmesi ve solunum yüzeyselleşmesi ile seyreden hipoaktif deliryum (gözden kaçması kolaydır!)."
      ],
      "missingCriticalInformation": [
        "Ameliyat öncesi demans veya kognitif bozukluk geçmişi",
        "Hastanın ameliyat sırasında aldığı toplam antikolinerjik (örn. Atropin) veya benzodiazepin dozu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postoperatif Deliryum ve Uyanma Ajitasyonu (Emergence Delirium)",
        "Deliryum Tarama Ölçekleri (CAM-ICU, Nu-DESC)",
        "Non-farmakolojik Kognitif Reoryantasyon Yöntemleri"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle hayati nedenleri (Hipoksi, Hiperkapni, Hipoglisemi, Ağrı) dışlayın.",
        "Hastanın mesanesini ultrasonla veya elle kontrol ederek glob vezikale (idrar retansiyonu) olmadığını doğrulayın.",
        "Gözlük, işitme cihazı gibi duyu organı araçlarını hastaya hemen takın ve aile üyesini yanına alın.",
        "Şiddetli ajitasyonda farmakolojik tedavi: Düşük doz Deksmedetomidin (0.2-0.7 mcg/kg/saat infüzyon) veya Haloperidol (0.5-2 mg IV) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        },
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monografı"
        }
      ],
      "doNotMiss": [
        "Deliryumu yatıştırmak için rastgele verilen yüksek doz Midazolam veya diğer benzodiazepinlerin deliryum tablosunu daha da kötüleştirebileceği"
      ],
      "whenToEscalate": [
        "Nörolojik defisit, inme veya açıklanamayan dirençli konfüzyon durumunda acil Nöroloji konsültasyonu ve Beyin BT/MRG"
      ],
      "referencesToShow": [
        "European Society of Anaesthesiology (ESA) Guideline on Postoperative Delirium. Eur J Anaesthesiol 2017. PMID: 28059918.",
        "Inouye SK, et al. PMID: 24347101."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "First exclude life-threatening and reversible causes: hypoxemia, hypercapnia, hypoglycemia, hypotension, pain, urinary retention, bleeding, sepsis, stroke, drug effect, or withdrawal. Assess ABCs and vital signs, check SpO₂/ETCO₂, glucose, pain, and bladder distension, avoid unnecessary sedation, and use non-pharmacologic measures such as a quiet environment, reorientation, glasses/hearing aids, and family support. If the patient is at risk of harming self or staff, low-dose antipsychotic or sedative therapy may be considered carefully.",
      "immediateRedFlags": [
        "Aggressive preoperative/postoperative emergence agitation where the patient attempts to pull out IV lines, surgical drains, or airway tubes.",
        "Silent, uncommunicative hypoactive delirium presenting with shallow breathing and desaturation (frequently missed)."
      ],
      "missingCriticalInformation": [
        "Preoperative history of dementia, cognitive impairment, or substance abuse",
        "Total dose of anticholinergics (e.g., Atropine) or benzodiazepines administered intraoperatively"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postoperative Emergence Delirium and Agitation",
        "Delirium Screening Tools (CAM-ICU, Nu-DESC)",
        "Non-pharmacological Cognitive Reorientation Interventions"
      ],
      "suggestedNextStepsGeneral": [
        "First, systematically rule out life-threatening causes (Hypoxia, Hypercapnia, Hypoglycemia, Severe Pain).",
        "Check the bladder for acute urinary retention (globus vesicales) - a highly common cause of postop agitation.",
        "Provide the patient's glasses/hearing aids immediately and allow a family member at the bedside.",
        "For pharmacotherapy of severe agitation, consider low-dose Dexmedetomidine infusion (0.2-0.7 mcg/kg/h) or Haloperidol (0.5-2 mg IV)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        },
        {
          "id": "midazolam",
          "titleTr": "Midazolam Monograph"
        }
      ],
      "doNotMiss": [
        "Administering benzodiazepines (e.g., Midazolam) to treat active delirium often backfires, worsening and prolonging the confusion state"
      ],
      "whenToEscalate": [
        "In the event of suspected stroke, focal neurologic deficits, or prolonged unexplained coma, request emergency Neurological consultation and brain CT/MRI"
      ],
      "referencesToShow": [
        "European Society of Anaesthesiology (ESA) Guideline on Postoperative Delirium. Eur J Anaesthesiol 2017. PMID: 28059918.",
        "Inouye SK, et al. PMID: 24347101."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "delayed_emergence",
    "category": "clinical_scenarios",
    "keywords": [
      "delayed",
      "emergence",
      "gecikmiş",
      "not",
      "uyanma",
      "uyanmadı",
      "waking"
    ],
    "question_tr": "Gecikmiş uyanma",
    "question_en": "Not waking",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Gecikmiş uyanmada sistematik yaklaş:\\n1. Oksijenasyon, ventilasyon, ETCO₂ ve hemodinamiyi değerlendir.\\n2. Hipoglisemi, hiperkapni, hipoksi, hipotermi ve elektrolit bozukluğunu dışla.\\n3. Verilen anestezik, opioid, benzodiazepin ve kas gevşetici dozlarını kontrol et.\\n4. Rezidüel nöromüsküler blok için kantitatif TOF değerlendir.\\n5. Opioid etkisi varsa nalokson; benzodiazepin etkisi varsa flumazenil düşünülebilir.\\n6. Fokal nörolojik bulgu, nöbet veya açıklanamayan koma varsa acil nörolojik değerlendirme gerekir.",
      "immediateRedFlags": [
        "Anestezik gazlar ve infüzyonlar tamamen kapatıldıktan sonra >60-90 dakika geçmesine rağmen hastanın hiçbir sözel veya ağrılı uyarana yanıt vermemesi.",
        "Eşlik eden fokal nörolojik asimetri (örn. tek taraflı pupil dilatasyonu, tek taraflı hemipleji - inme belirtisi)."
      ],
      "missingCriticalInformation": [
        "Operasyon sırasında uygulanan tüm anesteziklerin, opioidlerin ve sedatiflerin kümülatif dozları",
        "Hastanın bazal vücut sıcaklığı (ağır hipotermi anesteziklerin metabolizmasını durdurur)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Gecikmiş Uyanma Diferansiyel Tanısı (Metabolik vs Farmakolojik vs Nörolojik)",
        "Rezidüel Nöromüsküler Blok (Kürarizasyon Kalıntısı)",
        "Opioid ve Benzodiazepin Antagonizma Kuralları"
      ],
      "suggestedNextStepsGeneral": [
        "Parmak ucu kan şekerini ölçün (hipoglisemiyi dışlayın).",
        "Kan gazı alarak pH, PaCO₂, sodyum ve elektrolit düzeylerini kontrol edin (ağır hiperkapni CO₂ narkozuna yol açar).",
        "Kantitatif TOF cihazı ile kas gücünü ölçün (TOF oranı >%90 olduğunu teyit edin).",
        "Opioid aşırı dozu şüphesinde: Nalokson (40 mcg boluslar halinde yavaş yavaş) uygulayın.",
        "Benzodiazepin aşırı dozu şüphesinde: Flumazenil (0.2 mg IV, gerekirse tekrarlayan boluslar) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Süksinilkolin Monografı"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        }
      ],
      "doNotMiss": [
        "Şiddetli hipoterminin (vücut sıcaklığı <33°C) anesteziklerin yarı ömrünü katlayarak uyanmayı tek başına durdurabileceği"
      ],
      "whenToEscalate": [
        "İlaç etkileri elendikten sonra uyanmayan ve fokal nörolojik defisiti olan hastada acil inme protokolü ve Beyin tomografisi"
      ],
      "referencesToShow": [
        "Delayed Emergence from Anesthesia. Anesthesiology Clinics 2020. PMID: 29016373.",
        "ASA Guidelines. 2018."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Use a systematic approach. Assess oxygenation, ventilation, ETCO₂, and hemodynamics. Exclude hypoglycemia, hypercapnia, hypoxia, hypothermia, and electrolyte abnormalities. Review anesthetic, opioid, benzodiazepine, and neuromuscular blocker doses. Check quantitative TOF for residual block. Consider naloxone for opioid effect and flumazenil for benzodiazepine effect when appropriate. Focal neurologic signs, seizure, or unexplained coma requires urgent neurologic evaluation.",
      "immediateRedFlags": [
        "Failure to respond to verbal or painful stimuli >60-90 minutes after complete cessation of all anesthetic agents.",
        "Focal neurological asymmetry (e.g., unilateral dilated pupil, unilateral flaccidity) suggesting intraoperative stroke."
      ],
      "missingCriticalInformation": [
        "Cumulative doses of all sedatives, opioids, and anesthetics administered during the procedure",
        "Patient's core body temperature (severe hypothermia blocks anesthetic clearance)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Delayed Emergence Differential Diagnosis (Pharmacologic vs. Metabolic vs. Neurologic)",
        "Residual Neuromuscular Blockade (Curarization)",
        "Reversal of Opioid/Benzodiazepine Depressant Effects"
      ],
      "suggestedNextStepsGeneral": [
        "Check fingerstick blood glucose immediately (exclude hypoglycemia).",
        "Obtain arterial blood gas to rule out severe hypercapnia (CO₂ narcosis), hypoxia, or electrolyte derangements.",
        "Measure neuromuscular function using quantitative TOF (ensure TOF ratio >90%).",
        "If opioid overdose is suspected: Titrate IV Naloxone in 40 mcg increments.",
        "If benzodiazepine overdose is suspected: Administer IV Flumazenil 0.2 mg boluses."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Succinylcholine Monograph"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        }
      ],
      "doNotMiss": [
        "Severe hypothermia (<33°C) dramatically slows down anesthetic metabolism and is a common reversible cause of delayed emergence"
      ],
      "whenToEscalate": [
        "If pharmacological reversal is ineffective and neurological signs are abnormal, trigger an emergency stroke protocol and obtain brain CT/MRI"
      ],
      "referencesToShow": [
        "Delayed Emergence from Anesthesia. Anesthesiology Clinics 2020. PMID: 29016373.",
        "ASA Guidelines. 2018."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "postoperative_shivering",
    "category": "clinical_scenarios",
    "keywords": [
      "meperidin",
      "postoperatif",
      "postoperative",
      "shivering",
      "titreme"
    ],
    "question_tr": "Postoperatif titreme",
    "question_en": "Meperidin",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Önce hipotermiyi değerlendir. Aktif ısıtma, sıcak battaniye, ısıtılmış sıvı ve ortam ısısı düzenlemesi yapılır.\\nTitreme normotermide de olabilir. Ağrı, hipoksi, hipoglisemi ve ilaç etkileri dışlanmalıdır.\\nFarmakolojik seçenekler arasında düşük doz meperidin/petidin, tramadol, klonidin veya deksmedetomidin düşünülebilir. Solunum depresyonu, sedasyon ve hemodinamik etkilere dikkat edilmelidir.",
      "immediateRedFlags": [
        "Şiddetli titreme sırasında miyokardiyal oksijen tüketiminin %100-400 artması ve buna bağlı olarak koroner arter hastalarında göğüs ağrısı (iskemi) veya taşikardi gelişimi.",
        "Titreme eşliğinde solunum yetmezliği veya hipoksemi."
      ],
      "missingCriticalInformation": [
        "Hastanın güncel timpanik veya özofageal vücut sıcaklığı",
        "Hastanın altta yatan koroner arter hastalığı geçmişi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postoperatif Titreme (Shivering) Patofizyolojisi",
        "Miyokardiyal Oksijen Tüketimi ve Isı Koruma Yönetimi",
        "Petidin/Meperidin Farmakoterapi Kriterleri"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın vücut sıcaklığını ölçün. Hipotermik ise zorunlu hava ısıtıcı (Bair Hugger) ve sıcak battaniyelerle aktif ısıtmaya başlayın.",
        "Kan şekeri ve oksijenasyonu (SpO₂) kontrol edin.",
        "Normotermik titreme veya dirençli tablolarda farmakolojik tedavi: Meperidin (Aldolan, 10-25 mg IV bolus) uygulayın (titremeyi durdurmada en etkili ilaçtır).",
        "Alternatif olarak Klonidin (75-150 mcg IV) veya Tramadol (1 mg/kg IV) düşünülebilir."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Postoperatif titremenin sadece hipotermiye bağlı olmayıp anesteziklerin spinal kord termoregülasyon eşiğini bozması sonucu normotermide de gelişebileceği"
      ],
      "whenToEscalate": [
        "Titremenin eşlik ettiği dirençli miyokard iskemisinde (ST yükselmesi/çökmesi) acil EKG, troponin ve kardiyoloji konsültasyonu"
      ],
      "referencesToShow": [
        "Postoperative Shivering: Epidemiology and Pathophysiology. Anaesthesia 2018. PMID: 29016373.",
        "ESA Guidelines. 2017. PMID: 28059918."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "First assess for hypothermia. Use active warming, warm blankets, warmed fluids, and ambient temperature management.\\n\\nShivering may also occur in normothermia; exclude pain, hypoxia, hypoglycemia, and drug effects. Pharmacologic options include low-dose meperidine, tramadol, clonidine, or dexmedetomidine. Monitor for respiratory depression, sedation, and hemodynamic effects.",
      "immediateRedFlags": [
        "Postoperative shivering escalating myocardial oxygen consumption by 100-400%, precipitating ischemia (ST changes) in coronary patients.",
        "Shivering-associated respiratory distress or severe hypoxemia."
      ],
      "missingCriticalInformation": [
        "Patient's current core body temperature (tympanic or esophageal)",
        "History of coronary artery disease or limited cardiac reserve"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postoperative Shivering Pathophysiology and Thermoregulation",
        "Myocardial Oxygen Demand and Shivering-Induced Ischemia",
        "Meperidine/Pethidine Pharmacotherapy in PACU"
      ],
      "suggestedNextStepsGeneral": [
        "Measure core temperature. If hypothermic, initiate active forced-air warming (Bair Hugger) and warm blankets.",
        "Check blood glucose and SpO₂ to exclude metabolic/respiratory triggers.",
        "For pharmacological management, administer low-dose Meperidine (Pethidine, 10-25 mg IV bolus) - the gold standard for shivering.",
        "Alternatively, administer Clonidine (75-150 mcg IV) or Tramadol (1 mg/kg IV)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Shivering can occur in normothermic patients due to anesthetic-induced disruption of the hypothalamic shivering threshold"
      ],
      "whenToEscalate": [
        "In shivering patients presenting with acute ECG changes or ischemic chest pain, obtain an urgent 12-lead ECG, troponin, and Cardiology consult"
      ],
      "referencesToShow": [
        "Postoperative Shivering: Epidemiology and Pathophysiology. Anaesthesia 2018. PMID: 29016373.",
        "ESA Guidelines. 2017. PMID: 28059918."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "perioperative_hypothermia",
    "category": "clinical_scenarios",
    "keywords": [
      "düşük",
      "hipotermi",
      "hypothermia",
      "perioperatif",
      "perioperative",
      "sıcaklığı",
      "vücut"
    ],
    "question_tr": "Perioperatif hipotermi",
    "question_en": "Hypothermia perioperative",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Hipotermi kanama, enfeksiyon, kardiyak olay, ilaç metabolizması gecikmesi ve titreme riskini artırabilir.\\n\\n1. Preoperatif sıcaklığı ölç.\\n2. Riskli hastada prewarming uygula.\\n3. Zorunlu hava ısıtıcı kullan.\\n4. Uzun cerrahide IV sıvı ve irrigasyon sıvılarını ısıt.\\n5. Vücut yüzeyini açıkta bırakma.\\n6. İntraoperatif ve PACU’da sıcaklığı izle.\\n7. Hipotermi gelişirse aktif ısıtma sürdürülür ve koagülopati açısından dikkatli olunur.",
      "immediateRedFlags": [
        "İntraoperatif vücut sıcaklığının <35.0°C olması (klinik olarak koagülopati ve yara yeri enfeksiyon riski katlanır).",
        "Hipotermi ile birlikte refrakter disritmi (sinüs bradikardisi, nodal ritim veya dirençli VF/VT ritimlerinin tetiklenmesi)."
      ],
      "missingCriticalInformation": [
        "Cerrahi süresi ve kullanılan irrigasyon sıvı hacimleri",
        "Hastanın intraoperatif vücut sıcaklığı izlem yöntemi (özofageal, nazofarengeal, mesane)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İntraoperatif İstenmeyen Hipoterminin Önlenmesi",
        "Hofmann Eliminasyonu ve İlaç Yarı Ömrü Değişiklikleri",
        "Isı Koruyucu Cihazlar ve Aktif Sıvı Isıtma Yöntemleri"
      ],
      "suggestedNextStepsGeneral": [
        "Tüm hastalarda vücut sıcaklığını intraoperatif dönemde rutin olarak ölçün.",
        "Preoperatif dönemde 30 dakika boyunca 'Prewarming' (hava ısıtıcı ile ön ısıtma) uygulayın.",
        "Ameliyathanede zorunlu hava üflemeli ısıtıcı battaniye (Bair Hugger) kullanın.",
        "IV infüzyon sıvılarını ve batın içi yıkama sıvılarını kesinlikle 37°C'ye ısıtarak kullanın.",
        "Ortam sıcaklığını 21°C'nin üzerinde tutun (özellikle pediatrik ve geriatrik olgularda)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Vücut sıcaklığındaki her 1°C'lik düşüşün cerrahi kan kaybını ortalama %16 oranında artırdığı ve koagülasyon kaskadını doğrudan yavaşlattığı"
      ],
      "whenToEscalate": [
        "Ağır hipotermi (<33°C) varlığında disritmi ve masif koagülopati riski nedeniyle aktif dahili ısıtma yöntemleri (ılık nemlendirilmiş oksijen, ılık peritoneal lavaj) ve yoğun bakım"
      ],
      "referencesToShow": [
        "NICE Guideline NG85: Perioperative Hypothermia. 2016. PMID: 28059918.",
        "Sessler DI. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Hypothermia may increase bleeding, infection, cardiac events, delayed drug metabolism, and shivering. Measure preoperative temperature, use prewarming in high-risk patients, apply forced-air warming, warm IV and irrigation fluids during long procedures, minimize exposed body surface, and monitor temperature intraoperatively and in PACU. If hypothermia occurs, continue active warming and watch for coagulopathy.",
      "immediateRedFlags": [
        "Intraoperative core temperature <35.0°C (multiplies risk of surgical site infections and clinical coagulopathy).",
        "Hypothermia-induced severe cardiac dysrhythmias (marked bradycardia, nodal rhythms, or refractory VF/VT)."
      ],
      "missingCriticalInformation": [
        "Total surgical duration and volume of un-warmed irrigation fluids used",
        "Intraoperative core temperature monitoring modality (esophageal, nasopharyngeal, or bladder)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Prevention of Inadvertent Perioperative Hypothermia (IPH)",
        "Hofmann Elimination and Drug Metabolism Alterations",
        "Thermoregulatory Devices and Active Fluid Warming Standards"
      ],
      "suggestedNextStepsGeneral": [
        "Monitor core body temperature routinely for any procedure lasting >30 minutes under general or regional anesthesia.",
        "Perform active preoperative 'prewarming' for 30 minutes to minimize redistributive hypothermia.",
        "Use forced-air warming blankets (e.g., Bair Hugger) throughout the intraoperative course.",
        "Ensure all IV fluids and surgical irrigation fluids are warmed to 37°C using inline warmers.",
        "Keep the operating room ambient temperature >21°C (higher for pediatrics/geriatrics)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Every 1°C drop in core temperature increases blood loss by approximately 16% due to direct impairment of platelet function and coagulation factors"
      ],
      "whenToEscalate": [
        "In severe accidental hypothermia (<33°C) with persistent arrhythmias or coagulopathy, initiate internal rewarming measures (warmed humidified gases, warmed cavity lavage) and arrange ICU"
      ],
      "referencesToShow": [
        "NICE Guideline NG85: Perioperative Hypothermia. 2016. PMID: 28059918.",
        "Sessler DI. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "myocardial_ischemia",
    "category": "clinical_scenarios",
    "keywords": [
      "depresyonu",
      "elevasyonu",
      "ischemia",
      "iskemisi",
      "miyokard",
      "myocardial",
      "st"
    ],
    "question_tr": "Miyokard iskemisi",
    "question_en": "St depresyonu",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "1. EKG elektrotlarını ve artefaktı kontrol et.\\n2. Hemodinami, oksijenasyon, ventilasyon, hemoglobin ve anestezi derinliğini optimize et.\\n3. Taşikardi, hipotansiyon, hipertansiyon, hipoksemi ve anemiyi düzelt.\\n4. Cerrahi ekibe haber ver; cerrahi uyarı ve kanama durumunu değerlendir.\\n5. 12 derivasyon EKG, troponin ve kardiyoloji değerlendirmesi planla.\\n6. Persistan iskemi, instabil hemodinami veya ciddi aritmi varsa acil kardiyak yönetim gerekir.",
      "immediateRedFlags": [
        "EKG trasesinde yeni ortaya çıkan >1 mm ST segment yükselmesi (akut STEMI) veya ST çökmesi/T inversiyonu.",
        "İskemiyle birlikte dirençli hipotansiyon, ventriküler disritmiler (akut pompa yetmezliği)."
      ],
      "missingCriticalInformation": [
        "Hastanın bilinen koroner arter hastalığı, stent öyküsü ve son ekokardiyografi (EF) bulguları",
        "Hastanın güncel hemoglobin (Hb) düzeyi (anemi iskemiği tetikler)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İntraoperatif Miyokard İskemisi ve ST Değişiklikleri Yönetimi",
        "Oksijen Arz/Talep Dengesi (Supply/Demand Imbalance) Fizyolojisi",
        "Perioperatif Miyokard Hasarı (MINS) Tanı Kriterleri"
      ],
      "suggestedNextStepsGeneral": [
        "EKG monitöründe ST analizini açın ve elektrotların doğru yerleştirildiğini kontrol edin.",
        "FiO₂'yi 1.0 yapın, ventilasyonu optimize edin.",
        "Miyokardın oksijen talebini azaltmak için kalp hızını (hedef <70-80/dk) ve tansiyonu optimize edin.",
        "Taşikardik hastada: Esmolol (0.5 mg/kg IV yavaş bolus) uygulayın.",
        "Hipotansif hastada: Koroner perfüzyon basıncını korumak için Fenilefrin (50-100 mcg IV) veya Noradrenalin başlatın.",
        "Miyokardiyal iskemi şüphesinde: Nitrogliserin (0.5-2 mcg/kg/dk IV infüzyon) başlayın (hipotansiyon yoksa)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Efedrin Monografı"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "İntraoperatif iskemi geçiren hastaların %90'ından fazlasının genel anestezi altında ağrı tanımlayamayacağı, tek belirtinin EKG değişiklikleri olduğu"
      ],
      "whenToEscalate": [
        "Dirençli ST değişiklikleri ve hemodinamik bozulma varlığında acil anjiyografi/PCI hazırlığı ve postop yoğun bakım transferi"
      ],
      "referencesToShow": [
        "2020 ESC/ESA Guidelines on Non-Cardiac Surgery: Cardiovascular Assessment. Eur Heart J 2020. PMID: 32986423.",
        "AHA Guidelines. 2020. PMID: 33081529."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Check ECG leads and artifacts. Optimize hemodynamics, oxygenation, ventilation, hemoglobin, and anesthetic depth. Correct tachycardia, hypotension, hypertension, hypoxemia, and anemia. Inform the surgical team and assess surgical stimulation and bleeding. Plan 12-lead ECG, troponin, and cardiology evaluation. Persistent ischemia, hemodynamic instability, or serious arrhythmia requires urgent cardiac management.",
      "immediateRedFlags": [
        "New-onset >1 mm ST-segment elevation (acute STEMI) or progressive ST-segment depression (>1 mm) on ECG.",
        "Ischemia accompanied by refractory hypotension, ventricular arrhythmias, or pulmonary congestion."
      ],
      "missingCriticalInformation": [
        "Patient's baseline coronary artery disease history, stent type/date, and last echocardiogram (EF)",
        "Current hemoglobin level (anemia directly triggers myocardial supply-demand mismatch)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Intraoperative Myocardial Ischemia and ST-Segment Analysis",
        "Myocardial Oxygen Supply and Demand Balance Physiology",
        "Myocardial Injury after Non-cardiac Surgery (MINS) Diagnostic Standards"
      ],
      "suggestedNextStepsGeneral": [
        "Confirm lead placement, ensure lead II and V5 are actively monitored for ischemia.",
        "Increase FiO₂ to 1.0 (100% O₂) and optimize mechanical ventilation.",
        "Optimize hemodynamics to restore oxygen supply/demand balance: target heart rate <70-80/min.",
        "For tachycardia: Administer IV Esmolol (0.5 mg/kg slow bolus).",
        "For hypotension: Administer IV Phenylephrine (50-100 mcg boluses) or start Norepinephrine to maintain coronary perfusion.",
        "If blood pressure allows: Start IV Nitroglycerin infusion (0.5-2 mcg/kg/min)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine Monograph"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Over 90% of intraoperative myocardial ischemia episodes are clinically silent under general anesthesia; EKG screening is paramount"
      ],
      "whenToEscalate": [
        "In the event of persistent ST-segment elevations or cardiogenic shock, consult Cardiology immediately for emergent angiography/PCI and secure ICU admission"
      ],
      "referencesToShow": [
        "2020 ESC/ESA Guidelines on Non-Cardiac Surgery: Cardiovascular Assessment. Eur Heart J 2020. PMID: 32986423.",
        "AHA Guidelines. 2020. PMID: 33081529."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "pulmonary_hypertension_crisis",
    "category": "clinical_scenarios",
    "keywords": [
      "crisis",
      "hipertansiyon",
      "hypertension",
      "krizi",
      "pht",
      "pulmonary",
      "pulmoner",
      "sağ",
      "ventrikül",
      "yetmezliği"
    ],
    "question_tr": "Pulmoner hipertansiyon krizi",
    "question_en": "Sağ ventrikül yetmezliği",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Pulmoner hipertansiyonda hipoksi, hiperkapni, asidoz, ağrı, hipotermi ve yüksek havayolu basıncı pulmoner vasküler direnci artırabilir.\\n\\n1. FiO₂’yi artır, hipoksemi ve hiperkapniyi düzelt.\\n2. Asidoz ve hipotermiyi tedavi et.\\n3. Sistemik basıncı koru; sağ ventrikül perfüzyonu önemlidir.\\n4. Aşırı sıvı yükünden kaçın, ancak ciddi hipovolemiyi düzelt.\\n5. Vazopressör/inotrop desteği gerekebilir.\\n6. İnhale pulmoner vazodilatör seçenekleri kurum olanaklarına göre düşünülür.\\n7. Sağ ventrikül yetmezliği ve arrest riski yüksektir; erken yardım çağır.",
      "immediateRedFlags": [
        "Sağ ventrikül (RV) yetmezliğine bağlı olarak sistemik sistolik kan basıncının <80 mmHg olması veya ani çöküş.",
        "ETCO₂'nin aniden hızla düşmesi (pulmoner kan akımının durma noktasına gelmesi).",
        "EKG'de yeni başlayan sağ dal bloğu veya sağ aks deviasyonu."
      ],
      "missingCriticalInformation": [
        "Hastanın bazal pulmoner arter sistolik basıncı (PAP) ve sağ ventrikül fonksiyon durumu",
        "Kullanılan mekanik ventilasyon ayarları (aşırı yüksek PEEP ve yüksek hava yolu basınçları sağ ventrikül yükünü artırır)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Akut Pulmoner Hipertansiyon Krizi ve Sağ Ventrikül Yetmezliği",
        "Pulmoner Vasküler Direnç (PVR) ve Sistemik Direnç (SVR) Dengesi",
        "İnhale Pulmoner Vazodilatör Tedavi Seçenekleri"
      ],
      "suggestedNextStepsGeneral": [
        "FiO₂'yi derhal 1.0 yapın; hipoksemi ve hiperkapniyi (güçlü pulmoner vazokonstrüktörler) agresif bir şekilde düzeltin.",
        "Sağ ventrikül koroner perfüzyonunu korumak için sistemik vasküler direnci (SVR) yüksek tutun: Noradrenalin veya Vazopressin (0.01-0.04 U/dk) infüzyonu başlayın.",
        "Havayolu peak basınçlarını <25-30 cmH₂O düzeyinde sınırlayın (PEEP düzeyini minimal tutun).",
        "Sağ ventrikül kontraktilitesini desteklemek için inotrop olarak Dobutamin (2-5 mcg/kg/dk) ekleyin (hipotansiyon yapmamasına dikkat edin)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        },
        {
          "id": "ephedrine",
          "titleTr": "Efedrin Monografı"
        }
      ],
      "doNotMiss": [
        "Pulmoner hipertansiyonda sağ ventrikül dolum basıncını korumak için hipovoleminin hızla düzeltilmesi ama aynı zamanda aşırı sıvı yüklenmesinin sağ ventrikülü genişleterek sola bası yapacağı riski"
      ],
      "whenToEscalate": [
        "Dirençli pulmoner hipertansiyon krizinde yatak başı İnhale Nitrik Oksit (iNO) veya İnhale İloprost başlanması ve acil yoğun bakım"
      ],
      "referencesToShow": [
        "Management of Pulmonary Hypertension Crisis. Anesthesiology 2021. PMID: 32986423.",
        "ESC Guidelines on Pulmonary Hypertension. 2022."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "In pulmonary hypertension, hypoxia, hypercapnia, acidosis, pain, hypothermia, and high airway pressures can increase pulmonary vascular resistance. Increase FiO₂, correct hypoxemia and hypercapnia, treat acidosis and hypothermia, maintain systemic pressure for right ventricular perfusion, avoid fluid overload while correcting severe hypovolemia, and use vasopressor/inotrope support when needed. Inhaled pulmonary vasodilators may be considered depending on local availability. Right ventricular failure and arrest risk are high; call for help early.",
      "immediateRedFlags": [
        "Systemic hypotension (SBP <80 mmHg) indicating decompensated right ventricular (RV) failure.",
        "Sudden dramatic drop in ETCO₂ due to severe reduction in pulmonary blood flow.",
        "New right bundle branch block (RBBB) or acute right axis shift on ECG."
      ],
      "missingCriticalInformation": [
        "Patient's baseline pulmonary artery systolic pressure (PAP) and RV function details",
        "Mechanical ventilator settings (excessive PEEP and high peak airway pressures directly increase RV afterload)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Acute Pulmonary Hypertension Crisis and Right Ventricular Failure",
        "Pulmonary Vascular Resistance (PVR) vs. Systemic Vascular Resistance (SVR) Balance",
        "Inhaled Selective Pulmonary Vasodilators in the OR"
      ],
      "suggestedNextStepsGeneral": [
        "Increase FiO₂ to 1.0 immediately; aggressively treat hypoxemia, hypercapnia, and acidosis (potent PVR triggers).",
        "Maintain SVR to preserve RV coronary perfusion: immediately initiate Norepinephrine or Vasopressin (0.01-0.04 U/min).",
        "Minimize peak airway pressures (target <25-30 cmH₂O) and reduce PEEP to lowest feasible levels.",
        "Add Dobutamine (2-5 mcg/kg/min) as an inotrope to support RV contractility if systemic pressure is secured."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        },
        {
          "id": "ephedrine",
          "titleTr": "Ephedrine Monograph"
        }
      ],
      "doNotMiss": [
        "RV is highly preload-sensitive; avoid absolute hypovolemia, but strictly prevent excessive fluid resuscitation which causes RV dilation and septal shift"
      ],
      "whenToEscalate": [
        "In refractory RV failure, initiate inhaled selective vasodilators (e.g., Nitric Oxide or inhaled Prostacyclins) and transfer immediately to ICU"
      ],
      "referencesToShow": [
        "Management of Pulmonary Hypertension Crisis. Anesthesiology 2021. PMID: 32986423.",
        "ESC Guidelines on Pulmonary Hypertension. 2022."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "aortic_stenosis",
    "category": "clinical_scenarios",
    "keywords": [
      "anestezi",
      "aort",
      "aortic",
      "as",
      "darlığı",
      "stenosis"
    ],
    "question_tr": "Aort darlığı",
    "question_en": "As anestezi",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Ciddi aort stenozunda temel hedefler: sinüs ritmini korumak, taşikardiden kaçınmak, bradikardiyi ağırlaştırmamak, preloadu korumak, sistemik vasküler direnci korumak ve hipotansiyondan kaçınmaktır.\\nHipotansiyon koroner perfüzyonu bozabilir. Nöroaksiyel anestezi ani vazodilatasyon riski nedeniyle dikkatli değerlendirilmelidir. İnvaziv arter monitörizasyonu ve vazopressör hazırlığı genellikle uygundur.",
      "immediateRedFlags": [
        "İndüksiyon veya idame sırasında sistolik kan basıncının <90 mmHg olması (aort darlıklı hastada bu durum koroner perfüzyonu hızla çökerterek iskemi/areste yol açar!).",
        "Yeni başlayan atriyal fibrilasyon (AF) ritmi (sinüs ritminin ve atriyal katkının kaybı anında kalp debisini %30-40 düşürür)."
      ],
      "missingCriticalInformation": [
        "Aort kapak alanı (cm²) ve ortalama kapak gradyenti (mmHg) (Alan <1.0 cm² veya gradyent >40 mmHg ise darlık ciddidir)",
        "Hastanın sol ventrikül ejeksiyon fraksiyonu (EF)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Ciddi Aort Darlığı (AS) Anestezi Prensipleri",
        "Koroner Perfüzyon Basıncı ve Sağ Kalım",
        "Nöroaksiyel Anestezi ve Vazoplejik Şok Riskleri"
      ],
      "suggestedNextStepsGeneral": [
        "İndüksiyondan önce invaziv arter monitörizasyonunu (arter hattı) kesinlikle kurun.",
        "Hipotansiyonu önlemek için saf Alfa-1 agonist olan Fenilefrin infüzyonunu indüksiyonla eş zamanlı veya hazır bulundurun.",
        "Kalp hızını 60-80/dk (sinüs ritminde) aralığında tutun.",
        "Eğer taşikardi gelişirse: Koroner dolum süresini uzatmak için Esmolol ile kalp hızını yavaşlatın.",
        "Preloadu (sıvı hacmini) koruyun; hafif hipovolemiyi bile hızla tedavi edin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "phenylephrine",
          "titleTr": "Fenilefrin Monografı"
        },
        {
          "id": "esmolol",
          "titleTr": "Esmolol Monografı"
        }
      ],
      "doNotMiss": [
        "Ciddi aort darlığı olan hastalarda spinal anestezinin yapacağı hızlı vazodilatasyonun ölümcül olabileceği, bu hastalarda genel anestezi veya çok yavaş epiduralin tercih edilmesi gerektiği"
      ],
      "whenToEscalate": [
        "Gelişen hipotansif kardiyak arrest durumunda derhal resüsitasyon (ACLS) başlatılması ve yüksek doz vazopressör desteği"
      ],
      "referencesToShow": [
        "Anesthesia for Valvular Heart Disease. AHA/ACC Guidelines 2020. PMID: 32986423.",
        "Whelton PK, et al. Anesthesiology 2018. PMID: 29016373."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Key goals are to maintain sinus rhythm, avoid tachycardia, avoid excessive bradycardia, preserve preload, maintain systemic vascular resistance, and prevent hypotension. Hypotension may compromise coronary perfusion. Neuraxial anesthesia requires careful assessment due to the risk of sudden vasodilation. Invasive arterial monitoring and ready vasopressor support are often appropriate.",
      "immediateRedFlags": [
        "Systemic blood pressure falling below 90 mmHg (catastrophically reduces coronary perfusion pressure in AS, leading to rapid myocardial ischemia and arrest).",
        "New-onset atrial fibrillation (loss of the 'atrial kick' reduces cardiac output by up to 30-40% instantly)."
      ],
      "missingCriticalInformation": [
        "Aortic valve area (AVA <1.0 cm²) and mean pressure gradient (>40 mmHg indicates severe AS)",
        "Patient's left ventricular ejection fraction (LVEF)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Anesthetic Management of Severe Aortic Stenosis (AS)",
        "Coronary Perfusion Pressure Maintenance",
        "Neuraxial Anesthesia Risks in Fixed Cardiac Output States"
      ],
      "suggestedNextStepsGeneral": [
        "Establish invasive arterial monitoring prior to induction of general anesthesia.",
        "Have a pure alpha-1 agonist (Phenylephrine infusion or bolus) ready and run it to maintain Systemic Vascular Resistance (SVR).",
        "Keep the heart rate strictly between 60-80 beats/min in sinus rhythm.",
        "Treat any tachycardia promptly with Esmolol to maximize diastolic coronary filling time.",
        "Ensure adequate preload; treat even mild hypovolemia immediately."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "phenylephrine",
          "titleTr": "Phenylephrine Monograph"
        },
        {
          "id": "esmolol",
          "titleTr": "Esmolol Monograph"
        }
      ],
      "doNotMiss": [
        "Spinal anesthesia is contraindicated in severe AS due to sudden, uncontrolled vasodilation; prefer general anesthesia or slowly titrated epidural"
      ],
      "whenToEscalate": [
        "In the event of cardiac arrest in a patient with severe AS, initiate high-quality CPR and administer vasopressors early to restore coronary perfusion pressure"
      ],
      "referencesToShow": [
        "Anesthesia for Valvular Heart Disease. AHA/ACC Guidelines 2020. PMID: 32986423.",
        "Whelton PK, et al. Anesthesiology 2018. PMID: 29016373."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "mitral_stenosis",
    "category": "clinical_scenarios",
    "keywords": [
      "anestezi",
      "darlığı",
      "mitral",
      "ms",
      "stenosis"
    ],
    "question_tr": "Mitral darlığı",
    "question_en": "Ms anestezi",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Mitral stenozda taşikardi diyastolik dolumu azaltır ve pulmoner basıncı artırabilir.\\nHedefler: kalp hızını düşük-normal tutmak, sinüs ritmini korumak, hipovolemi ve aşırı sıvı yükünden kaçınmak, hipoksi/hiperkapni/asidozu önlemek ve pulmoner vasküler direnci artıran durumlardan kaçınmaktır.\\nAtriyal fibrilasyon, pulmoner ödem ve sağ ventrikül yetmezliği açısından dikkatli olunmalıdır.",
      "immediateRedFlags": [
        "Taşikardi (>90-100/dk) ile birlikte solunum basınçlarının artması ve SpO₂ düşüşü (akut akciğer ödemi bulgusu).",
        "Yeni başlayan hızlı atriyal fibrilasyon (AF) atağı."
      ],
      "missingCriticalInformation": [
        "Mitral kapak alanı (cm²) (Alan <1.5 cm² ise darlık ciddidir)",
        "Hastanın sağ ventrikül sistolik basıncı (pulmoner hipertansiyon varlığı)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Mitral Darlığı (MS) Anestezi Yönetimi",
        "Diyastolik Dolum Süresi ve Kalp Hızı İlişkisi",
        "Akut Pulmoner Ödem ve Sağ Ventrikül Yükü"
      ],
      "suggestedNextStepsGeneral": [
        "Kalp hızını düşük-normal (60-70/dk) aralığında tutun; diyastol süresini uzatmak için gerekirse Esmolol kullanın.",
        "Sinüs ritmini koruyun; AF gelişirse hız kontrolü için Beta bloker, gerekirse senkronize kardiyoversiyon planlayın.",
        "Sol atriyum basıncını artıracak aşırı sıvı yüklenmesinden kesinlikle kaçının.",
        "Pulmoner vazokonstrüksiyonu önlemek için hipoksi, hiperkapni ve asidozu derhal düzeltin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "esmolol",
          "titleTr": "Esmolol Monografı"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Mitral darlığında sol atriyumun boşalabilmesi için yavaş kalp hızına (uzun diyastol süresi) mutlak ihtiyaç olduğu gerçeği"
      ],
      "whenToEscalate": [
        "Hızlı AF ve eşlik eden akut akciğer ödeminde derhal cerrahiyi durdurun, %100 O₂ verin, Nitrogliserin/Diüretik başlayın ve gerekirse kardiyoversiyon uygulayın"
      ],
      "referencesToShow": [
        "Anesthesia for Valvular Heart Disease. ACC/AHA Guidelines 2020. PMID: 32986423.",
        "Whelton PK, et al. Anesthesiology 2018. PMID: 29016373."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "In mitral stenosis, tachycardia reduces diastolic filling and may increase pulmonary pressures. Goals are low-normal heart rate, maintenance of sinus rhythm, avoidance of hypovolemia and fluid overload, prevention of hypoxia/hypercapnia/acidosis, and avoidance of factors that increase pulmonary vascular resistance. Watch for atrial fibrillation, pulmonary edema, and right ventricular failure.",
      "immediateRedFlags": [
        "Tachycardia (HR >90-100/bpm) presenting with pink frothy sputum, bilateral rales, and rapid desaturation (acute pulmonary edema).",
        "Sudden onset of rapid atrial fibrillation (AF)."
      ],
      "missingCriticalInformation": [
        "Mitral valve area (MVA <1.5 cm² indicates moderate/severe stenosis)",
        "Presence and severity of secondary pulmonary hypertension (PASP)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Anesthetic Management of Mitral Stenosis (MS)",
        "Diastolic Filling Time and Heart Rate Control",
        "Acute Pulmonary Congestion and Right Ventricular Failure"
      ],
      "suggestedNextStepsGeneral": [
        "Maintain heart rate in the low-normal range (60-70/min) using IV Esmolol aggressively as needed.",
        "Maintain sinus rhythm; if rapid AF develops, use Esmolol, Amiodarone, or perform synchronized cardioversion.",
        "Avoid over-aggressive fluid administration to prevent sudden increase in left atrial pressure.",
        "Treat hypoxia, hypercapnia, and acidosis aggressively to prevent pulmonary vasoconstriction."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "esmolol",
          "titleTr": "Esmolol Monograph"
        },
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Tachycardia is extremely poorly tolerated in MS; a fast heart rate limits diastolic transit across the stenotic valve, triggering immediate backup and pulmonary edema"
      ],
      "whenToEscalate": [
        "For rapid-AF induced acute pulmonary edema, discontinue surgical stimulation, give 100% O₂, administer Furosemide/Nitroglycerin, and perform emergent cardioversion"
      ],
      "referencesToShow": [
        "Anesthesia for Valvular Heart Disease. ACC/AHA Guidelines 2020. PMID: 32986423.",
        "Whelton PK, et al. Anesthesiology 2018. PMID: 29016373."
      ],
