  {
    "id": "clinical_followup_neonatal_resus_why_0",
    "category": "clinical_followups",
    "keywords": [
      "clinical_followup_neonatal_resus_why_0",
      "cocuk",
      "followup",
      "neonatal",
      "pediatri",
      "pediatric",
      "resus",
      "var0",
      "why",
      "yenidoğan",
      "çocuk"
    ],
    "question_tr": "Yenidoğan resüsitasyonunda neden ventilasyon önceliklidir?",
    "question_en": "Why is ventilation the priority in neonatal resuscitation?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 Yenidoğanlarda kardiyak arrest ve bradikardinin temel nedeni neredeyse her zaman asfiksi ve solunumsal yetmezliktir. Kalp kası hipoksiktir ancak primer olarak sağlamdır. Akciğerlerin havalandırılması alveolleri açar, intrapulmoner şantları azaltır ve kalp hızını saniyeler içinde normalleştirir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 Neonatal bradycardia and cardiac arrest are almost exclusively asphyxial in origin. The myocardium is primarily healthy but hypoxic. Establishing lung expansion and effective ventilation decreases pulmonary vascular resistance, allowing immediate increase in heart rate.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
