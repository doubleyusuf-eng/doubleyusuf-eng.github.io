  {
    "id": "clinical_followup_anaphylaxis_rescue_alternatives_0",
    "category": "clinical_followups",
    "keywords": [
      "alerji",
      "allergy",
      "alternatives",
      "anafilaksi",
      "anaphylaxis",
      "clinical_followup_anaphylaxis_rescue_alternatives_0",
      "followup",
      "sok",
      "var0",
      "şok"
    ],
    "question_tr": "Adrenaline dirençli şokta alternatifler nelerdir?",
    "question_en": "What are the alternatives in epinephrine-resistant shock?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🔄 Adrenaline dirençli anafilaktik şokta Noradrenalin veya Vasopressin infüzyonuna geçilmelidir. Özellikle Beta-blokör kullanan hastalarda adrenalin etkisiz kalabilir; bu durumda Glukagon (1-5 mg IV yavaş bolus, ardından 1-5 mg/saat infüzyon) en önemli kurtarıcı alternatif ilaçtır.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🔄 In refractory anaphylactic shock, initiate Vasopressin or Norepinephrine infusion. In patients on beta-blockers, standard epinephrine may fail; here, Glucagon (1-5 mg slow IV bolus, followed by 1-5 mg/hour infusion) is the crucial rescue alternative.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
