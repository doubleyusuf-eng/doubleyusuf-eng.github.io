  {
    "id": "clinical_followup_ponv_rescue_how_0",
    "category": "clinical_followups",
    "keywords": [
      "bulantı",
      "clinical_followup_ponv_rescue_how_0",
      "followup",
      "kusma",
      "nausea",
      "ponv",
      "rescue",
      "var0",
      "vomiting"
    ],
    "question_tr": "Ponv profilaksisi nasıl planlanır?",
    "question_en": "How to plan ponv prophylaxis?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "💉 Orta riskli hastalarda (Apfel skoru 2) ikili kombinasyon: Deksametazon 4-8 mg IV (anestezi indüksiyonunda) ve Ondansetron 4 mg IV (cerrahi bitiminde) uygulanır. Yüksek riskli hastalarda (Apfel skoru 3-4) bunlara ek olarak total intravenöz anestezi (TIVA) tercih edilmelidir.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "💉 For moderate-risk patients (Apfel score 2), use a dual combination: Dexamethasone 4-8 mg IV (at induction) plus Ondansetron 4 mg IV (at the end of surgery). For high-risk patients (Apfel score 3-4), add total intravenous anesthesia (TIVA) with Propofol as an additional primary preventive.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    }
  },
