      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 Complications include severe tachycardia, malignant arrhythmias, myocardial ischemia/infarction, hypertensive crisis, and potential intracranial hemorrhage. Because of this, IV doses must be carefully diluted and titrated in microgram increments.",
