    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "1. Hastayı uyar, hava yolunu aç, oksijen ver.\\n2. Solunum sayısı, SpO₂, ETCO₂, sedasyon düzeyi ve hemodinamiyi değerlendir.\\n3. Destek ventilasyon gerekebilir.\\n4. Opioidleri durdur veya azalt.\\n5. Klinik olarak ciddi solunum depresyonunda nalokson titre edilerek verilir; amaç ağrıyı tamamen yok etmek değil, yeterli ventilasyonu sağlamaktır.\\n6. Naloksonun etkisi bazı opioidlerden kısa sürebileceği için yeniden sedasyon açısından izlem gerekir.\\n7. OSA, yaşlılık, böbrek yetmezliği ve eş zamanlı sedatifler riski artırır.",
      "immediateRedFlags": [
        "Solunum sayısının <8/dk olması, derin sedasyon (pinpoint pupiller) ve SpO₂'nin %90'ın altına inmesi (acil müdahale!).",
        "Hiperkapniye bağlı gelişen asidoz ve EKG ritim değişiklikleri."
      ],
      "missingCriticalInformation": [
        "Uygulanan son opioid türü (örn. Morfin, Fentanil, Remifentanil) ve kümülatif dozu",
        "Eşlik eden diğer sedatif ilaçların (örn. Midazolam) kullanımı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "PACU'da Opioid İlişkili Solunum Depresyonu",
        "Nalokson Doz Titrasyonu ve Güvenli Kullanım İlkeleri",
        "Obstrüktif Uyku Apnesi ve Opioid Duyarlılığı"
      ],
      "suggestedNextStepsGeneral": [
        "Hastayı güçlü bir şekilde uyarın, çene itme (jaw thrust) uygulayın ve maske ile %100 O₂ verin.",
        "Nalokson: 40 mcg (0.04 mg) IV bolus şeklinde sulandırarak yavaş yavaş uygulayın (hedef yeterli solunum dürtüsü kazanmaktır).",
        "Naloksonun etki süresi (30-45 dk) fentanil veya morfinden kısa olduğundan hastayı yeniden sedasyon yönünden izleyin."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "morphine",
          "titleTr": "Morfin Monografı"
        }
      ],
      "doNotMiss": [
        "Naloksonun aniden yüksek dozda (örn. 0.4 mg IV) verilmesi şiddetli ağrı krizini, sempatik deşarjı ve akut akciğer ödemini tetikleyebilir"
      ],
      "whenToEscalate": [
        "Naloksona rağmen açılmayan solunum veya apne durumunda havayolunun endotrakeal entübasyonla güvenceye alınması"
      ],
      "referencesToShow": [
        "Practice Guidelines for the Prevention, Detection, and Management of Respiratory Depression Associated with Opioids. Anesthesiology 2018. PMID: 29016373."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Stimulate the patient, open the airway, and provide oxygen. Assess respiratory rate, SpO₂, ETCO₂, sedation level, and hemodynamics. Assisted ventilation may be required. Stop or reduce opioids. In clinically significant respiratory depression, titrate naloxone to restore adequate ventilation rather than fully abolish analgesia. Monitor for resedation because naloxone may wear off before some opioids. OSA, older age, renal dysfunction, and concurrent sedatives increase risk.",
      "immediateRedFlags": [
        "Respiratory rate <8/min, pinpoint pupils, deep somnolence, and SpO₂ <90% (emergency response needed).",
        "Severe hypercapnia-induced respiratory acidosis and ECG changes."
      ],
      "missingCriticalInformation": [
        "Type of opioid administered (e.g., Morphine, Fentanyl, Remifentanil) and cumulative dose",
        "Concurrent use of other sedatives or hypnotics (e.g., Midazolam)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "PACU Opioid-Induced Respiratory Depression",
        "Naloxone Dose Titration and Safety Standards",
        "Obstructive Sleep Apnea and Opioid Sensitivity"
      ],
      "suggestedNextStepsGeneral": [
        "Aggressively stimulate the patient, perform jaw thrust, and deliver 100% O₂ via face mask.",
        "Naloxone: Dilute and titrate in 40 mcg (0.04 mg) IV increments (target is return of adequate breathing, not complete arousal).",
        "Monitor for resedation since the half-life of Naloxone (30-45 min) is shorter than most opioids."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "morphine",
          "titleTr": "Morphine Monograph"
        }
      ],
      "doNotMiss": [
        "Rapid IV push of high-dose Naloxone (e.g., 0.4 mg) can trigger acute severe withdrawal, catecholamine surge, and fatal pulmonary edema"
      ],
      "whenToEscalate": [
        "In patients with persistent apnea or unresponsive respiratory depression, secure the airway with endotracheal intubation"
      ],
      "referencesToShow": [
        "Practice Guidelines for the Prevention, Detection, and Management of Respiratory Depression Associated with Opioids. Anesthesiology 2018. PMID: 29016373."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "sugammadex",
    "category": "clinical_scenarios",
    "keywords": [
      "bridion",
      "sugammadeks",
      "sugammadex"
    ],
    "question_tr": "Sugammadeks",
    "question_en": "Bridion",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Sugammadeks dozu nöromüsküler blok derinliğine göre hesaplanır:\\nTOF count ≥2 ise genellikle 2 mg/kg.\\nPost-tetanic count var ama TOF yoksa derin blok için genellikle 4 mg/kg.\\nRoküronyum sonrası acil reversal gerekiyorsa genellikle 16 mg/kg.\\n\\nEkstübasyon için kantitatif TOF ratio ≥0.90 hedeflenmelidir. Klinik testler rezidüel bloğu dışlamak için tek başına güvenilir değildir.",
      "immediateRedFlags": [
        "Ekstübasyon sonrası hastada çene sarkması, 'floppy' görünüm, yutkunma güçlüğü ve SpO₂ düşüşü rezidüel kürarizasyon (blok kalıntısı) işaretidir.",
        "Kantitatif TOF izlemi olmadan sadece klinik güç testlerine (örn. 5 sn baş kaldırma) güvenilmesi yüksek postop pulmoner komplikasyon nedenidir."
      ],
      "missingCriticalInformation": [
        "Mevcut TOF (Train-of-Four) yanıtı sayısı (0-4 arası)",
        "Kullanılan kas gevşeticinin türü (Sugammadeks sadece Roküronyum ve Veküronyum'u geri çevirir!)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Kantitatif Nöromüsküler Monitörizasyon Standartları",
        "Rezidüel Kürarizasyon ve Postoperatif Pulmoner Komplikasyonlar",
        "Sugammadeks Doz Hesaplama Kriterleri"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle kantitatif TOF cihazı ile bloğun derinliğini (orta vs derin) ölçün.",
        "TOF yanıtı >=2 ise: Sugammadeks 2 mg/kg IV bolus uygulayın.",
        "TOF yanıtı 0 ama PTC (Post-Tetanic Count) >=1 ise: Sugammadeks 4 mg/kg IV uygulayın.",
        "Roküronyum (1.2 mg/kg) indüksiyonu sonrası 3 dk içinde acil reversal gerekiyorsa: Sugammadeks 16 mg/kg uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "rocuronium",
          "titleTr": "Roküronyum Monografı"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        }
      ],
      "doNotMiss": [
        "Sugammadeks hormonal kontraseptifleri bağlayabilir; hastalara 7 gün boyunca ek bariyer korunma yöntemi kullanmaları uyarısı yapılmalıdır"
      ],
      "whenToEscalate": [
        "Maksimum dozlara rağmen geçmeyen rezidüel blok durumunda hastanın solunum desteği ile PACU/yoğun bakımda izlenmesi"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Monitoring and Antagonism of Neuromuscular Blockade. Anesthesiology 2023. PMID: 36622802.",
        "Hunter JM. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Sugammadex dose depends on block depth:\\nTOF count ≥2: usually 2 mg/kg.\\nPost-tetanic count present but no TOF response: usually 4 mg/kg.\\nImmediate reversal after rocuronium: usually 16 mg/kg.\\n\\nA quantitative TOF ratio ≥0.90 should be targeted before extubation. Clinical tests alone are not reliable to exclude residual neuromuscular block.",
      "immediateRedFlags": [
        "Post-extubation jaw sag, 'floppy' posture, swallow difficulty, and falling SpO₂ point to critical residual curarization.",
        "Relying on clinical tests (e.g., 5s head lift) without quantitative TOF monitoring is a major cause of postop pulmonary complications."
      ],
      "missingCriticalInformation": [
        "Current TOF (Train-of-Four) response count (0 to 4)",
        "Type of neuromuscular blocker used (Sugammadex ONLY reverses Rocuronium and Vecuronium!)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Quantitative Neuromuscular Monitoring Guidelines",
        "Residual Curarization and Postoperative Pulmonary Complications",
        "Sugammadex Dosing Criteria"
      ],
      "suggestedNextStepsGeneral": [
        "Measure the depth of block (moderate vs deep) using a quantitative neuromuscular monitor.",
        "If TOF count is >=2: Administer Sugammadex 2 mg/kg IV.",
        "If TOF count is 0 but PTC (Post-Tetanic Count) is >=1: Administer Sugammadex 4 mg/kg IV.",
        "If immediate rescue reversal is needed within 3 min of Rocuronium 1.2 mg/kg: Administer Sugammadex 16 mg/kg IV."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "rocuronium",
          "titleTr": "Rocuronium Monograph"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        }
      ],
      "doNotMiss": [
        "Sugammadex binds hormonal contraceptives; advise female patients to use alternative barrier methods for the next 7 days"
      ],
      "whenToEscalate": [
        "In case of refractory residual block despite maximum doses, maintain ventilatory support and transfer to PACU/ICU"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Monitoring and Antagonism of Neuromuscular Blockade. Anesthesiology 2023. PMID: 36622802.",
        "Hunter JM. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "la_max_dose",
    "category": "clinical_scenarios",
    "keywords": [
      "anestezik",
      "dose",
      "la",
      "lokal",
      "maksimum",
      "max"
    ],
    "question_tr": "Maksimum doz",
    "question_en": "Lokal anestezik limit",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Maksimum doz ilaç, adrenalin kullanımı, uygulama yeri, hasta yaşı, gebelik, karaciğer hastalığı ve kardiyak hastalığa göre değişir.\\nGenel hesap: maksimum mg = hasta kilosu × güvenli mg/kg sınırı.\\n\\nToplam verilen tüm lokal anestezikler birlikte değerlendirilmelidir. Kombine lokal anestezik kullanılıyorsa toksisite katkısal kabul edilir. Yüksek riskli hastalarda daha düşük doz hedeflenir. LAST belirtileri açısından monitörizasyon ve lipid emülsiyon hazır bulundurulmalıdır.",
      "immediateRedFlags": [
        "Lokal anestezik enjekte edildikten hemen sonra gelişen ritim bozuklukları veya nöbet LAST'ın doğrudan kanıtıdır.",
        "Bupivakain gibi uzun etkili lokal anesteziklerin aşırı dozunda gelişen kardiyak arrest tedavisine son derece dirençlidir."
      ],
      "missingCriticalInformation": [
        "Kullanılan spesifik lokal anesteziklerin adı, konsantrasyonu ve solüsyona adrenalin eklenip eklenmediği",
        "Hastanın kilosu ve renal/hepatik fonksiyon durumu"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Lokal Anesteziklerin Maksimum Doz Sınırları",
        "Adrenalinin Toksisite Eşiğini Artırıcı Etkisi",
        "Kombine Lokal Anestezik Kullanımında Katkısal (Additive) Toksisite"
      ],
      "suggestedNextStepsGeneral": [
        "Lidokain için: Maksimum doz adrenalinsiz 4.5 mg/kg, adrenalinli 7 mg/kg'dır.",
        "Bupivakain (Marcaine) için: Maksimum doz adrenalinsiz 2.5 mg/kg, adrenalinli 3 mg/kg'dır.",
        "Ropivakain için: Maksimum doz 3 mg/kg'dır (adrenalinli/adrenalinsiz benzer).",
        "Kombine kullanımda, her ilacın maksimum doz yüzdelerini toplayın (toplam %100'ü geçmemelidir)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monografı"
        }
      ],
      "doNotMiss": [
        "Vaskülaritesi yüksek bölgelere (örn. interkostal, paraservikal) yapılan enjeksiyonlarda emilim çok hızlı olduğundan maksimum dozlar daha da düşürülmelidir"
      ],
      "whenToEscalate": [
        "LAST belirtileri başladığında enjeksiyonu derhal durdurun ve lipid kurtarma (%20 lipid emülsiyon) protokolüne geçin"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Regional Anesthesia. 2018. PMID: 29362691.",
        "Neal JM, et al. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Maximum dose depends on the drug, epinephrine use, injection site, age, pregnancy, liver disease, and cardiac disease.\\nGeneral formula: maximum mg = patient weight × safe mg/kg limit.\\n\\nAll local anesthetics administered should be considered together. With combined local anesthetics, toxicity is considered additive. Use lower targets in high-risk patients. Monitor for LAST and keep lipid emulsion immediately available.",
      "immediateRedFlags": [
        "Cardiac arrhythmias or seizures occurring immediately after local anesthetic injection confirm LAST.",
        "Overdose of long-acting agents (e.g., Bupivacaine) is highly cardiotoxic and extremely refractory to standard resuscitation."
      ],
      "missingCriticalInformation": [
        "Specific local anesthetics used, concentrations, and presence of epinephrine",
        "Patient weight and renal/hepatic function status"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Maximum Local Anesthetic Dosage Limits",
        "Epinephrine Adjuvant Effect on Systemic Absorption",
        "Additive Toxicity in Combined Local Anesthetic Techniques"
      ],
      "suggestedNextStepsGeneral": [
        "Lidocaine: Max dose is 4.5 mg/kg without epinephrine, and 7 mg/kg with epinephrine.",
        "Bupivacaine: Max dose is 2.5 mg/kg without epinephrine, and 3 mg/kg with epinephrine.",
        "Ropivacaine: Max dose is 3 mg/kg (similar with or without epinephrine).",
        "In combined blocks, ensure the sum of the percentages of each drug's max dose does not exceed 100%."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "propofol",
          "titleTr": "Propofol Monograph"
        }
      ],
      "doNotMiss": [
        "Injections in highly vascular areas (e.g., intercostal, paracervical) lead to extremely rapid absorption; reduce max targets accordingly"
      ],
      "whenToEscalate": [
        "At the earliest signs of systemic toxicity, stop the injection immediately and prepare 20% lipid emulsion therapy"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Regional Anesthesia. 2018. PMID: 29362691.",
        "Neal JM, et al. PMID: 29016373."
      ],
      "safetyLevel": "routine"
    }
  },
  {
    "id": "dantrolene_vials",
    "category": "clinical_scenarios",
    "keywords": [
      "dantrolen",
      "dantrolene",
      "flakon",
      "kaç",
      "vials"
    ],
    "question_tr": "Kaç flakon",
    "question_en": "Dantrolene vials",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Başlangıç dozu 2.5 mg/kg IV’dir.\\nHesap: toplam mg = kilo × 2.5.\\n20 mg flakon kullanılıyorsa flakon sayısı = toplam mg / 20, yukarı yuvarlanır.\\n250 mg flakon kullanılıyorsa flakon sayısı = toplam mg / 250, yukarı yuvarlanır.\\n\\nKlinik yanıt yoksa doz tekrarlanabilir; üst toplam doz ve kurum protokolü dikkate alınmalıdır. Dantrolen tedavisi volatil ajanların kesilmesi, yüksek akım oksijen, soğutma, hiperkalemi/asidoz tedavisi ve yoğun bakım izlemiyle birlikte yürütülür.",
      "immediateRedFlags": [
        "Dantrolen tedavisinin geciktirilmesi, Malign Hipertermi krizindeki mortaliteyi dramatik olarak artırır.",
        "Dantrolenin yavaş infüzyonla verilmesi yanlıştır; 2.5 mg/kg doz hızlı IV bolus olarak uygulanmalıdır."
      ],
      "missingCriticalInformation": [
        "Hastanın kilosu (tam doz hesaplaması için)",
        "Ameliyathanedeki veya hastanedeki mevcut Dantrolen flakon sayısı (MH arabası kontrolü)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Malign Hipertermi Krizinde Dantrolen Tedavisi",
        "Dantrolen Çözündürme ve Uygulama Tekniği",
        "MH Yönetiminde Destekleyici Tedaviler (Soğutma, Asidoz Tedavisi)"
      ],
      "suggestedNextStepsGeneral": [
        "Dantrolen başlangıç dozunu 2.5 mg/kg IV hızlı bolus olarak hesaplayın.",
        "Klasik Dantrolen (Dantrium / Revonto, 20 mg flakon): Her flakonu 60 mL steril koruyucusuz distile su ile eritin. (Serum fizyolojik KULLANMAYIN!).",
        "Yeni nesil Dantrolen (Ryanodex, 250 mg flakon): Her flakonu 5 mL distile su ile eritin (çözünmesi çok daha hızlıdır).",
        "MH belirtileri (hiperkapni, rijidite) gerileyene kadar her 5-10 dakikada bir dozu tekrarlayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "dantrolene_rescue",
          "titleTr": "Dantrolen Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Süksinilkolin Monografı"
        }
      ],
      "doNotMiss": [
        "Klasik Dantrolen flakonlarının (20 mg) çözünmesi son derece zordur; eritmeye yardımcı olacak ek personeli derhal organize edin"
      ],
      "whenToEscalate": [
        "Maksimum Dantrolen dozuna (10 mg/kg) rağmen düzelmeyen dirençli MH tablolarında yoğun bakım ve hemodiyaliz hazırlığı"
      ],
      "referencesToShow": [
        "MHAUS (Malignant Hyperthermia Association of the United States) Emergency Guidelines. 2021.",
        "Glauber V, et al. PMID: 32986423."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Initial dose is 2.5 mg/kg IV.\\nFormula: total mg = weight × 2.5.\\nIf using 20 mg vials: number of vials = total mg / 20, rounded up.\\nIf using 250 mg vials: number of vials = total mg / 250, rounded up.\\n\\nRepeat dosing may be required if there is no clinical response; follow maximum dosing and institutional protocol. Dantrolene must be combined with stopping triggers, high-flow oxygen, cooling, hyperkalemia/acidosis treatment, and ICU care.",
      "immediateRedFlags": [
        "Delaying Dantrolene administration in a malignant hyperthermia crisis dramatically increases mortality.",
        "Administering Dantrolene as a slow infusion is incorrect; the 2.5 mg/kg dose must be given as rapid IV bolus."
      ],
      "missingCriticalInformation": [
        "Patient weight (for exact dosing calculation)",
        "Total number of Dantrolene vials currently available in the operating room or hospital"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Malignant Hyperthermia Dantrolene Pharmacotherapy",
        "Dantrolene Reconstitution and Rapid Administration",
        "Supportive Care in MH (Cooling, Acidosis Correction)"
      ],
      "suggestedNextStepsGeneral": [
        "Calculate initial Dantrolene at 2.5 mg/kg IV rapid bolus.",
        "Standard Dantrolene (Dantrium / Revonto, 20 mg vial): Reconstitute each vial with 60 mL sterile preservative-free water. (Do NOT use saline!).",
        "High-solubility Dantrolene (Ryanodex, 250 mg vial): Reconstitute each vial with 5 mL sterile water (dissolves within seconds).",
        "Repeat doses every 5-10 minutes until hypercapnia and muscle rigidity resolve."
      ],
      "relatedAlgorithms": [
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "dantrolene_rescue",
          "titleTr": "Dantrolene Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Succinylcholine Monograph"
        }
      ],
      "doNotMiss": [
        "Standard 20 mg vials require warm sterile water and extensive shaking; immediately delegate multiple staff to assist with mixing"
      ],
      "whenToEscalate": [
        "In refractory MH cases unresponsive to maximum cumulative Dantrolene (10 mg/kg), prepare for emergent ICU transfer and hemodialysis"
      ],
      "referencesToShow": [
        "MHAUS (Malignant Hyperthermia Association of the United States) Emergency Guidelines. 2021.",
        "Glauber V, et al. PMID: 32986423."
      ],
      "safetyLevel": "emergency"
    }
  },
