  {
    "id": "clinical_followup_mtp_protocol_alternatives_0",
    "category": "clinical_followups",
    "keywords": [
      "alternatives",
      "bleeding",
      "clinical_followup_mtp_protocol_alternatives_0",
      "followup",
      "kanama",
      "massive",
      "mtp",
      "transfusion",
      "transfüzyon",
      "var0"
    ],
    "question_tr": "Masif transfüzyon alternatif pıhtılaşma tedavileri nelerdir?",
    "question_en": "What are the alternative coagulation therapies in mtp?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🔄 Standart oran tedavisine alternatif veya destek olarak, viskoelastik testler (ROTEM/TEG) eşliğinde hedefe yönelik koagülasyon tedavisi (Fibrinojen konsantresi, Protrombin Kompleks Konsantresi - PCC ve Traneksamik Asit - TXA) uygulanmalıdır. Bu yaklaşım kan ürünü ihtiyacını belirgin azaltır.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🔄 As an alternative or adjunct to fixed-ratio therapy, viscoelastic-guided coagulation management (using ROTEM/TEG) utilizing targeted factor concentrates (Fibrinogen concentrate, Prothrombin Complex Concentrate - PCC, and Tranexamic Acid - TXA) should be used. This significantly reduces overall transfusion needs.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    }
  },
