  {
    "id": "ards",
    "category": "clinical_scenarios",
    "keywords": [
      "ards",
      "koruyucu",
      "lung",
      "protective",
      "ventilasyon"
    ],
    "question_tr": "Koruyucu ventilasyon",
    "question_en": "Ards",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Tidal volüm gerçek kiloya göre değil, ideal/predicted body weight’e göre ayarlanır.\\nGenel hedef: 4–8 mL/kg PBW; ARDS’de sıklıkla 6 mL/kg PBW başlangıç.\\nPlato basıncı genellikle <30 cmH₂O hedeflenir.\\nDriving pressure düşük tutulmaya çalışılır.\\nPEEP oksijenasyon, hemodinami ve akciğer mekaniğine göre ayarlanır.\\n\\nHipoksemi varsa FiO₂/PEEP optimizasyonu, recruitment, prone pozisyon ve altta yatan nedenlerin tedavisi düşünülür.",
      "immediateRedFlags": [
        "Ventilatörde plato basıncının (Pplat) >30 cmH₂O olması akciğer barotravması ve ventilatör ilişkili akciğer hasarı (VALI) riskini artırır.",
        "Solunum sürüş basıncının (Driving Pressure = Pplat - PEEP) >15 cmH₂O olması mortalite ile doğrudan ilişkilidir."
      ],
      "missingCriticalInformation": [
        "Hastanın boyu ve cinsiyeti (İdeal Vücut Ağırlığı - PBW - hesaplamak için)",
        "Güncel arter kan gazı (PaO₂/FiO₂ oranı)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "ARDS Akciğer Koruyucu Ventilasyon (LTVT) Standartları",
        "İdeal Vücut Ağırlığı (PBW) Hesaplama İlkeleri",
        "Solunumsal Sürüş Basıncı (Driving Pressure) Yönetimi"
      ],
      "suggestedNextStepsGeneral": [
        "Hastanın cinsiyetine ve boyuna göre İdeal Vücut Ağırlığını (PBW) hesaplayın.",
        "Tidal hacmi PBW üzerinden 6 mL/kg olarak ayarlayın (Gerekirse 4-8 mL/kg aralığına titre edin).",
        "PEEP seviyesini FiO₂ ihtiyacına göre optimize edin (hedef PaO₂ 55-80 mmHg).",
        "Solunum sayısı ve I:E oranını pH >7.25 koruyacak şekilde ayarlayın (izin verilebilir hiperkapni)."
      ],
      "relatedAlgorithms": [
        {
          "id": "ards_ventilation",
          "titleTr": "ARDS Koruyucu Ventilasyon"
        },
        {
          "id": "sepsis_shock",
          "titleTr": "Sepsis & Şok Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Tidal hacim kesinlikle hastanın yatakta ölçülen gerçek (aktüel) kilosuna göre değil, ideal (PBW) kilosuna göre set edilmelidir"
      ],
      "whenToEscalate": [
        "Ağır ARDS (PaO₂/FiO₂ <150) varlığında erken prone pozisyonu (günlük en az 16 saat) ve dirençli durumlarda VV-ECMO değerlendirmesi"
      ],
      "referencesToShow": [
        "ARDS Clinical Trials Network. N Engl J Med 2000; 342:1301-1308. PMID: 10793162.",
        "Amato MB, et al. PMID: 25693562."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Tidal volume should be based on predicted body weight, not actual weight. General target: 4–8 mL/kg PBW; in ARDS, 6 mL/kg PBW is commonly used initially. Plateau pressure is generally targeted below 30 cmH₂O. Driving pressure should be minimized when possible. PEEP is adjusted according to oxygenation, hemodynamics, and mechanics. For hypoxemia, optimize FiO₂/PEEP, consider recruitment, prone positioning, and treat underlying causes.",
      "immediateRedFlags": [
        "Plateau pressure (Pplat) >30 cmH₂O significantly increases the risk of barotrauma and ventilator-induced lung injury (VILI).",
        "A driving pressure (Pplat - PEEP) >15 cmH₂O is strongly associated with increased mortality in ARDS."
      ],
      "missingCriticalInformation": [
        "Patient's height and biological sex (required to calculate Predicted Body Weight - PBW)",
        "Most recent arterial blood gas values (PaO₂/FiO₂ ratio)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "ARDS Lung-Protective Ventilation (LTVT) Standards",
        "Predicted Body Weight (PBW) Dosing Principles",
        "Driving Pressure Optimization in Mechanical Ventilation"
      ],
      "suggestedNextStepsGeneral": [
        "Calculate the patient's Predicted Body Weight (PBW) using sex and height.",
        "Set the initial tidal volume to 6 mL/kg of PBW (titrate within 4-8 mL/kg based on pressures).",
        "Titrate PEEP based on FiO₂ requirements (target PaO₂ 55-80 mmHg or SpO₂ 88-95%).",
        "Adjust respiratory rate to maintain pH >7.25 (permissive hypercapnia)."
      ],
      "relatedAlgorithms": [
        {
          "id": "ards_ventilation",
          "titleTr": "ARDS Ventilation Algorithm"
        },
        {
          "id": "sepsis_shock",
          "titleTr": "Sepsis & Shock Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Tidal volume must always be set based on the patient's calculated PBW, never their actual (scale) weight"
      ],
      "whenToEscalate": [
        "In severe ARDS (PaO₂/FiO₂ <150), initiate early prone positioning (at least 16h/day); consider VV-ECMO in refractory hypoxemia"
      ],
      "referencesToShow": [
        "ARDS Clinical Trials Network. N Engl J Med 2000; 342:1301-1308. PMID: 10793162.",
        "Amato MB, et al. PMID: 25693562."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "sepsis",
    "category": "clinical_scenarios",
    "keywords": [
      "sepsis",
      "septic",
      "septik",
      "shock",
      "şok"
    ],
    "question_tr": "Sepsis",
    "question_en": "Septic shock",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Sepsiste erken tanı, kaynak kontrolü ve antibiyotik önemlidir. Şok veya hipoperfüzyon varsa laktat değerlendir, kültürleri al, geniş spektrum antibiyotiği geciktirme, uygun sıvı resüsitasyonu başlat. Persistan hipotansiyonda vazopressör gerekir. İlk tercih genellikle noradrenalindir ve başlangıç MAP hedefi çoğu erişkin için yaklaşık 65 mmHg’dir. Yanıt, laktat, idrar çıkışı, kapiller dolum, mental durum ve kardiyak fonksiyonla yeniden değerlendirilmelidir.",
      "immediateRedFlags": [
        "Septik şokta tanı anından itibaren ilk 1 saat içinde geniş spektrumlu antibiyotik başlanmaması mortalite oranlarını doğrusal olarak artırır.",
        "Persistan yüksek laktat düzeyi (>4 mmol/L) yetersiz doku perfüzyonu ve kötü prognoz göstergesidir."
      ],
      "missingCriticalInformation": [
        "Hastanın qSOFA skoru kriterleri (solunum sayısı, bilinç durumu, sistolik tansiyon)",
        "Kaynak kontrolü için odak tespiti (batın içi, pulmoner, üriner kaynaklı mı?)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Surviving Sepsis Campaign (SSC) 1. Saat Paketi",
        "Sıvı Duyarlılığı ve Dinamik Hemodinamik Monitörizasyon",
        "Noradrenalin ve Vazopressör Tedavi Protokolleri"
      ],
      "suggestedNextStepsGeneral": [
        "Derhal kan kültürlerini (en az iki set) alın.",
        "İlk 1 saat içinde geniş spektrumlu ampirik IV antibiyotik başlayın.",
        "Hipoperfüzyon veya laktat >=4 mmol/L varlığında 30 mL/kg kristalloid sıvı yükleyin.",
        "Sıvı resüsitasyonuna dirençli hipotansiyonda Ortalama Arter Basıncını (OAB) >=65 mmHg tutmak için Noradrenalin infüzyonu başlatın."
      ],
      "relatedAlgorithms": [
        {
          "id": "sepsis_shock",
          "titleTr": "Sepsis & Şok Algoritması"
        },
        {
          "id": "ards_ventilation",
          "titleTr": "ARDS Koruyucu Ventilasyon"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Ortalama Arter Basıncı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Noradrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Sepsis resüsitasyonunda sıvı yüklemesi sırasında aşırı pozitif dengeden kaçınmak için dinamik sıvı duyarlılığı (örn. vuru hacmi varyasyonu) izlenmelidir"
      ],
      "whenToEscalate": [
        "Refrakter septik şokta (Noradrenaline dirençli) vazopressin (0.03 U/dk) ve hidrokortizon (200 mg/gün IV) eklenmesi"
      ],
      "referencesToShow": [
        "Surviving Sepsis Campaign Guidelines 2021. Intensive Care Med 2021. PMID: 34599691.",
        "Singer M, et al. PMID: 26903338."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Early recognition, source control, and antibiotics are essential. In shock or hypoperfusion, assess lactate, obtain cultures, do not delay broad-spectrum antibiotics, and start appropriate fluid resuscitation. Persistent hypotension requires vasopressors. Norepinephrine is generally first-line, and an initial MAP target of about 65 mmHg is used for most adults. Reassess response using lactate, urine output, capillary refill, mental status, and cardiac function.",
      "immediateRedFlags": [
        "Failure to administer broad-spectrum IV antibiotics within the first hour of recognizing septic shock linearly increases mortality.",
        "Persistent elevated lactate levels (>4 mmol/L) reflect ongoing hypoperfusion and predict poor survival."
      ],
      "missingCriticalInformation": [
        "Patient's qSOFA score criteria (respiratory rate, altered mental status, systolic BP)",
        "Infectious source identification (e.g., intra-abdominal, pulmonary, urinary source?)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Surviving Sepsis Campaign (SSC) 1-Hour Bundle",
        "Fluid Responsiveness and Dynamic Hemodynamic Parameters",
        "Norepinephrine and Vasopressor Infusion Guidelines"
      ],
      "suggestedNextStepsGeneral": [
        "Obtain blood cultures (at least two sets) immediately.",
        "Administer broad-spectrum empirical IV antibiotics within 1 hour.",
        "Give 30 mL/kg crystalloid fluid resuscitation for hypotension or lactate >=4 mmol/L.",
        "Initiate Norepinephrine infusion to maintain Mean Arterial Pressure (MAP) >=65 mmHg if hypotension is fluid-refractory."
      ],
      "relatedAlgorithms": [
        {
          "id": "sepsis_shock",
          "titleTr": "Sepsis & Shock Algorithm"
        },
        {
          "id": "ards_ventilation",
          "titleTr": "ARDS Ventilation Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "map",
          "titleTr": "MAP Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "norepinephrine",
          "titleTr": "Norepinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "Use dynamic measures of fluid responsiveness (e.g., stroke volume variation) to guide fluid therapy and avoid harmful positive fluid balance"
      ],
      "whenToEscalate": [
        "In refractory septic shock (high-dose Norepinephrine), add Vasopressin (0.03 U/min) and IV Hydrocortisone (200 mg/day)"
      ],
      "referencesToShow": [
        "Surviving Sepsis Campaign Guidelines 2021. Intensive Care Med 2021. PMID: 34599691.",
        "Singer M, et al. PMID: 26903338."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "hyperkalemia",
    "category": "clinical_scenarios",
    "keywords": [
      "hiperkalemi",
      "hyperkalemia",
      "potasyum"
    ],
    "question_tr": "Hiperkalemi",
    "question_en": "Potasyum",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "EKG değişikliği, ciddi hiperkalemi veya hemodinamik instabilite varsa acil tedavi gerekir.\\n\\n1. Kalsiyum vererek miyokardı stabilize et.\\n2. İnsülin + dekstroz ile potasyumu hücre içine kaydır.\\n3. Salbutamol ek tedavi olarak kullanılabilir.\\n4. Asidoz varsa sodyum bikarbonat düşünülebilir.\\n5. Potasyum kaynağını durdur; kan ürünleri, süksinilkolin, renal yetmezlik ve rabdomiyolizi değerlendir.\\n6. Eliminasyon için diürez, potasyum bağlayıcı veya diyaliz gerekebilir.\\n7. Glukozu tekrarlayan ölçümlerle izle.",
      "immediateRedFlags": [
        "Hiperkalemide EKG'de sivri T dalgaları, PR uzaması, QRS genişlemesi veya sinüzoidal dalga yapısı (areste gidişin kritik kırmızı bayrakları).",
        "Potasyum düzeyi >6.5 mmol/L olması mutlak acil tedavi gerektirir."
      ],
      "missingCriticalInformation": [
        "Hastanın güncel potasyum seviyesi (mmol/L)",
        "Eş zamanlı böbrek yetmezliği veya anüri varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Akut Perioperatif Hiperkalemi Yönetimi",
        "Miyokardiyal Stabilizasyon ve Hücre İçine Kaydırma Tedavileri",
        "Renal Eliminasyon ve Acil Hemodiyaliz Endikasyonları"
      ],
      "suggestedNextStepsGeneral": [
        "Miyokardı stabilize etmek için derhal 1 g Kalsiyum Glukonat veya Kalsiyum Klorür IV uygulayın (EKG değişikliği varsa).",
        "Potasyumu hücre içine kaydırmak için: 10 Ünite Regüler İnsülin + 50 mL %50 Dekstroz IV uygulayın.",
        "Ek olarak Salbutamol (10-20 mg nebülizatör veya inhaler) uygulayın.",
        "Metabolik asidoz eşlik ediyorsa Sodyum Bikarbonat (50 mEq IV) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Acil Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Checklist'i"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Süksinilkolin Monografı"
        }
      ],
      "doNotMiss": [
        "Hiperkalemisi olan veya şüphelenilen hastalarda Süksinilkolin kullanımı kesinlikle KONTRENDİKEDİR (potasyumu 0.5-1 mmol/L daha yükseltir!)"
      ],
      "whenToEscalate": [
        "Medikal tedaviye dirençli hiperkalemide ve anürisi olan hastalarda acil hemodiyaliz aktivasyonu"
      ],
      "referencesToShow": [
        "AHA Advanced Cardiovascular Life Support Guidelines, 2020. PMID: 33081529.",
        "European Resuscitation Council Guidelines. 2021. PMID: 33773824."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "ECG changes, severe hyperkalemia, or hemodynamic instability require emergency treatment. Stabilize myocardium with calcium, shift potassium intracellularly with insulin plus dextrose, consider salbutamol as adjunct therapy, consider sodium bicarbonate if acidosis is present, stop potassium sources, evaluate transfusion, succinylcholine, renal failure, and rhabdomyolysis. Potassium elimination may require diuresis, binders, or dialysis. Monitor glucose repeatedly.",
      "immediateRedFlags": [
        "ECG showing peaked T waves, PR prolongation, widened QRS, or a sinusoidal pattern (critical warnings for impending arrest).",
        "A serum potassium level >6.5 mmol/L is a medical emergency."
      ],
      "missingCriticalInformation": [
        "Exact serum potassium level (in mmol/L)",
        "Presence of renal failure or active anuria"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Acute Perioperative Hyperkalemia Management",
        "Myocardial Stabilization and Intracellular Shifting Therapies",
        "Renal Elimination and Emergency Hemodialysis Indications"
      ],
      "suggestedNextStepsGeneral": [
        "Stabilize the myocardium immediately with 1 g Calcium Gluconate or Calcium Chloride IV (if ECG changes are present).",
        "Shift potassium intracellularly: Administer 10 Units of Regular Insulin + 50 mL of Dextrose 50% IV.",
        "Add Albuterol/Salbutamol (10-20 mg nebulized) as adjunctive therapy.",
        "Administer Sodium Bicarbonate (50 mEq IV) if metabolic acidosis is present."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "cico_crisis",
          "titleTr": "CICO Emergency Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway Checklist"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "succinylcholine",
          "titleTr": "Succinylcholine Monograph"
        }
      ],
      "doNotMiss": [
        "Succinylcholine is strictly CONTRAINDICATED in hyperkalemia as it independently raises serum potassium by 0.5-1.0 mmol/L"
      ],
      "whenToEscalate": [
        "In refractory hyperkalemia unresponsive to medical therapy in anuric patients, arrange emergent hemodialysis immediately"
      ],
      "referencesToShow": [
        "AHA Advanced Cardiovascular Life Support Guidelines, 2020. PMID: 33081529.",
        "European Resuscitation Council Guidelines. 2021. PMID: 33773824."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "pediatric_tube",
