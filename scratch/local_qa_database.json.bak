  {
    "id": "postoperative_ventilator_weaning",
    "category": "clinical_scenarios",
    "keywords": [
      "ayırma",
      "postop",
      "postoperative",
      "ventilator",
      "ventilatörden",
      "weaning"
    ],
    "question_tr": "Postop ventilatörden ayırma",
    "question_en": "Ventilator weaning",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Weaning kararı sadece tek parametreye dayanmaz. 1. Altta yatan sorun düzeliyor mu? 2. Oksijenasyon kabul edilebilir mi? 3. Hemodinami stabil mi, yüksek vazopressör ihtiyacı yok mu? 4. Bilinç ve hava yolu koruma yeterli mi? 5. Sekresyon yönetimi ve öksürük yeterli mi? 6. Asidoz/elektrolit/hipotermi düzelmiş mi? 7. Spontan solunum denemesi tolere ediliyor mu? 8. Ekstübasyon sonrası başarısızlık riski yüksekse HFNC/NIV/CPAP ve yoğun bakım planlanmalıdır.",
      "immediateRedFlags": [
        "Weaning başlanır başlanmaz gelişen ağır ajitasyon, deliryum veya takipne (solunum hızı > 35/dk).",
        "Oksijen desteğine rağmen SpO2'nin <%90'ın altına düşmesi ve solunumsal asidoz (pH < 7.25).",
        "Hemodinamik instabilite, ciddi taşikardi veya yeni başlayan disritmiler."
      ],
      "missingCriticalInformation": [
        "Hastanın güncel arter kan gazı (ABG) değerleri",
        "Hastanın derin refleksleri ve nöromüsküler gücü (residual blok varlığı)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postoperatif Ventilatörden Ayırma",
        "Weaning Kriterleri ve Süreci",
        "Yoğun Bakım Derlenme Takibi"
      ],
      "suggestedNextStepsGeneral": [
        "Weaning öncesinde hastanın hemodinamik olarak stabil olduğunu ve sepsis bulgusu taşımadığını doğrulayın.",
        "Oksijenasyonun yeterli olduğunu (PaO2/FiO2 > 150-200 ve PEEP <= 8 cmH2O) teyit edin.",
        "Elektrolitleri (özellikle potasyum, magnezyum, fosfor) ve vücut sıcaklığını optimize edin.",
        "Spontan Solunum Denemesi (SBT) protokolünü başlatın."
      ],
      "relatedAlgorithms": [
        {
          "id": "ventilator_weaning",
          "titleTr": "Ventilatörden Ayırma"
        },
        {
          "id": "extubation_readiness",
          "titleTr": "Ekstübasyon Hazırlığı"
        }
      ],
      "relatedCalculators": [
        {
          "id": "rsbi_calculator",
          "titleTr": "RSBI Hesaplayıcı"
        },
        {
          "id": "pf_ratio_calculator",
          "titleTr": "P/F Oranı"
        },
        {
          "id": "abg_interpretation",
          "titleTr": "Kan Gazı"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Hastanın mental durumunun ve koopere olma yeteneğinin weaning başarısında en kritik faktörlerden biri olduğunu"
      ],
      "whenToEscalate": [
        "Hasta weaning denemesini tolere edemez, solunum yetmezliği ve ağır yorgunluk gelişirse, weaning'i durdurun ve tam mekanik ventilasyon desteğine geri dönün"
      ],
      "referencesToShow": [
        "ATS/CHEST Clinical Practice Guidelines on Weaning. 2017.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Weaning should not rely on a single parameter. Ask whether the underlying problem is improving, oxygenation is acceptable, hemodynamics are stable without high vasopressor need, consciousness and airway protection are adequate, secretion clearance and cough are sufficient, acidosis/electrolytes/hypothermia are corrected, and spontaneous breathing trial is tolerated. If post-extubation failure risk is high, plan HFNC/NIV/CPAP and ICU monitoring.",
      "immediateRedFlags": [
        "Severe agitation, delirium, or rapid tachypnea (RR > 35 bpm) upon starting weaning.",
        "Deteriorating oxygen saturation (SpO2 < 90%) and respiratory acidosis (pH < 7.25).",
        "Hemodynamic instability, severe tachycardia, or new onset arrhythmias."
      ],
      "missingCriticalInformation": [
        "The patient's current arterial blood gas (ABG) values",
        "The presence of residual neuromuscular blockade or muscle weakness"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Postoperative Ventilator Weaning",
        "Weaning Criteria and Protocol",
        "ICU Recovery Monitoring"
      ],
      "suggestedNextStepsGeneral": [
        "Confirm hemodynamic stability and absence of active sepsis/shock before weaning.",
        "Ensure adequate oxygenation (PaO2/FiO2 > 150-200 on PEEP <= 8 cmH2O).",
        "Optimize electrolytes (K, Mg, Phos) and maintain normothermia.",
        "Initiate a structured Spontaneous Breathing Trial (SBT)."
      ],
      "relatedAlgorithms": [
        {
          "id": "ventilator_weaning",
          "titleTr": "Ventilator Weaning"
        },
        {
          "id": "extubation_readiness",
          "titleTr": "Extubation Readiness"
        }
      ],
      "relatedCalculators": [
        {
          "id": "rsbi_calculator",
          "titleTr": "RSBI Calculator"
        },
        {
          "id": "pf_ratio_calculator",
          "titleTr": "P/F Ratio"
        },
        {
          "id": "abg_interpretation",
          "titleTr": "ABG Interpretation"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "The patient's mental status and ability to clear secretions are among the most critical qualitative predictors of weaning success"
      ],
      "whenToEscalate": [
        "If the patient fails the weaning trial, showing severe tachypnea, fatigue, or hemodynamic distress, abort the trial and return to full ventilator support"
      ],
      "referencesToShow": [
        "ATS/CHEST Clinical Practice Guidelines on Weaning. 2017.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "spontaneous_breathing_trial",
    "category": "clinical_scenarios",
    "keywords": [
      "breathing",
      "denemesi",
      "sbt",
      "solunum",
      "spontan",
      "spontaneous",
      "trial"
    ],
    "question_tr": "Spontan solunum denemesi",
    "question_en": "Spontaneous breathing trial",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Spontan solunum denemesi sırasında solunum işi, solunum sayısı, tidal volüm, SpO₂, ETCO₂/PaCO₂, kalp hızı, kan basıncı, ajitasyon, terleme ve yorgunluk izlenir. Başarısızlık bulguları: takipne, düşük tidal volüm, belirgin yardımcı kas kullanımı, desatürasyon, hiperkapni/asidoz, taşikardi, hipertansiyon/hipotansiyon, aritmi, mental durum bozulması veya bitkinlik. Başarılı SBT ekstübasyon başarısını garanti etmez; hava yolu ödemi, sekresyon, öksürük ve nöromüsküler güç ayrıca değerlendirilmelidir.",
      "immediateRedFlags": [
        "SBT sırasında solunum hızının > 35/dk olması veya %50'den fazla artması.",
        "Hızlı ve yüzeyel solunum indeksi (RSBI) değerinin > 105 olması.",
        "Akut göğüs ağrısı, diaforez (aşırı terleme) ve EKG'de iskemi değişiklikleri."
      ],
      "missingCriticalInformation": [
        "SBT'nin hangi modda yapıldığı (T-tüpü vs. düşük basınç desteği -PSV- modu)",
        "Hastanın balgam çıkarma ve öksürük gücü"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Spontan Solunum Denemesi (SBT)",
        "Ekstübasyon Öncesi Değerlendirme",
        "Hızlı Yüzeyel Solunum İndeksi (RSBI)"
      ],
      "suggestedNextStepsGeneral": [
        "SBT'yi genellikle 30-120 dakika boyunca T-tüpü veya düşük basınç desteği (PS 5-8, PEEP 0-5) ile uygulayın.",
        "SBT'nin 1. dakikasında ve sonunda RSBI (Frekans / Litre cinsinden Tidal Volüm) değerini hesaplayın.",
        "Solunum paterni, hemodinami ve SpO2'yi sürekli monitörize edin.",
        "Başarılı SBT sonrasında hastanın bilincini ve havayolu reflekslerini tekrar değerlendirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "sbt",
          "titleTr": "Spontan Solunum Denemesi"
        },
        {
          "id": "ventilator_weaning",
          "titleTr": "Ventilatörden Ayırma"
        },
        {
          "id": "extubation_readiness",
          "titleTr": "Ekstübasyon Hazırlığı"
        }
      ],
      "relatedCalculators": [
        {
          "id": "rsbi_calculator",
          "titleTr": "RSBI Hesaplayıcı"
        },
        {
          "id": "abg_interpretation",
          "titleTr": "Kan Gazı"
        },
        {
          "id": "pf_ratio_calculator",
          "titleTr": "P/F Oranı"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "SBT'yi başarıyla geçen hastaların bile zayıf öksürük veya aşırı sekresyonlar nedeniyle ekstübasyon sonrası tıkanıp tekrar entübe olabileceğini"
      ],
      "whenToEscalate": [
        "SBT esnasında RSBI > 105 saptanırsa veya solunum sıkıntısı gelişirse, denemeyi derhal sonlandırın ve hastayı ventilatörde dinlendirin"
      ],
      "referencesToShow": [
        "ATS/CHEST Clinical Practice Guidelines on Weaning. 2017.",
        "RSBI Validation Studies in Mechanical Ventilation."
      ],
      "safetyLevel": "urgent"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "During SBT, monitor work of breathing, respiratory rate, tidal volume, SpO₂, ETCO₂/PaCO₂, heart rate, blood pressure, agitation, sweating, and fatigue. Failure signs include tachypnea, low tidal volume, accessory muscle use, desaturation, hypercapnia/acidosis, tachycardia, hypertension/hypoxemia, arrhythmia, altered mental status, or exhaustion. A successful SBT does not guarantee successful extubation; airway edema, secretions, cough, and neuromuscular strength must also be assessed.",
      "immediateRedFlags": [
        "Respiratory rate > 35 bpm or an increase of > 50% from baseline during SBT.",
        "Rapid Shallow Breathing Index (RSBI) > 105.",
        "Acute chest pain, severe diaphoresis, or new ischemic ST changes on the ECG."
      ],
      "missingCriticalInformation": [
        "The mode of SBT (T-piece trial vs. low pressure support ventilation -PSV-)",
        "The patient's cough strength and secretion volume"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Spontaneous Breathing Trial (SBT)",
        "Pre-Extubation Assessment",
        "Rapid Shallow Breathing Index (RSBI)"
      ],
      "suggestedNextStepsGeneral": [
        "Perform the SBT for 30-120 minutes using either a T-piece or low PSV (PS 5-8 cmH2O, PEEP 0-5 cmH2O).",
        "Calculate RSBI (f/Vt in liters) at the 1st minute and before ending the trial.",
        "Monitor respiratory pattern, hemodynamics, and SpO2 continuously.",
        "Re-evaluate airway reflexes and level of consciousness after a successful trial."
      ],
      "relatedAlgorithms": [
        {
          "id": "sbt",
          "titleTr": "Spontaneous Breathing Trial"
        },
        {
          "id": "ventilator_weaning",
          "titleTr": "Ventilator Weaning"
        },
        {
          "id": "extubation_readiness",
          "titleTr": "Extubation Readiness"
        }
      ],
      "relatedCalculators": [
        {
          "id": "rsbi_calculator",
          "titleTr": "RSBI Calculator"
        },
        {
          "id": "abg_interpretation",
          "titleTr": "ABG Interpretation"
        },
        {
          "id": "pf_ratio_calculator",
          "titleTr": "P/F Ratio"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "A patient can pass the SBT perfectly but still fail extubation due to a weak cough or excessive secretions; assess airway clearance independently"
      ],
      "whenToEscalate": [
        "If the patient exhibits an RSBI > 105, severe accessory muscle use, or tachycardia during the SBT, abort the trial immediately and return to comfortable assist settings"
      ],
      "referencesToShow": [
        "ATS/CHEST Clinical Practice Guidelines on Weaning. 2017.",
        "RSBI Validation Studies in Mechanical Ventilation."
      ],
      "safetyLevel": "urgent"
    }
  },
  {
    "id": "extubation_failure_management",
    "category": "clinical_scenarios",
    "keywords": [
      "başarısızlığı",
      "ekstübasyon",
      "extubation",
      "failure",
      "management"
    ],
    "question_tr": "Ekstübasyon başarısızlığı",
    "question_en": "Extubation failure",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Ekstübasyon başarısızlığı hava yolu obstrüksiyonu, hipoksemi, hiperkapni, sekresyon, kas güçsüzlüğü, ödem, aspirasyon, kalp yetmezliği veya deliryum nedeniyle gelişebilir. 1. Oksijen ver ve yardım çağır. 2. Hava yolunu aç, suction yap, pozisyon ver. 3. Stridor varsa üst havayolu ödemi algoritmasına geç. 4. Hipoventilasyon varsa opioid/sedatif etkisi ve rezidüel blok düşün. 5. HFNC/NIV/CPAP seçilmiş hastada denenebilir; ancak kötüleşen hastada reentübasyon geciktirilmez. 6. Reentübasyon zor olacaksa erken kıdemli destek ve zor havayolu ekipmanı gerekir.",
      "immediateRedFlags": [
        "Ekstübasyon sonrası gelişen tam havayolu tıkanıklığı, paradoksal solunum ve bilinç kaybı.",
        "Maksimum oksijen desteğine rağmen SpO2'nin <%80'in altına düşmesi.",
        "Ağır post-ekstübasyon stridoru ve solunum yorgunluğu bulguları."
      ],
      "missingCriticalInformation": [
        "Ekstübasyon öncesi nöromüsküler bloğun Sugammadeks ile tam döndürülüp döndürülmediği",
        "Hastanın reentübasyonunun zor olup olmayacağı öyküsü"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Ekstübasyon Başarısızlığı Yönetimi",
        "Post-Ekstübasyon Solunum Yetmezliği",
        "Acil Havayolu Kurtarma"
      ],
      "suggestedNextStepsGeneral": [
        "Hastaya hemen maskeyle %100 oksijen verin ve kıdemli yardım çağırın.",
        "Oral veya nazal airway yerleştirip iki elle jaw-thrust (çene itme) uygulayın.",
        "Rezidüel opioid şüphesinde nalokson, kürarizasyon şüphesinde sugammadeks uygulayın.",
        "Stridor varsa nebulize adrenalin ve IV deksametazon tedavisini geciktirmeyin."
      ],
      "relatedAlgorithms": [
        {
          "id": "extubation_failure",
          "titleTr": "Ekstübasyon Başarısızlığı"
        },
        {
          "id": "stridor",
          "titleTr": "Post-ekstübasyon Stridoru"
        },
        {
          "id": "difficult_airway",
          "titleTr": "Zor Havayolu Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "oxygenation_calculator",
          "titleTr": "Oksijenasyon"
        },
        {
          "id": "tof_calculator",
          "titleTr": "TOF Hesaplayıcı"
        },
        {
          "id": "abg_interpretation",
          "titleTr": "Kan Gazı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "naloxone",
          "titleTr": "Nalokson"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadeks Monografı"
        },
        {
          "id": "nebulized_epinephrine",
          "titleTr": "Nebulize Adrenalin"
        },
        {
          "id": "dexamethasone",
          "titleTr": "Deksametazon Monografı"
        }
      ],
      "doNotMiss": [
        "Başarısız olan bir hastada non-invaziv desteklerle (NIV/HFNC) gereksiz yere vakit kaybetmenin reentübasyonu geciktirip kardiyak arrest riskini artıracağını"
      ],
      "whenToEscalate": [
        "Solunum yorgunluğu, SpO2 desatürasyonu ve letarji sürüyorsa, hiç vakit kaybetmeden zor havayolu arabasını hazırlayın ve hastayı derhal reentübe edin"
      ],
      "referencesToShow": [
        "Difficult Airway Society Guidelines on Extubation. Anaesthesia 2012.",
        "ASA Practice Advisory for Airway Management. 2022."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Extubation failure may result from airway obstruction, hypoxemia, hypercapnia, secretions, muscle weakness, edema, aspiration, heart failure, or delirium. Give oxygen and call for help. Open the airway, suction, and position the patient. If stridor occurs, follow the upper airway edema algorithm. If hypoventilation occurs, consider opioid/sedative effect and residual block. HFNC/NIV/CPAP may be tried in selected patients, but do not delay reintubation in a deteriorating patient. If reintubation may be difficult, obtain senior help and difficult airway equipment early.",
      "immediateRedFlags": [
        "Complete airway obstruction, paradoxical chest movement, and loss of consciousness post-extubation.",
        "Oxygen saturation dropping below 80% despite maximum non-invasive support.",
        "Severe post-extubation stridor with rapid exhaustion."
      ],
      "missingCriticalInformation": [
        "Complete reversal of neuromuscular blockade using Sugammadex prior to extubation",
        "Documentation of predicted or historical difficulty of reintubation"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Extubation Failure Management",
        "Post-Extubation Respiratory Failure",
        "Emergency Airway Rescue"
      ],
      "suggestedNextStepsGeneral": [
        "Administer 100% oxygen via bag-mask and call for emergency assistance.",
        "Insert an oral/nasal airway and perform a two-handed jaw thrust.",
        "Administer naloxone for suspected opioid overdose, or sugammadex for residual paralysis.",
        "For stridor, immediately give nebulized epinephrine and IV dexamethasone."
      ],
      "relatedAlgorithms": [
        {
          "id": "extubation_failure",
          "titleTr": "Extubation Failure"
        },
        {
          "id": "stridor",
          "titleTr": "Post-extubation Stridor"
        },
        {
          "id": "difficult_airway",
          "titleTr": "Difficult Airway"
        }
      ],
      "relatedCalculators": [
        {
          "id": "oxygenation_calculator",
          "titleTr": "Oxygenation"
        },
        {
          "id": "tof_calculator",
          "titleTr": "TOF Calculator"
        },
        {
          "id": "abg_interpretation",
          "titleTr": "ABG Interpretation"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "naloxone",
          "titleTr": "Naloxone"
        },
        {
          "id": "sugammadex",
          "titleTr": "Sugammadex Monograph"
        },
        {
          "id": "nebulized_epinephrine",
          "titleTr": "Nebulized Epinephrine"
        },
        {
          "id": "dexamethasone",
          "titleTr": "Dexamethasone Monograph"
        }
      ],
      "doNotMiss": [
        "Delaying reintubation by over-relying on non-invasive supports (NIV/HFNC) in a tiring patient can lead to sudden hypoxic cardiac arrest"
      ],
      "whenToEscalate": [
        "If the patient remains lethargic, hypoxic, and exhausted despite basic maneuvers, secure the difficult airway cart and perform immediate reintubation"
      ],
      "referencesToShow": [
        "Difficult Airway Society Guidelines on Extubation. Anaesthesia 2012.",
        "ASA Practice Advisory for Airway Management. 2022."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "postoperative_hypercapnia",
    "category": "clinical_scenarios",
    "keywords": [
      "hiperkapni",
      "hypercapnia",
