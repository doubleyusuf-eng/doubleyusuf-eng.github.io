      "sedation",
      "solunumu"
    ],
    "question_tr": "Anestezi derinleşti",
    "question_en": "Beklenmeyen derinleşme",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "1. Sedatif/analjezik uygulamasını durdur. 2. Hastayı uyar, hava yolunu aç, jaw thrust uygula. 3. Oksijen ver, gerekirse maske ventilasyonu yap. 4. SpO₂, ETCO₂, nabız ve kan basıncını değerlendir. 5. Opioid etkisi varsa nalokson; benzodiazepin etkisi varsa flumazenil filtre edilerek düşünülebilir. 6. Düzelmezse ileri havayolu ve resüsitasyon ekibi çağrılır. 7. Sedasyon sonrası yeniden sedasyon açısından izlem gerekir.",
      "immediateRedFlags": [
        "Sedasyon uygulanan hastanın verbal ve fiziksel uyarılara tamamen yanıtsız hale gelmesi (genel anestezi derinliği).",
        "SpO₂'nin <%90 olması, kapnografide dalga olmaması (apne) veya obstrüktif kapnogram dalgaları.",
        "Sedasyon derinleşmesi sonrasında gelişen derin sistemik hipotansiyon ve bradikardi."
      ],
      "missingCriticalInformation": [
        "Son 15 dakika içinde uygulanan sedatiflerin (Propofol, Midazolam, Fentanil vb.) tam dozları",
        "Hastanın eşlik eden nörolojik hasar veya serebral perfüzyon kısıtı varlığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Beklenmeyen Derin Sedasyon ve Apne Yönetimi",
        "Farmakolojik Reversal Ajanları (Nalokson, Flumazenil)",
        "Havayolu Açma Manevraları ve Maske Ventilasyonu"
      ],
      "suggestedNextStepsGeneral": [
        "Sedatif veya analjezik infüzyon pompalarını ve enjeksiyonları derhal DURDURUN.",
        "Hastaya yüksek sesle seslenin, omuzlarından sarsın ve gerekirse mandibular bası (jaw thrust) uygulayın.",
        "Yüz maskesi ve ambu ile %100 O₂ eşliğinde pozitif basınçlı maske ventilasyonuna başlayın.",
        "Benzodiazepin aşırı dozu şüphesinde Flumazenil (0.2 mg IV, yavaşça titre edilerek); opioid şüphesinde Nalokson (0.04-0.1 mg IV) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "procedural_sedation",
          "titleTr": "Girişimsel Sedasyon Algoritması"
        },
        {
          "id": "opioid_respiratory",
          "titleTr": "Opioid Solunum Depresyonu Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "naloxone_dose",
          "titleTr": "Nalokson Doz Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "naloxone",
          "titleTr": "Nalokson Monografı"
        },
        {
          "id": "flumazenil",
          "titleTr": "Flumazenil Monografı"
        },
        {
          "id": "oxygen",
          "titleTr": "Oksijen Monografı"
        }
      ],
      "doNotMiss": [
        "Flumazenil uygulamasının kronik benzodiazepin kullanan veya epilepsisi olan hastalarda akut nöbet krizini tetikleyebileceğini"
      ],
      "whenToEscalate": [
        "Apne veya üst havayolu obstrüksiyonu pozitif basınçlı maske ventilasyonuna rağmen düzelmezse zaman kaybetmeden acil entübasyon planlayın"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Moderate Procedural Sedation. Anesthesiology 2018.",
        "Reversal of Sedative Agents. BJA Education 2019."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Stop sedatives/analgesics. Stimulate the patient, open the airway, and apply jaw thrust. Provide oxygen and assist ventilation if needed. Assess SpO₂, ETCO₂, pulse, and blood pressure. If opioid effect is suspected, titrate naloxone; if benzodiazepine effect is suspected, consider titrated flumazenil. If unresolved, call for advanced airway and resuscitation support. Monitor for recurrent sedation afterward.",
      "immediateRedFlags": [
        "Complete unresponsiveness to verbal and painful physical commands (unintended general anesthesia).",
        "Hypoxemia (SpO₂ <90%) and flatline capnogram trace indicating complete apnea.",
        "Profound bradycardia and hypotension secondary to anesthetic myocardial depression."
      ],
      "missingCriticalInformation": [
        "Exact cumulative doses of sedatives (Propofol, Midazolam, Ketamine) and opioids administered",
        "Fasting (NPO) compliance and baseline aspiration risk"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Unintended Deep Sedation and Apnea Rescue",
        "Pharmacological Reversal Strategies (Naloxone, Flumazenil)",
        "Airway Re-establishment and Bag-Valve-Mask Ventilation"
      ],
      "suggestedNextStepsGeneral": [
        "Immediately STOP all sedative infusions, target-controlled pumps, and bolus injections.",
        "Loudly stimulate the patient and perform a firm jaw-thrust maneuver to clear the tongue.",
        "Apply a face mask and deliver positive-pressure ventilation with 100% oxygen using an Ambu bag.",
        "Titrate Flumazenil (0.2 mg IV, up to 1 mg) for benzodiazepines, or Naloxone (40-100 mcg IV) for opioids."
      ],
      "relatedAlgorithms": [
        {
          "id": "procedural_sedation",
          "titleTr": "Procedural Sedation Algorithm"
        },
        {
          "id": "opioid_respiratory",
          "titleTr": "Opioid Respiratory Depression Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "naloxone_dose",
          "titleTr": "Naloxone Dose Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "naloxone",
          "titleTr": "Naloxone Monograph"
        },
        {
          "id": "flumazenil",
          "titleTr": "Flumazenil Monograph"
        },
        {
          "id": "oxygen",
          "titleTr": "Oxygen Monograph"
        }
      ],
      "doNotMiss": [
        "Flumazenil can precipitate acute withdrawal seizures in patients with chronic benzodiazepine dependence or active epilepsy"
      ],
      "whenToEscalate": [
        "If the patient remains apneic or airway obstruction is persistent despite maneuvers and reversal, secure the airway immediately with a supraglottic device or intubation"
      ],
      "referencesToShow": [
        "ASA Practice Guidelines for Moderate Procedural Sedation. Anesthesiology 2018.",
        "Reversal of Sedative Agents. BJA Education 2019."
      ],
      "safetyLevel": "emergency"
    }
  },
  {
    "id": "contrast_media_reaction",
    "category": "clinical_scenarios",
    "keywords": [
      "contrast",
      "kontrast",
      "media",
      "radyoloji",
      "reaction",
      "reaksiyonu",
      "sedasyonu"
    ],
    "question_tr": "Kontrast reaksiyonu",
    "question_en": "Radyoloji sedasyonu",
    "safetyLevel": "emergency",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Kontrast reaksiyonları hafif ürtikerden bronkospazm, hipotansiyon ve anafilaksiye kadar değişebilir. 1. Kontrast uygulamasını durdur. 2. Yardım çağır, ABC değerlendir. 3. %100 oksijen ver, IV erişim ve monitörizasyon sağla. 4. Hipotansiyon/bronkospazm/laringospazm varsa anafilaksi algoritmasına geç; adrenalin ilk ilaçtır. 5. Hafif ürtikerde antihistaminik yeterli olabilir, ancak progresyon açısından izlem gerekir. 6. Olay belgelenmeli ve hasta sonraki kontrast kullanımı için bilgilendirilmelidir.",
      "immediateRedFlags": [
        "Kontrast enjeksiyonu sonrasında gelişen ani stridor, larenks ödemi veya tam havayolu tıkanıklığı.",
        "Masif bronkospazm, wheezing ve ventilasyon basıncının tavan yapması.",
        "Kontrast sonrası nabızsızlık veya refrakter hipotansiyon (Anafilaktik Şok)."
      ],
      "missingCriticalInformation": [
        "Kullanılan kontrast maddenin ciddiyeti ve ozmolalitesi (yüksek vs düşük ozmolaliteli kontrast)",
        "Hastanın bilinen astım, gıda veya ilaç alerjisi öyküsü"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Radyolojik Kontrast Madde Reaksiyonları",
        "Anafilaktik Şok ve Epinefrin Dozlaması",
        "Bronkospazm ve Laringospazm Kriz Tedavisi"
      ],
      "suggestedNextStepsGeneral": [
        "Şüpheli kontrast enjeksiyonunu DERHAL durdurun.",
        "Hastayı %100 yüksek akım O₂ ile solutun ve damar yolu açıklığını doğrulayın.",
        "Şiddetli reaksiyonlarda (hipotansiyon, bronkospazm) ilk planda Adrenalin (0.05-0.1 mg IV yavaşça veya 0.5 mg IM) uygulayın.",
        "Hacim genişletmek için IV izotonik sıvı bolusunu (1-2 L kristaloid) hızla gönderin."
      ],
      "relatedAlgorithms": [
        {
          "id": "anaphylaxis",
          "titleTr": "Anafilaksi Kurtarma Algoritması"
        },
        {
          "id": "nora_safety",
          "titleTr": "NORA Güvenlik Protokolü"
        }
      ],
      "relatedCalculators": [
        {
          "id": "epinephrine_dose",
          "titleTr": "Adrenalin Doz Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "epinephrine",
          "titleTr": "Adrenalin Monografı"
        },
        {
          "id": "pheniramine",
          "titleTr": "Feniramin Monografı"
        },
        {
          "id": "hydrocortisone",
          "titleTr": "Hidrokortizon Monografı"
        },
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol Monografı"
        }
      ],
      "doNotMiss": [
        "Radyolojik kontrast reaksiyonlarının gerçek IgE aracılı olmayabileceğini (anafilaktoid), ancak klinik yönetiminin anafilaksi ile tamamen AYNI olduğunu"
      ],
      "whenToEscalate": [
        "Gelişen larenks ödemi veya kardiyopulmoner kollaps durumunda derhal havayolunu güvenceye alın, CPR başlatın ve yoğun bakıma nakledin"
      ],
      "referencesToShow": [
        "ACR Manual on Contrast Media. American College of Radiology 2021.",
        "Management of Acute Contrast Reactions. RadioGraphics 2018. PMID: 29016373."
      ],
      "safetyLevel": "emergency"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Contrast reactions range from mild skin reactions (urticaria) to severe bronchospasm, hypotension, and life-threatening anaphylaxis. Stop contrast administration, call for help, assess ABCs, provide 100% oxygen, IV access, and monitoring. If hypotension, bronchospasm, or laryngospasm occurs, follow the anaphylaxis algorithm; epinephrine is first-line. Mild urticaria may respond to antihistamines, but observe for progression. Document the event and inform the patient for future contrast exposure.",
      "immediateRedFlags": [
        "Sudden acute upper airway stridor, facial/laryngeal angioedema post-contrast injection.",
        "Severe intractable bronchospasm and peak inspiratory pressure spikes.",
        "Anaphylactic shock (refractory hypotension and cardiovascular collapse)."
      ],
      "missingCriticalInformation": [
        "Type of contrast agent injected (high-osmolar vs. low-osmolar non-ionic contrast)",
        "Patient's history of prior contrast reactions or severe atopic disease (e.g. asthma)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Radiological Contrast Media Hypersensitivity Reactions",
        "Anaphylactic Shock Management and Epinephrine Dosing",
        "Bronchospasm and Laryngospasm Rescue Protocols"
      ],
      "suggestedNextStepsGeneral": [
        "STOP the contrast media infusion immediately.",
        "Administer 100% oxygen and secure large-bore intravenous access.",
        "For severe cardiovascular or respiratory distress, administer immediate IV Epinephrine (50-100 mcg titrated slowly).",
        "Initiate rapid fluid resuscitation with 1-2 L of isotonic crystalloids."
      ],
      "relatedAlgorithms": [
        {
          "id": "anaphylaxis",
          "titleTr": "Anaphylaxis Algorithm"
        },
        {
          "id": "nora_safety",
          "titleTr": "NORA Safety Protocol"
        }
      ],
      "relatedCalculators": [
        {
          "id": "epinephrine_dose",
          "titleTr": "Epinephrine Dose Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "epinephrine",
          "titleTr": "Epinephrine Monograph"
        },
        {
          "id": "pheniramine",
          "titleTr": "Pheniramine Monograph"
        },
        {
          "id": "hydrocortisone",
          "titleTr": "Hydrocortisone Monograph"
        },
        {
          "id": "salbutamol",
          "titleTr": "Salbutamol Monograph"
        }
      ],
      "doNotMiss": [
        "Contrast media reactions are often anaphylactoid (direct histamine release) but are clinically indistinguishable and treated identically to true IgE-mediated anaphylaxis"
      ],
      "whenToEscalate": [
        "In refractory anaphylactic shock or complete glottic closure, secure the airway immediately with endotracheal intubation or cricothyrotomy and initiate ACLS"
      ],
      "referencesToShow": [
        "ACR Manual on Contrast Media. American College of Radiology 2021.",
        "Management of Acute Contrast Reactions. RadioGraphics 2018. PMID: 29016373."
      ],
      "safetyLevel": "emergency"
    }
