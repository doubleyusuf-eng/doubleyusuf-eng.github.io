  {
    "id": "preoperative_anemia_management",
    "category": "clinical_scenarios",
    "keywords": [
      "anemi",
      "anemia",
      "demir",
      "eksikliği",
      "management",
      "preoperatif",
      "preoperative"
    ],
    "question_tr": "Preoperatif anemi",
    "question_en": "Preoperative anemia",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Anemi perioperatif transfüzyon, komplikasyon ve kötü sonuç riskini artırır. Elektif, yüksek kan kaybı beklenen cerrahilerde aneminin nedeni araştırılıp tedavi edilmesi tercih edilir. Demir eksikliği, kronik hastalık, B12/folat eksikliği ve renal hastalık değerlendirilmelidir. Tedavi için oral/IV demir, eritropoietin veya altta yatan nedene yönelik yaklaşım düşünülebilir. Acil cerrahide optimizasyon için zaman yoksa transfüzyon eşiği, kanama riski ve oksijen sunumu birlikte değerlendirilir.",
      "immediateRedFlags": [
        "Cerrahi sabahı tespit edilen ve önceden araştırılmamış derin anemi (Hb < 8 g/dL) (elektif cerrahi için kırmızı bayrak).",
        "Aktif iskemik kalp hastalığı olan anemik hastada derin taşikardi ve göğüs ağrısı."
      ],
      "missingCriticalInformation": [
        "Aneminin morfolojik tipi (mikrositer vs makrositer) ve demir paneli (ferritin, transferrin satürasyonu)",
        "Ameliyatın tahmini kan kaybı ve hastanın bazal kardiyopulmoner rezervi"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Preoperatif Anemi Optimizasyonu",
        "Hasta Kan Yönetimi (PBM) Kriterleri",
        "Demir Eksikliği Tedavisi"
      ],
      "suggestedNextStepsGeneral": [
        "Elektif majör cerrahilerden en az 2-4 hafta önce tam kan sayımı ve demir paneli isteyin.",
        "Demir eksikliği anemisi saptanırsa, emilim bozukluğu varsa veya cerrahiye az süre kaldıysa IV Demir replasmanı uygulayın.",
        "Kronik böbrek yetmezliği veya kronik hastalık anemisinde gerekli ise eritropoietin (EPO) desteğini planlayın.",
        "İntraoperatif dönemde kan kaybını ve gereksiz kan alma sıklığını minimuma indirin."
      ],
      "relatedAlgorithms": [
        {
          "id": "anemia_management",
          "titleTr": "Anemi Optimizasyon Algoritması"
        },
        {
          "id": "blood_refusal",
          "titleTr": "Hasta Kan Yönetimi"
        }
      ],
      "relatedCalculators": [
        {
          "id": "hemoglobin",
          "titleTr": "Hemoglobin Takip"
        },
        {
          "id": "abl",
          "titleTr": "İzin Verilebilir Kan Kaybı"
        },
        {
          "id": "ebv",
          "titleTr": "Tahmini Kan Hacmi"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "iron",
          "titleTr": "Demir Preparatları Monografı"
        },
        {
          "id": "erythropoietin",
          "titleTr": "Eritropoietin Monografı"
        },
        {
          "id": "tranexamic_acid",
          "titleTr": "Traneksamik Asit Monografı"
        }
      ],
      "doNotMiss": [
        "Oral demir tedavisinin hemoglobin düzeyini yükseltmek için en az 4-6 hafta süre gerektirdiğini, IV demirin ise daha hızlı yanıt verdiğini"
      ],
      "whenToEscalate": [
        "Acil cerrahide Hb < 7-8 g/dL (kardiyak hastada < 8-9 g/dL) ise ve klinik hipoperfüzyon bulguları varsa kan transfüzyonunu başlatın"
      ],
      "referencesToShow": [
        "Consensus Guidelines on Patient Blood Management. Anaesthesia 2017.",
        "SABM Clinical Practice Guidelines for PBM. 2021."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Anemia increases perioperative transfusion, complication, and poor outcome risk. For elective surgery with expected major blood loss, investigate and treat anemia when possible. Evaluate iron deficiency, chronic disease, B12/folate deficiency, and renal disease. Treatment may include oral/IV iron, erythropoietin, or cause-specific therapy. In urgent surgery, when optimization time is limited, transfusion thresholds, bleeding risk, and oxygen delivery must be considered together.",
      "immediateRedFlags": [
        "Unexplained severe anemia (Hb <8 g/dL) identified on the morning of elective major surgery.",
        "EKG changes or persistent tachycardia in an anemic patient with known coronary artery disease."
      ],
      "missingCriticalInformation": [
        "Complete iron profile (ferritin, transferrin saturation) and anemia etiology",
        "Estimated intraoperative blood loss and patient's baseline cardiovascular reserve"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Preoperative Anemia Optimization",
        "Patient Blood Management (PBM)",
        "Iron Deficiency Anemia Treatment"
      ],
      "suggestedNextStepsGeneral": [
        "Screen for anemia in all elective major surgery patients at least 2-4 weeks preoperatively.",
        "Administer IV iron rather than oral iron if the surgical date is within 2-3 weeks or oral absorption is poor.",
        "Consider recombinant Erythropoietin (EPO) for anemia of chronic kidney disease.",
        "Apply restrictive transfusion strategies intraoperatively, aiming for Hb >7-8 g/dL in hemodynamically stable patients."
      ],
      "relatedAlgorithms": [
        {
          "id": "anemia_management",
          "titleTr": "Anemia Management Algorithm"
        },
        {
          "id": "blood_refusal",
          "titleTr": "Patient Blood Management"
        }
      ],
      "relatedCalculators": [
        {
          "id": "hemoglobin",
          "titleTr": "Hemoglobin Monitor"
        },
        {
          "id": "abl",
          "titleTr": "Allowable Blood Loss"
        },
        {
          "id": "ebv",
          "titleTr": "Estimated Blood Volume"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "iron",
          "titleTr": "Iron Monograph"
        },
        {
          "id": "erythropoietin",
          "titleTr": "Erythropoietin Monograph"
        },
        {
          "id": "tranexamic_acid",
          "titleTr": "Tranexamic Acid Monograph"
        }
      ],
      "doNotMiss": [
        "Oral iron takes several weeks to show clinical effect; IV iron induces a more rapid rise in hemoglobin"
      ],
      "whenToEscalate": [
        "In urgent surgeries, if Hb drops below 7 g/dL (or <8 g/dL in patients with active cardiovascular disease) with tissue hypoxia, transfuse RBCs"
      ],
      "referencesToShow": [
        "Consensus Guidelines on Patient Blood Management. Anaesthesia 2017.",
        "SABM Clinical Practice Guidelines for PBM. 2021."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "thrombocytopenia_surgery_block",
    "category": "clinical_scenarios",
    "keywords": [
      "block",
      "blok",
      "cerrahi",
      "düşük",
      "platelet",
      "surgery",
      "thrombocytopenia",
      "trombosit",
      "trombositopeni"
    ],
    "question_tr": "Trombositopeni cerrahi",
    "question_en": "Thrombocytopenia block",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Karar trombosit sayısı, trend, kanama öyküsü, trombosit fonksiyonu, cerrahi tipi ve rejyonal tekniğe göre verilir. Majör kanama riski olan cerrahi, nöroaksiyel blok, göz/kraniyal/spinal kanal cerrahisi ve derin pleksus blokları daha yüksek eşik gerektirir. Trombosit sayısı stabil mi, DIC var mı, antiplatelet/antikoagülan kullanılıyor mu değerlendirilmelidir. Klinik kanama varsa sayıdan bağımsız olarak risk artar. Şüphede hematoloji görüşü alınır.",
      "immediateRedFlags": [
        "Trombositopenik hastada derin komprese edilemeyen periferik blok (örn. psoas kompartman bloğu) yapılması.",
        "Rejyonal anestezi sonrası bacaklarda ilerleyici kuvvetsizlik ve sfinkter disfonksiyonu (nöroaksiyel hematom)."
      ],
      "missingCriticalInformation": [
        "Trombositopeninin altta yatan nedeni ve fonksiyonel trombosit durumu",
        "Eş zamanlı antikoagülan veya antiplatelet ilaç kullanımı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Trombositopeni ve Cerrahi Güvenlik",
        "Rejyonal Anestezi Rejyonel Sınırlar",
        "Nöroaksiyel Hematom Önleme"
      ],
      "suggestedNextStepsGeneral": [
        "Cerrahi öncesi trombosit sayısını ve trendini son hemogram ile teyit edin.",
        "Elektif majör cerrahiler için trombosit sayısını >50.000/µL düzeyinde tutmayı hedefleyin.",
        "Nöroaksiyel bloklar (spinal/epidural) için trombosit sayısının en az 70.000-80.000/µL üzerinde olmasını ( SOAP standartları) arayın.",
        "Göz arkası cerrahisi veya kraniyotomi gibi kritik alan cerrahilerinde trombosit sayısını >100.000/µL düzeyine yükseltin."
      ],
      "relatedAlgorithms": [
        {
          "id": "thrombocytopenia",
          "titleTr": "Trombositopeni Yönetim Algoritması"
        },
        {
          "id": "neuraxial_safety",
          "titleTr": "Nöroaksiyel Güvenlik Kılavuzu"
        }
      ],
      "relatedCalculators": [
        {
          "id": "platelet_trend",
          "titleTr": "Trombosit Trend Hesaplayıcı"
        },
        {
          "id": "bleeding_risk",
          "titleTr": "Kanama Riski"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "tranexamic_acid",
          "titleTr": "Traneksamik Asit Monografı"
        }
      ],
      "doNotMiss": [
        "Sadece trombosit sayısının değil, klinik kanama bulgularının (peteşi, purpura) varlığının risk değerlendirmesinde birincil önemini"
      ],
      "whenToEscalate": [
        "Nöroaksiyel blok sonrasında nörolojik defisit gelişirse derhal acil lumbar dekompresif cerrahi ve MRI için hazırlık yapın"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Neuraxial Anesthesia. 2021.",
        "Guidelines on the Management of Thrombocytopenia. British Journal of Haematology 2017."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Decision depends on platelet count, trend, bleeding history, platelet function, surgical type, and regional technique. Major bleeding surgery, neuraxial block, eye/cranial/spinal canal surgery, and deep plexus blocks require higher caution. Assess whether platelets are stable, whether DIC is present, and whether antiplatelet/anticoagulant drugs are used. Clinical bleeding increases risk regardless of the count. Seek hematology input when uncertain.",
      "immediateRedFlags": [
        "Performing a deep, non-compressible nerve block in a patient with platelets <50,000/µL.",
        "Signs of spinal cord compression (progressive paraparesis) post-neuraxial puncture in a thrombocytopenic patient."
      ],
      "missingCriticalInformation": [
        "Underlying cause of thrombocytopenia and qualitative platelet function",
        "Concurrent use of low-molecular-weight heparin or antiplatelet agents"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Thrombocytopenia and Surgical Safety Limits",
        "Regional Anesthesia and Platelet Thresholds",
        "Spinal Hematoma Avoidance"
      ],
      "suggestedNextStepsGeneral": [
        "Confirm baseline platelet count and the absolute stability trend prior to the procedure.",
        "For general major surgery, target platelet counts of >50,000/µL.",
        "For spinal or epidural anesthesia, require a stable count of at least 70,000-80,000/µL.",
        "For high-risk closed-space surgeries (e.g. neurosurgery, posterior eye), optimize platelets to >100,000/µL."
      ],
      "relatedAlgorithms": [
        {
          "id": "thrombocytopenia",
          "titleTr": "Thrombocytopenia Management"
        },
        {
          "id": "neuraxial_safety",
          "titleTr": "Neuraxial Safety Guidelines"
        }
      ],
      "relatedCalculators": [
        {
          "id": "platelet_trend",
          "titleTr": "Platelet Trend Tracker"
        },
        {
          "id": "bleeding_risk",
          "titleTr": "Surgical Bleeding Risk"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "tranexamic_acid",
          "titleTr": "Tranexamic Acid Monograph"
        }
      ],
      "doNotMiss": [
        "Platelet quality and trend are as critical as the absolute count; clinical mucosal bleeding indicates severe coagulopathy"
      ],
      "whenToEscalate": [
        "If progressive postoperative paraplegia or bladder/bowel dysfunction occurs, order an immediate MRI to rule out spinal hematoma"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Neuraxial Anesthesia. 2021.",
        "Guidelines on the Management of Thrombocytopenia. British Journal of Haematology 2017."
      ],
      "safetyLevel": "elective"
    }
  },
  {
    "id": "local_anesthetic_allergy_history",
    "category": "clinical_scenarios",
    "keywords": [
      "alerji",
      "allergy",
      "anestezik",
      "anesthetic",
      "bupivakain",
      "history",
      "lidokain",
      "local",
      "lokal"
    ],
    "question_tr": "Lokal anestezik alerji",
    "question_en": "Local anesthetic allergy",
    "safetyLevel": "elective",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Gerçek lokal anestezik alerjisi nadirdir. Vazovagal reaksiyon, intravasküler enjeksiyon, adrenalin etkisi, panik veya toksisite alerjiyle karışabilir. Reaksiyonun tipi ayrıntılı sorgulanmalıdır: ürtiker, bronkospazm, hipotansiyon, anjiyoödem var mı? Ester ve amid lokal anestezikler farklı gruplardır; koruyucu maddeler de reaksiyon yapabilir. Elektif durumda alerji testi/immünoloji değerlendirmesi uygun olabilir. Acil durumda alternatif ilaç, preservative-free preparat ve anafilaksi hazırlığı düşünülür.",
      "immediateRedFlags": [
        "Lokal anestezik enjeksiyonu sonrasında gelişen ani anjiyoödem, hırıltı (bronkospazm) ve derin hipotansiyon.",
        "İntravasküler enjeksiyona bağlı gelişen akut nöbet veya kardiyak arrest (LAST - anafilaksi ile karışabilir)."
      ],
      "missingCriticalInformation": [
        "Önceki reaksiyonun detaylı kliniği (ürtiker vs çarpıntı vs bayılma)",
        "Reaksiyona neden olan lokal anesteziğin tam adı ve adrenalin içeriği"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Lokal Anestezik Alerjisi Yönetimi",
        "Lokal Anestezik Sistemik Toksisitesi (LAST)",
        "Anafilaksi ve Kriz Algoritması"
      ],
      "suggestedNextStepsGeneral": [
        "Önceki reaksiyonun vasovagal (bayılma, yavaş nabız) veya sempatik (çarpıntı, yüksek tansiyon) reaksiyon olup olmadığını sorgulayın.",
        "Elektif cerrahi öncesi hastayı cilt testi veya provokasyon testi için immünolojiye yönlendirin.",
        "Uygulama zorunlu ise, amid grubu lokal anesteziklerin (örn. Bupivakain, Ropivakain) ester grubuna göre daha az alerjenik olduğunu unutmayın.",
        "Preservative-free (koruyucu içermeyen) tek dozluk ampulleri tercih edin (metilparaben duyarlılığını önlemek için)."
      ],
      "relatedAlgorithms": [
        {
          "id": "anaphylaxis",
          "titleTr": "Anafilaksi Kurtarma Algoritması"
        },
        {
          "id": "last",
          "titleTr": "LAST Kriz Yönetimi"
        }
      ],
      "relatedCalculators": [
        {
          "id": "la_max_dose",
          "titleTr": "Lokal Anestezik Limit Hesaplayıcı"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "lidocaine",
          "titleTr": "Lidokain Monografı"
        },
        {
          "id": "bupivacaine",
          "titleTr": "Bupivakain Monografı"
        },
        {
          "id": "ropivacaine",
          "titleTr": "Ropivakain Monografı"
        },
        {
          "id": "epinephrine",
          "titleTr": "Adrenalin Monografı"
        }
      ],
      "doNotMiss": [
        "Gerçek IgE aracılı lokal anestezik alerjisinin tüm reaksiyonların %1'inden azını oluşturduğunu"
      ],
      "whenToEscalate": [
        "Lokal enjeksiyon sonrası anafilaktik şok gelişirse derhal adrenalin (IV 10-50 mcg veya IM 0.5 mg) uygulayın ve hava yolunu güvenceye alın"
      ],
      "referencesToShow": [
        "Allergy to Local Anesthetics. Journal of Allergy and Clinical Immunology 2018.",
        "ASRA Practice Advisory on Local Anesthetics. 2021."
      ],
      "safetyLevel": "elective"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "True local anesthetic allergy is rare. Vasovagal reaction, intravascular injection, epinephrine effect, anxiety, or toxicity may be mistaken for allergy. Clarify the reaction: urticaria, bronchospasm, hypotension, or angioedema? Ester and amide local anesthetics are different groups; preservatives may also cause reactions. In elective cases, allergy/immunology testing is appropriate. In urgent cases, consider alternative drugs, preservative-free formulations, and anaphylaxis preparedness.",
      "immediateRedFlags": [
        "Sudden generalized urticaria, facial angioedema, or severe bronchospasm following local anesthetic injection.",
        "Acute cardiovascular collapse or seizure shortly after block placement (anaphylaxis vs. LAST)."
      ],
      "missingCriticalInformation": [
        "Specific clinical presentation of the prior reaction (e.g. syncope, palpitations, rash)",
        "Exact name and class of the suspected local anesthetic agent"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Local Anesthetic Allergy Management",
        "Local Anesthetic Systemik Toxicity (LAST) Differential",
        "Perioperative Anaphylaxis Protocols"
      ],
      "suggestedNextStepsGeneral": [
        "Differentiate true allergy from vasovagal syncope or sympathetic epinephrine reactions.",
        "For elective cases, refer the patient to allergy/immunology for skin testing and graded challenge.",
        "If a local anesthetic is mandatory, choose an amide (e.g., ropivacaine, bupivacaine) as they rarely cross-react.",
        "Use preservative-free (MPF) formulations to avoid reactions to methylparaben or sulfites."
      ],
      "relatedAlgorithms": [
        {
          "id": "anaphylaxis",
          "titleTr": "Anaphylaxis Rescue Protocol"
        },
        {
          "id": "last",
          "titleTr": "LAST Rescue Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "la_max_dose",
          "titleTr": "Local Anesthetic Max Dose"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "lidocaine",
          "titleTr": "Lidocaine Monograph"
        },
        {
          "id": "bupivacaine",
          "titleTr": "Bupivacaine Monograph"
        },
        {
          "id": "ropivacaine",
          "titleTr": "Rocuronium Monograph"
        },
        {
          "id": "epinephrine",
          "titleTr": "Epinephrine Monograph"
        }
      ],
      "doNotMiss": [
        "True IgE-mediated allergy to local anesthetics constitutes less than 1% of all adverse local anesthetic reactions"
      ],
      "whenToEscalate": [
        "If severe systemic anaphylaxis occurs, immediately stop injection, administer Epinephrine, and initiate resuscitation"
      ],
      "referencesToShow": [
        "Allergy to Local Anesthetics. Journal of Allergy and Clinical Immunology 2018.",
        "ASRA Practice Advisory on Local Anesthetics. 2021."
      ],
      "safetyLevel": "elective"
    }
  },
