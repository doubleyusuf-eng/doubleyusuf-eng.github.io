    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "Femoral nerve block involves depositing local anesthetic around the femoral nerve at the inguinal crease to provide analgesia for anterior thigh, knee, and femoral shaft procedures.\n\nClinical Monitoring and Safety:\n1. Quadriceps Weakness and Fall Risk: The most critical monitoring parameter is quadriceps muscle paralysis. The patient must not ambulate unassisted; implement knee splints and crutches/assistence during mobilization.\n2. Assessment: Regularly document motor strength and sensory levels.\n3. Bleeding Controls: Although the groin is compressible, monitor for hematoma and bleeding due to proximity to the femoral artery.\n4. LAST: The injection is adjacent to the femoral artery; closely monitor for intravascular injection and systemic toxicity (tinnitus, metallic taste).\n5. Continuous Catheter: Regularly check the infusion pump rate, signs of catheter migration, motor block density, and insertion site for infection.\n6. Neurological Deficit: Document and evaluate any new or prolonged deficit (numbness of the anterior thigh, loss of knee extension) exceeding the expected block duration.",
      "immediateRedFlags": [
        "Patient fall due to unassisted ambulation with quadriceps paralysis.",
        "Rapidly expanding groin hematoma following inadvertent femoral artery puncture.",
        "Onset of seizures or cardiovascular instability (LAST)."
      ],
      "missingCriticalInformation": [
        "The patient's current anticoagulation regimen",
        "The need for an additional sciatic block to cover posterior knee pain"
      ],
      "likelyClinicalCategoriesToConsider": [
        "Femoral Block Monitoring Parameters",
        "Knee Surgery Multimodal Analgesia",
        "Fall Prevention and Rehabilitation"
      ],
      "suggestedNextStepsGeneral": [
        "Identify the femoral artery, femoral vein, and the triangular femoral nerve immediately lateral to the artery under ultrasound.",
        "Advance the needle beneath the nerve to observe circumferential spread ('donut sign').",
        "Place a 'Fall Risk' warning at the patient's bedside and alert the nursing team."
      ],
      "relatedAlgorithms": [
        {
          "id": "femoral_block",
          "titleTr": "Femoral Block"
        },
        {
          "id": "fall_prevention",
          "titleTr": "Fall Prevention Protocol"
        },
        {
          "id": "last_management",
          "titleTr": "LAST Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "local_anesthetic_max_dose",
          "titleTr": "LA Max Dose"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "ropivacaine",
          "titleTr": "Ropivacaine"
        },
        {
          "id": "bupivacaine",
          "titleTr": "Bupivacaine"
        }
      ],
      "doNotMiss": [
        "Femoral nerve block significantly weakens the quadriceps muscle, which may delay early physical rehabilitation compared with motor-sparing alternatives"
      ],
      "whenToEscalate": [
        "In the event of a persistent neurological deficit lasting beyond 48 hours post-block, order a neurology consult and schedule electromyography (EMG)"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Femoral Block.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "urgent"
    }
