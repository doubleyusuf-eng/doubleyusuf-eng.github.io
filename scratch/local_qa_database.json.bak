  {
    "id": "clinical_followup_mtp_protocol_contraindications_0",
    "category": "clinical_followups",
    "keywords": [
      "bleeding",
      "clinical_followup_mtp_protocol_contraindications_0",
      "contraindications",
      "followup",
      "kanama",
      "massive",
      "mtp",
      "transfusion",
      "transfüzyon",
      "var0"
    ],
    "question_tr": "Masif transfüzyonun kontrendikasyonları nelerdir?",
    "question_en": "What are the contraindications of massive transfusion?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "⚠️ Aktif masif kanama durumunda kan ürünleri transfüzyonunun hiçbir mutlak kontrendikasyonu yoktur. Ancak hastanın bilinen ciddi IgA eksikliği varsa anafilaktik reaksiyonları önlemek için yıkanmış kan ürünleri tercih edilmelidir, ancak acil durumda bu beklenmez.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "⚠️ There are no absolute contraindications to blood product transfusion during active massive hemorrhage. In patients with known severe IgA deficiency, washed products are preferred to avoid anaphylaxis, but in immediate exsanguination, emergency uncrossmatched blood must proceed.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
        "Follow-up Management"
      ],
      "suggestedNextStepsGeneral": [],
