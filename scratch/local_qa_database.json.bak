      "var1",
      "why",
      "şok"
    ],
    "question_tr": "Anaphylaxis rescue neden ilk tercih adrenalin olmalıdır?",
    "question_en": "Anaphylaxis rescue why is epinephrine the first-line drug?",
    "safetyLevel": "routine",
    "tr": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "Bu asistan bir hekimin klinik kararı yerine geçemez.",
      "conversationalText": "🚨 Adrenerjik reseptör uyarımı kritik öneme sahiptir. Alfa-1 reseptör uyarısı vazokonstriksiyon yaparak ağır hipotansiyonu ve laringeal ödemi düzeltir. Beta-2 uyarısı ise güçlü bronkodilasyon sağlar ve mast hücrelerinden medyatör salınımını durdurur. Antihistaminikler ve steroidler akut şoku geri döndüremez.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Klinik Gerekçe",
        "Takip Yönetimi"
      ],
      "suggestedNextStepsGeneral": [],
      "relatedAlgorithms": [],
      "relatedCalculators": [],
      "relatedDrugCards": [],
      "doNotMiss": [],
      "whenToEscalate": [],
      "referencesToShow": []
    },
    "en": {
      "safetyLevel": "routine",
      "notASubstituteWarning": "This response does not replace clinical judgment.",
      "conversationalText": "🚨 Adrenergic receptor stimulation is critical. Alpha-1 activation causes vasoconstriction, reversing profound hypotension and laryngeal edema. Beta-2 activation produces potent bronchodilation and halts further mast cell degranulation. Antihistamines and steroids cannot reverse acute shock.",
      "immediateRedFlags": [],
      "missingCriticalInformation": [],
      "likelyClinicalCategoriesToConsider": [
        "Clinical Rationale",
