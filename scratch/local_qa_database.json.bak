      ],
      "likelyClinicalCategoriesToConsider": [
        "GLP-1 Agonistleri Perioperatif Yönetimi",
        "Gecikmiş Gastrik Boşalma",
        "Pulmoner Aspirasyon Risk Yönetimi"
