  {
    "id": "bradycardia",
    "category": "clinical_scenarios",
    "keywords": [
      "bradikardi",
      "bradycardia",
      "düşük",
      "nabız"
    ],
    "question_tr": "Bradikardi",
    "question_en": "Nabız düşük",
    "safetyLevel": "urgent",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Önce hastanın perfüzyonunu değerlendir. Hipotansiyon, bilinç değişikliği, iskemi, şok veya kalp yetmezliği varsa instabil kabul edilir.\\nNedenler: hipoksi, vagal uyarı, derin anestezi, yüksek spinal, beta bloker, okülokardiyak refleks, laparoskopi, hiperkalemi.\\nYaklaşım: oksijenasyon ve ventilasyonu düzelt, cerrahi uyarıyı durdur, ilaçları kontrol et. Semptomatik bradikardide atropin verilebilir. Yanıt yoksa adrenalin/dopamin infüzyonu veya pacing düşünülür.",
      "immediateRedFlags": [
        "Hipotansiyonla birlikte seyreden progresif bradikardi, asistolik areste gidişin en önemli kırmızı bayrağıdır."
      ],
      "missingCriticalInformation": [
        "Hastanın perfüzyon durumu ve hemodinamik stabilitesi",
        "Oksijenasyon seviyesi (SpO₂)"
      ],
      "likelyClinicalCategoriesToConsider": [
        "İntraoperatif Semptomatik Bradikardi Yönetimi",
        "Vagal Refleksler ve Okülokardiyak Refleks",
        "Yüksek Spinal Blok Hemodinamik Etkileri"
      ],
      "suggestedNextStepsGeneral": [
        "Öncelikle oksijenasyonu ve ventilasyonu optimize edin.",
        "Cerrahi uyarıyı (özellikle göz kası çekilmesi veya periton traksiyonu varsa) durdurtun.",
        "Semptomatik bradikardide Atropin 0.5-1 mg IV uygulayın, gerekirse tekrarlayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "bradycardia_rescue",
          "titleTr": "Bradikardi Algoritması"
        },
        {
          "id": "sepsis_shock",
          "titleTr": "Sepsis & Şok Algoritması"
        }
      ],
      "relatedCalculators": [
