          "id": "aspiration_checklist",
          "titleTr": "Aspiration Checklist"
        },
        {
          "id": "npo_calculator",
          "titleTr": "Fasting Calculator"
        }
      ],
      "relatedDrugCards": [
        {
          "id": "sodium_citrate",
          "titleTr": "Sodium Citrate"
        },
        {
          "id": "famotidine",
          "titleTr": "Famotidine"
        },
        {
          "id": "pantoprazole",
          "titleTr": "Pantoprazole"
        },
        {
          "id": "metoclopramide",
          "titleTr": "Metoclopramide"
        },
        {
          "id": "ondansetron",
          "titleTr": "Ondansetron"
        }
      ],
      "doNotMiss": [
        "Pharmacologic prophylaxis does not empty the stomach; it only mitigates pulmonary damage by reducing acidity; mechanical airway protection is paramount"
      ],
      "whenToEscalate": [
        "In cases of active bowel obstruction or intractable vomiting, perform awake nasogastric decompression, utilize head-up positioning, and have a senior anesthesiologist secure the airway"
      ],
      "referencesToShow": [
        "2023 American Society of Anesthesiologists Practice Guidelines for Preoperative Fasting.",
        "Miller's Anesthesia, 9th Edition."
      ],
      "safetyLevel": "elective"
    }
