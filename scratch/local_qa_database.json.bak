    ],
    "question_tr": "Warfarin",
    "question_en": "Epidural",
    "safetyLevel": "routine",
    "tr": {
      "notASubstituteWarning": "Bu yanıt klinik kararın yerine geçmez. Klinik değerlendirmenizi temel alın.",
      "conversationalText": "Warfarin kullanan hastada nöroaksiyel blok için INR güvenli aralıkta olmalı ve ilaç yeterli süre kesilmiş olmalıdır. Pratikte warfarin genellikle yaklaşık 5 gün önce kesilir ve INR kontrol edilir. Epidural kateter varsa INR takibi, nörolojik izlem ve kateter çekim zamanı çok önemlidir. Motor blokta beklenmeyen uzama, yeni bel ağrısı, duyu-motor defisit veya sfinkter bozukluğu epidural hematom açısından acildir.",
      "immediateRedFlags": [
        "INR > 1.5 iken spinal/epidural veya kateter çekimi yapılması yüksek riskli epidural hematom nedenidir.",
        "Kateter çekimi sonrası gelişen bacaklarda güçsüzlük veya idrar kaçırma ACİL spinal kord kompresyonu bulgusudur."
      ],
      "missingCriticalInformation": [
        "Hastanın güncel INR değeri",
        "Warfarin kesildikten sonra köprüleme (LMWH) tedavisi başlanıp başlanmadığı"
      ],
      "likelyClinicalCategoriesToConsider": [
        "ASRA Antikoagülan Kılavuzu Standartları",
        "Warfarin Reversal ve Vitamin K/PCC Tedavileri",
        "Epidural Hematom ve Cerrahi Dekompresyon Zamanlaması"
      ],
      "suggestedNextStepsGeneral": [
        "Warfarini elektif girişimlerden en az 5 gün önce kesin ve operasyon sabahı INR kontrol edin.",
        "INR'nin kesinlikle <1.5 olduğunu görerek nöroaksiyel girişim planlayın.",
        "Acil reversal gerekiyorsa PCC (Protrombin Kompleks Konsantresi, 25-50 U/kg) ve Vitamin K (5-10 mg IV yavaş) uygulayın."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Antikoagülan Yönetim Algoritması"
        },
        {
          "id": "epidural_hematoma_suspicion",
          "titleTr": "Epidural Hematom Algoritması"
        }
      ],
      "relatedCalculators": [
        {
          "id": "asra_coagulation",
          "titleTr": "ASRA Antikoagülan Tablosu"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "Epidural kateter çekilirken de en az girişim öncesindeki gibi düşük INR (<1.5) ve bekleme sürelerine tam uyulması şarttır"
      ],
      "whenToEscalate": [
        "Nörolojik defisit durumunda zaman kaybetmeden acil Lomber MRG ve 8 saat içinde cerrahi dekompresyon"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Regional Anesthesia in Patients Receiving Antithrombotic Therapy. 2018. PMID: 29362691.",
        "Horlocker TT, et al. PMID: 29362691."
      ],
      "safetyLevel": "routine"
    },
    "en": {
      "notASubstituteWarning": "This response does not replace clinical judgment. Base decisions on your clinical assessment.",
      "conversationalText": "For neuraxial block in a patient taking warfarin, INR should be in a safe range and the drug should have been held for an adequate interval. In practice, warfarin is commonly stopped about 5 days before and INR is checked. If an epidural catheter is present, INR monitoring, neurologic checks, and catheter removal timing are critical. Unexpected prolonged motor block, new back pain, sensory-motor deficit, or sphincter dysfunction is an emergency red flag for epidural hematoma.",
      "immediateRedFlags": [
        "Performing spinal/epidural or catheter removal with INR > 1.5 carries a high risk for epidural hematoma.",
        "Weakness in lower extremities or urinary incontinence after catheter removal is an EMERGENCY spinal cord compression sign."
      ],
      "missingCriticalInformation": [
        "Patient's most recent INR value",
        "Whether bridging therapy (e.g., LMWH) was initiated after stopping Warfarin"
      ],
      "likelyClinicalCategoriesToConsider": [
        "ASRA Anticoagulant Guidelines Standards",
        "Warfarin Reversal and Vitamin K/PCC Therapy",
        "Epidural Hematoma and Surgical Decompression Timing"
      ],
      "suggestedNextStepsGeneral": [
        "Discontinue Warfarin at least 5 days prior to elective procedures and check INR on the morning of surgery.",
        "Ensure INR is strictly <1.5 before performing any neuraxial technique.",
        "For emergency reversal, administer PCC (25-50 U/kg) and slow IV Vitamin K (5-10 mg)."
      ],
      "relatedAlgorithms": [
        {
          "id": "coagulation_management",
          "titleTr": "Coagulation Management Algorithm"
        },
        {
          "id": "epidural_hematoma_suspicion",
          "titleTr": "Epidural Hematoma Algorithm"
        }
      ],
      "relatedCalculators": [
        {
          "id": "asra_coagulation",
          "titleTr": "ASRA Coagulation Table"
        }
      ],
      "relatedDrugCards": [],
      "doNotMiss": [
        "The same strict safe INR threshold (<1.5) and hold times apply during epidural catheter removal as during insertion"
      ],
      "whenToEscalate": [
        "In case of any new neurologic deficit, obtain an emergency Lumbar MRI and coordinate surgical decompression within 8 hours"
      ],
      "referencesToShow": [
        "ASRA Guidelines on Regional Anesthesia in Patients Receiving Antithrombotic Therapy. 2018. PMID: 29362691.",
        "Horlocker TT, et al. PMID: 29362691."
      ],
      "safetyLevel": "routine"
    }
  },
